---
import Layout from '../layouts/Layout.astro';
import BaseHead from '../components/BaseHead.astro';

const title = '404 - Η σελίδα δεν βρέθηκε | GreekHandy';
const description = 'Η σελίδα που ζητήσατε δεν είναι διαθέσιμη. Επιστρέψτε στην αρχική ή δείτε βασικές κατηγορίες υπηρεσιών στο GreekHandy.';
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <BaseHead title={title} description={description} canonicalUrl={Astro.url.href} />
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <main class="mx-auto max-w-4xl px-4 py-16">
    <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-blue-700">Σφάλμα 404</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Η σελίδα δεν βρέθηκε</h1>
      <p class="mt-3 max-w-2xl text-slate-600">
        Η διεύθυνση που ανοίξατε ίσως έχει αλλάξει ή δεν είναι πλέον διαθέσιμη.
        Μπορείτε να συνεχίσετε από την αρχική σελίδα ή να επιλέξετε μια βασική κατηγορία υπηρεσιών.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/" class="inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Επιστροφή στην Αρχική</a>
        <a href="/professionals" class="inline-flex rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Εύρεση Επαγγελματία</a>
      </div>
    </section>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Δημοφιλείς κατηγορίες</h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        <li><a href="/ilektrologoi" class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Ηλεκτρολόγοι</a></li>
        <li><a href="/ydravlikoi" class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Υδραυλικοί</a></li>
        <li><a href="/elaiokhrwmatistes" class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Ελαιοχρωματιστές</a></li>
        <li><a href="/katharismoi" class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Καθαρισμοί</a></li>
        <li><a href="/techniki-klimatismou" class="block rounded-lg border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">Κλιματισμός</a></li>
      </ul>
    </section>
  </main>
</Layout>
