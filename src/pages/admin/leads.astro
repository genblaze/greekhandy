---
import Layout from '../../layouts/Layout.astro';
import { loadAdminLeadsDirectoryData, type AdminLeadsDirectoryData } from '../../lib/admin-leads';

const isAuthorized = true;
const expectedKey = '';

const fallbackDirectoryData: AdminLeadsDirectoryData = {
  leads: [],
  categories: [],
  cities: [],
  statuses: [],
  summary: null,
  totalLeads: 0
};

let directoryData: AdminLeadsDirectoryData = fallbackDirectoryData;
let loadError: string | null = null;

try {
  directoryData = await loadAdminLeadsDirectoryData();
} catch {
  loadError = 'Αδυναμία φόρτωσης των leads. Ελέγξτε τα αρχεία στο data/leads και δοκιμάστε ξανά.';
}

const statusLabel = (status: string) => {
  if (status === 'new') return 'Νέο';
  if (status === 'contacted') return 'Επικοινωνήθηκε';
  if (status === 'qualified') return 'Κατάλληλο';
  if (status === 'rejected') return 'Απορρίφθηκε';
  return status
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
};

const summaryUpdatedAtRaw = directoryData.summary?.lastUpdated;
const summaryUpdatedAt = summaryUpdatedAtRaw && Number.isFinite(Date.parse(summaryUpdatedAtRaw))
  ? new Date(summaryUpdatedAtRaw).toLocaleString('el-GR')
  : null;

const hasLeads = directoryData.leads.length > 0;
---

<Layout title="Admin Leads Directory | GreekHandy" description="Admin leads directory with filters and sorting.">
  <main class="mx-auto max-w-7xl px-4 py-10 md:py-14" data-leads-root>
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Κατάλογος Leads</h1>
        <p class="mt-2 max-w-3xl text-sm text-slate-700 md:text-base">Ενοποιημένη προβολή leads με προηγμένα φίλτρα, αναζήτηση και ταξινόμηση.</p>
      </div>
      <a href="/admin" class="inline-flex min-h-10 items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
        Επιστροφή στο Admin
      </a>
    </div>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900" role="alert" aria-live="assertive">
        <p class="font-semibold">Μη εξουσιοδοτημένη πρόσβαση.</p>
        <p class="mt-1 text-sm">Συνδεθείτε με moderation key.</p>
        <form method="GET" class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input name="key" type="password" required class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-sm text-gray-900" placeholder="Moderation key" />
          <button type="submit" class="rounded-lg bg-amber-700 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-800">Σύνδεση</button>
        </form>
        {!expectedKey && <p class="mt-2 text-xs">Missing env: <code>PROFESSIONAL_MODERATION_KEY</code></p>}
      </div>
    )}

    {isAuthorized && (
      <>
        <section class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <article class="rounded-xl border border-sky-200 bg-gradient-to-br from-sky-50 to-blue-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-sky-700">Σύνολο Leads</p>
            <p class="mt-2 text-3xl font-bold text-sky-950">{directoryData.totalLeads}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Ενεργές Κατηγορίες</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">{directoryData.categories.length}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Πόλεις</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">{directoryData.cities.length}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Τελευταία ενημέρωση</p>
            <p class="mt-2 text-sm font-semibold text-slate-900">{summaryUpdatedAt || 'Δεν υπάρχει summary timestamp'}</p>
          </article>
        </section>

        {loadError && (
          <section class="mt-6 rounded-xl border border-rose-200 bg-rose-50 p-5 text-rose-900" role="alert" aria-live="assertive">
            <h2 class="text-lg font-bold">Σφάλμα φόρτωσης</h2>
            <p class="mt-2 text-sm">{loadError}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a href="/admin/leads" class="inline-flex min-h-10 items-center rounded-lg bg-rose-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-rose-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">Επανάληψη φόρτωσης</a>
              <a href="/admin" class="inline-flex min-h-10 items-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-800 transition hover:bg-rose-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">Πίσω στο Admin</a>
            </div>
          </section>
        )}

        {!loadError && (
          <div class="mt-6 grid gap-6 xl:grid-cols-[21rem_minmax(0,1fr)]">
            <aside class="xl:sticky xl:top-20 xl:h-[calc(100vh-7rem)]">
              <form data-filters-form class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm md:p-5" autocomplete="off">
                <div class="flex items-center justify-between gap-2">
                  <h2 class="text-lg font-bold text-slate-900">Φίλτρα</h2>
                  <button type="button" data-reset-filters class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Καθαρισμός</button>
                </div>

                <fieldset class="mt-4" aria-label="Φίλτρο κατηγορίας">
                  <legend class="text-xs font-semibold uppercase tracking-wide text-slate-500">Κατηγορία (βασικό φίλτρο)</legend>
                  <div class="mt-2 flex gap-2 overflow-x-auto pb-1 xl:flex-wrap xl:overflow-visible" role="group" aria-label="Επιλογή κατηγορίας">
                    <button
                      type="button"
                      data-category-tab
                      data-category-value="all"
                      data-category-label="Όλες"
                      aria-pressed="true"
                      class="inline-flex min-h-10 items-center gap-2 rounded-full border border-sky-600 bg-sky-600 px-4 py-2 text-sm font-semibold whitespace-nowrap text-white shadow-sm transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                    >
                      <span>Όλες</span>
                      <span data-category-count class="rounded-full bg-white/20 px-2 py-0.5 text-xs">{directoryData.leads.length}</span>
                    </button>
                    {directoryData.categories.map((category) => (
                      <button
                        type="button"
                        data-category-tab
                        data-category-value={category.slug}
                        data-category-label={category.label}
                        aria-pressed="false"
                        class="inline-flex min-h-10 items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold whitespace-nowrap text-slate-700 transition hover:border-sky-300 hover:text-sky-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                      >
                        <span>{category.label}</span>
                        <span data-category-count class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{category.count}</span>
                      </button>
                    ))}
                  </div>
                  <div data-category-context class="mt-3 rounded-xl border border-sky-100 bg-gradient-to-br from-sky-50 to-blue-50 p-3 text-xs text-sky-900">
                    Εμφάνιση όλων των κατηγοριών. Επιλέξτε κατηγορία για πιο στοχευμένη λίστα leads.
                  </div>
                </fieldset>

                <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <div>
                    <label for="leads-city-filter" class="text-sm font-semibold text-slate-700">Πόλη</label>
                    <select id="leads-city-filter" data-city-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="all">Όλες</option>
                      {directoryData.cities.map((city) => <option value={city}>{city}</option>)}
                    </select>
                  </div>

                  <div>
                    <label for="leads-status-filter" class="text-sm font-semibold text-slate-700">Κατάσταση</label>
                    <select id="leads-status-filter" data-status-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="all">Όλες</option>
                      {directoryData.statuses.map((status) => <option value={status}>{statusLabel(status)}</option>)}
                    </select>
                  </div>

                  <fieldset class="sm:col-span-2 xl:col-span-1" aria-label="Φίλτρο επικοινωνίας">
                    <legend class="text-sm font-semibold text-slate-700">Outreach</legend>
                    <div class="mt-1 grid grid-cols-3 gap-1 rounded-lg border border-slate-300 bg-slate-50 p-1" role="group" aria-label="Κατάσταση επικοινωνίας">
                      <button type="button" data-contacted-filter data-contacted-value="all" aria-pressed="true" class="min-h-9 rounded-md border border-sky-600 bg-sky-600 px-2 text-xs font-semibold text-white transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Όλα</button>
                      <button type="button" data-contacted-filter data-contacted-value="contacted" aria-pressed="false" class="min-h-9 rounded-md border border-transparent bg-transparent px-2 text-xs font-semibold text-slate-700 transition hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Επικοινωνήθηκαν</button>
                      <button type="button" data-contacted-filter data-contacted-value="not-contacted" aria-pressed="false" class="min-h-9 rounded-md border border-transparent bg-transparent px-2 text-xs font-semibold text-slate-700 transition hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Χωρίς επαφή</button>
                    </div>
                  </fieldset>

                  <div class="sm:col-span-2 xl:col-span-1">
                    <label for="leads-score-filter" class="text-sm font-semibold text-slate-700">Ελάχιστο score</label>
                    <select id="leads-score-filter" data-score-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="any">Όλα</option>
                      <option value="80">80+</option>
                      <option value="60">60+</option>
                      <option value="40">40+</option>
                    </select>
                  </div>
                </div>

                <div class="mt-3">
                  <label for="leads-search" class="text-sm font-semibold text-slate-700">Αναζήτηση</label>
                  <div class="relative mt-1">
                    <input
                      id="leads-search"
                      type="search"
                      data-search-input
                      placeholder="Όνομα, τηλέφωνο, email, score:80"
                      class="block min-h-10 w-full rounded-lg border border-slate-300 bg-white py-2 pr-10 pl-3 text-sm text-slate-900 placeholder:text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                    />
                    <button type="button" data-clear-search class="absolute inset-y-1 right-1 hidden min-h-8 items-center rounded-md px-2 text-xs font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500" aria-label="Καθαρισμός αναζήτησης">Καθ.</button>
                  </div>
                  <p class="mt-1 text-xs text-slate-500">Υποστηρίζονται πολλαπλοί όροι (π.χ. "Αθήνα νέο") και ειδικό φίλτρο score με μορφή <code>score:80</code>.</p>
                </div>

                <div class="mt-3">
                  <label for="leads-sort" class="text-sm font-semibold text-slate-700">Ταξινόμηση</label>
                  <select id="leads-sort" data-sort-select class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                    <option value="newest">Πιο πρόσφατα</option>
                    <option value="score">Score</option>
                    <option value="name">Όνομα</option>
                    <option value="category">Κατηγορία</option>
                    <option value="city">Πόλη</option>
                    <option value="status">Κατάσταση</option>
                  </select>
                </div>

                <div class="mt-4 border-t border-slate-200 pt-4">
                  <div class="flex items-center justify-between gap-2">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Ενεργά φίλτρα</p>
                    <button type="button" data-clear-url-filters class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός URL</button>
                  </div>
                  <div data-active-filters class="mt-2 flex flex-wrap gap-2" aria-live="polite"></div>
                  <p data-no-active-filters class="mt-2 text-xs text-slate-500">Δεν υπάρχουν ενεργά φίλτρα.</p>

                  <div class="mt-4 border-t border-slate-100 pt-3">
                    <div class="flex items-center justify-between gap-2">
                      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Saved presets</p>
                      <button type="button" data-save-preset class="inline-flex min-h-8 items-center rounded-md border border-indigo-300 bg-indigo-50 px-2.5 text-xs font-semibold text-indigo-800 transition hover:bg-indigo-100">Αποθήκευση τρέχοντος</button>
                    </div>
                    <div data-presets-list class="mt-2 flex flex-wrap gap-2"></div>
                    <p data-no-presets class="mt-2 text-xs text-slate-500">Δεν υπάρχουν αποθηκευμένα presets.</p>
                  </div>
                </div>
              </form>
            </aside>

            <section data-results-region aria-busy="false">
              <div class="sticky top-20 z-10 rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm backdrop-blur md:p-5">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <p class="text-sm text-slate-700" data-results-summary>
                    Εμφανίζονται <strong data-visible-count>{directoryData.leads.length}</strong> από <strong>{directoryData.leads.length}</strong> leads.
                  </p>
                  <div class="flex items-center gap-2">
                    <button type="button" data-export-csv class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Εξαγωγή CSV</button>
                    <div data-results-loading class="hidden items-center gap-2 rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700" role="status" aria-live="polite" aria-atomic="true">
                      <span class="h-3 w-3 animate-spin rounded-full border-2 border-sky-200 border-t-sky-700"></span>
                      Ενημέρωση αποτελεσμάτων
                    </div>
                  </div>
                </div>
                <div class="mt-3 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-3">
                  <p data-pagination-summary class="text-xs text-slate-600">Σελίδα 1 από 1</p>
                  <div class="flex items-center gap-2">
                    <button type="button" data-page-prev class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Προηγούμενη</button>
                    <button type="button" data-page-next class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Επόμενη</button>
                  </div>
                </div>
                <div class="mt-3 flex flex-wrap items-center gap-2 border-t border-slate-200 pt-3" role="group" aria-label="Bulk row actions">
                  <button type="button" data-select-visible class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Επιλογή ορατών</button>
                  <button type="button" data-clear-selection class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός</button>
                  <button type="button" data-bulk-contacted="true" class="inline-flex min-h-8 items-center rounded-md border border-emerald-300 bg-emerald-50 px-2.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Bulk: Επικοινωνήθηκε</button>
                  <button type="button" data-bulk-contacted="false" class="inline-flex min-h-8 items-center rounded-md border border-amber-300 bg-amber-50 px-2.5 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Bulk: Χωρίς επαφή</button>
                  <p data-selection-summary class="text-xs font-medium text-slate-600">0 επιλεγμένα</p>
                </div>
                <div class="mt-3 flex flex-wrap gap-2 border-t border-slate-200 pt-3" role="group" aria-label="Sortable columns">
                  <button type="button" data-sort-col="name" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Όνομα</button>
                  <button type="button" data-sort-col="category" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Κατηγορία</button>
                  <button type="button" data-sort-col="city" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Πόλη</button>
                  <button type="button" data-sort-col="score" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Score</button>
                  <button type="button" data-sort-col="status" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Κατάσταση</button>
                </div>
                <p data-live-region class="sr-only" aria-live="polite" aria-atomic="true"></p>
              </div>

              <section data-loading-skeleton class="mt-4 hidden space-y-3" aria-hidden="true">
                <div class="rounded-xl border border-sky-200 bg-sky-50 p-3 text-xs font-semibold text-sky-800">Φόρτωση και εφαρμογή φίλτρων...</div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
              </section>

              <section class="mt-4 space-y-3" data-leads-list>
                {directoryData.leads.map((lead) => (
                  <article
                    data-lead-card
                    data-lead-id={lead.id}
                    data-category={lead.categorySlug}
                    data-category-label={lead.categoryLabel}
                    data-city={lead.city}
                    data-status={lead.status}
                    data-status-label={statusLabel(lead.status)}
                    data-name={lead.name}
                    data-phone={lead.phone}
                    data-email={lead.email}
                    data-score={lead.score ?? -1}
                    data-notes={lead.sourceUrl ? `Πηγή: ${lead.sourceUrl}` : 'Δεν υπάρχουν διαθέσιμες σημειώσεις για αυτό το lead.'}
                    data-newest={lead.newestTs}
                    data-last-contacted=""
                    tabindex="0"
                    class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:shadow focus:outline-none focus:ring-2 focus:ring-sky-500 md:p-5"
                  >
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div class="flex items-start gap-3">
                        <input type="checkbox" data-row-select aria-label={`Επιλογή lead ${lead.name}`} class="mt-1 h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" />
                        <div>
                          <h2 class="text-lg font-bold text-slate-900">{lead.name}</h2>
                          <p class="mt-1 text-sm text-slate-600">{lead.categoryLabel} • {lead.city}</p>
                        </div>
                      </div>
                      <div class="flex flex-wrap items-center gap-2 text-xs">
                        <span data-status-chip class="rounded-full border px-2 py-1 font-semibold">{statusLabel(lead.status)}</span>
                        <span class="rounded-full bg-sky-100 px-2 py-1 font-semibold text-sky-800">Score: {lead.score ?? 'N/A'}</span>
                        <span data-outreach-badge class="rounded-full bg-amber-100 px-2 py-1 font-semibold text-amber-800">Χωρίς επικοινωνία</span>
                      </div>
                    </div>

                    <div class="mt-3 grid gap-2 text-sm text-slate-700 sm:grid-cols-2">
                      <p>
                        <strong>Τηλέφωνο:</strong>
                        {' '}
                        {lead.phone ? <a class="underline decoration-slate-300 underline-offset-2 hover:text-slate-900" href={`tel:${lead.phone}`}>{lead.phone}</a> : '—'}
                      </p>
                      <p>
                        <strong>Email:</strong>
                        {' '}
                        {lead.email ? <a class="underline decoration-slate-300 underline-offset-2 hover:text-slate-900" href={`mailto:${lead.email}`}>{lead.email}</a> : '—'}
                      </p>
                    </div>

                    <div class="mt-4 flex flex-wrap gap-2">
                      <button type="button" data-toggle-contacted="true" aria-pressed="false" class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Επικοινωνήθηκε</button>
                      <button type="button" data-toggle-contacted="false" aria-pressed="false" class="inline-flex min-h-9 items-center rounded-lg border border-amber-300 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Χωρίς επαφή</button>
                    </div>

                    <p data-last-contacted-display class="mt-2 text-xs font-medium text-slate-600">Τελευταία επικοινωνία: Ποτέ</p>

                    <div class="mt-3 rounded-lg border border-slate-200 bg-slate-50 p-3">
                      <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Activity timeline</p>
                      <ul data-activity-list class="mt-2 space-y-1 text-xs text-slate-700">
                        <li data-activity-empty class="text-slate-500">Δεν υπάρχουν πρόσφατα events.</li>
                      </ul>
                    </div>

                    <div class="mt-3 flex flex-wrap gap-2">
                      {lead.phone && <a href={`tel:${lead.phone}`} class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Κλήση τώρα</a>}
                      {lead.email && <a href={`mailto:${lead.email}`} class="inline-flex min-h-9 items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-800 transition hover:bg-sky-100">Email τώρα</a>}
                      <button type="button" data-copy-phone class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αντιγραφή τηλεφώνου</button>
                      <button type="button" data-copy-email class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αντιγραφή email</button>
                      <button type="button" data-open-detail class="inline-flex min-h-9 items-center rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-800 transition hover:bg-indigo-100">Λεπτομέρειες</button>
                    </div>

                    {lead.sourceUrl && (
                      <a href={lead.sourceUrl} target="_blank" rel="noreferrer" class="mt-4 inline-flex min-h-9 items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-sm font-semibold text-sky-800 transition hover:bg-sky-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                        Άνοιγμα πηγής
                      </a>
                    )}
                  </article>
                ))}
              </section>

              <section
                data-empty-state="no-data"
                class:list={[
                  'mt-4 rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-700',
                  hasLeads ? 'hidden' : ''
                ]}
              >
                <h2 class="text-lg font-bold text-slate-900">Δεν υπάρχουν διαθέσιμα leads</h2>
                <p class="mt-2 text-sm">Όταν προστεθούν νέα αρχεία στο `data/leads`, θα εμφανιστούν εδώ.</p>
              </section>

              <section data-empty-state="filtered" class="mt-4 hidden rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-700" role="status" aria-live="polite">
                <h2 class="text-lg font-bold text-slate-900">Δεν βρέθηκαν αποτελέσματα</h2>
                <p class="mt-2 text-sm">Δεν υπάρχει lead που να ταιριάζει με τα τρέχοντα φίλτρα.</p>
                <p class="mt-1 text-xs text-slate-500">Tip: Ξεκινήστε με μόνο κατηγορία και προσθέστε σταδιακά τα υπόλοιπα φίλτρα.</p>
                <button type="button" data-empty-reset class="mt-4 inline-flex min-h-10 items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Καθαρισμός φίλτρων</button>
              </section>

              <section data-runtime-error class="mt-4 hidden rounded-2xl border border-rose-200 bg-rose-50 p-6 text-rose-900" role="alert" aria-live="assertive">
                <h2 class="text-lg font-bold">Σφάλμα φίλτρων</h2>
                <p class="mt-2 text-sm" data-runtime-error-message>Παρουσιάστηκε απρόβλεπτο σφάλμα κατά την εφαρμογή φίλτρων.</p>
                <button type="button" data-runtime-reset class="mt-4 inline-flex min-h-10 items-center rounded-lg bg-rose-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-rose-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">
                  Επαναφορά φίλτρων
                </button>
              </section>

              <section data-selection-dock class="pointer-events-none fixed inset-x-0 bottom-3 z-30 hidden px-4">
                <div class="pointer-events-auto mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-white/95 px-4 py-3 shadow-xl backdrop-blur">
                  <p class="text-sm font-semibold text-slate-800"><span data-selection-dock-count>0</span> leads επιλεγμένα</p>
                  <div class="flex flex-wrap items-center gap-2">
                    <button type="button" data-selection-dock-contacted="true" class="inline-flex min-h-8 items-center rounded-md border border-emerald-300 bg-emerald-50 px-3 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Μαζικά: Επικοινωνήθηκε</button>
                    <button type="button" data-selection-dock-contacted="false" class="inline-flex min-h-8 items-center rounded-md border border-amber-300 bg-amber-50 px-3 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Μαζικά: Χωρίς επαφή</button>
                    <button type="button" data-selection-dock-clear class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-3 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός επιλογής</button>
                  </div>
                </div>
              </section>

              <section data-detail-panel class="pointer-events-none fixed inset-0 z-40 hidden">
                <button type="button" data-detail-overlay class="absolute inset-0 bg-slate-900/40"></button>
                <aside class="pointer-events-auto absolute right-0 top-0 h-full w-full max-w-md overflow-y-auto border-l border-slate-200 bg-white p-5 shadow-2xl">
                  <div class="flex items-start justify-between gap-3">
                    <h2 class="text-lg font-bold text-slate-900">Lead λεπτομέρειες</h2>
                    <button type="button" data-detail-close class="rounded-md border border-slate-300 px-2 py-1 text-xs font-semibold text-slate-700">Κλείσιμο</button>
                  </div>
                  <div class="mt-4 space-y-2 text-sm text-slate-700">
                    <p><strong>Όνομα:</strong> <span data-detail-name>—</span></p>
                    <p><strong>Κατηγορία:</strong> <span data-detail-category>—</span></p>
                    <p><strong>Πόλη:</strong> <span data-detail-city>—</span></p>
                    <p><strong>Κατάσταση:</strong> <span data-detail-status>—</span></p>
                    <p><strong>Score:</strong> <span data-detail-score>—</span></p>
                    <p><strong>Τηλέφωνο:</strong> <span data-detail-phone>—</span></p>
                    <p><strong>Email:</strong> <span data-detail-email>—</span></p>
                    <p><strong>Outreach:</strong> <span data-detail-outreach>—</span></p>
                    <p><strong>Τελευταία επικοινωνία:</strong> <span data-detail-last-contacted>—</span></p>
                  </div>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Preview σημειώσεων</p>
                    <p data-detail-notes class="mt-2 text-sm text-slate-700">—</p>
                  </div>
                </aside>
              </section>
            </section>
          </div>
        )}
      </>
    )}
  </main>

  <script>
    const root = document.querySelector('[data-leads-root]');

    if (root) {
      try {
        const cards = Array.from(root.querySelectorAll('[data-lead-card]'));
        const list = root.querySelector('[data-leads-list]');
        const categoryTabs = Array.from(root.querySelectorAll('[data-category-tab]'));
        const contactedFilterButtons = Array.from(root.querySelectorAll('[data-contacted-filter]'));
        const cityFilter = root.querySelector('[data-city-filter]');
        const statusFilter = root.querySelector('[data-status-filter]');
        const scoreFilter = root.querySelector('[data-score-filter]');
        const searchInput = root.querySelector('[data-search-input]');
        const clearSearchButton = root.querySelector('[data-clear-search]');
        const sortSelect = root.querySelector('[data-sort-select]');
        const sortColumnButtons = Array.from(root.querySelectorAll('[data-sort-col]'));
        const resetButton = root.querySelector('[data-reset-filters]');
        const visibleCount = root.querySelector('[data-visible-count]');
        const resultsSummary = root.querySelector('[data-results-summary]');
        const resultsLoading = root.querySelector('[data-results-loading]');
        const loadingSkeleton = root.querySelector('[data-loading-skeleton]');
        const liveRegion = root.querySelector('[data-live-region]');
        const activeFilters = root.querySelector('[data-active-filters]');
        const noActiveFilters = root.querySelector('[data-no-active-filters]');
        const clearUrlFiltersButton = root.querySelector('[data-clear-url-filters]');
        const savePresetButton = root.querySelector('[data-save-preset]');
        const presetsList = root.querySelector('[data-presets-list]');
        const noPresets = root.querySelector('[data-no-presets]');
        const exportCsvButton = root.querySelector('[data-export-csv]');
        const pagePrevButton = root.querySelector('[data-page-prev]');
        const pageNextButton = root.querySelector('[data-page-next]');
        const paginationSummary = root.querySelector('[data-pagination-summary]');
        const selectVisibleButton = root.querySelector('[data-select-visible]');
        const clearSelectionButton = root.querySelector('[data-clear-selection]');
        const bulkStatusButtons = Array.from(root.querySelectorAll('[data-bulk-contacted]'));
        const selectionSummary = root.querySelector('[data-selection-summary]');
        const selectionDock = root.querySelector('[data-selection-dock]');
        const selectionDockCount = root.querySelector('[data-selection-dock-count]');
        const selectionDockButtons = Array.from(root.querySelectorAll('[data-selection-dock-contacted]'));
        const selectionDockClear = root.querySelector('[data-selection-dock-clear]');
        const noDataState = root.querySelector('[data-empty-state="no-data"]');
        const filteredEmptyState = root.querySelector('[data-empty-state="filtered"]');
        const emptyReset = root.querySelector('[data-empty-reset]');
        const categoryContext = root.querySelector('[data-category-context]');
        const runtimeError = root.querySelector('[data-runtime-error]');
        const runtimeErrorMessage = root.querySelector('[data-runtime-error-message]');
        const runtimeReset = root.querySelector('[data-runtime-reset]');
        const detailPanel = root.querySelector('[data-detail-panel]');
        const detailOverlay = root.querySelector('[data-detail-overlay]');
        const detailClose = root.querySelector('[data-detail-close]');
        const detailName = root.querySelector('[data-detail-name]');
        const detailCategory = root.querySelector('[data-detail-category]');
        const detailCity = root.querySelector('[data-detail-city]');
        const detailStatus = root.querySelector('[data-detail-status]');
        const detailScore = root.querySelector('[data-detail-score]');
        const detailPhone = root.querySelector('[data-detail-phone]');
        const detailEmail = root.querySelector('[data-detail-email]');
        const detailOutreach = root.querySelector('[data-detail-outreach]');
        const detailLastContacted = root.querySelector('[data-detail-last-contacted]');
        const detailNotes = root.querySelector('[data-detail-notes]');
        const resultsRegion = root.querySelector('[data-results-region]');

        const OUTREACH_STORAGE_KEY = 'admin-leads-outreach-v1';
        const ACTIVITY_STORAGE_KEY = 'admin-leads-activity-v1';
        const CONTACTED_FILTER_VALUES = ['all', 'contacted', 'not-contacted'];
        const CONTACTED_FILTER_LABELS = {
          all: 'Όλα',
          contacted: 'Επικοινωνήθηκαν',
          'not-contacted': 'Χωρίς επαφή'
        };

        const toMaybeTimestamp = (value) => {
          if (typeof value === 'number' && Number.isFinite(value)) return value;
          if (typeof value === 'string') {
            const parsed = Date.parse(value);
            if (Number.isFinite(parsed)) return parsed;
          }
          return null;
        };

        const readOutreachState = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(OUTREACH_STORAGE_KEY) || '{}');
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
          } catch {
            return {};
          }
        };

        const writeOutreachState = (nextState) => {
          try {
            localStorage.setItem(OUTREACH_STORAGE_KEY, JSON.stringify(nextState));
          } catch {
            // Storage can fail in private sessions; keep runtime state in-memory.
          }
        };

        let outreachState = readOutreachState();

        const readActivityState = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(ACTIVITY_STORAGE_KEY) || '{}');
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
          } catch {
            return {};
          }
        };

        const writeActivityState = (nextState) => {
          try {
            localStorage.setItem(ACTIVITY_STORAGE_KEY, JSON.stringify(nextState));
          } catch {
            // ignore localStorage errors
          }
        };

        let activityState = readActivityState();
        const selectedLeadIds = new Set();

        const parsedCards = cards
          .filter((card) => card instanceof HTMLElement)
          .map((card) => {
            const id = card.dataset.leadId || '';
            const category = card.dataset.category || '';
            const categoryLabel = card.dataset.categoryLabel || category;
            const city = card.dataset.city || '';
            const status = card.dataset.status || '';
            const statusLabel = card.dataset.statusLabel || status;
            const name = card.dataset.name || '';
            const phone = card.dataset.phone || '';
            const email = card.dataset.email || '';
            const rawScore = Number(card.dataset.score || -1);
            const score = Number.isFinite(rawScore) ? rawScore : -1;
            const newest = Number(card.dataset.newest || 0);
            const storedOutreach = id && outreachState[id] && typeof outreachState[id] === 'object' ? outreachState[id] : null;
            const storedActivity = id && Array.isArray(activityState[id]) ? activityState[id] : [];
            const defaultContacted = status === 'contacted';
            const storedContacted = storedOutreach && typeof storedOutreach.contacted === 'boolean' ? storedOutreach.contacted : defaultContacted;
            const lastContactedTs = toMaybeTimestamp(storedOutreach?.lastContactedAt) ?? toMaybeTimestamp(card.dataset.lastContacted);
            const searchableText = [
              name,
              phone,
              email,
              categoryLabel,
              city,
              statusLabel,
              `score:${score}`,
              storedContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη'
            ].join(' ').toLowerCase();

            return {
              id,
              card,
              category,
              categoryLabel,
              city,
              status,
              statusLabel,
              name,
              phone,
              email,
              score,
              newest,
              searchableText,
              isContacted: storedContacted,
              lastContactedTs,
              activity: storedActivity
            };
          });

        const categoryLabelByValue = new Map();
        categoryTabs.forEach((tab) => {
          if (!(tab instanceof HTMLButtonElement)) return;
          const value = tab.dataset.categoryValue || 'all';
          const label = tab.dataset.categoryLabel || tab.textContent || value;
          categoryLabelByValue.set(value, label.trim());
        });

        const cityLabelByValue = new Map();
        const statusLabelByValue = new Map();

        if (cityFilter instanceof HTMLSelectElement) {
          Array.from(cityFilter.options).forEach((option) => {
            option.dataset.baseLabel = option.textContent || option.value;
            cityLabelByValue.set(option.value, option.textContent || option.value);
          });
        }

        if (statusFilter instanceof HTMLSelectElement) {
          Array.from(statusFilter.options).forEach((option) => {
            option.dataset.baseLabel = option.textContent || option.value;
            statusLabelByValue.set(option.value, option.textContent || option.value);
          });
        }

        const validCategories = new Set(Array.from(categoryLabelByValue.keys()));
        const validCities = new Set(parsedCards.map((entry) => entry.city));
        const validStatuses = new Set(parsedCards.map((entry) => entry.status));

        const state = {
          category: 'all',
          city: 'all',
          status: 'all',
          contacted: 'all',
          minScore: 'any',
          search: '',
          sort: 'newest',
          sortDir: 'desc',
          page: 1,
          perPage: 15
        };

        const hasAnyData = parsedCards.length > 0;
        let applyTimer = null;
        let lastFiltered = [];
        let lastTotalPages = 1;
        let activeDetailLeadId = '';
        const PRESET_STORAGE_KEY = 'admin-leads-presets-v1';

        const readPresets = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(PRESET_STORAGE_KEY) || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch {
            return [];
          }
        };

        const writePresets = (presets) => {
          localStorage.setItem(PRESET_STORAGE_KEY, JSON.stringify(presets.slice(0, 8)));
        };

        const renderPresets = () => {
          if (!(presetsList instanceof HTMLElement) || !(noPresets instanceof HTMLElement)) return;
          const presets = readPresets();
          presetsList.innerHTML = '';
          presets.forEach((preset) => {
            const applyBtn = document.createElement('button');
            applyBtn.type = 'button';
            applyBtn.dataset.presetName = preset.name;
            applyBtn.className = 'inline-flex min-h-8 items-center rounded-full border border-indigo-200 bg-indigo-50 px-3 text-xs font-semibold text-indigo-800 hover:bg-indigo-100';
            applyBtn.textContent = preset.name;
            presetsList.appendChild(applyBtn);
          });
          noPresets.classList.toggle('hidden', presets.length > 0);
        };

        const formatLastContacted = (ts) => {
          if (!Number.isFinite(ts) || ts <= 0) return 'Ποτέ';
          return new Date(ts).toLocaleString('el-GR');
        };

        const syncOutreachRecord = (entry) => {
          if (!entry.id) return;
          outreachState = {
            ...outreachState,
            [entry.id]: {
              contacted: Boolean(entry.isContacted),
              lastContactedAt: Number.isFinite(entry.lastContactedTs) ? new Date(entry.lastContactedTs).toISOString() : null
            }
          };
          writeOutreachState(outreachState);
        };

        const appendActivity = (entry, actionLabel) => {
          const event = {
            at: new Date().toISOString(),
            label: actionLabel
          };
          const next = [event, ...(Array.isArray(entry.activity) ? entry.activity : [])].slice(0, 6);
          entry.activity = next;
          if (!entry.id) return;
          activityState = {
            ...activityState,
            [entry.id]: next
          };
          writeActivityState(activityState);
        };

        const renderActivityTimeline = (entry) => {
          const listEl = entry.card.querySelector('[data-activity-list]');
          if (!(listEl instanceof HTMLElement)) return;
          listEl.innerHTML = '';

          const events = Array.isArray(entry.activity) ? entry.activity.slice(0, 3) : [];
          if (events.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'text-slate-500';
            empty.textContent = 'Δεν υπάρχουν πρόσφατα events.';
            listEl.appendChild(empty);
            return;
          }

          events.forEach((eventItem) => {
            const li = document.createElement('li');
            const ts = toMaybeTimestamp(eventItem?.at);
            li.className = 'flex items-center justify-between gap-2';
            li.innerHTML = `<span>${eventItem?.label || 'Ενέργεια'}</span><span class="text-slate-500">${Number.isFinite(ts) ? new Date(ts).toLocaleString('el-GR') : ''}</span>`;
            listEl.appendChild(li);
          });
        };

        const renderSelectionState = () => {
          const count = selectedLeadIds.size;
          if (selectionSummary instanceof HTMLElement) selectionSummary.textContent = `${count} επιλεγμένα`;
          if (selectionDockCount instanceof HTMLElement) selectionDockCount.textContent = String(count);
          if (selectionDock instanceof HTMLElement) selectionDock.classList.toggle('hidden', count === 0);
          parsedCards.forEach((entry) => {
            const checkbox = entry.card.querySelector('[data-row-select]');
            if (checkbox instanceof HTMLInputElement) checkbox.checked = selectedLeadIds.has(entry.id);
          });
          bulkStatusButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          selectionDockButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          if (clearSelectionButton instanceof HTMLButtonElement) clearSelectionButton.disabled = count === 0;
          if (selectionDockClear instanceof HTMLButtonElement) selectionDockClear.disabled = count === 0;
        };

        const renderStatusChip = (entry) => {
          const statusChip = entry.card.querySelector('[data-status-chip]');
          if (!(statusChip instanceof HTMLElement)) return;
          statusChip.textContent = entry.statusLabel;
          statusChip.className = 'rounded-full border px-2 py-1 font-semibold';

          if (entry.status === 'new') statusChip.classList.add('border-blue-200', 'bg-blue-50', 'text-blue-800');
          else if (entry.status === 'contacted') statusChip.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-800');
          else if (entry.status === 'qualified') statusChip.classList.add('border-violet-200', 'bg-violet-50', 'text-violet-800');
          else if (entry.status === 'rejected') statusChip.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
          else statusChip.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');
        };

        const renderCardOutreach = (entry) => {
          const badge = entry.card.querySelector('[data-outreach-badge]');
          const lastContacted = entry.card.querySelector('[data-last-contacted-display]');
          const markContactedButton = entry.card.querySelector('[data-toggle-contacted="true"]');
          const markNotContactedButton = entry.card.querySelector('[data-toggle-contacted="false"]');

          if (badge instanceof HTMLElement) {
            badge.textContent = entry.isContacted ? 'Επικοινωνήθηκε' : 'Χωρίς επικοινωνία';
            badge.classList.toggle('bg-emerald-100', entry.isContacted);
            badge.classList.toggle('text-emerald-800', entry.isContacted);
            badge.classList.toggle('bg-amber-100', !entry.isContacted);
            badge.classList.toggle('text-amber-800', !entry.isContacted);
          }

          if (lastContacted instanceof HTMLElement) {
            lastContacted.textContent = `Τελευταία επικοινωνία: ${formatLastContacted(entry.lastContactedTs)}`;
          }

          if (markContactedButton instanceof HTMLButtonElement) {
            markContactedButton.setAttribute('aria-pressed', entry.isContacted ? 'true' : 'false');
            markContactedButton.classList.toggle('bg-emerald-600', entry.isContacted);
            markContactedButton.classList.toggle('border-emerald-600', entry.isContacted);
            markContactedButton.classList.toggle('text-white', entry.isContacted);
            markContactedButton.classList.toggle('bg-emerald-50', !entry.isContacted);
            markContactedButton.classList.toggle('border-emerald-300', !entry.isContacted);
            markContactedButton.classList.toggle('text-emerald-800', !entry.isContacted);
          }

          if (markNotContactedButton instanceof HTMLButtonElement) {
            markNotContactedButton.setAttribute('aria-pressed', !entry.isContacted ? 'true' : 'false');
            markNotContactedButton.classList.toggle('bg-amber-600', !entry.isContacted);
            markNotContactedButton.classList.toggle('border-amber-600', !entry.isContacted);
            markNotContactedButton.classList.toggle('text-white', !entry.isContacted);
            markNotContactedButton.classList.toggle('bg-amber-50', entry.isContacted);
            markNotContactedButton.classList.toggle('border-amber-300', entry.isContacted);
            markNotContactedButton.classList.toggle('text-amber-800', entry.isContacted);
          }

          renderStatusChip(entry);
          renderActivityTimeline(entry);
        };

        const renderDetailOutreach = (entry) => {
          if (detailOutreach instanceof HTMLElement) {
            detailOutreach.textContent = entry.isContacted ? 'Επικοινωνήθηκε' : 'Χωρίς επικοινωνία';
          }
          if (detailLastContacted instanceof HTMLElement) {
            detailLastContacted.textContent = formatLastContacted(entry.lastContactedTs);
          }
        };

        parsedCards.forEach((entry) => {
          renderCardOutreach(entry);
        });

        const parseFromUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const category = params.get('category') || 'all';
          const city = params.get('city') || 'all';
          const status = params.get('status') || 'all';
          const contacted = params.get('contacted') || 'all';
          const minScore = params.get('minScore') || 'any';
          const search = (params.get('q') || '').trim();
          const sort = params.get('sort') || 'newest';
          const dir = params.get('dir') || 'desc';
          const page = Number(params.get('page') || '1');

          state.category = validCategories.has(category) ? category : 'all';
          state.city = city === 'all' || validCities.has(city) ? city : 'all';
          state.status = status === 'all' || validStatuses.has(status) ? status : 'all';
          state.contacted = CONTACTED_FILTER_VALUES.includes(contacted) ? contacted : 'all';
          state.minScore = ['any', '80', '60', '40'].includes(minScore) ? minScore : 'any';
          state.search = search;
          state.sort = ['newest', 'score', 'name', 'category', 'city', 'status'].includes(sort) ? sort : 'newest';
          state.sortDir = dir === 'asc' ? 'asc' : 'desc';
          state.page = Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
        };

        const syncControlsToState = () => {
          categoryTabs.forEach((tab) => {
            if (!(tab instanceof HTMLButtonElement)) return;
            const selected = tab.dataset.categoryValue === state.category;
            tab.setAttribute('aria-pressed', selected ? 'true' : 'false');
            tab.classList.toggle('bg-sky-600', selected);
            tab.classList.toggle('border-sky-600', selected);
            tab.classList.toggle('text-white', selected);
            tab.classList.toggle('shadow-sm', selected);
            tab.classList.toggle('bg-white', !selected);
            tab.classList.toggle('border-slate-300', !selected);
            tab.classList.toggle('text-slate-700', !selected);
          });

          contactedFilterButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const selected = button.dataset.contactedValue === state.contacted;
            button.setAttribute('aria-pressed', selected ? 'true' : 'false');
            button.classList.toggle('bg-sky-600', selected);
            button.classList.toggle('border-sky-600', selected);
            button.classList.toggle('text-white', selected);
            button.classList.toggle('bg-transparent', !selected);
            button.classList.toggle('border-transparent', !selected);
            button.classList.toggle('text-slate-700', !selected);
          });

          if (cityFilter instanceof HTMLSelectElement) cityFilter.value = state.city;
          if (statusFilter instanceof HTMLSelectElement) statusFilter.value = state.status;
          if (scoreFilter instanceof HTMLSelectElement) scoreFilter.value = state.minScore;
          if (searchInput instanceof HTMLInputElement) searchInput.value = state.search;
          if (sortSelect instanceof HTMLSelectElement) sortSelect.value = state.sort;
          const sortLabels = { name: 'Όνομα', category: 'Κατηγορία', city: 'Πόλη', score: 'Score', status: 'Κατάσταση' };
          sortColumnButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const key = button.dataset.sortCol || '';
            const isActive = key === state.sort;
            button.classList.toggle('bg-sky-600', isActive);
            button.classList.toggle('border-sky-600', isActive);
            button.classList.toggle('text-white', isActive);
            button.classList.toggle('text-slate-700', !isActive);
            button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            const base = sortLabels[key] || key;
            button.textContent = isActive ? `${base} ${state.sortDir === 'asc' ? '↑' : '↓'}` : base;
          });

          if (categoryContext instanceof HTMLElement) {
            const label = categoryLabelByValue.get(state.category) || 'Όλες';
            categoryContext.textContent = state.category === 'all'
              ? 'Εμφάνιση όλων των κατηγοριών. Επιλέξτε κατηγορία για πιο στοχευμένη λίστα leads.'
              : `Επιλεγμένη κατηγορία: ${label}. Τα υπόλοιπα φίλτρα λειτουργούν μέσα σε αυτήν.`;
          }

          if (clearSearchButton instanceof HTMLButtonElement) {
            clearSearchButton.classList.toggle('hidden', !state.search.trim());
            clearSearchButton.classList.toggle('inline-flex', Boolean(state.search.trim()));
          }
        };

        const setBusy = (isBusy) => {
          if (resultsRegion instanceof HTMLElement) resultsRegion.setAttribute('aria-busy', isBusy ? 'true' : 'false');
          if (resultsLoading instanceof HTMLElement) resultsLoading.classList.toggle('hidden', !isBusy);
          if (resultsLoading instanceof HTMLElement) resultsLoading.classList.toggle('inline-flex', isBusy);
          if (loadingSkeleton instanceof HTMLElement) loadingSkeleton.classList.toggle('hidden', !isBusy || !hasAnyData);
        };

        const matchesLead = (lead, criteria = state) => {
          const normalizedSearch = criteria.search.trim().toLowerCase();
          const scoreSearchMatch = normalizedSearch.match(/score\s*:\s*(\d+)/);
          const scoreFromSearch = scoreSearchMatch ? Number(scoreSearchMatch[1]) : null;
          const textSearch = normalizedSearch.replace(/score\s*:\s*\d+/g, '').replace(/\s+/g, ' ').trim();
          const searchTokens = textSearch ? textSearch.split(' ').filter(Boolean) : [];

          const minScore = criteria.minScore === 'any' ? -1 : Number(criteria.minScore);
          const effectiveScoreThreshold = Number.isFinite(scoreFromSearch) ? Math.max(minScore, scoreFromSearch) : minScore;

          const categoryMatch = criteria.category === 'all' || lead.category === criteria.category;
          const cityMatch = criteria.city === 'all' || lead.city === criteria.city;
          const statusMatch = criteria.status === 'all' || lead.status === criteria.status;
          const contactedMatch = criteria.contacted === 'all'
            || (criteria.contacted === 'contacted' ? lead.isContacted : !lead.isContacted);
          const scoreMatch = effectiveScoreThreshold <= -1 || lead.score >= effectiveScoreThreshold;
          const searchMatch = searchTokens.length === 0 || searchTokens.every((token) => lead.searchableText.includes(token));
          return categoryMatch && cityMatch && statusMatch && contactedMatch && scoreMatch && searchMatch;
        };

        const updateOptionCounts = () => {
          categoryTabs.forEach((tab) => {
            if (!(tab instanceof HTMLButtonElement)) return;
            const value = tab.dataset.categoryValue || 'all';
            const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, category: value })).length;
            const counter = tab.querySelector('[data-category-count]');
            if (counter) counter.textContent = String(count);
            tab.disabled = count === 0 && value !== state.category;
            tab.classList.toggle('opacity-50', tab.disabled);
            tab.classList.toggle('cursor-not-allowed', tab.disabled);
          });

          if (cityFilter instanceof HTMLSelectElement) {
            Array.from(cityFilter.options).forEach((option) => {
              const baseLabel = option.dataset.baseLabel || option.value;
              const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, city: option.value })).length;
              option.textContent = option.value === 'all' ? `${baseLabel} (${count})` : `${baseLabel} (${count})`;
              option.disabled = count === 0 && option.value !== state.city;
            });
          }

          if (statusFilter instanceof HTMLSelectElement) {
            Array.from(statusFilter.options).forEach((option) => {
              const baseLabel = option.dataset.baseLabel || option.value;
              const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, status: option.value })).length;
              option.textContent = option.value === 'all' ? `${baseLabel} (${count})` : `${baseLabel} (${count})`;
              option.disabled = count === 0 && option.value !== state.status;
            });
          }
        };

        const updateActiveFilters = () => {
          if (!(activeFilters instanceof HTMLElement) || !(noActiveFilters instanceof HTMLElement)) return;

          const items = [];
          if (state.category !== 'all') items.push({ key: 'category', label: `Κατηγορία: ${categoryLabelByValue.get(state.category) || state.category}` });
          if (state.city !== 'all') items.push({ key: 'city', label: `Πόλη: ${cityLabelByValue.get(state.city) || state.city}` });
          if (state.status !== 'all') items.push({ key: 'status', label: `Κατάσταση: ${statusLabelByValue.get(state.status) || state.status}` });
          if (state.contacted !== 'all') items.push({ key: 'contacted', label: `Outreach: ${CONTACTED_FILTER_LABELS[state.contacted] || state.contacted}` });
          if (state.minScore !== 'any') items.push({ key: 'minScore', label: `Score: ${state.minScore}+` });
          if (state.search.trim()) items.push({ key: 'search', label: `Αναζήτηση: “${state.search.trim()}”` });

          activeFilters.innerHTML = '';

          items.forEach((item) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.dataset.filterChip = item.key;
            button.className = 'inline-flex min-h-8 items-center gap-1 rounded-full border border-sky-300 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-800 transition hover:bg-sky-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2';
            button.setAttribute('aria-label', `Αφαίρεση φίλτρου ${item.label}`);
            button.textContent = `${item.label} ×`;
            activeFilters.appendChild(button);
          });

          noActiveFilters.classList.toggle('hidden', items.length > 0);
        };

        const syncUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const setParam = (key, value, defaultValue = 'all') => {
            if (!value || value === defaultValue) params.delete(key);
            else params.set(key, value);
          };

          setParam('category', state.category);
          setParam('city', state.city);
          setParam('status', state.status);
          setParam('contacted', state.contacted);
          setParam('minScore', state.minScore, 'any');
          setParam('sort', state.sort, 'newest');
          setParam('dir', state.sortDir, 'desc');
          setParam('page', String(state.page), '1');

          if (state.search.trim()) params.set('q', state.search.trim());
          else params.delete('q');

          const query = params.toString();
          const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
          window.history.replaceState({}, '', nextUrl);
        };

        const render = () => {
          if (!(list instanceof HTMLElement)) return;

          const filtered = parsedCards.filter((lead) => matchesLead(lead));

          filtered.sort((a, b) => {
            let result = 0;
            if (state.sort === 'score') result = (a.score - b.score);
            else if (state.sort === 'name') result = a.name.localeCompare(b.name, 'el');
            else if (state.sort === 'category') result = a.categoryLabel.localeCompare(b.categoryLabel, 'el');
            else if (state.sort === 'city') result = a.city.localeCompare(b.city, 'el');
            else if (state.sort === 'status') result = a.statusLabel.localeCompare(b.statusLabel, 'el');
            else result = a.newest - b.newest;

            if (result === 0) result = a.name.localeCompare(b.name, 'el');
            return state.sortDir === 'asc' ? result : -result;
          });

          lastFiltered = filtered;
          const totalFiltered = filtered.length;
          const totalPages = Math.max(1, Math.ceil(totalFiltered / state.perPage));
          lastTotalPages = totalPages;
          state.page = Math.min(Math.max(1, state.page), totalPages);

          const startIndex = (state.page - 1) * state.perPage;
          const paged = filtered.slice(startIndex, startIndex + state.perPage);

          parsedCards.forEach((entry) => {
            entry.card.hidden = true;
          });

          paged.forEach((entry) => {
            entry.card.hidden = false;
            list.appendChild(entry.card);
            renderCardOutreach(entry);
          });

          const visible = paged.length;
          if (visibleCount instanceof HTMLElement) visibleCount.textContent = String(totalFiltered);

          if (resultsSummary instanceof HTMLElement) {
            resultsSummary.innerHTML = `Εμφανίζονται <strong>${totalFiltered}</strong> από <strong>${parsedCards.length}</strong> leads.`;
          }

          if (paginationSummary instanceof HTMLElement) {
            paginationSummary.textContent = `Σελίδα ${state.page} από ${totalPages} • ${visible} στοιχεία σε αυτή τη σελίδα`;
          }

          if (pagePrevButton instanceof HTMLButtonElement) pagePrevButton.disabled = state.page <= 1;
          if (pageNextButton instanceof HTMLButtonElement) pageNextButton.disabled = state.page >= totalPages;
          if (exportCsvButton instanceof HTMLButtonElement) exportCsvButton.disabled = totalFiltered === 0;

          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = `Εμφανίζονται ${totalFiltered} από ${parsedCards.length} leads, σελίδα ${state.page} από ${totalPages}`;
          }

          if (noDataState instanceof HTMLElement) {
            noDataState.classList.toggle('hidden', parsedCards.length > 0);
          }

          if (filteredEmptyState instanceof HTMLElement) {
            const shouldShowFilteredEmpty = parsedCards.length > 0 && totalFiltered === 0;
            filteredEmptyState.classList.toggle('hidden', !shouldShowFilteredEmpty);
          }

          renderSelectionState();
        };

        const setRuntimeError = (message) => {
          if (runtimeError instanceof HTMLElement) runtimeError.classList.remove('hidden');
          if (runtimeErrorMessage instanceof HTMLElement) runtimeErrorMessage.textContent = message;
          if (list instanceof HTMLElement) list.classList.add('hidden');
          if (filteredEmptyState instanceof HTMLElement) filteredEmptyState.classList.add('hidden');
          if (loadingSkeleton instanceof HTMLElement) loadingSkeleton.classList.add('hidden');
        };

        const runFilters = () => {
          setBusy(true);
          window.requestAnimationFrame(() => {
            try {
              updateOptionCounts();
              updateActiveFilters();
              render();
              syncUrl();
              if (runtimeError instanceof HTMLElement) runtimeError.classList.add('hidden');
              if (list instanceof HTMLElement) list.classList.remove('hidden');
            } catch {
              setRuntimeError('Η εφαρμογή φίλτρων απέτυχε. Επιλέξτε επαναφορά φίλτρων για ανάκτηση.');
            } finally {
              setBusy(false);
            }
          });
        };

        const scheduleRun = (delay = 0) => {
          if (applyTimer) window.clearTimeout(applyTimer);
          applyTimer = window.setTimeout(runFilters, delay);
        };

        const resetFilters = () => {
          state.category = 'all';
          state.city = 'all';
          state.status = 'all';
          state.contacted = 'all';
          state.minScore = 'any';
          state.search = '';
          state.sort = 'newest';
          state.sortDir = 'desc';
          state.page = 1;
          syncControlsToState();
          scheduleRun();
        };

        parseFromUrl();
        syncControlsToState();
        renderPresets();

        categoryTabs.forEach((tab, index) => {
          if (!(tab instanceof HTMLButtonElement)) return;

          tab.addEventListener('click', () => {
            if (tab.disabled) return;
            state.category = tab.dataset.categoryValue || 'all';
            state.page = 1;
            syncControlsToState();
            scheduleRun();
          });

          tab.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
            event.preventDefault();
            const direction = event.key === 'ArrowRight' ? 1 : -1;

            let nextIndex = index;
            for (let i = 0; i < categoryTabs.length; i += 1) {
              nextIndex = (nextIndex + direction + categoryTabs.length) % categoryTabs.length;
              const candidate = categoryTabs[nextIndex];
              if (candidate instanceof HTMLButtonElement && !candidate.disabled) {
                candidate.focus();
                candidate.click();
                break;
              }
            }
          });
        });

        cityFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.city = target.value;
          state.page = 1;
          scheduleRun();
        });

        statusFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.status = target.value;
          state.page = 1;
          scheduleRun();
        });

        contactedFilterButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const value = button.dataset.contactedValue || 'all';
            if (!CONTACTED_FILTER_VALUES.includes(value)) return;
            state.contacted = value;
            state.page = 1;
            syncControlsToState();
            scheduleRun();
          });
        });

        scoreFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.minScore = target.value;
          state.page = 1;
          scheduleRun();
        });

        searchInput?.addEventListener('input', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLInputElement)) return;
          state.search = target.value;
          state.page = 1;
          syncControlsToState();
          scheduleRun(180);
        });

        clearSearchButton?.addEventListener('click', () => {
          state.search = '';
          syncControlsToState();
          if (searchInput instanceof HTMLInputElement) searchInput.focus();
          scheduleRun();
        });

        sortSelect?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.sort = target.value;
          state.sortDir = target.value === 'name' || target.value === 'category' || target.value === 'city' || target.value === 'status' ? 'asc' : 'desc';
          state.page = 1;
          scheduleRun();
        });

        sortColumnButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const key = button.dataset.sortCol;
            if (!key) return;
            if (state.sort === key) state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc';
            else {
              state.sort = key;
              state.sortDir = key === 'score' ? 'desc' : 'asc';
            }
            state.page = 1;
            if (sortSelect instanceof HTMLSelectElement) sortSelect.value = state.sort;
            syncControlsToState();
            scheduleRun();
          });
        });

        resetButton?.addEventListener('click', () => {
          resetFilters();
        });

        emptyReset?.addEventListener('click', () => {
          resetFilters();
        });

        activeFilters?.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const chip = target.closest('[data-filter-chip]');
          if (!(chip instanceof HTMLButtonElement)) return;

          const key = chip.dataset.filterChip;
          if (key === 'category') state.category = 'all';
          if (key === 'city') state.city = 'all';
          if (key === 'status') state.status = 'all';
          if (key === 'contacted') state.contacted = 'all';
          if (key === 'minScore') state.minScore = 'any';
          if (key === 'search') state.search = '';
          state.page = 1;

          syncControlsToState();
          scheduleRun();
        });

        clearUrlFiltersButton?.addEventListener('click', () => {
          resetFilters();
          window.history.replaceState({}, '', window.location.pathname);
        });

        savePresetButton?.addEventListener('click', () => {
          const name = window.prompt('Όνομα preset φίλτρων:')?.trim();
          if (!name) return;
          const presets = readPresets().filter((preset) => preset.name !== name);
          presets.unshift({
            name,
            state: {
              category: state.category,
              city: state.city,
              status: state.status,
              contacted: state.contacted,
              minScore: state.minScore,
              search: state.search,
              sort: state.sort,
              sortDir: state.sortDir
            }
          });
          writePresets(presets);
          renderPresets();
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Αποθηκεύτηκε preset: ${name}`;
        });

        presetsList?.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const button = target.closest('[data-preset-name]');
          if (!(button instanceof HTMLButtonElement)) return;
          const name = button.dataset.presetName || '';
          const preset = readPresets().find((item) => item.name === name);
          if (!preset?.state) return;
          state.category = preset.state.category || 'all';
          state.city = preset.state.city || 'all';
          state.status = preset.state.status || 'all';
          state.contacted = CONTACTED_FILTER_VALUES.includes(preset.state.contacted) ? preset.state.contacted : 'all';
          state.minScore = preset.state.minScore || 'any';
          state.search = preset.state.search || '';
          state.sort = preset.state.sort || 'newest';
          state.sortDir = preset.state.sortDir || 'desc';
          state.page = 1;
          syncControlsToState();
          scheduleRun();
        });

        const closeDetailPanel = () => {
          if (detailPanel instanceof HTMLElement) {
            detailPanel.classList.add('hidden');
            detailPanel.classList.add('pointer-events-none');
          }
          activeDetailLeadId = '';
        };

        const openDetailPanel = (entry) => {
          if (!(detailPanel instanceof HTMLElement)) return;
          activeDetailLeadId = entry.id;
          if (detailName instanceof HTMLElement) detailName.textContent = entry.name || '—';
          if (detailCategory instanceof HTMLElement) detailCategory.textContent = entry.categoryLabel || '—';
          if (detailCity instanceof HTMLElement) detailCity.textContent = entry.city || '—';
          if (detailStatus instanceof HTMLElement) detailStatus.textContent = entry.statusLabel || '—';
          if (detailScore instanceof HTMLElement) detailScore.textContent = String(entry.score ?? '—');
          if (detailPhone instanceof HTMLElement) detailPhone.textContent = entry.card.dataset.phone || '—';
          if (detailEmail instanceof HTMLElement) detailEmail.textContent = entry.card.dataset.email || '—';
          renderDetailOutreach(entry);
          if (detailNotes instanceof HTMLElement) detailNotes.textContent = entry.card.dataset.notes || 'Δεν υπάρχουν σημειώσεις.';
          detailPanel.classList.remove('hidden');
          detailPanel.classList.remove('pointer-events-none');
        };

        pagePrevButton?.addEventListener('click', () => {
          state.page = Math.max(1, state.page - 1);
          scheduleRun();
        });

        pageNextButton?.addEventListener('click', () => {
          state.page = Math.min(lastTotalPages, state.page + 1);
          scheduleRun();
        });

        selectVisibleButton?.addEventListener('click', () => {
          lastFiltered.slice((state.page - 1) * state.perPage, (state.page - 1) * state.perPage + state.perPage).forEach((entry) => {
            if (entry.id) selectedLeadIds.add(entry.id);
          });
          renderSelectionState();
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Επιλέχθηκαν ${selectedLeadIds.size} leads.`;
        });

        clearSelectionButton?.addEventListener('click', () => {
          selectedLeadIds.clear();
          renderSelectionState();
        });

        selectionDockClear?.addEventListener('click', () => {
          selectedLeadIds.clear();
          renderSelectionState();
        });

        const applyBulkOutreach = (targetContacted) => {
          let changed = 0;
          parsedCards.forEach((entry) => {
            if (!selectedLeadIds.has(entry.id)) return;
            entry.isContacted = targetContacted;
            entry.lastContactedTs = targetContacted ? Date.now() : null;
            entry.searchableText = [
              entry.name,
              entry.phone,
              entry.email,
              entry.categoryLabel,
              entry.city,
              entry.statusLabel,
              `score:${entry.score}`,
              targetContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη'
            ].join(' ').toLowerCase();
            appendActivity(entry, targetContacted ? 'Bulk: σημειώθηκε ως επικοινωνημένο' : 'Bulk: σημειώθηκε ως χωρίς επαφή');
            syncOutreachRecord(entry);
            renderCardOutreach(entry);
            changed += 1;
          });
          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = changed > 0
              ? `Ενημερώθηκαν ${changed} leads.`
              : 'Δεν υπάρχει επιλεγμένο lead για bulk ενέργεια.';
          }
          scheduleRun();
        };

        bulkStatusButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            applyBulkOutreach(button.dataset.bulkContacted === 'true');
          });
        });

        selectionDockButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            applyBulkOutreach(button.dataset.selectionDockContacted === 'true');
          });
        });

        detailOverlay?.addEventListener('click', closeDetailPanel);
        detailClose?.addEventListener('click', closeDetailPanel);

        window.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          if (event.key === 'Escape') closeDetailPanel();
          if (event.key === '/' && document.activeElement !== searchInput) {
            event.preventDefault();
            if (searchInput instanceof HTMLInputElement) searchInput.focus();
          }
          if (event.shiftKey && event.key.toLowerCase() === 'a') {
            event.preventDefault();
            selectVisibleButton?.dispatchEvent(new Event('click'));
          }
          if (event.shiftKey && event.key.toLowerCase() === 'u') {
            event.preventDefault();
            clearSelectionButton?.dispatchEvent(new Event('click'));
          }
        });

        list?.addEventListener('change', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLInputElement) || !target.matches('[data-row-select]')) return;
          const card = target.closest('[data-lead-card]');
          if (!(card instanceof HTMLElement)) return;
          const entry = parsedCards.find((item) => item.card === card);
          if (!entry?.id) return;
          if (target.checked) selectedLeadIds.add(entry.id);
          else selectedLeadIds.delete(entry.id);
          renderSelectionState();
        });

        list?.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent) || event.key !== 'Enter') return;
          const target = event.target;
          if (!(target instanceof HTMLElement) || !target.matches('[data-lead-card]')) return;
          const entry = parsedCards.find((item) => item.card === target);
          if (!entry) return;
          event.preventDefault();
          openDetailPanel(entry);
        });

        list?.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const card = target.closest('[data-lead-card]');
          if (!(card instanceof HTMLElement)) return;
          const entry = parsedCards.find((item) => item.card === card);
          if (!entry) return;

          const copyPhone = target.closest('[data-copy-phone]');
          const copyEmail = target.closest('[data-copy-email]');
          const openDetail = target.closest('[data-open-detail]');
          const outreachToggle = target.closest('[data-toggle-contacted]');

          if (outreachToggle instanceof HTMLButtonElement) {
            const nextValue = outreachToggle.dataset.toggleContacted === 'true';
            entry.isContacted = nextValue;
            entry.lastContactedTs = nextValue ? Date.now() : null;
            entry.searchableText = [
              entry.name,
              entry.phone,
              entry.email,
              entry.categoryLabel,
              entry.city,
              entry.statusLabel,
              `score:${entry.score}`,
              nextValue ? 'επικοινωνηθηκε' : 'χωρις επαφη'
            ].join(' ').toLowerCase();
            appendActivity(entry, nextValue ? 'Σημειώθηκε ως επικοινωνημένο' : 'Σημειώθηκε ως χωρίς επαφή');
            syncOutreachRecord(entry);
            renderCardOutreach(entry);
            if (activeDetailLeadId && activeDetailLeadId === entry.id) renderDetailOutreach(entry);
            if (liveRegion instanceof HTMLElement) {
              liveRegion.textContent = nextValue
                ? `Το lead ${entry.name} σημειώθηκε ως επικοινωνημένο.`
                : `Το lead ${entry.name} σημειώθηκε ως χωρίς επικοινωνία.`;
            }
            scheduleRun();
            return;
          }

          if (copyPhone) {
            const value = card.dataset.phone || '';
            if (!value) return;
            await navigator.clipboard.writeText(value).catch(() => {});
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Αντιγράφηκε το τηλέφωνο.';
          }

          if (copyEmail) {
            const value = card.dataset.email || '';
            if (!value) return;
            await navigator.clipboard.writeText(value).catch(() => {});
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Αντιγράφηκε το email.';
          }

          if (openDetail) {
            openDetailPanel(entry);
          }
        });

        exportCsvButton?.addEventListener('click', () => {
          const headers = ['name', 'category', 'city', 'status', 'score', 'phone', 'email'];
          const rows = lastFiltered.map((lead) => [
            lead.name,
            lead.categoryLabel,
            lead.city,
            lead.statusLabel,
            String(lead.score ?? ''),
            lead.card.dataset.phone || '',
            lead.card.dataset.email || ''
          ]);
          const escape = (value) => `"${String(value ?? '').replaceAll('"', '""')}"`;
          const csv = [headers.map(escape).join(','), ...rows.map((row) => row.map(escape).join(','))].join('\n');
          const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
          const link = document.createElement('a');
          const url = URL.createObjectURL(blob);
          const dateTag = new Date().toISOString().slice(0, 10);
          link.href = url;
          link.download = `leads-filtered-${dateTag}.csv`;
          link.click();
          URL.revokeObjectURL(url);
        });

        runtimeReset?.addEventListener('click', () => {
          resetFilters();
          if (runtimeError instanceof HTMLElement) runtimeError.classList.add('hidden');
          if (list instanceof HTMLElement) list.classList.remove('hidden');
        });

        runFilters();
      } catch {
        const runtimeError = root.querySelector('[data-runtime-error]');
        const runtimeErrorMessage = root.querySelector('[data-runtime-error-message]');
        if (runtimeError instanceof HTMLElement) runtimeError.classList.remove('hidden');
        if (runtimeErrorMessage instanceof HTMLElement) {
          runtimeErrorMessage.textContent = 'Η αρχικοποίηση του πίνακα φίλτρων απέτυχε. Κάντε ανανέωση σελίδας.';
        }
      }
    }
  </script>
</Layout>
