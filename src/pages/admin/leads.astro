---
import Layout from '../../layouts/Layout.astro';
import { loadAdminLeadsDirectoryData, type AdminLeadsDirectoryData } from '../../lib/admin-leads';

const isAuthorized = true;
const expectedKey = '';

const fallbackDirectoryData: AdminLeadsDirectoryData = {
  leads: [],
  categories: [],
  cities: [],
  statuses: [],
  summary: null,
  totalLeads: 0
};

let directoryData: AdminLeadsDirectoryData = fallbackDirectoryData;
let loadError: string | null = null;

try {
  directoryData = await loadAdminLeadsDirectoryData();
} catch {
  loadError = 'Αδυναμία φόρτωσης των leads. Ελέγξτε τα αρχεία στο data/leads και δοκιμάστε ξανά.';
}

const statusLabel = (status: string) => {
  if (status === 'new') return 'Νέο';
  if (status === 'contacted') return 'Επικοινωνήθηκε';
  if (status === 'qualified') return 'Κατάλληλο';
  if (status === 'rejected') return 'Απορρίφθηκε';
  return status
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
};

const summaryUpdatedAtRaw = directoryData.summary?.lastUpdated;
const summaryUpdatedAt = summaryUpdatedAtRaw && Number.isFinite(Date.parse(summaryUpdatedAtRaw))
  ? new Date(summaryUpdatedAtRaw).toLocaleString('el-GR')
  : null;

const hasLeads = directoryData.leads.length > 0;
---

<Layout title="Admin Leads Directory | GreekHandy" description="Admin leads directory with filters and sorting.">
  <main class="mx-auto max-w-7xl px-4 py-10 md:py-14" data-leads-root>
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Κατάλογος Leads</h1>
        <p class="mt-2 max-w-3xl text-sm text-slate-700 md:text-base">Ενοποιημένη προβολή leads με προηγμένα φίλτρα, αναζήτηση και ταξινόμηση.</p>
      </div>
      <a href="/admin" class="inline-flex min-h-10 items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
        Επιστροφή στο Admin
      </a>
    </div>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900" role="alert" aria-live="assertive">
        <p class="font-semibold">Μη εξουσιοδοτημένη πρόσβαση.</p>
        <p class="mt-1 text-sm">Συνδεθείτε με moderation key.</p>
        <form method="GET" class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input name="key" type="password" required class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-sm text-gray-900" placeholder="Moderation key" />
          <button type="submit" class="rounded-lg bg-amber-700 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-800">Σύνδεση</button>
        </form>
        {!expectedKey && <p class="mt-2 text-xs">Missing env: <code>PROFESSIONAL_MODERATION_KEY</code></p>}
      </div>
    )}

    {isAuthorized && (
      <>
        <section class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <article class="rounded-xl border border-sky-200 bg-gradient-to-br from-sky-50 to-blue-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-sky-700">Σύνολο Leads</p>
            <p class="mt-2 text-3xl font-bold text-sky-950">{directoryData.totalLeads}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Ενεργές Κατηγορίες</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">{directoryData.categories.length}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Πόλεις</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">{directoryData.cities.length}</p>
          </article>
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Τελευταία ενημέρωση</p>
            <p class="mt-2 text-sm font-semibold text-slate-900">{summaryUpdatedAt || 'Δεν υπάρχει summary timestamp'}</p>
          </article>
        </section>

        {loadError && (
          <section class="mt-6 rounded-xl border border-rose-200 bg-rose-50 p-5 text-rose-900" role="alert" aria-live="assertive">
            <h2 class="text-lg font-bold">Σφάλμα φόρτωσης</h2>
            <p class="mt-2 text-sm">{loadError}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a href="/admin/leads" class="inline-flex min-h-10 items-center rounded-lg bg-rose-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-rose-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">Επανάληψη φόρτωσης</a>
              <a href="/admin" class="inline-flex min-h-10 items-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-800 transition hover:bg-rose-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">Πίσω στο Admin</a>
            </div>
          </section>
        )}

        {!loadError && (
          <div class="mt-6 grid gap-6 xl:grid-cols-[21rem_minmax(0,1fr)]">
            <aside class="xl:sticky xl:top-20 xl:h-[calc(100vh-7rem)]">
              <form data-filters-form class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm md:p-5" autocomplete="off">
                <div class="flex items-center justify-between gap-2">
                  <h2 class="text-lg font-bold text-slate-900">Φίλτρα</h2>
                  <button type="button" data-reset-filters class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Καθαρισμός</button>
                </div>

                <fieldset class="mt-4" aria-label="Φίλτρο κατηγορίας">
                  <legend class="text-xs font-semibold uppercase tracking-wide text-slate-500">Κατηγορία (βασικό φίλτρο)</legend>
                  <div class="mt-2 flex gap-2 overflow-x-auto pb-1 xl:flex-wrap xl:overflow-visible" role="group" aria-label="Επιλογή κατηγορίας">
                    <button
                      type="button"
                      data-category-tab
                      data-category-value="all"
                      data-category-label="Όλες"
                      aria-pressed="true"
                      class="inline-flex min-h-10 items-center gap-2 rounded-full border border-sky-600 bg-sky-600 px-4 py-2 text-sm font-semibold whitespace-nowrap text-white shadow-sm transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                    >
                      <span>Όλες</span>
                      <span data-category-count class="rounded-full bg-white/20 px-2 py-0.5 text-xs">{directoryData.leads.length}</span>
                    </button>
                    {directoryData.categories.map((category) => (
                      <button
                        type="button"
                        data-category-tab
                        data-category-value={category.slug}
                        data-category-label={category.label}
                        aria-pressed="false"
                        class="inline-flex min-h-10 items-center gap-2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold whitespace-nowrap text-slate-700 transition hover:border-sky-300 hover:text-sky-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                      >
                        <span>{category.label}</span>
                        <span data-category-count class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{category.count}</span>
                      </button>
                    ))}
                  </div>
                  <div data-category-context class="mt-3 rounded-xl border border-sky-100 bg-gradient-to-br from-sky-50 to-blue-50 p-3 text-xs text-sky-900">
                    Εμφάνιση όλων των κατηγοριών. Επιλέξτε κατηγορία για πιο στοχευμένη λίστα leads.
                  </div>
                </fieldset>

                <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <div>
                    <label for="leads-city-filter" class="text-sm font-semibold text-slate-700">Πόλη</label>
                    <select id="leads-city-filter" data-city-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="all">Όλες</option>
                      {directoryData.cities.map((city) => <option value={city}>{city}</option>)}
                    </select>
                  </div>

                  <div>
                    <label for="leads-status-filter" class="text-sm font-semibold text-slate-700">Κατάσταση</label>
                    <select id="leads-status-filter" data-status-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="all">Όλες</option>
                      {directoryData.statuses.map((status) => <option value={status}>{statusLabel(status)}</option>)}
                    </select>
                  </div>

                  <fieldset class="sm:col-span-2 xl:col-span-1" aria-label="Φίλτρο επικοινωνίας">
                    <legend class="text-sm font-semibold text-slate-700">Outreach</legend>
                    <div class="mt-1 grid grid-cols-3 gap-1 rounded-lg border border-slate-300 bg-slate-50 p-1" role="group" aria-label="Κατάσταση επικοινωνίας">
                      <button type="button" data-contacted-filter data-contacted-value="all" aria-pressed="true" class="min-h-9 rounded-md border border-sky-600 bg-sky-600 px-2 text-xs font-semibold text-white transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Όλα</button>
                      <button type="button" data-contacted-filter data-contacted-value="contacted" aria-pressed="false" class="min-h-9 rounded-md border border-transparent bg-transparent px-2 text-xs font-semibold text-slate-700 transition hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Επικοινωνήθηκαν</button>
                      <button type="button" data-contacted-filter data-contacted-value="not-contacted" aria-pressed="false" class="min-h-9 rounded-md border border-transparent bg-transparent px-2 text-xs font-semibold text-slate-700 transition hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Χωρίς επαφή</button>
                    </div>
                  </fieldset>

                  <div class="sm:col-span-2 xl:col-span-1">
                    <label for="leads-score-filter" class="text-sm font-semibold text-slate-700">Ελάχιστο score</label>
                    <select id="leads-score-filter" data-score-filter class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                      <option value="any">Όλα</option>
                      <option value="80">80+</option>
                      <option value="60">60+</option>
                      <option value="40">40+</option>
                    </select>
                  </div>
                </div>

                <div class="mt-3">
                  <label for="leads-search" class="text-sm font-semibold text-slate-700">Αναζήτηση</label>
                  <div class="relative mt-1">
                    <input
                      id="leads-search"
                      type="search"
                      data-search-input
                      placeholder="Όνομα, τηλέφωνο, email, score:80"
                      class="block min-h-10 w-full rounded-lg border border-slate-300 bg-white py-2 pr-10 pl-3 text-sm text-slate-900 placeholder:text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
                    />
                    <button type="button" data-clear-search class="absolute inset-y-1 right-1 hidden min-h-8 items-center rounded-md px-2 text-xs font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500" aria-label="Καθαρισμός αναζήτησης">Καθ.</button>
                  </div>
                  <p class="mt-1 text-xs text-slate-500">Υποστηρίζονται πολλαπλοί όροι (π.χ. "Αθήνα νέο") και ειδικό φίλτρο score με μορφή <code>score:80</code>.</p>
                </div>

                <div class="mt-3">
                  <label for="leads-sort" class="text-sm font-semibold text-slate-700">Ταξινόμηση</label>
                  <select id="leads-sort" data-sort-select class="mt-1 block min-h-10 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                    <option value="newest">Πιο πρόσφατα</option>
                    <option value="score">Score</option>
                    <option value="name">Όνομα</option>
                    <option value="category">Κατηγορία</option>
                    <option value="city">Πόλη</option>
                    <option value="status">Κατάσταση</option>
                  </select>
                </div>

                <div class="mt-4 border-t border-slate-200 pt-4">
                  <div class="flex items-center justify-between gap-2">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Ενεργά φίλτρα</p>
                    <button type="button" data-clear-url-filters class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός URL</button>
                  </div>
                  <div data-active-filters class="mt-2 flex flex-wrap gap-2" aria-live="polite"></div>
                  <p data-no-active-filters class="mt-2 text-xs text-slate-500">Δεν υπάρχουν ενεργά φίλτρα.</p>

                  <div class="mt-4 border-t border-slate-100 pt-3">
                    <div class="flex items-center justify-between gap-2">
                      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Saved presets</p>
                      <div class="flex items-center gap-2">
                        <button type="button" data-copy-current-view class="inline-flex min-h-8 items-center rounded-md border border-sky-300 bg-sky-50 px-2.5 text-xs font-semibold text-sky-800 transition hover:bg-sky-100">Copy view URL</button>
                        <button type="button" data-save-preset class="inline-flex min-h-8 items-center rounded-md border border-indigo-300 bg-indigo-50 px-2.5 text-xs font-semibold text-indigo-800 transition hover:bg-indigo-100">Αποθήκευση τρέχοντος</button>
                      </div>
                    </div>
                    <div data-presets-list class="mt-2 flex flex-wrap gap-2"></div>
                    <p data-no-presets class="mt-2 text-xs text-slate-500">Δεν υπάρχουν αποθηκευμένα presets.</p>
                  </div>
                </div>
              </form>
            </aside>

            <section data-results-region aria-busy="false">
              <div class="sticky top-20 z-10 rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm backdrop-blur md:p-5">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <p class="text-sm text-slate-700" data-results-summary>
                    Εμφανίζονται <strong data-visible-count>{directoryData.leads.length}</strong> από <strong>{directoryData.leads.length}</strong> leads.
                  </p>
                  <div class="flex items-center gap-2">
                    <button type="button" data-export-csv aria-label="Εξαγωγή όλων των φιλτραρισμένων leads σε CSV" class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Εξαγωγή CSV</button>
                    <div data-results-loading class="hidden items-center gap-2 rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700" role="status" aria-live="polite" aria-atomic="true">
                      <span class="h-3 w-3 animate-spin rounded-full border-2 border-sky-200 border-t-sky-700"></span>
                      Ενημέρωση αποτελεσμάτων. Οι αλλαγές εφαρμόζονται με ασφάλεια.
                    </div>
                  </div>
                </div>
                <div class="mt-3 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-3">
                  <p data-pagination-summary class="text-xs text-slate-600">Σελίδα 1 από 1</p>
                  <div class="flex items-center gap-2">
                    <button type="button" data-page-prev aria-label="Μετάβαση στην προηγούμενη σελίδα αποτελεσμάτων" aria-controls="leads-list-region" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Προηγούμενη</button>
                    <button type="button" data-page-next aria-label="Μετάβαση στην επόμενη σελίδα αποτελεσμάτων" aria-controls="leads-list-region" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Επόμενη</button>
                  </div>
                </div>
                <div class="mt-3 flex flex-wrap items-center gap-2 border-t border-slate-200 pt-3" role="group" aria-label="Μαζικές ενέργειες μετατροπής">
                  <button type="button" data-select-visible aria-label="Επιλογή όλων των ορατών leads σε αυτή τη σελίδα" aria-keyshortcuts="Shift+A" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Επιλογή ορατών</button>
                  <button type="button" data-clear-selection aria-label="Καθαρισμός τρέχουσας επιλογής leads" aria-keyshortcuts="Shift+U Alt+Backspace" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός</button>
                  <button type="button" data-bulk-contacted="true" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+E" class="inline-flex min-h-8 items-center rounded-md border border-emerald-300 bg-emerald-50 px-2.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Μαζικά: Έγινε επαφή</button>
                  <button type="button" data-bulk-contacted="false" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+N" class="inline-flex min-h-8 items-center rounded-md border border-amber-300 bg-amber-50 px-2.5 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Μαζικά: Εκκρεμεί επαφή</button>
                  <button type="button" data-bulk-segment="hot" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+1" class="inline-flex min-h-8 items-center rounded-md border border-rose-300 bg-rose-50 px-2.5 text-xs font-semibold text-rose-800 transition hover:bg-rose-100">Μαζικά: Segment Hot</button>
                  <button type="button" data-bulk-segment="warm" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+2" class="inline-flex min-h-8 items-center rounded-md border border-orange-300 bg-orange-50 px-2.5 text-xs font-semibold text-orange-800 transition hover:bg-orange-100">Μαζικά: Segment Warm</button>
                  <button type="button" data-bulk-segment="cold" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+3" class="inline-flex min-h-8 items-center rounded-md border border-sky-300 bg-sky-50 px-2.5 text-xs font-semibold text-sky-800 transition hover:bg-sky-100">Μαζικά: Segment Cold</button>
                  <input type="datetime-local" data-bulk-followup-at aria-label="Ορισμός ημερομηνίας και ώρας follow-up για επιλεγμένα leads" class="min-h-8 rounded-md border border-slate-300 px-2 text-xs text-slate-800" />
                  <button type="button" data-bulk-followup-set aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+F" class="inline-flex min-h-8 items-center rounded-md border border-violet-300 bg-violet-50 px-2.5 text-xs font-semibold text-violet-800 transition hover:bg-violet-100">Μαζικά: Ορισμός follow-up</button>
                  <button type="button" data-bulk-outreach-undo aria-label="Αναίρεση τελευταίας μαζικής ενημέρωσης επικοινωνίας" aria-keyshortcuts="Alt+Z" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αναίρεση outreach</button>
                  <button type="button" data-shortcuts-help aria-label="Εμφάνιση λίστας συντομεύσεων πληκτρολογίου" aria-keyshortcuts="Shift+?" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 bg-white px-2.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Συντομεύσεις</button>
                  <p id="leads-selection-summary" data-selection-summary class="text-xs font-medium text-slate-600" role="status" aria-live="polite" aria-atomic="true">0 επιλεγμένα</p>
                </div>
                <p id="leads-bulk-prompt" class="mt-2 text-[11px] text-slate-600" aria-live="polite">Γρήγορη μετατροπή: πρώτα "Έγινε επαφή", μετά segment και follow-up. Η τελευταία μαζική αλλαγή outreach ανακαλείται για 5 λεπτά (κουμπί ή Alt+Z).</p>
                <div class="mt-3 grid gap-2 border-t border-slate-200 pt-3 sm:grid-cols-3" data-filter-analytics>
                  <p class="rounded-md border border-slate-200 bg-slate-50 px-2.5 py-1.5 text-xs text-slate-700">Με επαφή: <strong data-analytics-contacted>0</strong></p>
                  <p class="rounded-md border border-slate-200 bg-slate-50 px-2.5 py-1.5 text-xs text-slate-700">Κατάλληλα: <strong data-analytics-qualified>0</strong></p>
                  <p class="rounded-md border border-slate-200 bg-slate-50 px-2.5 py-1.5 text-xs text-slate-700">Μέσο score: <strong data-analytics-score>0</strong></p>
                </div>
                <div class="mt-2 grid gap-2 sm:grid-cols-3" data-segment-analytics>
                  <button type="button" data-select-segment-visible="hot" aria-keyshortcuts="Alt+Shift+H" class="rounded-md border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-left text-xs text-rose-900">Επιλογή ορατών Hot: <strong data-analytics-segment-hot>0</strong></button>
                  <button type="button" data-select-segment-visible="warm" aria-keyshortcuts="Alt+Shift+W" class="rounded-md border border-orange-200 bg-orange-50 px-2.5 py-1.5 text-left text-xs text-orange-900">Επιλογή ορατών Warm: <strong data-analytics-segment-warm>0</strong></button>
                  <button type="button" data-select-segment-visible="cold" aria-keyshortcuts="Alt+Shift+C" class="rounded-md border border-sky-200 bg-sky-50 px-2.5 py-1.5 text-left text-xs text-sky-900">Επιλογή ορατών Cold: <strong data-analytics-segment-cold>0</strong></button>
                </div>
                <div class="mt-3 grid gap-2 border-t border-slate-200 pt-3 sm:grid-cols-3" data-followup-board>
                  <p class="rounded-md border border-amber-200 bg-amber-50 px-2.5 py-1.5 text-xs text-amber-900">Ληγμένα follow-up: <strong data-followup-overdue>0</strong></p>
                  <p class="rounded-md border border-sky-200 bg-sky-50 px-2.5 py-1.5 text-xs text-sky-900">Follow-up σήμερα: <strong data-followup-today>0</strong></p>
                  <p class="rounded-md border border-indigo-200 bg-indigo-50 px-2.5 py-1.5 text-xs text-indigo-900">Follow-up 7ημέρου: <strong data-followup-week>0</strong></p>
                </div>
                <p class="mt-3 text-[11px] text-slate-500" aria-live="polite">Συντομεύσεις: `/` αναζήτηση, Shift+A επιλογή ορατών, Shift+U καθαρισμός επιλογής, Alt+1/2/3 segment, Alt+Shift+H/W/C επιλογή segment ορατών, Alt+Shift+E/N outreach, Alt+D focus πεδίου follow-up, Alt+Shift+F εφαρμογή follow-up, Alt+Z αναίρεση, Shift+? βοήθεια.</p>
                <div class="mt-2 flex flex-wrap gap-2 border-t border-slate-200 pt-3" role="group" aria-label="Sortable columns">
                  <button type="button" data-sort-col="name" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Όνομα</button>
                  <button type="button" data-sort-col="category" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Κατηγορία</button>
                  <button type="button" data-sort-col="city" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Πόλη</button>
                  <button type="button" data-sort-col="score" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Score</button>
                  <button type="button" data-sort-col="status" class="rounded-md border border-slate-300 px-2.5 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-100">Κατάσταση</button>
                </div>
                <p data-live-region class="sr-only" aria-live="polite" aria-atomic="true"></p>
                <p data-state-live-region class="sr-only" aria-live="assertive" aria-atomic="true"></p>
              </div>

              <section data-loading-skeleton class="mt-4 hidden space-y-3" role="status" aria-live="polite" aria-atomic="true" aria-hidden="true">
                <div class="rounded-xl border border-sky-200 bg-sky-50 p-3 text-xs font-semibold text-sky-800">Εφαρμόζονται φίλτρα και ταξινόμηση. Τα αποτελέσματα θα εμφανιστούν άμεσα.</div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
                <div class="h-24 animate-pulse rounded-2xl border border-slate-200 bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100"></div>
              </section>

              <section id="leads-list-region" class="mt-4 space-y-3" data-leads-list>
                {directoryData.leads.map((lead) => (
                  <article
                    data-lead-card
                    data-lead-id={lead.id}
                    data-category={lead.categorySlug}
                    data-category-label={lead.categoryLabel}
                    data-city={lead.city}
                    data-status={lead.status}
                    data-status-label={statusLabel(lead.status)}
                    data-name={lead.name}
                    data-phone={lead.phone}
                    data-email={lead.email}
                    data-score={lead.score ?? -1}
                    data-notes={lead.sourceUrl ? `Πηγή: ${lead.sourceUrl}` : 'Δεν υπάρχουν διαθέσιμες σημειώσεις για αυτό το lead.'}
                    data-newest={lead.newestTs}
                    data-last-contacted=""
                    tabindex="0"
                    class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-slate-300 hover:shadow focus:outline-none focus:ring-2 focus:ring-sky-500 md:p-5"
                  >
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div class="flex items-start gap-3">
                        <input type="checkbox" data-row-select aria-label={`Επιλογή lead ${lead.name}`} class="mt-1 h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" />
                        <div>
                          <h2 class="text-lg font-bold text-slate-900">{lead.name}</h2>
                          <p class="mt-1 text-sm text-slate-600">{lead.categoryLabel} • {lead.city}</p>
                        </div>
                      </div>
                      <div class="flex flex-wrap items-center gap-2 text-xs">
                        <span data-status-chip class="rounded-full border px-2 py-1 font-semibold">{statusLabel(lead.status)}</span>
                        <span class="rounded-full bg-sky-100 px-2 py-1 font-semibold text-sky-800">Score: {lead.score ?? 'N/A'}</span>
                        <span data-outreach-badge class="rounded-full bg-amber-100 px-2 py-1 font-semibold text-amber-800">Χωρίς επικοινωνία</span>
                        <span data-segment-badge class="rounded-full border border-slate-200 bg-slate-50 px-2 py-1 font-semibold text-slate-700">Segment: untagged</span>
                        <span data-reminder-badge class="rounded-full border border-violet-200 bg-violet-50 px-2 py-1 font-semibold text-violet-800">Follow-up: none</span>
                      </div>
                    </div>

                    <div class="mt-3 grid gap-2 text-sm text-slate-700 sm:grid-cols-2">
                      <p>
                        <strong>Τηλέφωνο:</strong>
                        {' '}
                        {lead.phone ? <a class="underline decoration-slate-300 underline-offset-2 hover:text-slate-900" href={`tel:${lead.phone}`}>{lead.phone}</a> : '—'}
                      </p>
                      <p>
                        <strong>Email:</strong>
                        {' '}
                        {lead.email ? <a class="underline decoration-slate-300 underline-offset-2 hover:text-slate-900" href={`mailto:${lead.email}`}>{lead.email}</a> : '—'}
                      </p>
                    </div>

                    <div class="mt-4 flex flex-wrap gap-2">
                      <button type="button" data-toggle-contacted="true" aria-pressed="false" class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Σημείωση: Έγινε επαφή</button>
                      <button type="button" data-toggle-contacted="false" aria-pressed="false" class="inline-flex min-h-9 items-center rounded-lg border border-amber-300 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Σημείωση: Εκκρεμεί επαφή</button>
                    </div>

                    <p data-last-contacted-display class="mt-2 text-xs font-medium text-slate-600">Τελευταία επικοινωνία: Ποτέ</p>
                    <p data-next-best-action-hint class="mt-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700">
                      Επόμενο βήμα μετατροπής: κάντε πρώτη επαφή (κλήση ή email) και ορίστε follow-up.
                    </p>

                    <div class="mt-3 rounded-lg border border-slate-200 bg-slate-50 p-3">
                      <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Activity timeline</p>
                      <ul data-activity-list class="mt-2 space-y-1 text-xs text-slate-700">
                        <li data-activity-empty class="text-slate-500">Δεν υπάρχουν πρόσφατα events.</li>
                      </ul>
                    </div>

                    <div class="mt-3 rounded-lg border border-slate-200 bg-white p-3">
                      <div class="flex flex-wrap items-center gap-2">
                        <button type="button" data-set-segment="hot" aria-label={`Ορισμός segment σε hot για ${lead.name}`} class="inline-flex min-h-8 items-center rounded-md border border-rose-300 bg-rose-50 px-2.5 text-xs font-semibold text-rose-800">Hot</button>
                        <button type="button" data-set-segment="warm" aria-label={`Ορισμός segment σε warm για ${lead.name}`} class="inline-flex min-h-8 items-center rounded-md border border-orange-300 bg-orange-50 px-2.5 text-xs font-semibold text-orange-800">Warm</button>
                        <button type="button" data-set-segment="cold" aria-label={`Ορισμός segment σε cold για ${lead.name}`} class="inline-flex min-h-8 items-center rounded-md border border-sky-300 bg-sky-50 px-2.5 text-xs font-semibold text-sky-800">Cold</button>
                        <button type="button" data-triage-quick="contact-now" aria-label={`Γρήγορο triage για ${lead.name}: σημείωση ως έγινε επαφή`} class="inline-flex min-h-8 items-center rounded-md border border-emerald-300 bg-emerald-50 px-2.5 text-xs font-semibold text-emerald-800">Γρήγορο triage: Έγινε επαφή τώρα</button>
                        <button type="button" data-triage-quick="followup-2d" aria-label={`Γρήγορο triage για ${lead.name}: follow-up σε 2 ημέρες`} class="inline-flex min-h-8 items-center rounded-md border border-violet-300 bg-violet-50 px-2.5 text-xs font-semibold text-violet-800">Γρήγορο triage: Follow-up +2 ημέρες</button>
                      </div>
                      <p data-triage-hint class="mt-2 text-[11px] text-slate-600">Triage 20": μαρκάρετε επαφή, επιλέξτε segment και αφήστε σύντομη σημείωση για το επόμενο βήμα.</p>
                      <label class="mt-3 block text-[11px] font-semibold uppercase tracking-wide text-slate-500">Quick note</label>
                      <div class="mt-1 flex gap-2">
                        <input type="text" data-note-input aria-label={`Σύντομη σημείωση για ${lead.name}`} placeholder="Σύντομη σημείωση για follow-up" class="w-full rounded-md border border-slate-300 px-2.5 py-1.5 text-xs text-slate-800" />
                        <button type="button" data-save-note class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700">Αποθήκευση</button>
                      </div>
                    </div>

                    <div class="mt-3 flex flex-wrap gap-2">
                      {lead.phone && <a href={`tel:${lead.phone}`} class="inline-flex min-h-9 items-center rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Κλήση τώρα</a>}
                      {lead.email && <a href={`mailto:${lead.email}`} class="inline-flex min-h-9 items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-800 transition hover:bg-sky-100">Email τώρα</a>}
                      <button type="button" data-copy-phone class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αντιγραφή τηλεφώνου</button>
                      <button type="button" data-copy-email class="inline-flex min-h-9 items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αντιγραφή email</button>
                      <button type="button" data-open-detail class="inline-flex min-h-9 items-center rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-800 transition hover:bg-indigo-100">Λεπτομέρειες</button>
                    </div>

                    {lead.sourceUrl && (
                      <a href={lead.sourceUrl} target="_blank" rel="noreferrer" class="mt-4 inline-flex min-h-9 items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-sm font-semibold text-sky-800 transition hover:bg-sky-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">
                        Άνοιγμα πηγής
                      </a>
                    )}
                  </article>
                ))}
              </section>

              <section
                data-empty-state="no-data"
                class:list={[
                  'mt-4 rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-700',
                  hasLeads ? 'hidden' : ''
                ]}
              >
                <h2 class="text-lg font-bold text-slate-900">Δεν υπάρχουν διαθέσιμα leads</h2>
                <p class="mt-2 text-sm">Όταν προστεθούν νέα αρχεία στο `data/leads`, θα εμφανιστούν εδώ.</p>
              </section>

              <section data-empty-state="filtered" class="mt-4 hidden rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center text-slate-700" role="status" aria-live="polite" aria-atomic="true">
                <h2 class="text-lg font-bold text-slate-900">Δεν βρέθηκαν leads με αυτά τα φίλτρα</h2>
                <p class="mt-2 text-sm">Δεν υπάρχει απώλεια δεδομένων. Απλώς δεν ταιριάζει κανένα lead στα τρέχοντα κριτήρια.</p>
                <p class="mt-1 text-xs text-slate-500">Προτεινόμενο βήμα: καθαρίστε τα φίλτρα και ξεκινήστε με κατηγορία + πόλη για πιο σταδιακό narrowing.</p>
                <div class="mt-4 flex flex-wrap items-center justify-center gap-2">
                  <button type="button" data-empty-reset aria-label="Καθαρισμός όλων των φίλτρων και επιστροφή σε πλήρη λίστα leads" class="inline-flex min-h-10 items-center rounded-lg bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Καθαρισμός φίλτρων</button>
                  <button type="button" data-empty-clear-search aria-label="Αφαίρεση μόνο του όρου αναζήτησης" class="inline-flex min-h-10 items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2">Αφαίρεση αναζήτησης</button>
                </div>
              </section>

              <section data-runtime-error class="mt-4 hidden rounded-2xl border border-rose-200 bg-rose-50 p-6 text-rose-900" role="alert" aria-live="assertive">
                <h2 class="text-lg font-bold">Σφάλμα φίλτρων</h2>
                <p class="mt-2 text-sm" data-runtime-error-message>Παρουσιάστηκε απρόβλεπτο σφάλμα κατά την εφαρμογή φίλτρων. Τα δεδομένα σας δεν χάθηκαν.</p>
                <p class="mt-1 text-xs text-rose-700">Προτεινόμενο βήμα: επαναφέρετε φίλτρα για άμεση ανάκτηση ή φορτώστε ξανά τη σελίδα.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <button type="button" data-runtime-reset aria-label="Επαναφορά φίλτρων για ανάκτηση προβολής" class="inline-flex min-h-10 items-center rounded-lg bg-rose-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-rose-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">
                    Επαναφορά φίλτρων
                  </button>
                  <button type="button" data-runtime-reload aria-label="Πλήρης ανανέωση σελίδας leads" class="inline-flex min-h-10 items-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-800 transition hover:bg-rose-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2">
                    Ανανέωση σελίδας
                  </button>
                </div>
              </section>

              <section data-selection-dock class="pointer-events-none fixed inset-x-0 bottom-3 z-30 hidden px-4">
                <div class="pointer-events-auto mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-white/95 px-4 py-3 shadow-xl backdrop-blur">
                  <div>
                    <p class="text-sm font-semibold text-slate-800"><span data-selection-dock-count>0</span> leads επιλεγμένα <span class="ml-2 text-xs font-medium text-slate-500">(Shift+A επιλογή ορατών)</span></p>
                    <p data-selection-next-hint id="leads-selection-next-hint" class="mt-1 text-xs text-slate-600" aria-live="polite">Επόμενο βήμα μετατροπής: εφαρμόστε outreach, μετά segment και follow-up. Alt+Z για άμεση αναίρεση της τελευταίας μαζικής outreach αλλαγής.</p>
                    <p data-selection-last-action class="mt-1 text-[11px] text-slate-500" aria-live="polite">Τελευταία ενέργεια: —</p>
                    <p data-selection-segment-breakdown class="mt-0.5 text-[11px] text-slate-500" aria-live="polite">Επιλεγμένα ανά segment: hot 0 • warm 0 • cold 0 • untagged 0</p>
                    <p data-undo-availability class="mt-0.5 text-[11px] text-slate-500" aria-live="polite">Αναίρεση outreach: μη διαθέσιμη μέχρι την επόμενη μαζική αλλαγή.</p>
                  </div>
                  <div class="flex flex-wrap items-center gap-2">
                    <button type="button" data-selection-dock-contacted="true" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+E" class="inline-flex min-h-8 items-center rounded-md border border-emerald-300 bg-emerald-50 px-3 text-xs font-semibold text-emerald-800 transition hover:bg-emerald-100">Μαζικά: Έγινε επαφή</button>
                    <button type="button" data-selection-dock-contacted="false" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+N" class="inline-flex min-h-8 items-center rounded-md border border-amber-300 bg-amber-50 px-3 text-xs font-semibold text-amber-800 transition hover:bg-amber-100">Μαζικά: Εκκρεμεί επαφή</button>
                    <button type="button" data-selection-dock-segment="hot" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+1" class="inline-flex min-h-8 items-center rounded-md border border-rose-300 bg-rose-50 px-3 text-xs font-semibold text-rose-800 transition hover:bg-rose-100">Segment Hot</button>
                    <button type="button" data-selection-dock-segment="warm" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+2" class="inline-flex min-h-8 items-center rounded-md border border-orange-300 bg-orange-50 px-3 text-xs font-semibold text-orange-800 transition hover:bg-orange-100">Segment Warm</button>
                    <button type="button" data-selection-dock-segment="cold" aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+3" class="inline-flex min-h-8 items-center rounded-md border border-sky-300 bg-sky-50 px-3 text-xs font-semibold text-sky-800 transition hover:bg-sky-100">Segment Cold</button>
                    <input type="datetime-local" data-selection-dock-followup-at aria-label="Ορισμός ημερομηνίας και ώρας follow-up για επιλεγμένα leads" class="min-h-8 rounded-md border border-slate-300 px-2 text-xs text-slate-800" />
                    <button type="button" data-selection-dock-followup-set aria-describedby="leads-selection-summary leads-selection-next-hint leads-bulk-prompt" aria-keyshortcuts="Alt+Shift+F" class="inline-flex min-h-8 items-center rounded-md border border-violet-300 bg-violet-50 px-3 text-xs font-semibold text-violet-800 transition hover:bg-violet-100">Ορισμός follow-up</button>
                    <button type="button" data-selection-dock-outreach-undo aria-label="Αναίρεση τελευταίας μαζικής ενημέρωσης επικοινωνίας" aria-keyshortcuts="Alt+Z" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 bg-white px-3 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Αναίρεση outreach</button>
                    <button type="button" data-selection-dock-clear aria-label="Καθαρισμός επιλογής από το dock" class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-3 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Καθαρισμός επιλογής</button>
                  </div>
                </div>
              </section>

              <section data-detail-panel class="pointer-events-none fixed inset-0 z-40 hidden">
                <button type="button" data-detail-overlay class="absolute inset-0 bg-slate-900/40"></button>
                <aside class="pointer-events-auto absolute right-0 top-0 h-full w-full max-w-md overflow-y-auto border-l border-slate-200 bg-white p-5 shadow-2xl">
                  <div class="flex items-start justify-between gap-3">
                    <h2 class="text-lg font-bold text-slate-900">Lead λεπτομέρειες</h2>
                    <button type="button" data-detail-close class="rounded-md border border-slate-300 px-2 py-1 text-xs font-semibold text-slate-700">Κλείσιμο</button>
                  </div>
                  <div class="mt-4 space-y-2 text-sm text-slate-700">
                    <p><strong>Όνομα:</strong> <span data-detail-name>—</span></p>
                    <p><strong>Κατηγορία:</strong> <span data-detail-category>—</span></p>
                    <p><strong>Πόλη:</strong> <span data-detail-city>—</span></p>
                    <p><strong>Κατάσταση:</strong> <span data-detail-status>—</span></p>
                    <p><strong>Score:</strong> <span data-detail-score>—</span></p>
                    <p><strong>Τηλέφωνο:</strong> <span data-detail-phone>—</span></p>
                    <p><strong>Email:</strong> <span data-detail-email>—</span></p>
                    <p><strong>Outreach:</strong> <span data-detail-outreach>—</span></p>
                    <p><strong>Τελευταία επικοινωνία:</strong> <span data-detail-last-contacted>—</span></p>
                  </div>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Preview σημειώσεων</p>
                    <p data-detail-notes class="mt-2 text-sm text-slate-700">—</p>
                  </div>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-white p-3">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Πλήρες ιστορικό επικοινωνίας</p>
                    <ul data-detail-history class="mt-2 space-y-1 text-xs text-slate-700">
                      <li class="text-slate-500">Δεν υπάρχουν events.</li>
                    </ul>
                  </div>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-white p-3">
                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Quick next-action scheduler</p>
                    <div class="mt-2 grid gap-2">
                      <select data-detail-next-action-kind class="rounded-md border border-slate-300 px-2 py-1.5 text-xs text-slate-800">
                        <option value="call">Κλήση</option>
                        <option value="email">Email</option>
                        <option value="followup">Follow-up</option>
                        <option value="meeting">Συνάντηση</option>
                      </select>
                      <input type="datetime-local" data-detail-next-action-at class="rounded-md border border-slate-300 px-2 py-1.5 text-xs text-slate-800" />
                      <div class="flex gap-2">
                        <button type="button" data-detail-next-action-save class="inline-flex min-h-8 items-center rounded-md border border-indigo-300 bg-indigo-50 px-2.5 text-xs font-semibold text-indigo-800">Αποθήκευση</button>
                        <button type="button" data-detail-next-action-clear class="inline-flex min-h-8 items-center rounded-md border border-slate-300 px-2.5 text-xs font-semibold text-slate-700">Καθαρισμός</button>
                      </div>
                      <p data-detail-next-action-preview class="text-xs text-slate-600">Δεν υπάρχει προγραμματισμένη ενέργεια.</p>
                    </div>
                  </div>
                </aside>
              </section>
            </section>
          </div>
        )}
      </>
    )}
  </main>

  <script>
    const root = document.querySelector('[data-leads-root]');

    if (root) {
      try {
        const cards = Array.from(root.querySelectorAll('[data-lead-card]'));
        const list = root.querySelector('[data-leads-list]');
        const categoryTabs = Array.from(root.querySelectorAll('[data-category-tab]'));
        const contactedFilterButtons = Array.from(root.querySelectorAll('[data-contacted-filter]'));
        const cityFilter = root.querySelector('[data-city-filter]');
        const statusFilter = root.querySelector('[data-status-filter]');
        const scoreFilter = root.querySelector('[data-score-filter]');
        const searchInput = root.querySelector('[data-search-input]');
        const clearSearchButton = root.querySelector('[data-clear-search]');
        const sortSelect = root.querySelector('[data-sort-select]');
        const sortColumnButtons = Array.from(root.querySelectorAll('[data-sort-col]'));
        const resetButton = root.querySelector('[data-reset-filters]');
        const visibleCount = root.querySelector('[data-visible-count]');
        const resultsSummary = root.querySelector('[data-results-summary]');
        const resultsLoading = root.querySelector('[data-results-loading]');
        const loadingSkeleton = root.querySelector('[data-loading-skeleton]');
        const liveRegion = root.querySelector('[data-live-region]');
        const stateLiveRegion = root.querySelector('[data-state-live-region]');
        const activeFilters = root.querySelector('[data-active-filters]');
        const noActiveFilters = root.querySelector('[data-no-active-filters]');
        const clearUrlFiltersButton = root.querySelector('[data-clear-url-filters]');
        const savePresetButton = root.querySelector('[data-save-preset]');
        const copyCurrentViewButton = root.querySelector('[data-copy-current-view]');
        const presetsList = root.querySelector('[data-presets-list]');
        const noPresets = root.querySelector('[data-no-presets]');
        const exportCsvButton = root.querySelector('[data-export-csv]');
        const pagePrevButton = root.querySelector('[data-page-prev]');
        const pageNextButton = root.querySelector('[data-page-next]');
        const paginationSummary = root.querySelector('[data-pagination-summary]');
        const selectVisibleButton = root.querySelector('[data-select-visible]');
        const clearSelectionButton = root.querySelector('[data-clear-selection]');
        const bulkStatusButtons = Array.from(root.querySelectorAll('[data-bulk-contacted]'));
        const bulkSegmentButtons = Array.from(root.querySelectorAll('[data-bulk-segment]'));
        const bulkFollowupAt = root.querySelector('[data-bulk-followup-at]');
        const bulkFollowupSet = root.querySelector('[data-bulk-followup-set]');
        const bulkOutreachUndo = root.querySelector('[data-bulk-outreach-undo]');
        const shortcutsHelpButton = root.querySelector('[data-shortcuts-help]');
        const selectionSummary = root.querySelector('[data-selection-summary]');
        const selectionDock = root.querySelector('[data-selection-dock]');
        const selectionDockCount = root.querySelector('[data-selection-dock-count]');
        const selectionNextHint = root.querySelector('[data-selection-next-hint]');
        const selectionLastAction = root.querySelector('[data-selection-last-action]');
        const selectionSegmentBreakdown = root.querySelector('[data-selection-segment-breakdown]');
        const undoAvailability = root.querySelector('[data-undo-availability]');
        const selectionDockButtons = Array.from(root.querySelectorAll('[data-selection-dock-contacted]'));
        const selectionDockSegmentButtons = Array.from(root.querySelectorAll('[data-selection-dock-segment]'));
        const selectionDockFollowupAt = root.querySelector('[data-selection-dock-followup-at]');
        const selectionDockFollowupSet = root.querySelector('[data-selection-dock-followup-set]');
        const selectionDockOutreachUndo = root.querySelector('[data-selection-dock-outreach-undo]');
        const selectionDockClear = root.querySelector('[data-selection-dock-clear]');
        const analyticsContacted = root.querySelector('[data-analytics-contacted]');
        const analyticsQualified = root.querySelector('[data-analytics-qualified]');
        const analyticsScore = root.querySelector('[data-analytics-score]');
        const followupOverdue = root.querySelector('[data-followup-overdue]');
        const followupToday = root.querySelector('[data-followup-today]');
        const followupWeek = root.querySelector('[data-followup-week]');
        const analyticsSegmentHot = root.querySelector('[data-analytics-segment-hot]');
        const analyticsSegmentWarm = root.querySelector('[data-analytics-segment-warm]');
        const analyticsSegmentCold = root.querySelector('[data-analytics-segment-cold]');
        const selectSegmentVisibleButtons = Array.from(root.querySelectorAll('[data-select-segment-visible]'));
        const noDataState = root.querySelector('[data-empty-state="no-data"]');
        const filteredEmptyState = root.querySelector('[data-empty-state="filtered"]');
        const emptyReset = root.querySelector('[data-empty-reset]');
        const emptyClearSearch = root.querySelector('[data-empty-clear-search]');
        const categoryContext = root.querySelector('[data-category-context]');
        const runtimeError = root.querySelector('[data-runtime-error]');
        const runtimeErrorMessage = root.querySelector('[data-runtime-error-message]');
        const runtimeReset = root.querySelector('[data-runtime-reset]');
        const runtimeReload = root.querySelector('[data-runtime-reload]');
        const detailPanel = root.querySelector('[data-detail-panel]');
        const detailOverlay = root.querySelector('[data-detail-overlay]');
        const detailClose = root.querySelector('[data-detail-close]');
        const detailName = root.querySelector('[data-detail-name]');
        const detailCategory = root.querySelector('[data-detail-category]');
        const detailCity = root.querySelector('[data-detail-city]');
        const detailStatus = root.querySelector('[data-detail-status]');
        const detailScore = root.querySelector('[data-detail-score]');
        const detailPhone = root.querySelector('[data-detail-phone]');
        const detailEmail = root.querySelector('[data-detail-email]');
        const detailOutreach = root.querySelector('[data-detail-outreach]');
        const detailLastContacted = root.querySelector('[data-detail-last-contacted]');
        const detailNotes = root.querySelector('[data-detail-notes]');
        const detailHistory = root.querySelector('[data-detail-history]');
        const detailNextActionKind = root.querySelector('[data-detail-next-action-kind]');
        const detailNextActionAt = root.querySelector('[data-detail-next-action-at]');
        const detailNextActionSave = root.querySelector('[data-detail-next-action-save]');
        const detailNextActionClear = root.querySelector('[data-detail-next-action-clear]');
        const detailNextActionPreview = root.querySelector('[data-detail-next-action-preview]');
        const resultsRegion = root.querySelector('[data-results-region]');

        const OUTREACH_STORAGE_KEY = 'admin-leads-outreach-v1';
        const ACTIVITY_STORAGE_KEY = 'admin-leads-activity-v1';
        const SEGMENT_STORAGE_KEY = 'admin-leads-segment-v1';
        const NOTES_STORAGE_KEY = 'admin-leads-notes-v1';
        const NEXT_ACTION_STORAGE_KEY = 'admin-leads-next-action-v1';
        const CONTACTED_FILTER_VALUES = ['all', 'contacted', 'not-contacted'];
        const CONTACTED_FILTER_LABELS = {
          all: 'Όλα',
          contacted: 'Επικοινωνήθηκαν',
          'not-contacted': 'Χωρίς επαφή'
        };
        const NEXT_ACTION_KIND_LABELS = {
          call: 'κλήση',
          email: 'email',
          followup: 'follow-up',
          meeting: 'συνάντηση'
        };

        const announcePolite = (message) => {
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = message;
        };

        const announceState = (message) => {
          if (stateLiveRegion instanceof HTMLElement) stateLiveRegion.textContent = message;
          else announcePolite(message);
        };

        const BULK_UNDO_WINDOW_MS = 5 * 60 * 1000;
        const BULK_UNDO_WINDOW_MINUTES = Math.floor(BULK_UNDO_WINDOW_MS / 60000);

        const isUndoAvailable = () => {
          if (!lastBulkOutreachSnapshot?.createdAt) return false;
          return Date.now() - lastBulkOutreachSnapshot.createdAt <= BULK_UNDO_WINDOW_MS;
        };

        const formatUndoCountdown = (remainingMs) => {
          const safeMs = Math.max(0, remainingMs);
          const totalSeconds = Math.floor(safeMs / 1000);
          const minutes = Math.floor(totalSeconds / 60);
          const seconds = totalSeconds % 60;
          return `${minutes}:${String(seconds).padStart(2, '0')}`;
        };

        const setLastActionNote = (message) => {
          if (selectionLastAction instanceof HTMLElement) {
            selectionLastAction.textContent = `Τελευταία ενέργεια: ${message}`;
          }
        };

        const toMaybeTimestamp = (value) => {
          if (typeof value === 'number' && Number.isFinite(value)) return value;
          if (typeof value === 'string') {
            const parsed = Date.parse(value);
            if (Number.isFinite(parsed)) return parsed;
          }
          return null;
        };

        const readOutreachState = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(OUTREACH_STORAGE_KEY) || '{}');
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
          } catch {
            return {};
          }
        };

        const writeOutreachState = (nextState) => {
          try {
            localStorage.setItem(OUTREACH_STORAGE_KEY, JSON.stringify(nextState));
          } catch {
            // Storage can fail in private sessions; keep runtime state in-memory.
          }
        };

        let outreachState = readOutreachState();

        const readActivityState = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(ACTIVITY_STORAGE_KEY) || '{}');
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
          } catch {
            return {};
          }
        };

        const writeActivityState = (nextState) => {
          try {
            localStorage.setItem(ACTIVITY_STORAGE_KEY, JSON.stringify(nextState));
          } catch {
            // ignore localStorage errors
          }
        };

        let activityState = readActivityState();

        const readMapState = (key) => {
          try {
            const parsed = JSON.parse(localStorage.getItem(key) || '{}');
            return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
          } catch {
            return {};
          }
        };

        const writeMapState = (key, payload) => {
          try {
            localStorage.setItem(key, JSON.stringify(payload));
          } catch {
            // ignore localStorage errors
          }
        };

        let segmentState = readMapState(SEGMENT_STORAGE_KEY);
        let notesState = readMapState(NOTES_STORAGE_KEY);
        let nextActionState = readMapState(NEXT_ACTION_STORAGE_KEY);
        const selectedLeadIds = new Set();

        const parsedCards = cards
          .filter((card) => card instanceof HTMLElement)
          .map((card) => {
            const id = card.dataset.leadId || '';
            const category = card.dataset.category || '';
            const categoryLabel = card.dataset.categoryLabel || category;
            const city = card.dataset.city || '';
            const status = card.dataset.status || '';
            const statusLabel = card.dataset.statusLabel || status;
            const name = card.dataset.name || '';
            const phone = card.dataset.phone || '';
            const email = card.dataset.email || '';
            const rawScore = Number(card.dataset.score || -1);
            const score = Number.isFinite(rawScore) ? rawScore : -1;
            const newest = Number(card.dataset.newest || 0);
            const storedOutreach = id && outreachState[id] && typeof outreachState[id] === 'object' ? outreachState[id] : null;
            const storedActivity = id && Array.isArray(activityState[id]) ? activityState[id] : [];
            const defaultContacted = status === 'contacted';
            const storedContacted = storedOutreach && typeof storedOutreach.contacted === 'boolean' ? storedOutreach.contacted : defaultContacted;
            const lastContactedTs = toMaybeTimestamp(storedOutreach?.lastContactedAt) ?? toMaybeTimestamp(card.dataset.lastContacted);
            const segment = typeof segmentState[id] === 'string' ? segmentState[id] : 'untagged';
            const note = typeof notesState[id] === 'string' ? notesState[id] : '';
            const nextAction = nextActionState[id] && typeof nextActionState[id] === 'object' ? nextActionState[id] : null;
            const searchableText = [
              name,
              phone,
              email,
              categoryLabel,
              city,
              statusLabel,
              `score:${score}`,
              storedContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη',
              segment,
              note
            ].join(' ').toLowerCase();

            return {
              id,
              card,
              category,
              categoryLabel,
              city,
              status,
              statusLabel,
              name,
              phone,
              email,
              score,
              newest,
              searchableText,
              isContacted: storedContacted,
              lastContactedTs,
              activity: storedActivity,
              segment,
              note,
              nextAction
            };
          });

        const categoryLabelByValue = new Map();
        categoryTabs.forEach((tab) => {
          if (!(tab instanceof HTMLButtonElement)) return;
          const value = tab.dataset.categoryValue || 'all';
          const label = tab.dataset.categoryLabel || tab.textContent || value;
          categoryLabelByValue.set(value, label.trim());
        });

        const cityLabelByValue = new Map();
        const statusLabelByValue = new Map();

        if (cityFilter instanceof HTMLSelectElement) {
          Array.from(cityFilter.options).forEach((option) => {
            option.dataset.baseLabel = option.textContent || option.value;
            cityLabelByValue.set(option.value, option.textContent || option.value);
          });
        }

        if (statusFilter instanceof HTMLSelectElement) {
          Array.from(statusFilter.options).forEach((option) => {
            option.dataset.baseLabel = option.textContent || option.value;
            statusLabelByValue.set(option.value, option.textContent || option.value);
          });
        }

        const validCategories = new Set(Array.from(categoryLabelByValue.keys()));
        const validCities = new Set(parsedCards.map((entry) => entry.city));
        const validStatuses = new Set(parsedCards.map((entry) => entry.status));

        const state = {
          category: 'all',
          city: 'all',
          status: 'all',
          contacted: 'all',
          minScore: 'any',
          search: '',
          sort: 'newest',
          sortDir: 'desc',
          page: 1,
          perPage: 15
        };

        const hasAnyData = parsedCards.length > 0;
        let applyTimer = null;
        let lastFiltered = [];
        let lastTotalPages = 1;
        let activeDetailLeadId = '';
        let previousSelectionCount = null;
        let previousRenderedViewState = '';
        let lastBulkOutreachSnapshot = null;
        const PRESET_STORAGE_KEY = 'admin-leads-presets-v1';

        const readPresets = () => {
          try {
            const parsed = JSON.parse(localStorage.getItem(PRESET_STORAGE_KEY) || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch {
            return [];
          }
        };

        const writePresets = (presets) => {
          localStorage.setItem(PRESET_STORAGE_KEY, JSON.stringify(presets.slice(0, 8)));
        };

        const renderPresets = () => {
          if (!(presetsList instanceof HTMLElement) || !(noPresets instanceof HTMLElement)) return;
          const presets = readPresets();
          presetsList.innerHTML = '';
          presets.forEach((preset) => {
            const row = document.createElement('div');
            row.className = 'inline-flex items-center gap-1 rounded-full border border-indigo-200 bg-indigo-50 p-1';

            const applyBtn = document.createElement('button');
            applyBtn.type = 'button';
            applyBtn.dataset.presetName = preset.name;
            applyBtn.className = 'inline-flex min-h-7 items-center rounded-full px-2 text-xs font-semibold text-indigo-900 hover:bg-indigo-100';
            applyBtn.textContent = preset.name;

            const copyBtn = document.createElement('button');
            copyBtn.type = 'button';
            copyBtn.dataset.presetCopy = preset.name;
            copyBtn.className = 'inline-flex min-h-7 items-center rounded-full border border-indigo-300 bg-white px-2 text-[11px] font-semibold text-indigo-700 hover:bg-indigo-100';
            copyBtn.textContent = 'Copy URL';

            row.appendChild(applyBtn);
            row.appendChild(copyBtn);
            presetsList.appendChild(row);
          });
          noPresets.classList.toggle('hidden', presets.length > 0);
        };

        const formatLastContacted = (ts) => {
          if (!Number.isFinite(ts) || ts <= 0) return 'Ποτέ';
          return new Date(ts).toLocaleString('el-GR');
        };

        const syncOutreachRecord = (entry) => {
          if (!entry.id) return;
          outreachState = {
            ...outreachState,
            [entry.id]: {
              contacted: Boolean(entry.isContacted),
              lastContactedAt: Number.isFinite(entry.lastContactedTs) ? new Date(entry.lastContactedTs).toISOString() : null
            }
          };
          writeOutreachState(outreachState);
        };

        const appendActivity = (entry, actionLabel) => {
          const event = {
            at: new Date().toISOString(),
            label: actionLabel
          };
          const next = [event, ...(Array.isArray(entry.activity) ? entry.activity : [])].slice(0, 6);
          entry.activity = next;
          if (!entry.id) return;
          activityState = {
            ...activityState,
            [entry.id]: next
          };
          writeActivityState(activityState);
        };

        const renderActivityTimeline = (entry) => {
          const listEl = entry.card.querySelector('[data-activity-list]');
          if (!(listEl instanceof HTMLElement)) return;
          listEl.innerHTML = '';

          const events = Array.isArray(entry.activity) ? entry.activity.slice(0, 3) : [];
          if (events.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'text-slate-500';
            empty.textContent = 'Δεν υπάρχουν πρόσφατα events.';
            listEl.appendChild(empty);
            return;
          }

          events.forEach((eventItem) => {
            const li = document.createElement('li');
            const ts = toMaybeTimestamp(eventItem?.at);
            li.className = 'flex items-center justify-between gap-2';
            li.innerHTML = `<span>${eventItem?.label || 'Ενέργεια'}</span><span class="text-slate-500">${Number.isFinite(ts) ? new Date(ts).toLocaleString('el-GR') : ''}</span>`;
            listEl.appendChild(li);
          });
        };

        const renderSelectionState = () => {
          const count = selectedLeadIds.size;
          if (selectionSummary instanceof HTMLElement) selectionSummary.textContent = `${count} επιλεγμένα`;
          if (selectionDockCount instanceof HTMLElement) selectionDockCount.textContent = String(count);
          if (selectionDock instanceof HTMLElement) selectionDock.classList.toggle('hidden', count === 0);

          const selectedEntries = parsedCards.filter((entry) => selectedLeadIds.has(entry.id));
          const withoutContact = selectedEntries.filter((entry) => !entry.isContacted).length;
          const overdueFollowups = selectedEntries.filter((entry) => classifyFollowup(entry.nextAction?.at) === 'overdue').length;
          const selectedHot = selectedEntries.filter((entry) => entry.segment === 'hot').length;
          const selectedWarm = selectedEntries.filter((entry) => entry.segment === 'warm').length;
          const selectedCold = selectedEntries.filter((entry) => entry.segment === 'cold').length;
          const selectedUntagged = selectedEntries.length - selectedHot - selectedWarm - selectedCold;
          if (selectionSegmentBreakdown instanceof HTMLElement) {
            selectionSegmentBreakdown.textContent = `Επιλεγμένα ανά segment: hot ${selectedHot} • warm ${selectedWarm} • cold ${selectedCold} • untagged ${selectedUntagged}`;
          }
          if (selectionNextHint instanceof HTMLElement) {
            if (count === 0) {
              selectionNextHint.textContent = 'Επόμενο βήμα μετατροπής: επιλέξτε ορατά leads (Shift+A) και εφαρμόστε την κατάλληλη μαζική ενέργεια.';
            } else if (withoutContact > 0) {
              selectionNextHint.textContent = `Προτεραιότητα μετατροπής: ${withoutContact} επιλεγμένα lead χωρίς επαφή. Ξεκινήστε με "Μαζικά: Έγινε επαφή".`;
            } else if (overdueFollowups > 0) {
              selectionNextHint.textContent = `Προτεραιότητα εκτέλεσης: ${overdueFollowups} επιλεγμένα lead με ληγμένο follow-up. Ορίστε νέα ημερομηνία τώρα.`;
            } else {
              selectionNextHint.textContent = 'Επόμενο βήμα μετατροπής: ενημερώστε segment και follow-up για καθαρή προώθηση pipeline.';
            }
          }

          parsedCards.forEach((entry) => {
            const checkbox = entry.card.querySelector('[data-row-select]');
            if (checkbox instanceof HTMLInputElement) checkbox.checked = selectedLeadIds.has(entry.id);
          });
          bulkStatusButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          bulkSegmentButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          if (bulkFollowupSet instanceof HTMLButtonElement) bulkFollowupSet.disabled = count === 0;
          if (selectionDockFollowupSet instanceof HTMLButtonElement) selectionDockFollowupSet.disabled = count === 0;
          selectionDockButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          selectionDockSegmentButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) button.disabled = count === 0;
          });
          if (clearSelectionButton instanceof HTMLButtonElement) clearSelectionButton.disabled = count === 0;
          if (selectionDockClear instanceof HTMLButtonElement) selectionDockClear.disabled = count === 0;
          const undoAvailable = isUndoAvailable();
          if (bulkOutreachUndo instanceof HTMLButtonElement) bulkOutreachUndo.disabled = !undoAvailable;
          if (selectionDockOutreachUndo instanceof HTMLButtonElement) selectionDockOutreachUndo.disabled = !undoAvailable;
          if (undoAvailability instanceof HTMLElement) {
            if (!lastBulkOutreachSnapshot?.createdAt) {
              undoAvailability.textContent = `Αναίρεση outreach: μη διαθέσιμη. Θα ενεργοποιηθεί για ${BULK_UNDO_WINDOW_MINUTES} λεπτά μετά την επόμενη μαζική outreach αλλαγή.`;
            } else {
              const remainingMs = BULK_UNDO_WINDOW_MS - (Date.now() - lastBulkOutreachSnapshot.createdAt);
              const remainingLabel = formatUndoCountdown(remainingMs);
              undoAvailability.textContent = undoAvailable
                ? `Αναίρεση outreach: διαθέσιμη για ${remainingLabel}. Χρησιμοποιήστε το κουμπί "Αναίρεση outreach" ή Alt+Z.`
                : 'Αναίρεση outreach: το παράθυρο έληξε. Καμία άλλη αλλαγή δεν επηρεάστηκε.';
            }
          }

          bulkStatusButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const action = button.dataset.bulkContacted === 'true'
              ? 'Μαζική επισήμανση ως επικοινωνημένα'
              : 'Μαζική επισήμανση ως χωρίς επαφή';
            button.setAttribute('aria-label', `${action} για ${count} επιλεγμένα leads`);
          });
          bulkSegmentButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const segment = button.dataset.bulkSegment || 'untagged';
            button.setAttribute('aria-label', `Μαζική ενημέρωση segment σε ${segment} για ${count} επιλεγμένα leads`);
          });
          selectionDockButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const action = button.dataset.selectionDockContacted === 'true'
              ? 'Μαζική επισήμανση ως επικοινωνημένα'
              : 'Μαζική επισήμανση ως χωρίς επαφή';
            button.setAttribute('aria-label', `${action} από το dock για ${count} επιλεγμένα leads`);
          });
          selectionDockSegmentButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const segment = button.dataset.selectionDockSegment || 'untagged';
            button.setAttribute('aria-label', `Μαζική ενημέρωση segment σε ${segment} από το dock για ${count} επιλεγμένα leads`);
          });
          if (bulkFollowupSet instanceof HTMLButtonElement) {
            bulkFollowupSet.setAttribute('aria-label', `Ορισμός follow-up ημερομηνίας για ${count} επιλεγμένα leads`);
          }
          if (selectionDockFollowupSet instanceof HTMLButtonElement) {
            selectionDockFollowupSet.setAttribute('aria-label', `Ορισμός follow-up ημερομηνίας από το dock για ${count} επιλεγμένα leads`);
          }
          if (bulkOutreachUndo instanceof HTMLButtonElement) {
            bulkOutreachUndo.setAttribute('aria-label', isUndoAvailable()
              ? `Αναίρεση τελευταίας μαζικής outreach ενέργειας για ${lastBulkOutreachSnapshot.changed} leads`
              : `Δεν υπάρχει διαθέσιμη πρόσφατη μαζική outreach ενέργεια για αναίρεση μέσα στο παράθυρο ${BULK_UNDO_WINDOW_MINUTES} λεπτών`);
          }
          if (selectionDockOutreachUndo instanceof HTMLButtonElement) {
            selectionDockOutreachUndo.setAttribute('aria-label', isUndoAvailable()
              ? `Αναίρεση τελευταίας μαζικής outreach ενέργειας από το dock για ${lastBulkOutreachSnapshot.changed} leads`
              : `Δεν υπάρχει διαθέσιμη πρόσφατη μαζική outreach ενέργεια για αναίρεση μέσα στο παράθυρο ${BULK_UNDO_WINDOW_MINUTES} λεπτών`);
          }

          if (selectionLastAction instanceof HTMLElement && lastBulkOutreachSnapshot && !isUndoAvailable()) {
            selectionLastAction.textContent = 'Τελευταία ενέργεια: Το παράθυρο αναίρεσης outreach έληξε, η κατάσταση παραμένει όπως εφαρμόστηκε.';
          }

          if (previousSelectionCount !== null && previousSelectionCount !== count) {
            announcePolite(count > 0
              ? `Επιλέχθηκαν ${count} leads για μαζικές ενέργειες.`
              : 'Η τρέχουσα επιλογή καθαρίστηκε.');
          }
          previousSelectionCount = count;
        };

        const renderStatusChip = (entry) => {
          const statusChip = entry.card.querySelector('[data-status-chip]');
          if (!(statusChip instanceof HTMLElement)) return;
          statusChip.textContent = entry.statusLabel;
          statusChip.className = 'rounded-full border px-2 py-1 font-semibold';

          if (entry.status === 'new') statusChip.classList.add('border-blue-200', 'bg-blue-50', 'text-blue-800');
          else if (entry.status === 'contacted') statusChip.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-800');
          else if (entry.status === 'qualified') statusChip.classList.add('border-violet-200', 'bg-violet-50', 'text-violet-800');
          else if (entry.status === 'rejected') statusChip.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
          else statusChip.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');
        };

        const classifyFollowup = (at) => {
          const ts = toMaybeTimestamp(at);
          if (!Number.isFinite(ts)) return 'none';
          const now = Date.now();
          if (ts < now) return 'overdue';
          const todayEnd = new Date();
          todayEnd.setHours(23, 59, 59, 999);
          if (ts <= todayEnd.getTime()) return 'today';
          const weekEnd = new Date();
          weekEnd.setDate(weekEnd.getDate() + 7);
          weekEnd.setHours(23, 59, 59, 999);
          if (ts <= weekEnd.getTime()) return 'week';
          return 'later';
        };

        const renderSegmentBadge = (entry) => {
          const segmentBadge = entry.card.querySelector('[data-segment-badge]');
          if (!(segmentBadge instanceof HTMLElement)) return;
          const segment = entry.segment || 'untagged';
          segmentBadge.textContent = `Segment: ${segment}`;
          segmentBadge.className = 'rounded-full border px-2 py-1 font-semibold';
          if (segment === 'hot') segmentBadge.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
          else if (segment === 'warm') segmentBadge.classList.add('border-orange-200', 'bg-orange-50', 'text-orange-800');
          else if (segment === 'cold') segmentBadge.classList.add('border-sky-200', 'bg-sky-50', 'text-sky-800');
          else segmentBadge.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');

          const reminderBadge = entry.card.querySelector('[data-reminder-badge]');
          if (reminderBadge instanceof HTMLElement) {
            const followupClass = classifyFollowup(entry.nextAction?.at);
            reminderBadge.className = 'rounded-full border px-2 py-1 font-semibold';
            if (followupClass === 'overdue') {
              reminderBadge.textContent = 'Follow-up: overdue';
              reminderBadge.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
            } else if (followupClass === 'today') {
              reminderBadge.textContent = 'Follow-up: today';
              reminderBadge.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-800');
            } else if (followupClass === 'week') {
              reminderBadge.textContent = 'Follow-up: this week';
              reminderBadge.classList.add('border-indigo-200', 'bg-indigo-50', 'text-indigo-800');
            } else if (followupClass === 'later') {
              reminderBadge.textContent = 'Follow-up: scheduled';
              reminderBadge.classList.add('border-sky-200', 'bg-sky-50', 'text-sky-800');
            } else {
              reminderBadge.textContent = 'Follow-up: none';
              reminderBadge.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');
            }
          }

          const noteInput = entry.card.querySelector('[data-note-input]');
          if (noteInput instanceof HTMLInputElement && noteInput.value !== entry.note) noteInput.value = entry.note || '';
        };

        const resolveNextBestActionHint = (entry) => {
          const scheduledAt = toMaybeTimestamp(entry.nextAction?.at);
          const followupClass = classifyFollowup(entry.nextAction?.at);
          const actionKind = NEXT_ACTION_KIND_LABELS[entry.nextAction?.kind] || 'follow-up';
          const hasPhone = Boolean(entry.phone);
          const hasEmail = Boolean(entry.email);

          if (Number.isFinite(scheduledAt)) {
            if (followupClass === 'overdue') {
              return {
                tone: 'critical',
                text: `Επόμενο βήμα μετατροπής: Η προγραμματισμένη ${actionKind} έχει λήξει. Εκτελέστε την τώρα και ενημερώστε αποτέλεσμα.`
              };
            }
            if (followupClass === 'today') {
              return {
                tone: 'due-soon',
                text: `Επόμενο βήμα μετατροπής: ${actionKind} σήμερα στις ${new Date(scheduledAt).toLocaleTimeString('el-GR', { hour: '2-digit', minute: '2-digit' })}. Ετοιμάστε σημείωση πριν την εκτέλεση.`
              };
            }
            return {
              tone: 'scheduled',
              text: `Επόμενο βήμα μετατροπής: ${actionKind} στις ${new Date(scheduledAt).toLocaleString('el-GR')}. Επιβεβαιώστε segment και στόχο κλήσης/email.`
            };
          }

          if (!entry.isContacted) {
            if (hasPhone && hasEmail) {
              return { tone: 'priority', text: 'Επόμενο βήμα μετατροπής: Ξεκινήστε πρώτη επαφή με κλήση ή email και καταγράψτε σύντομη σημείωση.' };
            }
            if (hasPhone) {
              return { tone: 'priority', text: 'Επόμενο βήμα μετατροπής: Ξεκινήστε πρώτη επαφή με κλήση και ορίστε follow-up.' };
            }
            if (hasEmail) {
              return { tone: 'priority', text: 'Επόμενο βήμα μετατροπής: Ξεκινήστε πρώτη επαφή με email και ορίστε follow-up.' };
            }
            return { tone: 'info', text: 'Επόμενο βήμα μετατροπής: Συμπληρώστε τηλέφωνο ή email πριν το outreach.' };
          }

          if (entry.status === 'qualified') {
            return { tone: 'progress', text: 'Επόμενο βήμα μετατροπής: Κλείστε συνάντηση ή follow-up για να κλείσει η ευκαιρία.' };
          }

          return { tone: 'info', text: 'Επόμενο βήμα μετατροπής: Ορίστε follow-up ώστε να μη χαθεί το momentum.' };
        };

        const renderNextBestActionHint = (entry) => {
          const hintElement = entry.card.querySelector('[data-next-best-action-hint]');
          if (!(hintElement instanceof HTMLElement)) return;
          const hint = resolveNextBestActionHint(entry);
          hintElement.textContent = hint.text;
          hintElement.className = 'mt-2 rounded-lg border px-3 py-2 text-xs font-semibold';

          if (hint.tone === 'critical') {
            hintElement.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
          } else if (hint.tone === 'due-soon') {
            hintElement.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-900');
          } else if (hint.tone === 'scheduled') {
            hintElement.classList.add('border-indigo-200', 'bg-indigo-50', 'text-indigo-900');
          } else if (hint.tone === 'priority') {
            hintElement.classList.add('border-sky-200', 'bg-sky-50', 'text-sky-900');
          } else if (hint.tone === 'progress') {
            hintElement.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-900');
          } else {
            hintElement.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-700');
          }
        };

        const renderCardOutreach = (entry) => {
          const badge = entry.card.querySelector('[data-outreach-badge]');
          const lastContacted = entry.card.querySelector('[data-last-contacted-display]');
          const markContactedButton = entry.card.querySelector('[data-toggle-contacted="true"]');
          const markNotContactedButton = entry.card.querySelector('[data-toggle-contacted="false"]');

          if (badge instanceof HTMLElement) {
            badge.textContent = entry.isContacted ? 'Επικοινωνήθηκε' : 'Χωρίς επικοινωνία';
            badge.classList.toggle('bg-emerald-100', entry.isContacted);
            badge.classList.toggle('text-emerald-800', entry.isContacted);
            badge.classList.toggle('bg-amber-100', !entry.isContacted);
            badge.classList.toggle('text-amber-800', !entry.isContacted);
          }

          if (lastContacted instanceof HTMLElement) {
            lastContacted.textContent = `Τελευταία επικοινωνία: ${formatLastContacted(entry.lastContactedTs)}`;
          }

          if (markContactedButton instanceof HTMLButtonElement) {
            markContactedButton.setAttribute('aria-pressed', entry.isContacted ? 'true' : 'false');
            markContactedButton.setAttribute('aria-label', `Σημείωση lead ${entry.name} ως έγινε επαφή`);
            markContactedButton.classList.toggle('bg-emerald-600', entry.isContacted);
            markContactedButton.classList.toggle('border-emerald-600', entry.isContacted);
            markContactedButton.classList.toggle('text-white', entry.isContacted);
            markContactedButton.classList.toggle('bg-emerald-50', !entry.isContacted);
            markContactedButton.classList.toggle('border-emerald-300', !entry.isContacted);
            markContactedButton.classList.toggle('text-emerald-800', !entry.isContacted);
          }

          if (markNotContactedButton instanceof HTMLButtonElement) {
            markNotContactedButton.setAttribute('aria-pressed', !entry.isContacted ? 'true' : 'false');
            markNotContactedButton.setAttribute('aria-label', `Σημείωση lead ${entry.name} ως εκκρεμεί επαφή`);
            markNotContactedButton.classList.toggle('bg-amber-600', !entry.isContacted);
            markNotContactedButton.classList.toggle('border-amber-600', !entry.isContacted);
            markNotContactedButton.classList.toggle('text-white', !entry.isContacted);
            markNotContactedButton.classList.toggle('bg-amber-50', entry.isContacted);
            markNotContactedButton.classList.toggle('border-amber-300', entry.isContacted);
            markNotContactedButton.classList.toggle('text-amber-800', entry.isContacted);
          }

          renderStatusChip(entry);
          renderSegmentBadge(entry);
          renderNextBestActionHint(entry);
          renderActivityTimeline(entry);
        };

        const renderDetailOutreach = (entry) => {
          if (detailOutreach instanceof HTMLElement) {
            detailOutreach.textContent = entry.isContacted ? 'Επικοινωνήθηκε' : 'Χωρίς επικοινωνία';
          }
          if (detailLastContacted instanceof HTMLElement) {
            detailLastContacted.textContent = formatLastContacted(entry.lastContactedTs);
          }
        };

        const renderDetailHistory = (entry) => {
          if (!(detailHistory instanceof HTMLElement)) return;
          detailHistory.innerHTML = '';
          const events = Array.isArray(entry.activity) ? entry.activity : [];
          if (events.length === 0) {
            const li = document.createElement('li');
            li.className = 'text-slate-500';
            li.textContent = 'Δεν υπάρχουν events.';
            detailHistory.appendChild(li);
            return;
          }
          events.forEach((eventItem) => {
            const ts = toMaybeTimestamp(eventItem?.at);
            const li = document.createElement('li');
            li.className = 'flex items-center justify-between gap-2';
            li.innerHTML = `<span>${eventItem?.label || 'Ενέργεια'}</span><span class="text-slate-500">${Number.isFinite(ts) ? new Date(ts).toLocaleString('el-GR') : ''}</span>`;
            detailHistory.appendChild(li);
          });
        };

        const renderDetailNextAction = (entry) => {
          const next = entry?.nextAction;
          if (detailNextActionKind instanceof HTMLSelectElement) detailNextActionKind.value = next?.kind || 'call';
          if (detailNextActionAt instanceof HTMLInputElement) detailNextActionAt.value = next?.at || '';
          if (detailNextActionPreview instanceof HTMLElement) {
            detailNextActionPreview.textContent = next?.at
              ? `Επόμενο βήμα: ${next.kind || 'followup'} στις ${new Date(next.at).toLocaleString('el-GR')}`
              : 'Δεν υπάρχει προγραμματισμένη ενέργεια.';
          }
        };

        parsedCards.forEach((entry) => {
          renderCardOutreach(entry);
        });

        const parseFromUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const category = params.get('category') || 'all';
          const city = params.get('city') || 'all';
          const status = params.get('status') || 'all';
          const contacted = params.get('contacted') || 'all';
          const minScore = params.get('minScore') || 'any';
          const search = (params.get('q') || '').trim();
          const sort = params.get('sort') || 'newest';
          const dir = params.get('dir') || 'desc';
          const page = Number(params.get('page') || '1');

          state.category = validCategories.has(category) ? category : 'all';
          state.city = city === 'all' || validCities.has(city) ? city : 'all';
          state.status = status === 'all' || validStatuses.has(status) ? status : 'all';
          state.contacted = CONTACTED_FILTER_VALUES.includes(contacted) ? contacted : 'all';
          state.minScore = ['any', '80', '60', '40'].includes(minScore) ? minScore : 'any';
          state.search = search;
          state.sort = ['newest', 'score', 'name', 'category', 'city', 'status'].includes(sort) ? sort : 'newest';
          state.sortDir = dir === 'asc' ? 'asc' : 'desc';
          state.page = Number.isFinite(page) && page > 0 ? Math.floor(page) : 1;
        };

        const syncControlsToState = () => {
          categoryTabs.forEach((tab) => {
            if (!(tab instanceof HTMLButtonElement)) return;
            const selected = tab.dataset.categoryValue === state.category;
            tab.setAttribute('aria-pressed', selected ? 'true' : 'false');
            tab.classList.toggle('bg-sky-600', selected);
            tab.classList.toggle('border-sky-600', selected);
            tab.classList.toggle('text-white', selected);
            tab.classList.toggle('shadow-sm', selected);
            tab.classList.toggle('bg-white', !selected);
            tab.classList.toggle('border-slate-300', !selected);
            tab.classList.toggle('text-slate-700', !selected);
          });

          contactedFilterButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const selected = button.dataset.contactedValue === state.contacted;
            button.setAttribute('aria-pressed', selected ? 'true' : 'false');
            button.classList.toggle('bg-sky-600', selected);
            button.classList.toggle('border-sky-600', selected);
            button.classList.toggle('text-white', selected);
            button.classList.toggle('bg-transparent', !selected);
            button.classList.toggle('border-transparent', !selected);
            button.classList.toggle('text-slate-700', !selected);
          });

          if (cityFilter instanceof HTMLSelectElement) cityFilter.value = state.city;
          if (statusFilter instanceof HTMLSelectElement) statusFilter.value = state.status;
          if (scoreFilter instanceof HTMLSelectElement) scoreFilter.value = state.minScore;
          if (searchInput instanceof HTMLInputElement) searchInput.value = state.search;
          if (sortSelect instanceof HTMLSelectElement) sortSelect.value = state.sort;
          const sortLabels = { name: 'Όνομα', category: 'Κατηγορία', city: 'Πόλη', score: 'Score', status: 'Κατάσταση' };
          sortColumnButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const key = button.dataset.sortCol || '';
            const isActive = key === state.sort;
            button.classList.toggle('bg-sky-600', isActive);
            button.classList.toggle('border-sky-600', isActive);
            button.classList.toggle('text-white', isActive);
            button.classList.toggle('text-slate-700', !isActive);
            button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            const base = sortLabels[key] || key;
            button.textContent = isActive ? `${base} ${state.sortDir === 'asc' ? '↑' : '↓'}` : base;
          });

          if (categoryContext instanceof HTMLElement) {
            const label = categoryLabelByValue.get(state.category) || 'Όλες';
            categoryContext.textContent = state.category === 'all'
              ? 'Εμφάνιση όλων των κατηγοριών. Επιλέξτε κατηγορία για πιο στοχευμένη λίστα leads.'
              : `Επιλεγμένη κατηγορία: ${label}. Τα υπόλοιπα φίλτρα λειτουργούν μέσα σε αυτήν.`;
          }

          if (clearSearchButton instanceof HTMLButtonElement) {
            clearSearchButton.classList.toggle('hidden', !state.search.trim());
            clearSearchButton.classList.toggle('inline-flex', Boolean(state.search.trim()));
          }
          if (emptyClearSearch instanceof HTMLButtonElement) {
            emptyClearSearch.disabled = !state.search.trim();
            emptyClearSearch.classList.toggle('opacity-60', !state.search.trim());
            emptyClearSearch.classList.toggle('cursor-not-allowed', !state.search.trim());
          }
        };

        const setBusy = (isBusy) => {
          if (resultsRegion instanceof HTMLElement) resultsRegion.setAttribute('aria-busy', isBusy ? 'true' : 'false');
          if (resultsLoading instanceof HTMLElement) resultsLoading.classList.toggle('hidden', !isBusy);
          if (resultsLoading instanceof HTMLElement) resultsLoading.classList.toggle('inline-flex', isBusy);
          if (loadingSkeleton instanceof HTMLElement) {
            const showLoading = Boolean(isBusy && hasAnyData);
            loadingSkeleton.classList.toggle('hidden', !showLoading);
            loadingSkeleton.setAttribute('aria-hidden', showLoading ? 'false' : 'true');
          }
        };

        const matchesLead = (lead, criteria = state) => {
          const normalizedSearch = criteria.search.trim().toLowerCase();
          const scoreSearchMatch = normalizedSearch.match(/score\s*:\s*(\d+)/);
          const scoreFromSearch = scoreSearchMatch ? Number(scoreSearchMatch[1]) : null;
          const textSearch = normalizedSearch.replace(/score\s*:\s*\d+/g, '').replace(/\s+/g, ' ').trim();
          const searchTokens = textSearch ? textSearch.split(' ').filter(Boolean) : [];

          const minScore = criteria.minScore === 'any' ? -1 : Number(criteria.minScore);
          const effectiveScoreThreshold = Number.isFinite(scoreFromSearch) ? Math.max(minScore, scoreFromSearch) : minScore;

          const categoryMatch = criteria.category === 'all' || lead.category === criteria.category;
          const cityMatch = criteria.city === 'all' || lead.city === criteria.city;
          const statusMatch = criteria.status === 'all' || lead.status === criteria.status;
          const contactedMatch = criteria.contacted === 'all'
            || (criteria.contacted === 'contacted' ? lead.isContacted : !lead.isContacted);
          const scoreMatch = effectiveScoreThreshold <= -1 || lead.score >= effectiveScoreThreshold;
          const searchMatch = searchTokens.length === 0 || searchTokens.every((token) => lead.searchableText.includes(token));
          return categoryMatch && cityMatch && statusMatch && contactedMatch && scoreMatch && searchMatch;
        };

        const updateOptionCounts = () => {
          categoryTabs.forEach((tab) => {
            if (!(tab instanceof HTMLButtonElement)) return;
            const value = tab.dataset.categoryValue || 'all';
            const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, category: value })).length;
            const counter = tab.querySelector('[data-category-count]');
            if (counter) counter.textContent = String(count);
            tab.disabled = count === 0 && value !== state.category;
            tab.classList.toggle('opacity-50', tab.disabled);
            tab.classList.toggle('cursor-not-allowed', tab.disabled);
          });

          if (cityFilter instanceof HTMLSelectElement) {
            Array.from(cityFilter.options).forEach((option) => {
              const baseLabel = option.dataset.baseLabel || option.value;
              const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, city: option.value })).length;
              option.textContent = option.value === 'all' ? `${baseLabel} (${count})` : `${baseLabel} (${count})`;
              option.disabled = count === 0 && option.value !== state.city;
            });
          }

          if (statusFilter instanceof HTMLSelectElement) {
            Array.from(statusFilter.options).forEach((option) => {
              const baseLabel = option.dataset.baseLabel || option.value;
              const count = parsedCards.filter((lead) => matchesLead(lead, { ...state, status: option.value })).length;
              option.textContent = option.value === 'all' ? `${baseLabel} (${count})` : `${baseLabel} (${count})`;
              option.disabled = count === 0 && option.value !== state.status;
            });
          }
        };

        const updateActiveFilters = () => {
          if (!(activeFilters instanceof HTMLElement) || !(noActiveFilters instanceof HTMLElement)) return;

          const items = [];
          if (state.category !== 'all') items.push({ key: 'category', label: `Κατηγορία: ${categoryLabelByValue.get(state.category) || state.category}` });
          if (state.city !== 'all') items.push({ key: 'city', label: `Πόλη: ${cityLabelByValue.get(state.city) || state.city}` });
          if (state.status !== 'all') items.push({ key: 'status', label: `Κατάσταση: ${statusLabelByValue.get(state.status) || state.status}` });
          if (state.contacted !== 'all') items.push({ key: 'contacted', label: `Outreach: ${CONTACTED_FILTER_LABELS[state.contacted] || state.contacted}` });
          if (state.minScore !== 'any') items.push({ key: 'minScore', label: `Score: ${state.minScore}+` });
          if (state.search.trim()) items.push({ key: 'search', label: `Αναζήτηση: “${state.search.trim()}”` });

          activeFilters.innerHTML = '';

          items.forEach((item) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.dataset.filterChip = item.key;
            button.className = 'inline-flex min-h-8 items-center gap-1 rounded-full border border-sky-300 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-800 transition hover:bg-sky-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2';
            button.setAttribute('aria-label', `Αφαίρεση φίλτρου ${item.label}`);
            button.textContent = `${item.label} ×`;
            activeFilters.appendChild(button);
          });

          noActiveFilters.classList.toggle('hidden', items.length > 0);
        };

        const syncUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const setParam = (key, value, defaultValue = 'all') => {
            if (!value || value === defaultValue) params.delete(key);
            else params.set(key, value);
          };

          setParam('category', state.category);
          setParam('city', state.city);
          setParam('status', state.status);
          setParam('contacted', state.contacted);
          setParam('minScore', state.minScore, 'any');
          setParam('sort', state.sort, 'newest');
          setParam('dir', state.sortDir, 'desc');
          setParam('page', String(state.page), '1');

          if (state.search.trim()) params.set('q', state.search.trim());
          else params.delete('q');

          const query = params.toString();
          const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
          window.history.replaceState({}, '', nextUrl);
        };

        const render = () => {
          if (!(list instanceof HTMLElement)) return;

          const filtered = parsedCards.filter((lead) => matchesLead(lead));

          filtered.sort((a, b) => {
            let result = 0;
            if (state.sort === 'score') result = (a.score - b.score);
            else if (state.sort === 'name') result = a.name.localeCompare(b.name, 'el');
            else if (state.sort === 'category') result = a.categoryLabel.localeCompare(b.categoryLabel, 'el');
            else if (state.sort === 'city') result = a.city.localeCompare(b.city, 'el');
            else if (state.sort === 'status') result = a.statusLabel.localeCompare(b.statusLabel, 'el');
            else result = a.newest - b.newest;

            if (result === 0) result = a.name.localeCompare(b.name, 'el');
            return state.sortDir === 'asc' ? result : -result;
          });

          lastFiltered = filtered;
          const totalFiltered = filtered.length;
          const totalPages = Math.max(1, Math.ceil(totalFiltered / state.perPage));
          lastTotalPages = totalPages;
          state.page = Math.min(Math.max(1, state.page), totalPages);

          const startIndex = (state.page - 1) * state.perPage;
          const paged = filtered.slice(startIndex, startIndex + state.perPage);

          parsedCards.forEach((entry) => {
            entry.card.hidden = true;
          });

          paged.forEach((entry) => {
            entry.card.hidden = false;
            list.appendChild(entry.card);
            renderCardOutreach(entry);
          });

          const visible = paged.length;
          if (visibleCount instanceof HTMLElement) visibleCount.textContent = String(totalFiltered);

          if (resultsSummary instanceof HTMLElement) {
            resultsSummary.innerHTML = `Εμφανίζονται <strong>${totalFiltered}</strong> από <strong>${parsedCards.length}</strong> leads.`;
          }

          const contactedCount = filtered.filter((lead) => lead.isContacted).length;
          const qualifiedCount = filtered.filter((lead) => lead.status === 'qualified').length;
          const avgScore = filtered.length > 0
            ? Math.round((filtered.reduce((sum, lead) => sum + (Number.isFinite(lead.score) ? lead.score : 0), 0) / filtered.length) * 10) / 10
            : 0;
          const overdueCount = filtered.filter((lead) => classifyFollowup(lead.nextAction?.at) === 'overdue').length;
          const todayCount = filtered.filter((lead) => classifyFollowup(lead.nextAction?.at) === 'today').length;
          const weekCount = filtered.filter((lead) => classifyFollowup(lead.nextAction?.at) === 'week').length;
          const hotCount = filtered.filter((lead) => lead.segment === 'hot').length;
          const warmCount = filtered.filter((lead) => lead.segment === 'warm').length;
          const coldCount = filtered.filter((lead) => lead.segment === 'cold').length;
          if (analyticsContacted instanceof HTMLElement) analyticsContacted.textContent = String(contactedCount);
          if (analyticsQualified instanceof HTMLElement) analyticsQualified.textContent = String(qualifiedCount);
          if (analyticsScore instanceof HTMLElement) analyticsScore.textContent = String(avgScore);
          if (followupOverdue instanceof HTMLElement) followupOverdue.textContent = String(overdueCount);
          if (followupToday instanceof HTMLElement) followupToday.textContent = String(todayCount);
          if (followupWeek instanceof HTMLElement) followupWeek.textContent = String(weekCount);
          if (analyticsSegmentHot instanceof HTMLElement) analyticsSegmentHot.textContent = String(hotCount);
          if (analyticsSegmentWarm instanceof HTMLElement) analyticsSegmentWarm.textContent = String(warmCount);
          if (analyticsSegmentCold instanceof HTMLElement) analyticsSegmentCold.textContent = String(coldCount);

          selectSegmentVisibleButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;
            const segment = button.dataset.selectSegmentVisible;
            const countBySegment = segment === 'hot' ? hotCount : segment === 'warm' ? warmCount : coldCount;
            button.disabled = countBySegment === 0;
            button.setAttribute('aria-label', `Επιλογή ορατών leads με segment ${segment} (${countBySegment})`);
          });

          if (paginationSummary instanceof HTMLElement) {
            paginationSummary.textContent = `Σελίδα ${state.page} από ${totalPages} • ${visible} στοιχεία σε αυτή τη σελίδα`;
          }

          if (pagePrevButton instanceof HTMLButtonElement) pagePrevButton.disabled = state.page <= 1;
          if (pageNextButton instanceof HTMLButtonElement) pageNextButton.disabled = state.page >= totalPages;
          if (exportCsvButton instanceof HTMLButtonElement) exportCsvButton.disabled = totalFiltered === 0;

          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = `Εμφανίζονται ${totalFiltered} από ${parsedCards.length} leads, σελίδα ${state.page} από ${totalPages}`;
          }

          if (noDataState instanceof HTMLElement) {
            noDataState.classList.toggle('hidden', parsedCards.length > 0);
          }

          if (filteredEmptyState instanceof HTMLElement) {
            const shouldShowFilteredEmpty = parsedCards.length > 0 && totalFiltered === 0;
            filteredEmptyState.classList.toggle('hidden', !shouldShowFilteredEmpty);
          }

          const currentViewState = !hasAnyData ? 'no-data' : totalFiltered === 0 ? 'filtered-empty' : 'results';
          if (currentViewState !== previousRenderedViewState) {
            if (currentViewState === 'filtered-empty') {
              announceState('Δεν βρέθηκαν αποτελέσματα με τα τρέχοντα φίλτρα. Χρησιμοποιήστε το κουμπί Καθαρισμός φίλτρων για άμεση επαναφορά.');
            } else if (currentViewState === 'no-data') {
              announceState('Δεν υπάρχουν διαθέσιμα leads ακόμη. Όταν προστεθούν νέα αρχεία, η λίστα θα ενημερωθεί.');
            } else if (previousRenderedViewState) {
              announceState(`Τα αποτελέσματα είναι ξανά διαθέσιμα. Βρέθηκαν ${totalFiltered} leads.`);
            }
            previousRenderedViewState = currentViewState;
          }

          renderSelectionState();
        };

        const setRuntimeError = (message) => {
          if (runtimeError instanceof HTMLElement) runtimeError.classList.remove('hidden');
          if (runtimeErrorMessage instanceof HTMLElement) runtimeErrorMessage.textContent = message;
          if (list instanceof HTMLElement) list.classList.add('hidden');
          if (filteredEmptyState instanceof HTMLElement) filteredEmptyState.classList.add('hidden');
          if (loadingSkeleton instanceof HTMLElement) {
            loadingSkeleton.classList.add('hidden');
            loadingSkeleton.setAttribute('aria-hidden', 'true');
          }
          announceState('Παρουσιάστηκε σφάλμα στην εφαρμογή φίλτρων. Επιλέξτε Επαναφορά φίλτρων ή Ανανέωση σελίδας.');
        };

        const runFilters = () => {
          setBusy(true);
          window.requestAnimationFrame(() => {
            try {
              const hadRuntimeError = runtimeError instanceof HTMLElement && !runtimeError.classList.contains('hidden');
              updateOptionCounts();
              updateActiveFilters();
              render();
              syncUrl();
              if (runtimeError instanceof HTMLElement) runtimeError.classList.add('hidden');
              if (list instanceof HTMLElement) list.classList.remove('hidden');
              if (hadRuntimeError) {
                announceState('Η προβολή αποκαταστάθηκε επιτυχώς και τα φίλτρα λειτουργούν ξανά.');
              }
            } catch {
              setRuntimeError('Η εφαρμογή φίλτρων απέτυχε προσωρινά. Επιλέξτε επαναφορά φίλτρων για ασφαλή ανάκτηση.');
            } finally {
              setBusy(false);
            }
          });
        };

        const scheduleRun = (delay = 0) => {
          if (applyTimer) window.clearTimeout(applyTimer);
          applyTimer = window.setTimeout(runFilters, delay);
        };

        const resetFilters = () => {
          state.category = 'all';
          state.city = 'all';
          state.status = 'all';
          state.contacted = 'all';
          state.minScore = 'any';
          state.search = '';
          state.sort = 'newest';
          state.sortDir = 'desc';
          state.page = 1;
          syncControlsToState();
          scheduleRun();
        };

        parseFromUrl();
        syncControlsToState();
        renderPresets();

        categoryTabs.forEach((tab, index) => {
          if (!(tab instanceof HTMLButtonElement)) return;

          tab.addEventListener('click', () => {
            if (tab.disabled) return;
            state.category = tab.dataset.categoryValue || 'all';
            state.page = 1;
            syncControlsToState();
            scheduleRun();
          });

          tab.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
            event.preventDefault();
            const direction = event.key === 'ArrowRight' ? 1 : -1;

            let nextIndex = index;
            for (let i = 0; i < categoryTabs.length; i += 1) {
              nextIndex = (nextIndex + direction + categoryTabs.length) % categoryTabs.length;
              const candidate = categoryTabs[nextIndex];
              if (candidate instanceof HTMLButtonElement && !candidate.disabled) {
                candidate.focus();
                candidate.click();
                break;
              }
            }
          });
        });

        cityFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.city = target.value;
          state.page = 1;
          scheduleRun();
        });

        statusFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.status = target.value;
          state.page = 1;
          scheduleRun();
        });

        contactedFilterButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const value = button.dataset.contactedValue || 'all';
            if (!CONTACTED_FILTER_VALUES.includes(value)) return;
            state.contacted = value;
            state.page = 1;
            syncControlsToState();
            scheduleRun();
          });
        });

        scoreFilter?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.minScore = target.value;
          state.page = 1;
          scheduleRun();
        });

        searchInput?.addEventListener('input', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLInputElement)) return;
          state.search = target.value;
          state.page = 1;
          syncControlsToState();
          scheduleRun(180);
        });

        clearSearchButton?.addEventListener('click', () => {
          state.search = '';
          syncControlsToState();
          if (searchInput instanceof HTMLInputElement) searchInput.focus();
          scheduleRun();
        });

        sortSelect?.addEventListener('change', (event) => {
          const target = event.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.sort = target.value;
          state.sortDir = target.value === 'name' || target.value === 'category' || target.value === 'city' || target.value === 'status' ? 'asc' : 'desc';
          state.page = 1;
          scheduleRun();
        });

        sortColumnButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const key = button.dataset.sortCol;
            if (!key) return;
            if (state.sort === key) state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc';
            else {
              state.sort = key;
              state.sortDir = key === 'score' ? 'desc' : 'asc';
            }
            state.page = 1;
            if (sortSelect instanceof HTMLSelectElement) sortSelect.value = state.sort;
            syncControlsToState();
            scheduleRun();
          });
        });

        resetButton?.addEventListener('click', () => {
          resetFilters();
        });

        emptyReset?.addEventListener('click', () => {
          resetFilters();
          announceState('Τα φίλτρα καθαρίστηκαν. Εμφανίζεται ξανά η πλήρης λίστα leads.');
        });

        emptyClearSearch?.addEventListener('click', () => {
          if (!state.search.trim()) return;
          state.search = '';
          state.page = 1;
          syncControlsToState();
          scheduleRun();
          announcePolite('Αφαιρέθηκε ο όρος αναζήτησης. Τα υπόλοιπα φίλτρα παραμένουν ενεργά.');
        });

        activeFilters?.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const chip = target.closest('[data-filter-chip]');
          if (!(chip instanceof HTMLButtonElement)) return;

          const key = chip.dataset.filterChip;
          if (key === 'category') state.category = 'all';
          if (key === 'city') state.city = 'all';
          if (key === 'status') state.status = 'all';
          if (key === 'contacted') state.contacted = 'all';
          if (key === 'minScore') state.minScore = 'any';
          if (key === 'search') state.search = '';
          state.page = 1;

          syncControlsToState();
          scheduleRun();
        });

        clearUrlFiltersButton?.addEventListener('click', () => {
          resetFilters();
          window.history.replaceState({}, '', window.location.pathname);
        });

        const currentViewUrl = () => `${window.location.origin}${window.location.pathname}${window.location.search}`;

        copyCurrentViewButton?.addEventListener('click', async () => {
          const url = currentViewUrl();
          await navigator.clipboard.writeText(url).catch(() => {});
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Αντιγράφηκε το URL της τρέχουσας προβολής.';
        });

        savePresetButton?.addEventListener('click', () => {
          const name = window.prompt('Όνομα preset φίλτρων:')?.trim();
          if (!name) return;
          const presets = readPresets().filter((preset) => preset.name !== name);
          presets.unshift({
            name,
            query: window.location.search || '',
            state: {
              category: state.category,
              city: state.city,
              status: state.status,
              contacted: state.contacted,
              minScore: state.minScore,
              search: state.search,
              sort: state.sort,
              sortDir: state.sortDir
            }
          });
          writePresets(presets);
          renderPresets();
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Αποθηκεύτηκε preset: ${name}`;
        });

        presetsList?.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;

          const copyButton = target.closest('[data-preset-copy]');
          if (copyButton instanceof HTMLButtonElement) {
            const name = copyButton.dataset.presetCopy || '';
            const preset = readPresets().find((item) => item.name === name);
            const query = typeof preset?.query === 'string' ? preset.query : '';
            const shareUrl = `${window.location.origin}${window.location.pathname}${query}`;
            await navigator.clipboard.writeText(shareUrl).catch(() => {});
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Αντιγράφηκε το URL για το preset ${name}.`;
            return;
          }

          const button = target.closest('[data-preset-name]');
          if (!(button instanceof HTMLButtonElement)) return;
          const name = button.dataset.presetName || '';
          const preset = readPresets().find((item) => item.name === name);
          if (!preset?.state) return;
          state.category = preset.state.category || 'all';
          state.city = preset.state.city || 'all';
          state.status = preset.state.status || 'all';
          state.contacted = CONTACTED_FILTER_VALUES.includes(preset.state.contacted) ? preset.state.contacted : 'all';
          state.minScore = preset.state.minScore || 'any';
          state.search = preset.state.search || '';
          state.sort = preset.state.sort || 'newest';
          state.sortDir = preset.state.sortDir || 'desc';
          state.page = 1;
          syncControlsToState();
          scheduleRun();
        });

        const closeDetailPanel = () => {
          if (detailPanel instanceof HTMLElement) {
            detailPanel.classList.add('hidden');
            detailPanel.classList.add('pointer-events-none');
          }
          activeDetailLeadId = '';
        };

        const syncActiveDetail = (entry) => {
          if (!activeDetailLeadId || activeDetailLeadId !== entry.id) return;
          renderDetailOutreach(entry);
          renderDetailHistory(entry);
          renderDetailNextAction(entry);
        };

        const openDetailPanel = (entry) => {
          if (!(detailPanel instanceof HTMLElement)) return;
          activeDetailLeadId = entry.id;
          if (detailName instanceof HTMLElement) detailName.textContent = entry.name || '—';
          if (detailCategory instanceof HTMLElement) detailCategory.textContent = entry.categoryLabel || '—';
          if (detailCity instanceof HTMLElement) detailCity.textContent = entry.city || '—';
          if (detailStatus instanceof HTMLElement) detailStatus.textContent = entry.statusLabel || '—';
          if (detailScore instanceof HTMLElement) detailScore.textContent = String(entry.score ?? '—');
          if (detailPhone instanceof HTMLElement) detailPhone.textContent = entry.card.dataset.phone || '—';
          if (detailEmail instanceof HTMLElement) detailEmail.textContent = entry.card.dataset.email || '—';
          renderDetailOutreach(entry);
          renderDetailHistory(entry);
          renderDetailNextAction(entry);
          if (detailNotes instanceof HTMLElement) detailNotes.textContent = entry.card.dataset.notes || 'Δεν υπάρχουν σημειώσεις.';
          detailPanel.classList.remove('hidden');
          detailPanel.classList.remove('pointer-events-none');
        };

        const getActiveDetailEntry = () => parsedCards.find((entry) => entry.id === activeDetailLeadId);

        pagePrevButton?.addEventListener('click', () => {
          state.page = Math.max(1, state.page - 1);
          scheduleRun();
        });

        pageNextButton?.addEventListener('click', () => {
          state.page = Math.min(lastTotalPages, state.page + 1);
          scheduleRun();
        });

        selectVisibleButton?.addEventListener('click', () => {
          lastFiltered.slice((state.page - 1) * state.perPage, (state.page - 1) * state.perPage + state.perPage).forEach((entry) => {
            if (entry.id) selectedLeadIds.add(entry.id);
          });
          renderSelectionState();
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Επιλέχθηκαν ${selectedLeadIds.size} leads.`;
        });

        selectSegmentVisibleButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const targetSegment = button.dataset.selectSegmentVisible;
            if (!targetSegment) return;
            const visiblePageLeads = lastFiltered.slice((state.page - 1) * state.perPage, (state.page - 1) * state.perPage + state.perPage);
            let added = 0;
            visiblePageLeads.forEach((entry) => {
              if (entry.segment !== targetSegment || !entry.id) return;
              if (!selectedLeadIds.has(entry.id)) added += 1;
              selectedLeadIds.add(entry.id);
            });
            renderSelectionState();
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = added > 0
              ? `Επιλέχθηκαν ${added} ορατά leads του segment ${targetSegment}.`
              : `Δεν υπάρχουν νέα ορατά leads για segment ${targetSegment}.`;
          });
        });

        clearSelectionButton?.addEventListener('click', () => {
          selectedLeadIds.clear();
          renderSelectionState();
        });

        selectionDockClear?.addEventListener('click', () => {
          selectedLeadIds.clear();
          renderSelectionState();
        });

        const applyBulkOutreach = (targetContacted) => {
          const count = selectedLeadIds.size;
          if (count <= 0) return;
          const nextLabel = targetContacted ? 'Έγινε επαφή' : 'Εκκρεμεί επαφή';
          const impacted = parsedCards.filter((entry) => selectedLeadIds.has(entry.id) && entry.isContacted !== targetContacted).length;
          const ok = window.confirm(`Μαζική ενημέρωση outreach: ${nextLabel}\n\nΣύνολο επιλογής: ${count} leads\nΘα αλλάξουν πραγματικά: ${impacted} leads\n\nΑσφάλεια: μπορείτε να κάνετε αναίρεση για ${BULK_UNDO_WINDOW_MINUTES} λεπτά από το κουμπί ή με Alt+Z.`);
          if (!ok) return;

          const snapshot = [];
          let changed = 0;
          parsedCards.forEach((entry) => {
            if (!selectedLeadIds.has(entry.id)) return;
            if (entry.isContacted === targetContacted) return;
            snapshot.push({ id: entry.id, isContacted: entry.isContacted, lastContactedTs: entry.lastContactedTs });
            entry.isContacted = targetContacted;
            entry.lastContactedTs = targetContacted ? Date.now() : null;
            entry.searchableText = [
              entry.name,
              entry.phone,
              entry.email,
              entry.categoryLabel,
              entry.city,
              entry.statusLabel,
              `score:${entry.score}`,
              targetContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη',
              entry.segment,
              entry.note
            ].join(' ').toLowerCase();
            appendActivity(entry, targetContacted ? 'Bulk: σημειώθηκε ως επικοινωνημένο' : 'Bulk: σημειώθηκε ως χωρίς επαφή');
            syncOutreachRecord(entry);
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            changed += 1;
          });

          lastBulkOutreachSnapshot = changed > 0 ? { entries: snapshot, changed, targetContacted, createdAt: Date.now() } : null;

          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = changed > 0
              ? `Ενημερώθηκαν ${changed} leads σε "${nextLabel}". Η αναίρεση παραμένει διαθέσιμη για ${BULK_UNDO_WINDOW_MINUTES} λεπτά.`
              : 'Δεν υπάρχει επιλεγμένο lead για bulk ενέργεια.';
          }
          if (changed > 0) {
            const undoUntil = new Date(Date.now() + BULK_UNDO_WINDOW_MS).toLocaleTimeString('el-GR', { hour: '2-digit', minute: '2-digit' });
            setLastActionNote(`Bulk outreach → ${nextLabel} (${changed} leads, αναίρεση έως ${undoUntil})`);
          }
          renderSelectionState();
          scheduleRun();
        };

        const undoBulkOutreach = () => {
          if (!lastBulkOutreachSnapshot?.entries?.length) return;
          if (!isUndoAvailable()) {
            setLastActionNote('Το παράθυρο αναίρεσης outreach έχει λήξει.');
            announcePolite('Η αναίρεση δεν είναι πλέον διαθέσιμη γιατί έληξε το χρονικό παράθυρο.');
            renderSelectionState();
            return;
          }
          const ok = window.confirm(`Αναίρεση τελευταίας μαζικής outreach ενέργειας για ${lastBulkOutreachSnapshot.changed} leads;\n\nΘα επανέλθουν μόνο οι outreach τιμές που άλλαξαν στο τελευταίο βήμα.`);
          if (!ok) return;

          lastBulkOutreachSnapshot.entries.forEach((item) => {
            const entry = parsedCards.find((lead) => lead.id === item.id);
            if (!entry) return;
            entry.isContacted = Boolean(item.isContacted);
            entry.lastContactedTs = item.lastContactedTs ?? null;
            entry.searchableText = [entry.name, entry.phone, entry.email, entry.categoryLabel, entry.city, entry.statusLabel, `score:${entry.score}`, entry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', entry.segment, entry.note].join(' ').toLowerCase();
            appendActivity(entry, 'Undo: επαναφορά προηγούμενης outreach κατάστασης');
            syncOutreachRecord(entry);
            renderCardOutreach(entry);
            syncActiveDetail(entry);
          });

          const restoredCount = lastBulkOutreachSnapshot.changed;
          lastBulkOutreachSnapshot = null;
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Ολοκληρώθηκε αναίρεση outreach για ${restoredCount} leads. Οι υπόλοιπες ενέργειες παρέμειναν ανέπαφες.`;
          setLastActionNote(`Undo bulk outreach (${restoredCount} leads)`);
          renderSelectionState();
          scheduleRun();
        };

        const applyBulkSegment = (segmentValue) => {
          const count = selectedLeadIds.size;
          if (count <= 0) return;
          const ok = window.confirm(`Επιβεβαίωση μαζικού segment '${segmentValue}' για ${count} leads;\n\nΗ ενέργεια επηρεάζει μόνο το segment.`);
          if (!ok) return;

          let changed = 0;
          parsedCards.forEach((entry) => {
            if (!selectedLeadIds.has(entry.id)) return;
            entry.segment = segmentValue;
            segmentState = { ...segmentState, [entry.id]: segmentValue };
            entry.searchableText = [entry.name, entry.phone, entry.email, entry.categoryLabel, entry.city, entry.statusLabel, `score:${entry.score}`, entry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', entry.segment, entry.note].join(' ').toLowerCase();
            appendActivity(entry, `Bulk: segment → ${segmentValue}`);
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            changed += 1;
          });
          writeMapState(SEGMENT_STORAGE_KEY, segmentState);
          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = changed > 0
              ? `Ενημερώθηκε segment για ${changed} leads.`
              : 'Δεν υπάρχει επιλεγμένο lead για bulk segment.';
          }
          if (changed > 0) setLastActionNote(`Bulk segment → ${segmentValue} (${changed} leads)`);
          scheduleRun();
        };

        const applyBulkFollowupDate = (isoDateTime) => {
          const count = selectedLeadIds.size;
          if (count <= 0 || !isoDateTime) return;
          const ok = window.confirm(`Ορισμός follow-up για ${count} leads στις ${new Date(isoDateTime).toLocaleString('el-GR')};\n\nΗ ενέργεια παραμένει περιορισμένη στα επιλεγμένα leads.`);
          if (!ok) return;

          let changed = 0;
          parsedCards.forEach((entry) => {
            if (!selectedLeadIds.has(entry.id)) return;
            entry.nextAction = { kind: entry.nextAction?.kind || 'followup', at: isoDateTime };
            nextActionState = { ...nextActionState, [entry.id]: entry.nextAction };
            appendActivity(entry, 'Bulk: ορίστηκε follow-up ημερομηνία');
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            changed += 1;
          });
          writeMapState(NEXT_ACTION_STORAGE_KEY, nextActionState);
          if (liveRegion instanceof HTMLElement) {
            liveRegion.textContent = changed > 0
              ? `Ορίστηκε follow-up για ${changed} leads.`
              : 'Δεν υπάρχει επιλεγμένο lead για follow-up.';
          }
          if (changed > 0) setLastActionNote(`Bulk follow-up ημερομηνία (${changed} leads)`);
          scheduleRun();
        };

        bulkStatusButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            applyBulkOutreach(button.dataset.bulkContacted === 'true');
          });
        });

        bulkSegmentButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const segmentValue = button.dataset.bulkSegment;
            if (!segmentValue) return;
            applyBulkSegment(segmentValue);
          });
        });

        selectionDockButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            applyBulkOutreach(button.dataset.selectionDockContacted === 'true');
          });
        });

        selectionDockSegmentButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.addEventListener('click', () => {
            const segmentValue = button.dataset.selectionDockSegment;
            if (!segmentValue) return;
            applyBulkSegment(segmentValue);
          });
        });

        bulkOutreachUndo?.addEventListener('click', () => {
          undoBulkOutreach();
        });

        selectionDockOutreachUndo?.addEventListener('click', () => {
          undoBulkOutreach();
        });

        bulkFollowupSet?.addEventListener('click', () => {
          const at = bulkFollowupAt instanceof HTMLInputElement ? bulkFollowupAt.value : '';
          applyBulkFollowupDate(at);
        });

        selectionDockFollowupSet?.addEventListener('click', () => {
          const at = selectionDockFollowupAt instanceof HTMLInputElement ? selectionDockFollowupAt.value : '';
          applyBulkFollowupDate(at);
        });

        detailOverlay?.addEventListener('click', closeDetailPanel);
        detailClose?.addEventListener('click', closeDetailPanel);

        detailNextActionSave?.addEventListener('click', () => {
          const entry = getActiveDetailEntry();
          if (!entry) return;
          const kind = detailNextActionKind instanceof HTMLSelectElement ? detailNextActionKind.value : 'followup';
          const at = detailNextActionAt instanceof HTMLInputElement ? detailNextActionAt.value : '';
          entry.nextAction = at ? { kind, at } : null;
          nextActionState = { ...nextActionState, [entry.id]: entry.nextAction };
          writeMapState(NEXT_ACTION_STORAGE_KEY, nextActionState);
          appendActivity(entry, at ? `Προγραμματίστηκε ${kind}` : 'Καθαρίστηκε next-action');
          renderDetailNextAction(entry);
          renderCardOutreach(entry);
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = at ? 'Αποθηκεύτηκε επόμενη ενέργεια.' : 'Αφαιρέθηκε επόμενη ενέργεια.';
        });

        detailNextActionClear?.addEventListener('click', () => {
          const entry = getActiveDetailEntry();
          if (!entry) return;
          entry.nextAction = null;
          nextActionState = { ...nextActionState, [entry.id]: null };
          writeMapState(NEXT_ACTION_STORAGE_KEY, nextActionState);
          appendActivity(entry, 'Καθαρίστηκε next-action');
          renderDetailNextAction(entry);
          renderDetailHistory(entry);
        });

        const showShortcutsHelp = () => {
          window.alert(
            'Συντομεύσεις leads:\n'
            + '/ focus αναζήτησης\n'
            + 'Shift+A επιλογή ορατών\n'
            + 'Shift+U καθαρισμός επιλογής\n'
            + 'Alt+Backspace καθαρισμός επιλογής\n'
            + 'Alt+1/2/3 μαζικό segment\n'
            + 'Alt+Shift+H/W/C επιλογή ορατών ανά segment\n'
            + 'Alt+Shift+E/N μαζικό outreach\n'
            + 'Alt+D focus πεδίου follow-up\n'
            + 'Alt+Shift+F εφαρμογή follow-up\n'
            + `Alt+Z undo τελευταίου bulk outreach (εντός ${BULK_UNDO_WINDOW_MINUTES} λεπτών)\n`
            + 'Alt+U focus κουμπιού undo\n'
            + 'J/K πλοήγηση καρτών\n'
            + 'C/N/H/W/L/S triage στο detail drawer'
          );
        };

        shortcutsHelpButton?.addEventListener('click', showShortcutsHelp);

        const isEditableTarget = (target) => {
          if (!(target instanceof HTMLElement)) return false;
          if (target.isContentEditable) return true;
          return target instanceof HTMLInputElement
            || target instanceof HTMLTextAreaElement
            || target instanceof HTMLSelectElement;
        };

        window.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          if (event.key === 'Escape') {
            closeDetailPanel();
            return;
          }

          const typingContext = isEditableTarget(event.target);
          const hasSystemModifier = event.ctrlKey || event.metaKey;
          const key = event.key.toLowerCase();

          if (!typingContext && !hasSystemModifier && !event.altKey && !event.shiftKey && event.key === '/' && document.activeElement !== searchInput) {
            event.preventDefault();
            if (searchInput instanceof HTMLInputElement) searchInput.focus();
          }
          if (!typingContext && !hasSystemModifier && event.shiftKey && key === 'a') {
            event.preventDefault();
            selectVisibleButton?.dispatchEvent(new Event('click'));
          }
          if (!typingContext && !hasSystemModifier && event.shiftKey && key === 'u') {
            event.preventDefault();
            clearSelectionButton?.dispatchEvent(new Event('click'));
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.key === '1') {
            event.preventDefault();
            const btn = root.querySelector('[data-bulk-segment="hot"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.key === '2') {
            event.preventDefault();
            const btn = root.querySelector('[data-bulk-segment="warm"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.key === '3') {
            event.preventDefault();
            const btn = root.querySelector('[data-bulk-segment="cold"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'h') {
            event.preventDefault();
            const btn = root.querySelector('[data-select-segment-visible="hot"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'w') {
            event.preventDefault();
            const btn = root.querySelector('[data-select-segment-visible="warm"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'c') {
            event.preventDefault();
            const btn = root.querySelector('[data-select-segment-visible="cold"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'e') {
            event.preventDefault();
            const btn = root.querySelector('[data-bulk-contacted="true"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'n') {
            event.preventDefault();
            const btn = root.querySelector('[data-bulk-contacted="false"]');
            if (btn instanceof HTMLButtonElement && !btn.disabled) btn.click();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && key === 'd') {
            event.preventDefault();
            if (selectionDockFollowupAt instanceof HTMLInputElement && !selectionDockFollowupAt.disabled) selectionDockFollowupAt.focus();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.shiftKey && key === 'f') {
            event.preventDefault();
            const at = (selectionDockFollowupAt instanceof HTMLInputElement && selectionDockFollowupAt.value)
              ? selectionDockFollowupAt.value
              : (bulkFollowupAt instanceof HTMLInputElement ? bulkFollowupAt.value : '');
            applyBulkFollowupDate(at);
          }
          if (!typingContext && !hasSystemModifier && event.altKey && key === 'z') {
            event.preventDefault();
            undoBulkOutreach();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && key === 'u') {
            event.preventDefault();
            if (selectionDockOutreachUndo instanceof HTMLButtonElement && !selectionDockOutreachUndo.disabled) selectionDockOutreachUndo.focus();
            else if (bulkOutreachUndo instanceof HTMLButtonElement && !bulkOutreachUndo.disabled) bulkOutreachUndo.focus();
          }
          if (!typingContext && !hasSystemModifier && event.altKey && event.key === 'Backspace') {
            event.preventDefault();
            selectedLeadIds.clear();
            renderSelectionState();
            announcePolite('Καθαρίστηκε η επιλογή μέσω συντόμευσης πληκτρολογίου.');
          }
          if (!typingContext && !hasSystemModifier && event.shiftKey && event.key === '?') {
            event.preventDefault();
            showShortcutsHelp();
          }

          const activeEntry = getActiveDetailEntry();
          const inTextInput = isEditableTarget(document.activeElement);
          if (activeEntry && !inTextInput && !hasSystemModifier && !event.altKey && !event.shiftKey) {
            if (key === 'c') {
              event.preventDefault();
              activeEntry.isContacted = true;
              activeEntry.lastContactedTs = Date.now();
              activeEntry.searchableText = [activeEntry.name, activeEntry.phone, activeEntry.email, activeEntry.categoryLabel, activeEntry.city, activeEntry.statusLabel, `score:${activeEntry.score}`, 'επικοινωνηθηκε', activeEntry.segment, activeEntry.note].join(' ').toLowerCase();
              appendActivity(activeEntry, 'Shortcut: σημειώθηκε ως επικοινωνημένο');
              syncOutreachRecord(activeEntry);
              renderCardOutreach(activeEntry);
              syncActiveDetail(activeEntry);
              scheduleRun();
            }
            if (key === 'n') {
              event.preventDefault();
              activeEntry.isContacted = false;
              activeEntry.lastContactedTs = null;
              activeEntry.searchableText = [activeEntry.name, activeEntry.phone, activeEntry.email, activeEntry.categoryLabel, activeEntry.city, activeEntry.statusLabel, `score:${activeEntry.score}`, 'χωρις επαφη', activeEntry.segment, activeEntry.note].join(' ').toLowerCase();
              appendActivity(activeEntry, 'Shortcut: σημειώθηκε ως χωρίς επαφή');
              syncOutreachRecord(activeEntry);
              renderCardOutreach(activeEntry);
              syncActiveDetail(activeEntry);
              scheduleRun();
            }
            if (['h', 'w', 'l'].includes(key)) {
              event.preventDefault();
              const segment = key === 'h' ? 'hot' : key === 'w' ? 'warm' : 'cold';
              activeEntry.segment = segment;
              segmentState = { ...segmentState, [activeEntry.id]: segment };
              writeMapState(SEGMENT_STORAGE_KEY, segmentState);
              activeEntry.searchableText = [activeEntry.name, activeEntry.phone, activeEntry.email, activeEntry.categoryLabel, activeEntry.city, activeEntry.statusLabel, `score:${activeEntry.score}`, activeEntry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', activeEntry.segment, activeEntry.note].join(' ').toLowerCase();
              appendActivity(activeEntry, `Shortcut: segment → ${segment}`);
              renderCardOutreach(activeEntry);
              syncActiveDetail(activeEntry);
              scheduleRun();
            }
            if (key === 's' && detailNextActionAt instanceof HTMLInputElement) {
              event.preventDefault();
              detailNextActionAt.focus();
            }
          }

          if (!typingContext && !hasSystemModifier && !event.altKey && !event.shiftKey && (key === 'j' || key === 'k')) {
            const visibleCards = parsedCards.filter((entry) => !entry.card.hidden).map((entry) => entry.card);
            const activeIndex = visibleCards.findIndex((card) => card === document.activeElement);
            if (activeIndex !== -1) {
              event.preventDefault();
              const delta = key === 'j' ? 1 : -1;
              const nextIndex = Math.min(Math.max(activeIndex + delta, 0), visibleCards.length - 1);
              visibleCards[nextIndex]?.focus();
            }
          }
        });

        list?.addEventListener('change', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLInputElement) || !target.matches('[data-row-select]')) return;
          const card = target.closest('[data-lead-card]');
          if (!(card instanceof HTMLElement)) return;
          const entry = parsedCards.find((item) => item.card === card);
          if (!entry?.id) return;
          if (target.checked) selectedLeadIds.add(entry.id);
          else selectedLeadIds.delete(entry.id);
          renderSelectionState();
        });

        list?.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          const target = event.target;

          if (event.key === 'Enter' && target instanceof HTMLInputElement && target.matches('[data-note-input]')) {
            event.preventDefault();
            const card = target.closest('[data-lead-card]');
            if (!(card instanceof HTMLElement)) return;
            const entry = parsedCards.find((item) => item.card === card);
            if (!entry) return;
            entry.note = target.value.trim();
            notesState = { ...notesState, [entry.id]: entry.note };
            writeMapState(NOTES_STORAGE_KEY, notesState);
            appendActivity(entry, entry.note ? 'Αποθηκεύτηκε σημείωση' : 'Καθαρίστηκε σημείωση');
            renderCardOutreach(entry);
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Η σημείωση αποθηκεύτηκε.';
            scheduleRun();
            return;
          }

          if (event.key === 'Enter' && target instanceof HTMLElement && target.matches('[data-lead-card]')) {
            const entry = parsedCards.find((item) => item.card === target);
            if (!entry) return;
            event.preventDefault();
            openDetailPanel(entry);
          }
        });

        list?.addEventListener('focusout', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLInputElement) || !target.matches('[data-note-input]')) return;
          const card = target.closest('[data-lead-card]');
          if (!(card instanceof HTMLElement)) return;
          const entry = parsedCards.find((item) => item.card === card);
          if (!entry) return;
          const nextNote = target.value.trim();
          if ((entry.note || '') === nextNote) return;
          entry.note = nextNote;
          notesState = { ...notesState, [entry.id]: entry.note };
          writeMapState(NOTES_STORAGE_KEY, notesState);
          appendActivity(entry, entry.note ? 'Auto-save σημείωσης' : 'Καθαρίστηκε σημείωση');
          renderCardOutreach(entry);
          if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Η σημείωση αποθηκεύτηκε αυτόματα.';
          scheduleRun();
        });

        list?.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const card = target.closest('[data-lead-card]');
          if (!(card instanceof HTMLElement)) return;
          const entry = parsedCards.find((item) => item.card === card);
          if (!entry) return;

          const copyPhone = target.closest('[data-copy-phone]');
          const copyEmail = target.closest('[data-copy-email]');
          const openDetail = target.closest('[data-open-detail]');
          const outreachToggle = target.closest('[data-toggle-contacted]');
          const setSegment = target.closest('[data-set-segment]');
          const triageQuick = target.closest('[data-triage-quick]');
          const saveNote = target.closest('[data-save-note]');

          if (outreachToggle instanceof HTMLButtonElement) {
            const nextValue = outreachToggle.dataset.toggleContacted === 'true';
            entry.isContacted = nextValue;
            entry.lastContactedTs = nextValue ? Date.now() : null;
            entry.searchableText = [
              entry.name,
              entry.phone,
              entry.email,
              entry.categoryLabel,
              entry.city,
              entry.statusLabel,
              `score:${entry.score}`,
              nextValue ? 'επικοινωνηθηκε' : 'χωρις επαφη',
              entry.segment,
              entry.note
            ].join(' ').toLowerCase();
            appendActivity(entry, nextValue ? 'Σημειώθηκε ως επικοινωνημένο' : 'Σημειώθηκε ως χωρίς επαφή');
            syncOutreachRecord(entry);
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            if (liveRegion instanceof HTMLElement) {
              liveRegion.textContent = nextValue
                ? `Το lead ${entry.name} σημειώθηκε ως επικοινωνημένο.`
                : `Το lead ${entry.name} σημειώθηκε ως χωρίς επικοινωνία.`;
            }
            scheduleRun();
            return;
          }

          if (setSegment instanceof HTMLButtonElement) {
            const value = setSegment.dataset.setSegment || 'untagged';
            entry.segment = value;
            segmentState = { ...segmentState, [entry.id]: value };
            writeMapState(SEGMENT_STORAGE_KEY, segmentState);
            entry.searchableText = [entry.name, entry.phone, entry.email, entry.categoryLabel, entry.city, entry.statusLabel, `score:${entry.score}`, entry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', entry.segment, entry.note].join(' ').toLowerCase();
            appendActivity(entry, `Segment: ${value}`);
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = `Το lead ${entry.name} σημειώθηκε ως ${value}.`;
            scheduleRun();
            return;
          }

          if (triageQuick instanceof HTMLButtonElement) {
            const mode = triageQuick.dataset.triageQuick;
            if (mode === 'contact-now') {
              entry.isContacted = true;
              entry.lastContactedTs = Date.now();
              appendActivity(entry, 'Γρήγορο triage: έγινε επαφή τώρα');
              syncOutreachRecord(entry);
            }
            if (mode === 'followup-2d') {
              const future = new Date(Date.now() + 2 * 24 * 60 * 60 * 1000);
              const isoLocal = new Date(future.getTime() - future.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
              entry.nextAction = { kind: 'followup', at: isoLocal };
              nextActionState = { ...nextActionState, [entry.id]: entry.nextAction };
              writeMapState(NEXT_ACTION_STORAGE_KEY, nextActionState);
              appendActivity(entry, 'Γρήγορο triage: follow-up +2 ημέρες');
            }
            entry.searchableText = [entry.name, entry.phone, entry.email, entry.categoryLabel, entry.city, entry.statusLabel, `score:${entry.score}`, entry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', entry.segment, entry.note].join(' ').toLowerCase();
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Εφαρμόστηκε γρήγορη triage ενέργεια.';
            scheduleRun();
            return;
          }

          if (saveNote instanceof HTMLButtonElement) {
            const noteInput = entry.card.querySelector('[data-note-input]');
            const value = noteInput instanceof HTMLInputElement ? noteInput.value.trim() : '';
            entry.note = value;
            notesState = { ...notesState, [entry.id]: value };
            writeMapState(NOTES_STORAGE_KEY, notesState);
            entry.searchableText = [entry.name, entry.phone, entry.email, entry.categoryLabel, entry.city, entry.statusLabel, `score:${entry.score}`, entry.isContacted ? 'επικοινωνηθηκε' : 'χωρις επαφη', entry.segment, entry.note].join(' ').toLowerCase();
            appendActivity(entry, value ? 'Αποθηκεύτηκε σημείωση' : 'Καθαρίστηκε σημείωση');
            renderCardOutreach(entry);
            syncActiveDetail(entry);
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = value ? 'Η σημείωση αποθηκεύτηκε.' : 'Η σημείωση αφαιρέθηκε.';
            scheduleRun();
            return;
          }

          if (copyPhone) {
            const value = card.dataset.phone || '';
            if (!value) return;
            await navigator.clipboard.writeText(value).catch(() => {});
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Αντιγράφηκε το τηλέφωνο.';
          }

          if (copyEmail) {
            const value = card.dataset.email || '';
            if (!value) return;
            await navigator.clipboard.writeText(value).catch(() => {});
            if (liveRegion instanceof HTMLElement) liveRegion.textContent = 'Αντιγράφηκε το email.';
          }

          if (openDetail) {
            openDetailPanel(entry);
          }
        });

        exportCsvButton?.addEventListener('click', () => {
          const headers = ['name', 'category', 'city', 'status', 'score', 'phone', 'email'];
          const rows = lastFiltered.map((lead) => [
            lead.name,
            lead.categoryLabel,
            lead.city,
            lead.statusLabel,
            String(lead.score ?? ''),
            lead.card.dataset.phone || '',
            lead.card.dataset.email || ''
          ]);
          const escape = (value) => `"${String(value ?? '').replaceAll('"', '""')}"`;
          const csv = [headers.map(escape).join(','), ...rows.map((row) => row.map(escape).join(','))].join('\n');
          const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
          const link = document.createElement('a');
          const url = URL.createObjectURL(blob);
          const dateTag = new Date().toISOString().slice(0, 10);
          link.href = url;
          link.download = `leads-filtered-${dateTag}.csv`;
          link.click();
          URL.revokeObjectURL(url);
        });

        runtimeReset?.addEventListener('click', () => {
          resetFilters();
          if (runtimeError instanceof HTMLElement) runtimeError.classList.add('hidden');
          if (list instanceof HTMLElement) list.classList.remove('hidden');
          announceState('Επαναφορά φίλτρων ολοκληρώθηκε. Η προβολή είναι ξανά διαθέσιμη.');
        });

        runtimeReload?.addEventListener('click', () => {
          window.location.reload();
        });

        runFilters();
      } catch {
        const runtimeError = root.querySelector('[data-runtime-error]');
        const runtimeErrorMessage = root.querySelector('[data-runtime-error-message]');
        if (runtimeError instanceof HTMLElement) runtimeError.classList.remove('hidden');
        if (runtimeErrorMessage instanceof HTMLElement) {
          runtimeErrorMessage.textContent = 'Η αρχικοποίηση του πίνακα φίλτρων απέτυχε. Τα δεδομένα παραμένουν ασφαλή. Κάντε ανανέωση σελίδας.';
        }
      }
    }
  </script>
</Layout>
