---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const profilesFile = await import('../../../data/professionals.json');
const profiles = (profilesFile.default ?? profilesFile) as Array<{
  slug: string;
  name: string;
  profession: string;
  city: string;
  areasServed: string[];
  experienceYears: number;
  bio: string;
  services: string[];
  phone: string;
  email: string;
  approved?: boolean;
  published?: boolean;
}>;

export function getStaticPaths() {
  const profilesFile = Object.values(import.meta.glob('../../../data/professionals.json', { eager: true }))[0] as any;
  const profiles = (profilesFile.default ?? profilesFile) as Array<{ slug: string; approved?: boolean; published?: boolean }>;

  return profiles
    .filter((profile) => profile.approved === true && profile.published === true)
    .map((profile) => ({
    params: { slug: profile.slug },
    props: { profile }
  }));
}

const { profile } = Astro.props as { profile: (typeof profiles)[number] };
---

<Layout
  title={`${profile.name} | ${profile.profession} | GreekHandy`}
  description={`Δείτε το προφίλ του/της ${profile.name}, ${profile.profession} στη ${profile.city}.`}
>
  <main class="mx-auto max-w-4xl px-4 py-14">
    <a href="/professionals" class="text-sm font-semibold text-blue-700 hover:underline">&larr; Όλοι οι επαγγελματίες</a>

    <section class="mt-4 rounded-2xl border border-gray-200 bg-white p-7 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">{profile.profession}</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{profile.name}</h1>
      <p class="mt-2 text-gray-600">{profile.city} • {profile.experienceYears} χρόνια εμπειρίας</p>

      <p class="mt-6 leading-relaxed text-gray-700">{profile.bio}</p>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div>
          <h2 class="text-lg font-bold text-gray-900">Υπηρεσίες</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
            {profile.services.map((service) => <li>{service}</li>)}
          </ul>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900">Περιοχές εξυπηρέτησης</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
            {profile.areasServed.map((area) => <li>{area}</li>)}
          </ul>
        </div>
      </div>

      <div class="mt-8 rounded-xl bg-blue-50 p-5">
        <h2 class="text-lg font-bold text-gray-900">Στοιχεία επικοινωνίας</h2>
        <p class="mt-2 text-gray-700">Τηλέφωνο: <a href={`tel:${profile.phone}`} class="font-semibold text-blue-700">{profile.phone}</a></p>
        <p class="mt-1 text-gray-700">Email: <a href={`mailto:${profile.email}`} class="font-semibold text-blue-700">{profile.email}</a></p>
      </div>
    </section>
  </main>
</Layout>
