          <div class="mt-4">
            <label for="senderPhone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο (προαιρετικό)</label>
            <input id="senderPhone" name="senderPhone" maxlength="40" pattern="[0-9+()\-\s]{7,20}" title="Αν συμπληρωθεί, το τηλέφωνο πρέπει να έχει 7-20 χαρακτήρες." class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
          </div>

          <div class="mt-4">
            <label for="initialMessage" class="mb-1 block text-sm font-semibold text-gray-800">Μήνυμα *</label>
            <textarea id="initialMessage" name="message" rows="4" required maxlength="2000" data-trim-required aria-describedby="message-moderation-hint submit-feedback-live" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>
          <p id="message-moderation-hint" class="mt-2 text-xs text-indigo-800">Η συνομιλία δημιουργείται σε pending triage και μπορεί να περιοριστεί από moderation.</p>

            <button type="submit" class="mt-4 rounded-lg bg-indigo-700 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-800 disabled:cursor-not-allowed disabled:opacity-70" data-default-label="Αποστολή μηνύματος" data-pending-label="Αποστολή...">Αποστολή μηνύματος</button>
          </form>
        </details>

        <details id="contact-details" class="group rounded-xl border border-slate-200 bg-slate-50/80 p-5" data-secondary-contact-disclosure>
          <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:hidden">
            Δευτερεύουσα επιλογή: προβολή στοιχείων επικοινωνίας
          </summary>
          <div class="mt-3 rounded-xl border border-slate-200 bg-white p-4">
            <p class="text-slate-700">Τηλέφωνο: <a href={`tel:${profile.phone}`} class="font-semibold text-blue-700">{profile.phone}</a></p>
            <p class="mt-1 text-slate-700">Email: <a href={`mailto:${profile.email}`} class="font-semibold text-blue-700">{profile.email}</a></p>
            <p class="mt-2 text-xs text-slate-500">Για ταχύτερη επεξεργασία προτιμήστε το κύριο αίτημα συνεργασίας.</p>
          </div>
        </details>
      </section>
      <div id="profile-offline-alert" class="mt-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert" aria-live="assertive" aria-atomic="true">
        <p class="font-semibold">Εντοπίστηκε απώλεια σύνδεσης.</p>
        <p class="mt-1 text-xs">Οι υποβολές κριτικής/αιτήματος/μηνύματος μπλοκάρονται προσωρινά μέχρι να επανέλθει το δίκτυο.</p>
      </div>
      <p id="submit-feedback-live" class="sr-only" role="status" aria-live="assertive" aria-atomic="true"></p>
    </section>

    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const feedbackStatuses = {
          review: ['loading', 'pending', 'approved', 'rejected', 'offline', 'invalid', 'error'],
          booking: ['loading', 'submitted', 'offline', 'invalid', 'error'],
          message: ['loading', 'submitted', 'offline', 'invalid', 'blocked', 'error']
        };
        const feedbackStatusAliases = {
          review: { submitted: 'pending' }
        };
        const submitLiveRegion = document.querySelector('#submit-feedback-live');
        const profileOfflineAlert = document.querySelector('#profile-offline-alert');
        const secondaryReviewsDisclosure = document.querySelector('[data-secondary-reviews-disclosure]');
        const secondaryMessageDisclosure = document.querySelector('[data-secondary-message-disclosure]');
        const secondaryContactDisclosure = document.querySelector('[data-secondary-contact-disclosure]');
        const primaryBookingForm = document.querySelector('[data-booking-form]');
        const profileMediaImages = Array.from(document.querySelectorAll('[data-prof-media-img]')).filter((item) => item instanceof HTMLImageElement);
        const pendingForms = Array.from(document.querySelectorAll('[data-pending-form]')).filter((form) => form instanceof HTMLFormElement);
        const pendingTimeouts = new WeakMap();
        const isOffline = () => typeof navigator !== 'undefined' && navigator.onLine === false;
        const hardenProfileMedia = () => {
          for (const img of profileMediaImages) {
            if (!(img instanceof HTMLImageElement)) continue;
            const fallbackSrc = img.dataset.fallbackSrc || '';
            const ensureFallback = () => {
              if (!fallbackSrc) return;
              img.dataset.mediaState = 'fallback';
              if (img.src !== fallbackSrc) img.src = fallbackSrc;
            };
            img.addEventListener('error', ensureFallback);
            if (img.complete && (!img.naturalWidth || !img.naturalHeight)) ensureFallback();
          }
        };
        hardenProfileMedia();

        const getSessionFlag = (key) => {
          try {
            return window.sessionStorage.getItem(key);
          } catch {
            return null;
          }
        };
        const setSessionFlag = (key, value) => {
          try {
            window.sessionStorage.setItem(key, value);
          } catch {
            // Ignore storage failures (private mode / blocked storage) to keep UX functional.
          }
        };
        const clearPendingTimeout = (form) => {
          const timer = pendingTimeouts.get(form);
          if (typeof timer === 'number') {
            window.clearTimeout(timer);
          }
          pendingTimeouts.delete(form);
        };
        const announceSubmitState = (message) => {
          if (submitLiveRegion instanceof HTMLElement) submitLiveRegion.textContent = message;
        };
        const collapseSecondaryActions = () => {
          if (secondaryReviewsDisclosure instanceof HTMLDetailsElement) {
            secondaryReviewsDisclosure.open = false;
          }
          if (secondaryMessageDisclosure instanceof HTMLDetailsElement) {
            secondaryMessageDisclosure.open = false;
          }
          if (secondaryContactDisclosure instanceof HTMLDetailsElement) {
            secondaryContactDisclosure.open = false;
          }
        };
        const syncOfflineSubmitAvailability = () => {
          const offline = isOffline();
          for (const form of pendingForms) {
            const submitButton = form.querySelector('button[type="submit"]');
            if (!(submitButton instanceof HTMLButtonElement)) continue;
            if (form.getAttribute('aria-busy') === 'true') continue;
            if (offline) {
              submitButton.setAttribute('data-offline-disabled', submitButton.disabled ? 'true' : 'false');
              submitButton.disabled = true;
              submitButton.setAttribute('aria-disabled', 'true');
              continue;
            }
            const wasDisabled = submitButton.getAttribute('data-offline-disabled') === 'true';
            submitButton.removeAttribute('data-offline-disabled');
            submitButton.disabled = wasDisabled;
            if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
          }
        };
        const syncOfflineAlert = () => {
          const offline = isOffline();
          if (profileOfflineAlert instanceof HTMLElement) {
            profileOfflineAlert.classList.toggle('hidden', !offline);
          }
          syncOfflineSubmitAvailability();
          if (!offline) {
            if (
              submitLiveRegion instanceof HTMLElement
              && typeof submitLiveRegion.textContent === 'string'
              && submitLiveRegion.textContent.includes('Δεν υπάρχει σύνδεση')
            ) submitLiveRegion.textContent = '';
            return;
          }
          announceSubmitState('Δεν υπάρχει σύνδεση. Οι υποβολές είναι προσωρινά ανενεργές.');
        };
        const openDisclosure = (element) => {
          if (element instanceof HTMLDetailsElement) {
            element.open = true;
          }
        };
        const syncSecondaryActionsWithIntent = () => {
          const hash = window.location.hash || '';
          if (params.get('review') || hash === '#reviews' || hash === '#submit-review' || hash === '#secondary-reviews') {
            openDisclosure(secondaryReviewsDisclosure);
          }
          if (params.get('message') || hash === '#secondary-actions') {
            openDisclosure(secondaryMessageDisclosure);
          }
          if (hash === '#contact-details') {
            openDisclosure(secondaryContactDisclosure);
          }
        };

        const syncPrimaryCtaFocus = () => {
          if (!(primaryBookingForm instanceof HTMLFormElement)) return;
          const hasBookingOutcome = Boolean(params.get('booking'));
          if (hasBookingOutcome) {
            collapseSecondaryActions();
          }

          primaryBookingForm.addEventListener('focusin', () => {
            collapseSecondaryActions();
            announceSubmitState('Κύρια διαδρομή: συμπληρώστε το αίτημα συνεργασίας για γρηγορότερη εξυπηρέτηση.');
          });
        };
        const reviewListRoot = document.querySelector('[data-review-list-root]');
        const initialReviewListState = reviewListRoot?.getAttribute('data-review-list-initial-state') || 'ready';
        const reviewListStatusElement = document.querySelector('[data-review-list-status]');
        const reviewListStatusLabelElement = document.querySelector('[data-review-list-status-label]');
        const reviewListTrustElement = document.querySelector('[data-review-list-trust]');
        const reviewListExpectationElement = document.querySelector('[data-review-list-expectation]');
        const reviewListStateMeta = {
          ready: {
            label: 'Αξιόπιστη',
            toneClass: 'border-emerald-200 bg-emerald-50 text-emerald-800',
            trustMessage: 'Αξιοπιστία: υψηλή, με βάση εγκεκριμένες δημόσιες κριτικές.',
            expectationMessage: 'Τι να περιμένετε: νέες κριτικές εμφανίζονται μόνο μετά το moderation.'
          },
          empty: {
            label: 'Χωρίς εγκεκριμένες',
            toneClass: 'border-blue-200 bg-blue-50 text-blue-800',
            trustMessage: 'Αξιοπιστία: δεν υπάρχει ακόμη δείγμα βαθμολόγησης.',
            expectationMessage: 'Τι να περιμένετε: η σύνοψη ενεργοποιείται μόλις εγκριθεί η πρώτη κριτική.'
          },
          loading: {
            label: 'Έλεγχος ενημέρωσης',
            toneClass: 'border-blue-200 bg-blue-100 text-blue-900',
            trustMessage: 'Αξιοπιστία: προσωρινά υπό ανανέωση.',
            expectationMessage: 'Τι να περιμένετε: θα εμφανιστούν τα πιο πρόσφατα εγκεκριμένα δεδομένα.'
          },
          error: {
            label: 'Προσωρινά μη διαθέσιμη',
            toneClass: 'border-slate-200 bg-slate-100 text-slate-700',
            trustMessage: 'Οι κριτικές δεν είναι προσωρινά διαθέσιμες.',
            expectationMessage: 'Δοκιμάστε ξανά σε λίγο για ενημερωμένη εικόνα.'
          }
        };
        const setReviewListState = (state) => {
          const loadingShell = document.querySelector('[data-review-loading-shell]');
          const reviewContent = document.querySelector('[data-review-content]');
          const normalizedState = Object.prototype.hasOwnProperty.call(reviewListStateMeta, state) ? state : 'error';
          const statusMeta = reviewListStateMeta[normalizedState];

          if (loadingShell) {
            loadingShell.classList.toggle('hidden', normalizedState !== 'loading');
          }

          if (reviewContent) {
            reviewContent.classList.toggle('hidden', normalizedState === 'loading');
            reviewContent.setAttribute('aria-busy', normalizedState === 'loading' ? 'true' : 'false');
          }

          if (reviewListStatusElement instanceof HTMLElement) {
            const baseClass = reviewListStatusElement.getAttribute('data-base-class') || '';
            reviewListStatusElement.className = `${baseClass} ${statusMeta.toneClass}`.trim();
          }

          if (reviewListStatusLabelElement instanceof HTMLElement) {
            reviewListStatusLabelElement.textContent = statusMeta.label;
          }
          if (reviewListTrustElement instanceof HTMLElement) {
            reviewListTrustElement.textContent = statusMeta.trustMessage;
          }
          if (reviewListExpectationElement instanceof HTMLElement) {
            reviewListExpectationElement.textContent = statusMeta.expectationMessage;
          }
        };
        const syncReviewListStateWithReviewFeedback = (status) => {
          if (status === 'loading') {
            setReviewListState('loading');
            return;
          }

          setReviewListState(initialReviewListState);
        };

        const showFeedbackStatus = (groupName, status) => {
          const group = document.querySelector(`[data-feedback-group="${groupName}"]`);
          if (!group) return;

          const allowedStatuses = feedbackStatuses[groupName] || [];
          const aliasMap = feedbackStatusAliases[groupName] || {};
          const resolvedStatus = aliasMap[status] || status;
          const normalizedStatus = allowedStatuses.includes(resolvedStatus)
            ? resolvedStatus
            : (allowedStatuses.includes('error') ? 'error' : null);
          if (!normalizedStatus) return;

          const messages = Array.from(group.querySelectorAll('[data-feedback-status]'));
          let activeMessage = null;
          for (const message of messages) {
            const currentStatus = message.getAttribute('data-feedback-status');
            const isVisible = currentStatus === normalizedStatus;
            message.classList.toggle('hidden', !isVisible);
            message.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
            if (isVisible) {
              activeMessage = message;
              const assertive = normalizedStatus === 'invalid' || normalizedStatus === 'error' || normalizedStatus === 'blocked' || normalizedStatus === 'offline';
              message.setAttribute('role', assertive ? 'alert' : 'status');
              message.setAttribute('aria-live', assertive ? 'assertive' : 'polite');
              message.setAttribute('aria-atomic', 'true');
            } else {
              message.removeAttribute('role');
              message.removeAttribute('aria-live');
              message.removeAttribute('aria-atomic');
            }
          }
          if (group instanceof HTMLElement) {
            const assertiveGroup = normalizedStatus === 'invalid' || normalizedStatus === 'error' || normalizedStatus === 'blocked' || normalizedStatus === 'offline';
            group.setAttribute('role', assertiveGroup ? 'alert' : 'status');
            group.setAttribute('aria-live', assertiveGroup ? 'assertive' : 'polite');
            group.setAttribute('aria-atomic', 'true');
            group.setAttribute('data-feedback-active-status', normalizedStatus);
          }
          if (activeMessage instanceof HTMLElement) {
            const plainText = (activeMessage.textContent || '').replace(/\s+/g, ' ').trim();
            if (plainText) announceSubmitState(plainText);
          }

          if (groupName === 'review') {
            syncReviewListStateWithReviewFeedback(normalizedStatus);
          }
        };

        const applyFeedback = (groupName, queryParam) => {
          const status = params.get(queryParam);
          if (!status) return;

          if (groupName === 'review') {
            const reviewAttempted = getSessionFlag('review-submit-attempted') === '1';
            const serverOutcomeStatuses = new Set(['pending', 'approved', 'rejected']);
            if (!reviewAttempted && !serverOutcomeStatuses.has(status)) {
              return;
            }
          }

          showFeedbackStatus(groupName, status);
        };

        applyFeedback('review', 'review');
        applyFeedback('booking', 'booking');
        applyFeedback('message', 'message');
        syncSecondaryActionsWithIntent();
        syncPrimaryCtaFocus();
        if (!params.get('review')) {
          setReviewListState(initialReviewListState);
        }

        const reviewForm = document.querySelector('[data-review-form]');
        if (reviewForm instanceof HTMLFormElement) {
          const markReviewInteracted = () => setSessionFlag('review-submit-attempted', '1');
          reviewForm.addEventListener('input', markReviewInteracted, { once: true });
          reviewForm.addEventListener('submit', () => {
            markReviewInteracted();
          });
        }

        const setFormPending = (form, isPending) => {
          const submitButton = form.querySelector('button[type="submit"]');
          if (!(submitButton instanceof HTMLButtonElement)) return;
          const controls = Array.from(form.querySelectorAll('button, input, select, textarea')).filter((control) => (
            !(control instanceof HTMLInputElement && control.type === 'hidden')
          ));
          clearPendingTimeout(form);

          form.setAttribute('aria-busy', isPending ? 'true' : 'false');
          form.classList.toggle('opacity-80', isPending);

          if (isPending) {
            for (const control of controls) {
              control.setAttribute('data-pending-disabled', control.disabled ? 'true' : 'false');
              control.disabled = true;
              control.setAttribute('aria-disabled', 'true');
            }
            const defaultLabel = submitButton.getAttribute('data-default-label') || submitButton.textContent || 'Αποστολή';
            const pendingLabel = submitButton.getAttribute('data-pending-label') || 'Αποστολή...';
            form.setAttribute('data-submit-label', defaultLabel);
            submitButton.textContent = pendingLabel;
            submitButton.setAttribute('aria-busy', 'true');
            const timeoutMs = Number(form.getAttribute('data-pending-timeout-ms') || '15000');
            if (Number.isFinite(timeoutMs) && timeoutMs > 0) {
              const timeoutId = window.setTimeout(() => {
                if (form.getAttribute('aria-busy') !== 'true') return;
                setFormPending(form, false);
                announceSubmitState(form.getAttribute('data-pending-timeout-label') || 'Η υποβολή καθυστέρησε. Δοκιμάστε ξανά.');
                const feedbackGroup = form.getAttribute('data-feedback-group-name');
                if (feedbackGroup) showFeedbackStatus(feedbackGroup, 'error');
              }, timeoutMs);
              pendingTimeouts.set(form, timeoutId);
            }
            return;
          }

          for (const control of controls) {
            const wasDisabled = control.getAttribute('data-pending-disabled') === 'true';
            control.disabled = wasDisabled;
            control.removeAttribute('data-pending-disabled');
            if (!control.disabled) control.removeAttribute('aria-disabled');
          }
          const defaultLabel = form.getAttribute('data-submit-label') || submitButton.getAttribute('data-default-label') || 'Αποστολή';
          submitButton.textContent = defaultLabel;
          submitButton.removeAttribute('aria-busy');
          if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
          syncOfflineSubmitAvailability();
        };

        const updateMessageFieldValidity = (form, forceInvalidState = false) => {
          const messageField = form.querySelector('textarea[name="message"]');
          if (!(messageField instanceof HTMLTextAreaElement)) return;
          const isValid = messageField.value.trim().length > 0;
          const touched = forceInvalidState || form.getAttribute('data-message-touched') === 'true';
          messageField.setCustomValidity(isValid ? '' : 'Συμπληρώστε μήνυμα.');
          messageField.setAttribute('aria-invalid', (!isValid && touched) ? 'true' : 'false');
        };
        const updateTrimRequiredFields = (form, forceInvalidState = false) => {
          const fields = Array.from(form.querySelectorAll('[data-trim-required]')).filter((field) => (
            field instanceof HTMLTextAreaElement || field instanceof HTMLInputElement
          ));
          for (const field of fields) {
            const isValid = field.value.trim().length > 0;
            const touched = forceInvalidState || field.getAttribute('data-trim-touched') === 'true';
            field.setCustomValidity(isValid ? '' : 'Συμπληρώστε το πεδίο.');
            field.setAttribute('aria-invalid', (!isValid && touched) ? 'true' : 'false');
          }
        };

        const bookingFieldValidators = {
          name: (value) => value.trim().length >= 2,
          phone: (value) => /^[0-9+()\-\s]{7,20}$/.test(value.trim()),
          email: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim()),
          preferredDate: (value) => value.trim() === '' || (value.trim().length >= 4 && /\d/.test(value))
        };

        const updateBookingFieldValidity = (form, forceInvalidState = false) => {
          if (!form.hasAttribute('data-booking-form')) return;
          const fields = Array.from(form.querySelectorAll('[data-booking-validate]')).filter((field) => field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement);
          const invalidRules = [];
          for (const field of fields) {
            const rule = field.getAttribute('data-booking-validate') || '';
            const validator = bookingFieldValidators[rule];
            if (!validator) continue;
            const isValid = validator(field.value || '');
            const touched = forceInvalidState || field.getAttribute('data-booking-touched') === 'true';
            const errorEl = document.getElementById(`${field.id}-error`);
            if (!isValid && touched) {
              field.setAttribute('aria-invalid', 'true');
              if (errorEl instanceof HTMLElement) errorEl.classList.remove('hidden');
            } else {
              field.setAttribute('aria-invalid', 'false');
              if (errorEl instanceof HTMLElement) errorEl.classList.add('hidden');
            }
            if (!isValid) invalidRules.push(rule);
            if (rule === 'preferredDate') {
              field.setCustomValidity(isValid ? '' : 'Προσθέστε σαφή ημέρα/ώρα.');
            } else {
              field.setCustomValidity(isValid ? '' : 'Συμπληρώστε έγκυρη τιμή.');
            }
          }

          const summary = form.querySelector('[data-booking-validation-summary]');
          if (summary instanceof HTMLElement) {
            const mapped = {
              name: 'ονοματεπώνυμο',
              phone: 'τηλέφωνο',
              email: 'email',
              preferredDate: 'προτιμώμενο πρόγραμμα'
            };
            if (invalidRules.length === 0) {
              summary.textContent = 'Έλεγχος φόρμας: όλα τα βασικά πεδία είναι έγκυρα. Μπορείτε να προχωρήσετε.';
            } else {
              const uniqueLabels = [...new Set(invalidRules.map((rule) => mapped[rule] || rule))];
              summary.textContent = `Έλεγχος φόρμας: χρειάζεται διόρθωση στα πεδία ${uniqueLabels.join(', ')}.`;
            }
          }
        };

        for (const form of pendingForms) {
          const feedbackGroupName = form.getAttribute('data-feedback-group-name') || '';
          updateTrimRequiredFields(form);
          updateBookingFieldValidity(form);
          form.addEventListener('input', (event) => {
            if (!(event.target instanceof HTMLElement)) return;
            if (event.target.hasAttribute('data-trim-required')) {
              event.target.setAttribute('data-trim-touched', 'true');
              updateTrimRequiredFields(form);
            }
            if (event.target.hasAttribute('data-booking-validate')) {
              event.target.setAttribute('data-booking-touched', 'true');
              updateBookingFieldValidity(form);
            }
          });
          form.addEventListener('blur', (event) => {
            if (!(event.target instanceof HTMLElement)) return;
            if (!event.target.hasAttribute('data-booking-validate')) return;
            event.target.setAttribute('data-booking-touched', 'true');
            updateBookingFieldValidity(form);
          }, true);
          if (form.hasAttribute('data-message-form')) {
            updateMessageFieldValidity(form);
            form.addEventListener('input', (event) => {
              if (!(event.target instanceof HTMLElement)) return;
              if (event.target.getAttribute('name') !== 'message') return;
              form.setAttribute('data-message-touched', 'true');
              updateMessageFieldValidity(form);
            });
          }
          form.addEventListener('submit', (event) => {
            if (isOffline()) {
              event.preventDefault();
              if (feedbackGroupName) showFeedbackStatus(feedbackGroupName, 'offline');
              announceSubmitState('Δεν υπάρχει σύνδεση. Δοκιμάστε ξανά μόλις επανέλθει το δίκτυο.');
              syncOfflineAlert();
              return;
            }
            if (form.getAttribute('aria-busy') === 'true') {
              event.preventDefault();
              announceSubmitState('Η υποβολή βρίσκεται ήδη σε εξέλιξη.');
              return;
            }

            if (form.hasAttribute('data-message-form')) {
              updateMessageFieldValidity(form, true);
            }
            updateTrimRequiredFields(form, true);
            updateBookingFieldValidity(form, true);

            if (!form.checkValidity()) {
              event.preventDefault();
              if (feedbackGroupName) showFeedbackStatus(feedbackGroupName, 'invalid');
              form.reportValidity();
              announceSubmitState('Ελέγξτε τα πεδία και δοκιμάστε ξανά.');
              return;
            }

            if (feedbackGroupName) {
              showFeedbackStatus(feedbackGroupName, 'loading');
            }

            announceSubmitState(form.getAttribute('data-pending-live-label') || 'Η υποβολή εκτελείται.');
            setFormPending(form, true);
          });
        }

        window.addEventListener('pageshow', () => {
          for (const form of pendingForms) {
            setFormPending(form, false);
            updateTrimRequiredFields(form);
            updateBookingFieldValidity(form);
            if (form.hasAttribute('data-message-form')) {
              updateMessageFieldValidity(form);
            }
          }
          announceSubmitState('');
          syncOfflineAlert();
        });
        window.addEventListener('hashchange', () => {
          syncSecondaryActionsWithIntent();
        });
        window.addEventListener('online', syncOfflineAlert);
        window.addEventListener('offline', syncOfflineAlert);
        syncOfflineAlert();
      })();
    </script>
  </main>
</Layout>
