---
import Layout from '../../layouts/Layout.astro';
import {
  readFormFlash,
  clearFormFlash
} from '../../lib/form-flash';
import { supabaseServer } from '../../lib/supabase-server';
import { assertPublishedProfilesHaveValidMedia, getProfessionalFallbackImage, resolveProfessionalImageForPublishedProfile } from '../../lib/professional-images';

export const prerender = true;

const profilesFile = await import('../../../data/professionals.json');
const reviewBadgeCopyFile = await import('../../../data/review-verified-badge-copy.json');
const profiles = (profilesFile.default ?? profilesFile) as Array<{
  slug: string;
  name: string;
  profession: string;
  city: string;
  areasServed: string[];
  experienceYears: number;
  bio: string;
  services: string[];
  profilePhotoUrl?: string;
  portfolioPhotos?: string[];
  phone: string;
  email: string;
  approved?: boolean;
  published?: boolean;
}>;

export async function getStaticPaths() {
  const profilesFile = Object.values(import.meta.glob('../../../data/professionals.json', { eager: true }))[0] as any;
  const profiles = (profilesFile.default ?? profilesFile) as Array<{ slug: string; approved?: boolean; published?: boolean; profilePhotoUrl?: string }>;

  const publishedProfiles = profiles
    .filter((profile) => profile.approved === true && profile.published === true);

  await assertPublishedProfilesHaveValidMedia(publishedProfiles);

  return publishedProfiles.map((profile) => ({
    params: { slug: profile.slug },
    props: { profile }
  }));
}

interface ApprovedReview {
  id: string;
  reviewerName: string;
  rating: number;
  comment: string;
  verified?: boolean;
  submittedAt: string;
}

const { profile } = Astro.props as { profile: (typeof profiles)[number] };
const fallbackProfileImage = getProfessionalFallbackImage();
const profileImageSrc = await resolveProfessionalImageForPublishedProfile(profile.profilePhotoUrl);
const hasHeroMedia = Boolean(profileImageSrc && profileImageSrc !== fallbackProfileImage);

const cleanListText = (value: string) => value.replace(/\s+/g, ' ').replace(/[\u0000-\u001F\u007F]/g, '').trim();
const safeServices = (profile.services || [])
  .map((item) => cleanListText(String(item || '')))
  .filter((item) => item.length >= 2 && item.length <= 120)
  .slice(0, 24);
const safeAreasServed = (profile.areasServed || [])
  .map((item) => cleanListText(String(item || '')))
  .filter((item) => item.length >= 2 && item.length <= 80)
  .slice(0, 24);

const rawPortfolioPhotos = (profile.portfolioPhotos || []).map((photo) => String(photo || '').trim()).filter(Boolean);
const portfolioResolvedEntries = await Promise.all(
  rawPortfolioPhotos.map(async (photo) => ({
    original: photo,
    resolved: await resolveProfessionalImageForPublishedProfile(photo)
  }))
);
const portfolioImageSources = portfolioResolvedEntries
  .filter((entry) => entry.original.startsWith('/professionals/') || entry.original.startsWith('http://') || entry.original.startsWith('https://'))
  .map((entry) => entry.resolved)
  .filter((src, index, arr) => src !== fallbackProfileImage && arr.indexOf(src) === index)
  .slice(0, 12);
const reviewBadgeCopy = (reviewBadgeCopyFile.default ?? reviewBadgeCopyFile) as any;
const verifiedBadgeLabel = reviewBadgeCopy?.publicBadge?.defaultLabel || 'Επιβεβαιωμένη αξιολόγηση';
const verifiedBadgeTooltip = reviewBadgeCopy?.publicBadge?.tooltip || 'Η αξιολόγηση συνδέεται με πραγματικό αίτημα υπηρεσίας μέσω Greek Handy.';
const verifiedBadgeDisclaimer = reviewBadgeCopy?.publicBadge?.disclaimer || '';

const { data: approvedRows, error: approvedRowsError } = await supabaseServer
  .from('reviews')
  .select('id, reviewer_name, rating, comment, verified, created_at')
  .eq('status', 'approved')
  .eq('service_slug', profile.slug)
  .order('created_at', { ascending: false });

if (approvedRowsError) {
  console.error('[professional-profile-reviews] fetch failed', {
    slug: profile.slug,
    error: approvedRowsError
  });
}

const approvedReviews: ApprovedReview[] = (approvedRows || []).map((row: any) => ({
  id: row.id,
  reviewerName: row.reviewer_name || 'Ανώνυμος Πελάτης',
  rating: Math.max(1, Math.min(5, Number(row.rating) || 1)),
  comment: row.comment || '',
  verified: Boolean(row.verified),
  submittedAt: row.created_at
}));

const hasApprovedReviewsError = Boolean(approvedRowsError);
const reviewsCount = approvedReviews.length;
const reviewsLabel = reviewsCount === 1 ? 'κριτική' : 'κριτικές';
type ReviewListState = 'ready' | 'empty' | 'error';
const initialReviewListState: ReviewListState = hasApprovedReviewsError
  ? 'error'
  : (reviewsCount === 0 ? 'empty' : 'ready');
const reviewListStateLabels: Record<ReviewListState, string> = {
  ready: 'Διαθέσιμες',
  empty: 'Χωρίς εγκεκριμένες',
  error: 'Προσωρινά μη διαθέσιμη'
};
const reviewListStatusTones: Record<ReviewListState, string> = {
  ready: 'border-emerald-200 bg-emerald-50 text-emerald-800',
  empty: 'border-blue-200 bg-blue-50 text-blue-800',
  error: 'border-slate-200 bg-slate-100 text-slate-700'
};
const reviewListStateTrustCopy: Record<ReviewListState, { reliability: string; expectation: string }> = {
  ready: {
    reliability: 'Αξιοπιστία: υψηλή, με βάση εγκεκριμένες δημόσιες κριτικές.',
    expectation: 'Τι να περιμένετε: νέες κριτικές εμφανίζονται μόνο μετά τον απαραίτητο έλεγχο.'
  },
  empty: {
    reliability: 'Αξιοπιστία: δεν υπάρχει ακόμη δείγμα βαθμολόγησης.',
    expectation: 'Τι να περιμένετε: η σύνοψη ενεργοποιείται μόλις εγκριθεί η πρώτη κριτική.'
  },
  error: {
    reliability: 'Οι κριτικές δεν είναι προσωρινά διαθέσιμες.',
    expectation: 'Δοκιμάστε ξανά σε λίγο για ενημερωμένη εικόνα.'
  }
};
const initialReviewListStatusTone = reviewListStatusTones[initialReviewListState];
const initialReviewListTrustCopy = reviewListStateTrustCopy[initialReviewListState];
const reviewReloadHref = `${Astro.url.pathname}#reviews`;
const verifiedReviewsCount = approvedReviews.filter((review) => review.verified).length;
const highlightedReviews = approvedReviews.slice(0, 8);
const averageRatingValue = reviewsCount > 0
  ? approvedReviews.reduce((sum, review) => sum + review.rating, 0) / reviewsCount
  : null;
const averageRating = averageRatingValue !== null
  ? averageRatingValue.toFixed(1)
  : null;
const averageRatingStars = averageRatingValue !== null
  ? '★'.repeat(Math.round(averageRatingValue)) + '☆'.repeat(5 - Math.round(averageRatingValue))
  : '';
const ratingDistribution = [5, 4, 3, 2, 1].map((star) => {
  const count = approvedReviews.filter((review) => review.rating === star).length;
  return {
    star,
    count,
    percentage: reviewsCount > 0 ? Math.round((count / reviewsCount) * 100) : 0
  };
});
const positiveReviewsCount = approvedReviews.filter((review) => review.rating >= 4).length;
const recommendationRate = reviewsCount > 0
  ? Math.round((positiveReviewsCount / reviewsCount) * 100)
  : 0;
const recentApprovedReviewDate = approvedReviews[0]?.submittedAt
  ? new Date(approvedReviews[0].submittedAt).toLocaleDateString('el-GR', { day: '2-digit', month: 'long', year: 'numeric' })
  : null;
const averageRatingSummary = averageRatingValue === null
  ? null
  : averageRatingValue >= 4.8
    ? 'Εξαιρετική συνολική εμπειρία πελατών.'
    : averageRatingValue >= 4.4
      ? 'Πολύ υψηλή ικανοποίηση στις περισσότερες συνεργασίες.'
      : averageRatingValue >= 4
        ? 'Σταθερά θετικές αξιολογήσεις από πελάτες.'
        : averageRatingValue >= 3
          ? 'Μικτή εικόνα με περιθώριο για βελτίωση.'
          : 'Αυτή τη στιγμή οι αξιολογήσεις δείχνουν ανάγκη βελτίωσης.';
const formatReviewDate = (dateValue: string) =>
  new Date(dateValue).toLocaleDateString('el-GR', { day: '2-digit', month: 'long', year: 'numeric' });
const renderStarRating = (rating: number) => '★'.repeat(rating) + '☆'.repeat(5 - rating);

const proofTimelineItems = [
  reviewsCount > 0
    ? {
        key: 'jobs',
        label: 'Ολοκληρωμένες συνεργασίες',
        value: `${reviewsCount}+ τεκμηριωμένες`,
        tone: 'border-emerald-200 bg-emerald-50 text-emerald-900'
      }
    : null,
  recommendationRate > 0
    ? {
        key: 'response',
        label: 'Αξιοπιστία ανταπόκρισης',
        value: `${recommendationRate}% θετικές αξιολογήσεις`,
        tone: 'border-blue-200 bg-blue-50 text-blue-900'
      }
    : null,
  recentApprovedReviewDate
    ? {
        key: 'recency',
        label: 'Πιο πρόσφατη αξιολόγηση',
        value: recentApprovedReviewDate,
        tone: 'border-violet-200 bg-violet-50 text-violet-900'
      }
    : null
].filter(Boolean) as Array<{ key: string; label: string; value: string; tone: string }>;
const hasProofTimeline = proofTimelineItems.length > 0;

const profileUrl = new URL(`/professionals/${profile.slug}`, Astro.site).toString();
const siteUrl = new URL('/', Astro.site).toString();

const professionalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'LocalBusiness'],
  '@id': `${profileUrl}#business`,
  name: profile.name,
  description: profile.bio,
  url: profileUrl,
  image: profileImageSrc,
  telephone: profile.phone || undefined,
  email: profile.email ? `mailto:${profile.email}` : undefined,
  areaServed: (profile.areasServed?.length ? profile.areasServed : [profile.city]).filter(Boolean).map((area) => ({
    '@type': 'City',
    name: area
  })),
  address: profile.city
    ? {
        '@type': 'PostalAddress',
        addressLocality: profile.city,
        addressCountry: 'GR'
      }
    : undefined,
  provider: {
    '@type': 'Organization',
    '@id': `${siteUrl}#organization`,
    name: 'GreekHandy',
    url: siteUrl
  },
  aggregateRating: averageRatingValue !== null
    ? {
        '@type': 'AggregateRating',
        ratingValue: Number(averageRatingValue.toFixed(1)),
        reviewCount: reviewsCount,
        bestRating: 5,
        worstRating: 1
      }
    : undefined
};

const profileMetaTitle = `${profile.name} | ${profile.profession} σε ${profile.city || 'Ελλάδα'} | GreekHandy`;
const profileMetaDescription = `Επαγγελματικό προφίλ GreekHandy: ${profile.name}, ${profile.profession}${profile.city ? ` στη ${profile.city}` : ''}. Δείτε υπηρεσίες, περιοχές εξυπηρέτησης και αξιολογήσεις πελατών.`;
const query = Astro.url.searchParams;
const bookingStatusParam = (query.get('bookingStatus') || query.get('booking') || '').toLowerCase();
const reviewStatusParam = (query.get('review') || '').toLowerCase();
const messageStatusParam = (query.get('message') || '').toLowerCase();
const bookingFlash = readFormFlash(Astro.cookies, `booking:${profile.slug}`);
const reviewFlash = readFormFlash(Astro.cookies, `review:${profile.slug}`);
const messageFlash = readFormFlash(Astro.cookies, `message:${profile.slug}`);
const hasBookingFlashErrors = Boolean(bookingFlash.errors && Object.keys(bookingFlash.errors).length > 0);
const hasReviewFlashErrors = Boolean(reviewFlash.errors && Object.keys(reviewFlash.errors).length > 0);
const hasMessageFlashErrors = Boolean(messageFlash.errors && Object.keys(messageFlash.errors).length > 0);

const bookingValue = (field: string) => bookingFlash.values?.[field] || '';
const bookingError = (field: string) => bookingFlash.errors?.[field] || '';
const reviewValue = (field: string) => reviewFlash.values?.[field] || '';
const reviewError = (field: string) => reviewFlash.errors?.[field] || '';
const messageValue = (field: string) => messageFlash.values?.[field] || '';
const messageError = (field: string) => messageFlash.errors?.[field] || '';
if (bookingStatusParam === 'invalid' || bookingStatusParam === 'error') {
  clearFormFlash(Astro.cookies, `booking:${profile.slug}`);
}
if (reviewStatusParam === 'invalid' || reviewStatusParam === 'error') {
  clearFormFlash(Astro.cookies, `review:${profile.slug}`);
}
if (messageStatusParam === 'invalid' || messageStatusParam === 'error') {
  clearFormFlash(Astro.cookies, `message:${profile.slug}`);
}

const hasServerValidationErrors = (prefix: 'booking' | 'review' | 'message') => {
  if (prefix === 'booking') return hasBookingFlashErrors;
  if (prefix === 'review') return hasReviewFlashErrors;
  return hasMessageFlashErrors;
};

---

<Layout
  title={profileMetaTitle}
  description={profileMetaDescription}
  canonicalUrl={profileUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
  </Fragment>

  <main class="mx-auto max-w-4xl px-4 py-14">
    <a href="/professionals" class="text-sm font-semibold text-blue-700 hover:underline">&larr; Όλοι οι επαγγελματίες</a>

    <section class="mt-4 overflow-hidden rounded-3xl border border-blue-100 bg-gradient-to-br from-white via-blue-50/40 to-indigo-50/50 p-7 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-blue-700">{profile.profession}</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{profile.name}</h1>
      <p class="mt-2 text-slate-600">{profile.city} • {profile.experienceYears} χρόνια εμπειρίας</p>

      <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-blue-200 bg-white px-3 py-2">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-blue-700">Δημόσιες κριτικές</p>
          <p class="text-sm font-semibold text-slate-900">{reviewsCount} {reviewsLabel}</p>
        </div>
        <div class="rounded-xl border border-amber-200 bg-white px-3 py-2">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-amber-700">Βαθμολογία</p>
          <p class="text-sm font-semibold text-slate-900">{averageRating ? `${averageRating}/5` : 'Χωρίς βαθμολογία ακόμα'}</p>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-white px-3 py-2">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-emerald-700">Επιβεβαιωμένες κριτικές</p>
          <p class="text-sm font-semibold text-slate-900">{verifiedReviewsCount > 0 ? `${verifiedReviewsCount} επιβεβαιωμένες` : 'Δεν υπάρχουν επιβεβαιωμένες ακόμη'}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white px-3 py-2">
          <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-600">Περιοχές</p>
          <p class="text-sm font-semibold text-slate-900">{(profile.areasServed?.length || 0) > 0 ? `${profile.areasServed.length} περιοχές` : '1 βασική περιοχή'}</p>
        </div>
      </div>

      {hasProofTimeline && (
        <section class="mt-4 rounded-2xl border border-slate-200 bg-white/95 p-3.5 md:p-4" aria-labelledby="profile-proof-timeline-heading">
          <h2 id="profile-proof-timeline-heading" class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-700">Χρονογραμμή αξιοπιστίας</h2>
          <ul class="mt-2.5 space-y-2" role="list" aria-label="Δείκτες αξιοπιστίας προφίλ">
            {proofTimelineItems.map((item) => (
              <li class={`rounded-lg border px-3 py-2 ${item.tone}`}>
                <p class="text-[11px] font-semibold uppercase tracking-wide">{item.label}</p>
                <p class="mt-0.5 text-sm font-semibold leading-relaxed md:text-[0.95rem]">{item.value}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      {hasHeroMedia ? (
        <div class="mt-6 overflow-hidden rounded-xl border border-slate-200 bg-gradient-to-br from-slate-100 to-slate-200 aspect-[16/9]" data-prof-media-shell data-profile-hero-media>
          <img
            src={profileImageSrc}
            alt={`Φωτογραφία ${profile.name}`}
            class="h-full w-full object-cover transition-opacity duration-300"
            loading="eager"
            decoding="async"
            data-prof-media-img
            data-fallback-src={fallbackProfileImage}
            data-hero-media="1"
            onerror={`this.onerror=null;const fallback='${fallbackProfileImage}';if(this.src!==fallback){this.src=fallback;this.dataset.mediaState='fallback';}else{this.closest('[data-profile-hero-media]')?.classList.add('hidden');document.querySelector('[data-profile-hero-media-note]')?.classList.remove('hidden');}`}
          />
        </div>
      ) : null}
      <p data-profile-hero-media-note class={`mt-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 ${hasHeroMedia ? 'hidden' : ''}`}>Η φωτογραφία προφίλ δεν είναι προσωρινά διαθέσιμη. Μπορείτε να συνεχίσετε κανονικά με το κύριο αίτημα συνεργασίας.</p>

      <p class="mt-6 leading-relaxed text-gray-700">{profile.bio?.trim() || 'Ο επαγγελματίας είναι διαθέσιμος για ανάθεση υπηρεσιών στην περιοχή του προφίλ.'}</p>

      {portfolioImageSources.length === 0 && (
        <p class="mt-3 text-xs text-slate-500">Δεν υπάρχουν ακόμη φωτογραφίες portfolio για δημόσια προβολή. Η ενότητα θα εμφανιστεί αυτόματα μόλις προστεθούν έγκυρα δείγματα.</p>
      )}

      <div class="mt-6 rounded-2xl border border-blue-200 bg-white/90 p-4 shadow-sm">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-blue-700">Κύρια διαδρομή επικοινωνίας</p>
        <div class="mt-2 flex flex-wrap items-center gap-2.5">
          <a
            href="#primary-conversion"
            class="inline-flex items-center rounded-full bg-blue-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
            aria-describedby="profile-primary-cta-hint profile-primary-cta-proof"
            aria-label="Βασικό βήμα: Ζητήστε υπηρεσία"
          >
            Βήμα 1: Υποβάλετε αίτημα υπηρεσίας
          </a>
        </div>
        <p id="profile-primary-cta-hint" class="mt-2 text-xs text-slate-600">Για προσφορά ή ραντεβού, ακολουθήστε πρώτα την κύρια φόρμα αιτήματος. Οι υπόλοιπες επιλογές είναι προαιρετικές και εμφανίζονται χαμηλότερα μόνο όταν τις χρειάζεστε.</p>
        <p id="profile-primary-cta-proof" class="mt-1 text-xs text-blue-800">Η κύρια φόρμα δείχνει καθαρά τα επόμενα βήματα, ώστε να γνωρίζετε ακριβώς τι ακολουθεί μετά την αποστολή και τον έλεγχο.</p>
        <details class="mt-2 text-xs text-slate-500">
          <summary class="cursor-pointer font-semibold text-slate-700">Προαιρετικά: άλλες επιλογές επικοινωνίας</summary>
          <p class="mt-1">Αν δεν θέλετε να ξεκινήσετε με το κύριο αίτημα, μπορείτε να ανοίξετε τις
            <a href="#secondary-actions" class="font-semibold text-slate-700 underline underline-offset-2 hover:text-slate-900">δευτερεύουσες επιλογές</a>.
          </p>
        </details>
      </div>

      {portfolioImageSources.length > 0 && (
        <div class="mt-8" data-portfolio-section>
          <h2 class="text-lg font-bold text-slate-900">Portfolio</h2>
          <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2" data-portfolio-grid>
            {portfolioImageSources.map((photo, index) => (
              <figure class="aspect-[4/3] overflow-hidden rounded-xl border border-slate-200 bg-slate-100 shadow-sm" data-portfolio-frame>
                <img
                  src={photo}
                  alt={`Portfolio ${profile.name} ${index + 1}`}
                  class="h-full w-full object-cover transition-opacity duration-300"
                  loading="lazy"
                  decoding="async"
                  data-prof-media-img
                  data-fallback-src={fallbackProfileImage}
                  data-hide-on-error="1"
                  onerror="this.closest('[data-portfolio-frame]')?.classList.add('hidden');"
                />
              </figure>
            ))}
          </div>
          <p data-portfolio-empty class="mt-3 hidden text-sm text-slate-600">
            Το portfolio θα εμφανιστεί μόλις προστεθούν έγκυρες φωτογραφίες έργων.
          </p>
        </div>
      )}

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-5" aria-labelledby="profile-core-services-heading">
          <h2 id="profile-core-services-heading" class="text-base font-bold text-slate-900 md:text-lg md:uppercase md:tracking-[0.08em]">Βασικές υπηρεσίες προφίλ</h2>
          {safeServices.length > 0 ? (
            <ul class="mt-3 grid gap-1.5 md:gap-2" aria-label="Λίστα βασικών υπηρεσιών προφίλ">
              {safeServices.map((service) => (
                <li class="rounded-md border border-slate-200 bg-white px-3 py-2 text-sm leading-relaxed text-slate-700 break-words [overflow-wrap:anywhere] md:rounded-lg md:font-medium">
                  {service}
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-3 rounded-lg border border-dashed border-slate-300 bg-white px-3 py-2 text-sm text-slate-600">Δεν έχουν δηλωθεί βασικές υπηρεσίες ακόμη.</p>
          )}
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-lg font-bold text-slate-900">Περιοχές εξυπηρέτησης</h2>
          {safeAreasServed.length > 0 ? (
            <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-700">
              {safeAreasServed.map((area) => <li class="break-words">{area}</li>)}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-slate-600">Δεν έχουν δηλωθεί περιοχές εξυπηρέτησης.</p>
          )}
        </div>
      </div>

      <style>
        [data-prof-media-shell] { position: relative; }
        [data-prof-media-shell]::after { content: ""; position: absolute; inset: 0; background: linear-gradient(120deg, rgba(255,255,255,0.04), rgba(255,255,255,0.3), rgba(255,255,255,0.04)); pointer-events: none; }
        [data-prof-media-img][data-media-state="fallback"] { object-fit: cover; background: radial-gradient(circle at top right, #dbeafe, #e2e8f0 45%, #f8fafc); }
      </style>

      <div class="mt-10 flex items-center gap-3">
        <span class="h-px flex-1 bg-slate-200"></span>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Εμπειρία & Κριτικές</p>
        <span class="h-px flex-1 bg-slate-200"></span>
      </div>

      <details id="secondary-reviews" class="mt-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" data-secondary-reviews-disclosure>
        <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:hidden">
          Δευτερεύουσα επιλογή: αξιολογήσεις και υποβολή κριτικής
        </summary>
        <p class="mt-2 text-xs text-slate-600">Οι αξιολογήσεις και η φόρμα κριτικής παραμένουν διαθέσιμες εδώ χωρίς να ανταγωνίζονται το κύριο CTA.</p>
        <section
          id="reviews"
          class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 md:bg-gradient-to-b md:from-white md:via-slate-50/60 md:to-white md:p-6"
          data-review-list-root
          data-review-list-initial-state={initialReviewListState}
        >
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-bold text-gray-900">Αξιολογήσεις</h2>
            <p class="mt-1 text-xs text-gray-600">Δημόσια εμφανίζονται μόνο κριτικές που έχουν εγκριθεί. Όσες βρίσκονται σε έλεγχο ή δεν εγκρίνονται δεν επηρεάζουν τη δημόσια εικόνα.</p>
            {verifiedBadgeDisclaimer && <p class="mt-1 text-xs text-gray-500">{verifiedBadgeDisclaimer}</p>}
          </div>
          <div class="flex flex-col items-end gap-2">
            <div class="rounded-full border border-slate-200 bg-white px-4 py-1.5 text-xs font-semibold text-slate-700 shadow-sm">
              {reviewsCount} {reviewsLabel}
            </div>
            <p
              data-review-list-status
              data-base-class="inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-semibold"
              class={`inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-semibold ${initialReviewListStatusTone}`}
            >
              Κατάσταση λίστας:
              <span data-review-list-status-label class="ml-1">{reviewListStateLabels[initialReviewListState]}</span>
            </p>
            <div class="hidden max-w-xs text-right md:block">
              <p data-review-list-trust class="text-[11px] text-slate-600">{initialReviewListTrustCopy.reliability}</p>
              <p data-review-list-expectation class="mt-0.5 text-[11px] text-slate-500">{initialReviewListTrustCopy.expectation}</p>
            </div>
          </div>
        </div>

        {!hasApprovedReviewsError && reviewsCount > 0 && (
          <div class="mt-5 grid gap-4 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,1fr)]">
            <article class="rounded-2xl border border-amber-200 bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-amber-700">Μέση βαθμολογία</p>
              <div class="mt-3 flex items-end gap-2">
                <p class="text-5xl font-bold leading-none text-amber-800">{averageRating}</p>
                <p class="pb-1 text-sm font-semibold text-amber-700">/5</p>
              </div>
              <p class="mt-2 text-base font-semibold text-amber-700">{averageRatingStars}</p>
              {averageRatingSummary && <p class="mt-3 text-sm text-slate-700">{averageRatingSummary}</p>}
              <p class="mt-2 text-xs text-slate-500">Η αξιολόγηση βασίζεται μόνο σε κριτικές που έχουν εγκριθεί για δημόσια προβολή.</p>

              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="text-xs text-slate-500">Σύνολο</p>
                  <p class="text-sm font-semibold text-slate-900">{reviewsCount} {reviewsLabel}</p>
                </div>
                <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2">
                  <p class="text-xs text-emerald-700">Θετικές</p>
                  <p class="text-sm font-semibold text-emerald-900">{recommendationRate}% (4★+)</p>
                </div>
                <div class="rounded-xl border border-blue-200 bg-blue-50 px-3 py-2">
                  <p class="text-xs text-blue-700">Επιβεβαιωμένες</p>
                  <p class="text-sm font-semibold text-blue-900">{verifiedReviewsCount}</p>
                </div>
              </div>

              {recentApprovedReviewDate && <p class="mt-4 text-xs text-slate-500">Τελευταία δημοσίευση: {recentApprovedReviewDate}</p>}
            </article>

            <article class="hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm md:block">
              <p class="text-sm font-semibold text-slate-900">Κατανομή βαθμολογιών</p>
              <div class="mt-4 space-y-2.5">
                {ratingDistribution.map((row) => (
                  <div class="flex items-center gap-3 text-xs text-slate-700">
                    <span class="w-10 font-semibold">{row.star}★</span>
                    <div class="h-2.5 flex-1 overflow-hidden rounded-full bg-slate-200">
                      <div class="h-full rounded-full bg-gradient-to-r from-amber-300 to-amber-500" style={`width: ${row.percentage}%`}></div>
                    </div>
                    <span class="w-20 text-right">{row.count} ({row.percentage}%)</span>
                  </div>
                ))}
              </div>
            </article>
          </div>
        )}

        <div data-review-loading-shell class="mt-5 hidden rounded-2xl border border-blue-200 bg-blue-50/80 p-4 text-blue-900" role="status" aria-live="polite">
          <div class="flex items-center gap-3">
            <span class="inline-block h-5 w-5 animate-spin rounded-full border-2 border-blue-300 border-t-blue-700"></span>
            <div>
              <p class="text-sm font-semibold">Φόρτωση λίστας κριτικών...</p>
              <p class="text-xs text-blue-800">Ελέγχουμε τις πιο πρόσφατες εγκεκριμένες κριτικές για αξιόπιστη εμφάνιση.</p>
            </div>
          </div>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div class="h-20 animate-pulse rounded-xl bg-white/90"></div>
            <div class="h-20 animate-pulse rounded-xl bg-white/90"></div>
          </div>
        </div>

        <div data-review-content class="mt-5">
          {hasApprovedReviewsError && (
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700" role="status" aria-live="polite">
              <p class="font-semibold">Οι κριτικές δεν είναι προσωρινά διαθέσιμες.</p>
              <p class="mt-1">Η αξιοπιστία βαθμολογίας δεν μπορεί να υπολογιστεί αυτή τη στιγμή λόγω προσωρινού σφάλματος φόρτωσης.</p>
              <p class="mt-1 text-xs text-slate-500">Η ενότητα προφίλ παραμένει κανονικά διαθέσιμη και μπορείτε να δοκιμάσετε ξανά.</p>
              <a href={reviewReloadHref} class="mt-3 inline-flex rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">
                Ανανέωση ενότητας
              </a>
            </div>
          )}

          {!hasApprovedReviewsError && reviewsCount === 0 && (
            <div class="rounded-2xl border border-dashed border-blue-200 bg-gradient-to-br from-blue-50 to-sky-50 px-5 py-6 text-sm text-blue-900" role="status" aria-live="polite">
              <p class="font-semibold">Δεν υπάρχουν ακόμη δημοσιευμένες αξιολογήσεις. Η πρώτη εγκεκριμένη αξιολόγηση θα εμφανιστεί αυτόματα εδώ.</p>
              <p class="mt-1 text-blue-800">Δεν υπάρχει ακόμη δείγμα δημοσιευμένων αξιολογήσεων για στατιστική σύνοψη.</p>
              <p class="mt-1 text-xs text-blue-700">Τι να περιμένετε: οι νέες κριτικές εμφανίζονται μετά τον απαραίτητο έλεγχο και τότε ενημερώνεται αυτόματα η σύνοψη.</p>
              <a href="#submit-review" class="mt-3 inline-flex rounded-md bg-blue-700 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-800">
                Γράψτε κριτική
              </a>
            </div>
          )}

          {!hasApprovedReviewsError && highlightedReviews.length > 0 && (
            <div class="grid gap-4 md:grid-cols-2">
              {highlightedReviews.map((review) => (
                <article class="group relative overflow-hidden rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition duration-200 md:rounded-2xl md:p-5 md:hover:-translate-y-0.5 md:hover:shadow-md">
                  <div class="pointer-events-none absolute inset-x-0 top-0 hidden h-1 bg-gradient-to-r from-rose-200 via-amber-300 to-emerald-300 md:block"></div>
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <p class="text-sm font-semibold text-slate-900">{review.reviewerName}</p>
                      <p class="mt-1 text-sm font-semibold text-amber-700">{renderStarRating(review.rating)} <span class="text-xs font-medium text-slate-500">({review.rating}.0/5)</span></p>
                    </div>
                    {review.verified && (
                      <span
                        class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-0.5 text-[11px] font-semibold text-emerald-800"
                        title={verifiedBadgeTooltip}
                      >
                        ✓ {verifiedBadgeLabel}
                      </span>
                    )}
                  </div>
                  <p class="mt-3 text-sm leading-relaxed text-slate-700">{review.comment}</p>
                  <p class="mt-4 text-xs text-slate-500">{formatReviewDate(review.submittedAt)} • Δημοσιεύτηκε μετά από έγκριση</p>
                </article>
              ))}
            </div>
          )}
        </div>

        <form
          action="/api/reviews/submit"
          method="POST"
          class="mt-6 rounded-xl border border-blue-100 bg-blue-50 p-4"
          data-review-form
          data-pending-form
          data-feedback-group-name="review"
          data-pending-live-label="Η υποβολή κριτικής εκτελείται."
          data-pending-timeout-label="Η υποβολή κριτικής καθυστέρησε. Ελέγξτε τη σύνδεση και δοκιμάστε ξανά."
          data-pending-timeout-ms="18000"
          id="submit-review"
          aria-describedby="review-feedback submit-feedback-live profile-offline-alert"
        >
          <h3 class="text-base font-bold text-gray-900">Υποβολή κριτικής</h3>
          <p class="mt-1 text-xs text-gray-600">Οι κριτικές ελέγχονται και γίνονται δημόσιες μόνο μετά από έγκριση.</p>

          <div class="mt-3 space-y-2" data-feedback-group="review" id="review-feedback" role="status" aria-live="polite" aria-atomic="true">
            <p data-feedback-status="loading" class="hidden rounded-md border border-blue-200 bg-white px-3 py-2 text-sm text-blue-800">
              <span class="inline-flex items-center gap-2">
                <svg class="h-4 w-4 animate-spin text-blue-700" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" class="opacity-25" stroke="currentColor" stroke-width="3"></circle>
                  <path d="M21 12a9 9 0 0 0-9-9" class="opacity-90" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
                </svg>
                Υποβολή κριτικής...
              </span>
            </p>
            <p data-feedback-status="pending" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Ευχαριστούμε! Η κριτική σας καταχωρήθηκε και εξετάζεται πριν τη δημόσια εμφάνιση.</p>
            <p data-feedback-status="approved" class="hidden rounded-md bg-emerald-100 px-3 py-2 text-sm text-emerald-800">Η κριτική σας είναι πλέον δημόσια και υπολογίζεται στη συνολική εικόνα.</p>
            <p data-feedback-status="rejected" class="hidden rounded-md bg-slate-100 px-3 py-2 text-sm text-slate-800">Η κριτική δεν δημοσιεύτηκε. Μπορείτε να υποβάλετε νέα, πιο συγκεκριμένη εμπειρία.</p>
            <p data-feedback-status="offline" class="hidden rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">Δεν υπάρχει σύνδεση. Η υποβολή κριτικής είναι προσωρινά ανενεργή.</p>
            <p data-feedback-status="invalid" class={`${reviewStatusParam === 'invalid' ? '' : 'hidden'} rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800`}>Διορθώστε τα επισημασμένα πεδία για να συνεχίσετε.</p>
            <p data-feedback-status="error" class={`${reviewStatusParam === 'error' ? '' : 'hidden'} rounded-md bg-red-100 px-3 py-2 text-sm text-red-800`}>Παρουσιάστηκε προσωρινό πρόβλημα υποβολής. Δοκιμάστε ξανά σε λίγο.</p>
          </div>

          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}#submit-review`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <div>
              <label for="reviewerName" class="mb-1 block text-sm font-semibold text-gray-800">Όνομα</label>
              <input id="reviewerName" name="reviewerName" type="text" maxlength="80" value={reviewValue('reviewerName')} aria-invalid={reviewError('reviewerName') ? 'true' : undefined} class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              {reviewError('reviewerName') && <p class="mt-1 text-xs text-amber-700" role="alert">{reviewError('reviewerName')}</p>}
            </div>
            <div>
              <label for="reviewerEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email (προαιρετικό)</label>
              <input id="reviewerEmail" name="reviewerEmail" type="email" maxlength="160" value={reviewValue('reviewerEmail')} aria-invalid={reviewError('reviewerEmail') ? 'true' : undefined} class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              {reviewError('reviewerEmail') && <p class="mt-1 text-xs text-amber-700" role="alert">{reviewError('reviewerEmail')}</p>}
            </div>
            <div class="md:col-span-2">
              <label for="rating" class="mb-1 block text-sm font-semibold text-gray-800">Βαθμολογία (1-5) *</label>
              <select id="rating" name="rating" required aria-invalid={reviewError('rating') ? 'true' : undefined} class="w-full rounded-lg border border-gray-300 px-3 py-2.5">
                <option value="" selected={reviewValue('rating') === ''}>Επιλέξτε</option>
                <option value="5" selected={reviewValue('rating') === '5'}>5 - Εξαιρετικά</option>
                <option value="4" selected={reviewValue('rating') === '4'}>4 - Πολύ καλά</option>
                <option value="3" selected={reviewValue('rating') === '3'}>3 - Καλά</option>
                <option value="2" selected={reviewValue('rating') === '2'}>2 - Μέτρια</option>
                <option value="1" selected={reviewValue('rating') === '1'}>1 - Χρειάζεται βελτίωση</option>
              </select>
              {reviewError('rating') && <p class="mt-1 text-xs text-amber-700" role="alert">{reviewError('rating')}</p>}
            </div>
          </div>

          <div class="mt-4">
            <label for="comment" class="mb-1 block text-sm font-semibold text-gray-800">Σχόλιο *</label>
            <textarea id="comment" name="comment" rows="4" required maxlength="1200" data-trim-required class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>

          <button
            type="submit"
            class="mt-4 rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:cursor-not-allowed disabled:opacity-70"
            data-review-submit-button
            data-default-label="Αποστολή κριτικής"
            data-pending-label="Αποστολή..."
          >
            Αποστολή κριτικής
          </button>
        </form>
        </section>
      </details>

      <div id="primary-conversion" class="mt-10 flex items-center gap-3">
        <span class="h-px flex-1 bg-slate-200"></span>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">Αίτημα Υπηρεσίας</p>
        <span class="h-px flex-1 bg-slate-200"></span>
      </div>

      <section data-gh-widget-avoid class="mt-4 rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 to-white p-5 md:p-6" role="region" aria-labelledby="primary-cta-heading">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-blue-700">Προτεραιότητα 1</p>
            <h2 id="primary-cta-heading" class="text-lg font-bold text-gray-900">Κύριο αίτημα συνεργασίας</h2>
            <p class="mt-1 text-sm text-gray-600">Συμπληρώστε μία φόρμα για προσφορά ή ραντεβού. Θα λάβετε ενημέρωση για την πορεία του αιτήματος.</p>
            <p class="mt-1 text-xs text-slate-600">Για ταχύτερη εξυπηρέτηση, ξεκινήστε από αυτή τη φόρμα και χρησιμοποιήστε τις δευτερεύουσες επιλογές μόνο αν χρειάζεται.</p>
          </div>
        </div>
        <p class="mt-3 rounded-lg border border-blue-200 bg-white px-3 py-2 text-xs text-blue-800">Η πορεία του αιτήματος ενημερώνεται σταδιακά: πρώτα σε αναμονή και έπειτα ολοκληρώνεται με τελική απόφαση.</p>

        <div class="mt-3 space-y-2" data-feedback-group="booking" id="booking-feedback" role="status" aria-live="polite" aria-atomic="true" aria-relevant="additions text">
          <p data-feedback-status="loading" class="hidden rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-sm text-blue-800">
            <span class="inline-flex items-center gap-2">
              <svg class="h-4 w-4 animate-spin text-blue-700" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="9" class="opacity-25" stroke="currentColor" stroke-width="3"></circle>
                <path d="M21 12a9 9 0 0 0-9-9" class="opacity-90" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
              </svg>
              Η υποβολή του αιτήματος κράτησης είναι σε εξέλιξη...
            </span>
          </p>
          <p data-feedback-status="submitted" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Το αίτημά σας καταχωρήθηκε και προωθήθηκε για έλεγχο. Θα ενημερωθείτε μόλις υπάρξει εξέλιξη.</p>
          <p data-feedback-status="offline" class="hidden rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
            Δεν υπάρχει σύνδεση. Μόλις επανέλθει το δίκτυο, επιλέξτε νέα προσπάθεια.
            <button type="button" data-feedback-retry="booking" class="ml-2 inline-flex rounded-md border border-amber-300 bg-white px-2 py-0.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100">Νέα προσπάθεια</button>
          </p>
          <p data-feedback-status="invalid" class={`${bookingStatusParam === 'invalid' ? '' : 'hidden'} rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800`}>Ελέγξτε στοιχεία επικοινωνίας, προτιμώμενη ημέρα/ώρα και λεπτομέρειες αιτήματος, και υποβάλετε ξανά.</p>
          <p data-feedback-status="error" class={`${bookingStatusParam === 'error' ? '' : 'hidden'} rounded-md bg-red-100 px-3 py-2 text-sm text-red-800`}>
            Η αποστολή δεν ολοκληρώθηκε. Τα στοιχεία σας παραμένουν στη φόρμα για άμεση επανάληψη.
            <button type="button" data-feedback-retry="booking" class="ml-2 inline-flex rounded-md border border-red-300 bg-white px-2 py-0.5 text-xs font-semibold text-red-900 transition hover:bg-red-100">Νέα προσπάθεια</button>
          </p>
        </div>

        <form
          action="/api/bookings/submit"
          method="POST"
          class="mt-4"
          data-pending-form
          data-booking-form
          data-booking-draft-key={`booking-draft:${profile.slug}`}
          data-feedback-group-name="booking"
          data-pending-live-label="Η υποβολή του αιτήματος κράτησης είναι σε εξέλιξη."
          data-pending-timeout-label="Η υποβολή καθυστέρησε. Ελέγξτε σύνδεση και χρησιμοποιήστε νέα προσπάθεια."
          data-pending-timeout-ms="18000"
          aria-describedby="booking-feedback submit-feedback-live profile-offline-alert"
        >
          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}#primary-conversion`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="bookingService" class="mb-1 block text-sm font-semibold text-gray-800">Υπηρεσία *</label>
              <select id="bookingService" name="service" required data-booking-validate="service" data-field-input="service" class="w-full rounded-lg border border-gray-300 px-3 py-2.5">
                <option value="">Επιλέξτε υπηρεσία</option>
                {safeServices.length > 0
                  ? safeServices.map((service) => <option value={service}>{service}</option>)
                  : <option value={profile.profession}>{profile.profession}</option>}
              </select>
              <p id="bookingService-error" data-field-error-for="service" data-default-error="Επιλέξτε υπηρεσία." class="mt-1 hidden text-xs text-amber-700" role="alert">Επιλέξτε υπηρεσία.</p>
            </div>
            <div>
              <label for="customerName" class="mb-1 block text-sm font-semibold text-gray-800">Ονοματεπώνυμο *</label>
              <input id="customerName" name="customerName" required maxlength="120" data-booking-validate="name" data-field-input="customerName" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="customerName-error" data-field-error-for="customerName" data-default-error="Συμπληρώστε έγκυρο ονοματεπώνυμο (τουλάχιστον 2 χαρακτήρες)." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε έγκυρο ονοματεπώνυμο (τουλάχιστον 2 χαρακτήρες).</p>
            </div>
            <div>
              <label for="bookingPhone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο *</label>
              <input id="bookingPhone" name="phone" required maxlength="40" pattern="[0-9+()\-\s]{7,20}" title="Συμπληρώστε έγκυρο τηλέφωνο (7-20 χαρακτήρες)." data-booking-validate="phone" data-field-input="phone" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="bookingPhone-error" data-field-error-for="phone" data-default-error="Το τηλέφωνο πρέπει να έχει 7–20 χαρακτήρες (ψηφία ή σύμβολα +()-)." class="mt-1 hidden text-xs text-amber-700" role="alert">Το τηλέφωνο πρέπει να έχει 7–20 χαρακτήρες (ψηφία ή σύμβολα +()-).</p>
            </div>
            <div>
              <label for="bookingEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email *</label>
              <input id="bookingEmail" name="email" type="email" required maxlength="160" data-booking-validate="email" data-field-input="email" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="bookingEmail-error" data-field-error-for="email" data-default-error="Συμπληρώστε έγκυρη διεύθυνση email." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε έγκυρη διεύθυνση email.</p>
            </div>
            <div class="md:col-span-2">
              <label for="preferredDate" class="mb-1 block text-sm font-semibold text-gray-800">Προτιμώμενο πρόγραμμα (ημερομηνία/ώρα)</label>
              <input id="preferredDate" name="preferredDate" type="text" maxlength="80" placeholder="π.χ. 12/03 απόγευμα ή Σάββατο πρωί" data-booking-validate="preferredDate" data-field-input="preferredDate" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="preferredDate-error" data-field-error-for="preferredDate" data-default-error="Προσθέστε σαφή ημέρα/ώρα (π.χ. 12/03 πρωί ή Τρίτη 18:00)." class="mt-1 hidden text-xs text-amber-700" role="alert">Προσθέστε σαφή ημέρα/ώρα (π.χ. 12/03 πρωί ή Τρίτη 18:00).</p>
            </div>
          </div>

          <div class="mt-4">
            <label for="bookingMessage" class="mb-1 block text-sm font-semibold text-gray-800">Λεπτομέρειες αιτήματος *</label>
            <textarea id="bookingMessage" name="message" rows="4" required maxlength="2000" data-trim-required data-booking-validate="message" data-field-input="message" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
            <p id="bookingMessage-error" data-field-error-for="message" data-default-error="Συμπληρώστε λεπτομέρειες για το αίτημά σας." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε λεπτομέρειες για το αίτημά σας.</p>
          </div>

          <p class="mt-2 text-xs text-blue-700">Η πορεία του αιτήματος ενημερώνεται βήμα-βήμα: αρχική καταχώριση, έλεγχος και τελική ενημέρωση.</p>
          <p class="mt-1 hidden text-xs text-slate-600" data-booking-validation-summary aria-live="polite">Συμπληρώστε στοιχεία επικοινωνίας και προτιμώμενο πρόγραμμα για ταχύτερη ανάθεση. Αν υπάρχει σφάλμα, διορθώστε και ξαναδοκιμάστε χωρίς απώλεια στοιχείων.</p>
          <p class="mt-1 text-xs text-slate-700" data-booking-step-state aria-live="polite">{bookingStatusParam === 'submitted' ? 'Βήμα 3/3: Η καταχώριση ολοκληρώθηκε επιτυχώς.' : bookingStatusParam === 'invalid' ? 'Βήμα 2/3: Διορθώστε τα επισημασμένα πεδία και ξαναδοκιμάστε.' : bookingStatusParam === 'error' ? 'Βήμα 2/3: Προσωρινό πρόβλημα αποστολής. Πατήστε «Νέα προσπάθεια».' : 'Βήμα 1/3: Συμπληρώστε τα στοιχεία και συνεχίστε.'}</p>

          <button type="submit" class="mt-4 rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:cursor-not-allowed disabled:opacity-70" data-default-label="Αποστολή αιτήματος" data-pending-label="Υποβολή...">Αποστολή αιτήματος</button>
        </form>
      </section>

      <details id="secondary-actions" class="group mt-5 rounded-2xl border border-slate-200 bg-white p-4 md:p-5" data-secondary-actions-disclosure role="region" aria-label="Δευτερεύουσες επιλογές επικοινωνίας">
        <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:hidden">
          Δευτερεύουσες επιλογές (μόνο αν τις χρειάζεστε)
        </summary>
        <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3" role="note" aria-live="polite">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600">Προτεραιότητα 2-3</p>
          <p class="mt-1 text-sm text-slate-700">Η κύρια διαδρομή είναι το αίτημα συνεργασίας: υποβολή → επιβεβαίωση → απάντηση. Οι εναλλακτικές επιλογές εμφανίζονται μόνο για σύντομη διευκρίνιση ή άμεση επαφή.</p>
        </div>
        <div class="mt-3 flex flex-wrap gap-2" role="tablist" aria-label="Εναλλακτικές ενέργειες επικοινωνίας">
          <button type="button" role="tab" aria-selected="true" aria-controls="secondary-message-panel" id="secondary-tab-message" data-secondary-tab-target="message" class="rounded-full border border-indigo-200 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-800">Μήνυμα</button>
          <button type="button" role="tab" aria-selected="false" aria-controls="secondary-contact-panel" id="secondary-tab-contact" data-secondary-tab-target="contact" class="rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700">Στοιχεία επικοινωνίας</button>
        </div>
        <div class="mt-3 space-y-3">
        <details id="secondary-message-panel" class="group rounded-xl border border-indigo-100 bg-indigo-50/70 p-5" data-secondary-message-disclosure data-secondary-panel="message" role="region" aria-label="Δευτερεύουσα επιλογή μηνύματος">
          <summary class="cursor-pointer list-none text-sm font-semibold text-indigo-900 marker:hidden">
            Προαιρετικά: σύντομη συζήτηση με μήνυμα
          </summary>
          <p class="mt-2 text-sm text-indigo-800">Χρησιμοποιήστε τη συνομιλία όταν θέλετε πρώτα σύντομη διευκρίνιση πριν από πλήρες αίτημα.</p>

          <div class="mt-3 space-y-2" data-feedback-group="message" id="message-feedback" role="status" aria-live="polite" aria-atomic="true" aria-relevant="additions text">
          <p data-feedback-status="loading" class="hidden rounded-md border border-indigo-200 bg-indigo-50 px-3 py-2 text-sm text-indigo-800">
            <span class="inline-flex items-center gap-2">
              <svg class="h-4 w-4 animate-spin text-indigo-700" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="9" class="opacity-25" stroke="currentColor" stroke-width="3"></circle>
                <path d="M21 12a9 9 0 0 0-9-9" class="opacity-90" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
              </svg>
              Η αποστολή του μηνύματος είναι σε εξέλιξη...
            </span>
          </p>
          <p data-feedback-status="submitted" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Το μήνυμά σας στάλθηκε επιτυχώς. Μπορείτε να συνεχίσετε από τη σελίδα συνομιλίας.</p>
          <p data-feedback-status="offline" class="hidden rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
            Δεν υπάρχει σύνδεση. Μόλις επανέλθει το δίκτυο, επιλέξτε νέα προσπάθεια.
            <button type="button" data-feedback-retry="message" class="ml-2 inline-flex rounded-md border border-amber-300 bg-white px-2 py-0.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100">Νέα προσπάθεια</button>
          </p>
          <p data-feedback-status="invalid" class={`${messageStatusParam === 'invalid' ? '' : 'hidden'} rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800`}>Ελέγξτε τα πεδία επικοινωνίας και το μήνυμα, και υποβάλετε ξανά.</p>
          <p data-feedback-status="blocked" class={`${messageStatusParam === 'blocked' ? '' : 'hidden'} rounded-md bg-red-100 px-3 py-2 text-sm text-red-800`}>Η συγκεκριμένη συνομιλία δεν είναι διαθέσιμη αυτή τη στιγμή.</p>
          <p data-feedback-status="error" class={`${messageStatusParam === 'error' ? '' : 'hidden'} rounded-md bg-red-100 px-3 py-2 text-sm text-red-800`}>
            Η αποστολή δεν ολοκληρώθηκε. Το κείμενό σας παραμένει στη φόρμα για άμεση επανάληψη.
            <button type="button" data-feedback-retry="message" class="ml-2 inline-flex rounded-md border border-red-300 bg-white px-2 py-0.5 text-xs font-semibold text-red-900 transition hover:bg-red-100">Νέα προσπάθεια</button>
          </p>
        </div>

          <form
            action="/api/messages/submit"
            method="POST"
            class="mt-4"
            data-pending-form
            data-message-form
            data-feedback-group-name="message"
            data-pending-live-label="Η υποβολή του μηνύματος είναι σε εξέλιξη."
            data-pending-timeout-label="Η υποβολή καθυστέρησε. Ελέγξτε σύνδεση και χρησιμοποιήστε νέα προσπάθεια."
            data-pending-timeout-ms="18000"
            aria-describedby="message-feedback message-moderation-hint submit-feedback-live profile-offline-alert"
          >
          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="recipientEmail" value={profile.email} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}#secondary-message-panel`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="senderName" class="mb-1 block text-sm font-semibold text-gray-800">Ονοματεπώνυμο *</label>
              <input id="senderName" name="senderName" required maxlength="120" data-message-validate="senderName" data-field-input="senderName" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="senderName-error" data-field-error-for="senderName" data-default-error="Συμπληρώστε έγκυρο ονοματεπώνυμο." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε έγκυρο ονοματεπώνυμο.</p>
            </div>
            <div>
              <label for="senderEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email *</label>
              <input id="senderEmail" name="senderEmail" type="email" required maxlength="160" data-message-validate="senderEmail" data-field-input="senderEmail" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
              <p id="senderEmail-error" data-field-error-for="senderEmail" data-default-error="Συμπληρώστε έγκυρη διεύθυνση email." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε έγκυρη διεύθυνση email.</p>
            </div>
          </div>

          <div class="mt-4">
            <label for="senderPhone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο (προαιρετικό)</label>
            <input id="senderPhone" name="senderPhone" maxlength="40" pattern="[0-9+()\-\s]{7,20}" title="Αν συμπληρωθεί, το τηλέφωνο πρέπει να έχει 7-20 χαρακτήρες." data-message-validate="senderPhone" data-field-input="senderPhone" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            <p id="senderPhone-error" data-field-error-for="senderPhone" data-default-error="Αν συμπληρωθεί, το τηλέφωνο πρέπει να έχει 7–20 χαρακτήρες." class="mt-1 hidden text-xs text-amber-700" role="alert">Αν συμπληρωθεί, το τηλέφωνο πρέπει να έχει 7–20 χαρακτήρες.</p>
          </div>

          <div class="mt-4">
            <label for="initialMessage" class="mb-1 block text-sm font-semibold text-gray-800">Μήνυμα *</label>
            <textarea id="initialMessage" name="message" rows="4" required maxlength="2000" data-trim-required data-message-validate="message" data-field-input="message" aria-describedby="message-moderation-hint submit-feedback-live" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
            <p id="initialMessage-error" data-field-error-for="message" data-default-error="Συμπληρώστε μήνυμα." class="mt-1 hidden text-xs text-amber-700" role="alert">Συμπληρώστε μήνυμα.</p>
          </div>
          <p id="message-moderation-hint" class="mt-2 text-xs text-indigo-800">Το μήνυμα ελέγχεται για ασφαλή επικοινωνία και προωθείται στον επαγγελματία.</p>

            <button type="submit" class="mt-4 rounded-lg bg-indigo-700 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-800 disabled:cursor-not-allowed disabled:opacity-70" data-default-label="Αποστολή μηνύματος" data-pending-label="Υποβολή...">Αποστολή μηνύματος</button>
          </form>
        </details>

        <details id="secondary-contact-panel" class="group rounded-xl border border-slate-200 bg-slate-50/80 p-5" data-secondary-contact-disclosure data-secondary-panel="contact" role="region" aria-label="Δευτερεύουσα επιλογή στοιχείων επικοινωνίας">
          <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:hidden">
            Προαιρετικά: στοιχεία άμεσης επικοινωνίας
          </summary>
          <div class="mt-3 rounded-xl border border-slate-200 bg-white p-4">
            <p class="text-slate-700">Τηλέφωνο: <a href={`tel:${profile.phone}`} class="font-semibold text-blue-700">{profile.phone}</a></p>
            <p class="mt-1 text-slate-700">Email: <a href={`mailto:${profile.email}`} class="font-semibold text-blue-700">{profile.email}</a></p>
            <p class="mt-2 text-xs text-slate-500">Για ταχύτερη επεξεργασία προτιμήστε το κύριο αίτημα συνεργασίας.</p>
          </div>
        </details>
        </div>
      </details>
      <div id="profile-offline-alert" class="mt-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert" aria-live="assertive" aria-atomic="true">
        <p class="font-semibold">Εντοπίστηκε απώλεια σύνδεσης.</p>
        <p class="mt-1 text-xs">Οι υποβολές κριτικής/αιτήματος/μηνύματος μπλοκάρονται προσωρινά μέχρι να επανέλθει το δίκτυο.</p>
      </div>
      <p id="submit-feedback-live" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
    </section>

    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const feedbackStatuses = {
          review: ['loading', 'pending', 'approved', 'rejected', 'offline', 'invalid', 'error'],
          booking: ['loading', 'submitted', 'offline', 'invalid', 'error'],
          message: ['loading', 'submitted', 'offline', 'invalid', 'blocked', 'error']
        };
        const feedbackStatusAliases = {
          review: { submitted: 'pending' }
        };
        const submitLiveRegion = document.querySelector('#submit-feedback-live');
        const profileOfflineAlert = document.querySelector('#profile-offline-alert');
        const secondaryActionsDisclosure = document.querySelector('[data-secondary-actions-disclosure]');
        const secondaryReviewsDisclosure = document.querySelector('[data-secondary-reviews-disclosure]');
        const secondaryMessageDisclosure = document.querySelector('[data-secondary-message-disclosure]');
        const secondaryContactDisclosure = document.querySelector('[data-secondary-contact-disclosure]');
        const secondaryTabButtons = Array.from(document.querySelectorAll('[data-secondary-tab-target]'));
        const primaryBookingForm = document.querySelector('[data-booking-form]');
        const profileMediaImages = Array.from(document.querySelectorAll('[data-prof-media-img]')).filter((item) => item instanceof HTMLImageElement);
        const portfolioSection = document.querySelector('[data-portfolio-section]');
        const portfolioGrid = document.querySelector('[data-portfolio-grid]');
        const portfolioEmpty = document.querySelector('[data-portfolio-empty]');
        const syncPortfolioState = () => {
          if (!(portfolioGrid instanceof HTMLElement) || !(portfolioEmpty instanceof HTMLElement)) return;
          const frames = Array.from(portfolioGrid.querySelectorAll('[data-portfolio-frame]')).filter((item) => item instanceof HTMLElement);
          const visibleFrames = frames.filter((frame) => !frame.classList.contains('hidden'));
          const shouldShowEmpty = visibleFrames.length === 0;
          portfolioGrid.classList.toggle('hidden', shouldShowEmpty);
          portfolioEmpty.classList.toggle('hidden', !shouldShowEmpty);
          if (portfolioSection instanceof HTMLElement) portfolioSection.classList.toggle('hidden', shouldShowEmpty);
        };

        const pendingForms = Array.from(document.querySelectorAll('[data-pending-form]')).filter((form) => form instanceof HTMLFormElement);
        const pendingTimeouts = new WeakMap();
        const bookingValidationTimers = new WeakMap();
        const isOffline = () => typeof navigator !== 'undefined' && navigator.onLine === false;
        const hardenProfileMedia = () => {
          for (const img of profileMediaImages) {
            if (!(img instanceof HTMLImageElement)) continue;
            const fallbackSrc = img.dataset.fallbackSrc || '';
            const hideHeroMediaContainer = () => {
              if (img.dataset.heroMedia !== '1') return;
              img.closest('[data-profile-hero-media]')?.classList.add('hidden');
              const heroMediaNote = document.querySelector('[data-profile-hero-media-note]');
              if (heroMediaNote instanceof HTMLElement) heroMediaNote.classList.remove('hidden');
            };
            const ensureFallback = () => {
              if (img.dataset.hideOnError === '1') {
                img.closest('[data-portfolio-frame]')?.classList.add('hidden');
                syncPortfolioState();
                return;
              }
              if (!fallbackSrc) {
                hideHeroMediaContainer();
                return;
              }
              if (img.src === fallbackSrc) {
                hideHeroMediaContainer();
                return;
              }
              img.dataset.mediaState = 'fallback';
              const mediaShell = img.closest('[data-prof-media-shell]');
              if (mediaShell instanceof HTMLElement) mediaShell.dataset.mediaShell = 'fallback';
              img.src = fallbackSrc;
            };
            img.addEventListener('error', () => { ensureFallback(); syncPortfolioState(); });
            if (img.complete && (!img.naturalWidth || !img.naturalHeight)) ensureFallback();
          }
        };
        hardenProfileMedia();
        syncPortfolioState();

        const getSessionFlag = (key) => {
          try {
            return window.sessionStorage.getItem(key);
          } catch {
            return null;
          }
        };
        const setSessionFlag = (key, value) => {
          try {
            window.sessionStorage.setItem(key, value);
          } catch {
            // Ignore storage failures (private mode / blocked storage) to keep UX functional.
          }
        };
        const feedbackInteractionFlagKeys = {
          review: 'profile-feedback-review-interacted',
          booking: 'profile-feedback-booking-interacted',
          message: 'profile-feedback-message-interacted'
        };
        const hasFeedbackInteraction = (groupName) => {
          const key = feedbackInteractionFlagKeys[groupName];
          if (!key) return false;
          return getSessionFlag(key) === '1';
        };
        const markFeedbackInteraction = (groupName) => {
          const key = feedbackInteractionFlagKeys[groupName];
          if (!key) return;
          setSessionFlag(key, '1');
          if (groupName === 'review') {
            // Keep compatibility with previous storage key to avoid regressions for ongoing sessions.
            setSessionFlag('review-submit-attempted', '1');
          }
        };
        const clearPendingTimeout = (form) => {
          const timer = pendingTimeouts.get(form);
          if (typeof timer === 'number') {
            window.clearTimeout(timer);
          }
          pendingTimeouts.delete(form);
        };
        const announceSubmitState = (message, politeness = 'polite') => {
          if (!(submitLiveRegion instanceof HTMLElement)) return;
          submitLiveRegion.setAttribute('role', politeness === 'assertive' ? 'alert' : 'status');
          submitLiveRegion.setAttribute('aria-live', politeness === 'assertive' ? 'assertive' : 'polite');
          submitLiveRegion.textContent = message;
        };
        const collapseSecondaryActions = () => {
          if (secondaryActionsDisclosure instanceof HTMLDetailsElement) {
            secondaryActionsDisclosure.open = false;
          }
          if (secondaryReviewsDisclosure instanceof HTMLDetailsElement) {
            secondaryReviewsDisclosure.open = false;
          }
          if (secondaryMessageDisclosure instanceof HTMLDetailsElement) {
            secondaryMessageDisclosure.open = false;
          }
          if (secondaryContactDisclosure instanceof HTMLDetailsElement) {
            secondaryContactDisclosure.open = false;
          }
        };
        const syncOfflineSubmitAvailability = () => {
          const offline = isOffline();
          for (const form of pendingForms) {
            const submitButton = form.querySelector('button[type="submit"]');
            if (!(submitButton instanceof HTMLButtonElement)) continue;
            if (form.getAttribute('aria-busy') === 'true') continue;
            if (offline) {
              submitButton.setAttribute('data-offline-disabled', submitButton.disabled ? 'true' : 'false');
              submitButton.disabled = true;
              submitButton.setAttribute('aria-disabled', 'true');
              continue;
            }
            const wasDisabled = submitButton.getAttribute('data-offline-disabled') === 'true';
            submitButton.removeAttribute('data-offline-disabled');
            submitButton.disabled = wasDisabled;
            if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
          }
        };
        const syncOfflineAlert = () => {
          const offline = isOffline();
          if (profileOfflineAlert instanceof HTMLElement) {
            profileOfflineAlert.classList.toggle('hidden', !offline);
          }
          syncOfflineSubmitAvailability();
          if (!offline) {
            if (
              submitLiveRegion instanceof HTMLElement
              && typeof submitLiveRegion.textContent === 'string'
              && submitLiveRegion.textContent.includes('Δεν υπάρχει σύνδεση')
            ) submitLiveRegion.textContent = '';
            return;
          }
          announceSubmitState('Δεν υπάρχει σύνδεση. Οι υποβολές είναι προσωρινά ανενεργές.', 'assertive');
        };
        const openDisclosure = (element) => {
          if (element instanceof HTMLDetailsElement) {
            element.open = true;
          }
        };
        const setSecondaryTab = (target) => {
          const isMessage = target === 'message';
          if (secondaryActionsDisclosure instanceof HTMLDetailsElement) {
            secondaryActionsDisclosure.open = true;
          }
          if (secondaryMessageDisclosure instanceof HTMLDetailsElement) {
            secondaryMessageDisclosure.open = isMessage;
          }
          if (secondaryContactDisclosure instanceof HTMLDetailsElement) {
            secondaryContactDisclosure.open = !isMessage;
          }
          for (const tab of secondaryTabButtons) {
            if (!(tab instanceof HTMLButtonElement)) continue;
            const active = tab.dataset.secondaryTabTarget === target;
            tab.setAttribute('aria-selected', active ? 'true' : 'false');
            tab.classList.toggle('bg-indigo-50', active);
            tab.classList.toggle('border-indigo-200', active);
            tab.classList.toggle('text-indigo-800', active);
            tab.classList.toggle('bg-white', !active);
            tab.classList.toggle('border-slate-300', !active);
            tab.classList.toggle('text-slate-700', !active);
          }
        };
        const syncSecondaryActionsWithIntent = () => {
          const hash = window.location.hash || '';
          if (params.get('review') || hash === '#reviews' || hash === '#submit-review' || hash === '#secondary-reviews') {
            openDisclosure(secondaryReviewsDisclosure);
          }
          if (params.get('message')) {
            setSecondaryTab('message');
          }
          if (hash === '#secondary-actions') {
            openDisclosure(secondaryActionsDisclosure);
          }
          if (hash === '#secondary-contact-panel' || hash === '#contact-details') {
            setSecondaryTab('contact');
          }
        };

        const syncPrimaryCtaFocus = () => {
          if (!(primaryBookingForm instanceof HTMLFormElement)) return;
          const hasBookingOutcome = Boolean(params.get('booking'));
          if (hasBookingOutcome) {
            collapseSecondaryActions();
          }

          primaryBookingForm.addEventListener('focusin', () => {
            collapseSecondaryActions();
            announceSubmitState('Κύρια διαδρομή: συμπληρώστε το αίτημα συνεργασίας για γρηγορότερη εξυπηρέτηση.');
          });
        };

        const syncSecondaryAccordion = () => {
          const panels = [secondaryReviewsDisclosure, secondaryMessageDisclosure, secondaryContactDisclosure]
            .filter((panel) => panel instanceof HTMLDetailsElement);

          for (const panel of panels) {
            panel.addEventListener('toggle', () => {
              if (!panel.open) return;
              for (const other of panels) {
                if (other !== panel) other.open = false;
              }
              if (secondaryActionsDisclosure instanceof HTMLDetailsElement && panel !== secondaryReviewsDisclosure) {
                secondaryActionsDisclosure.open = true;
              }
              if (panel === secondaryMessageDisclosure) setSecondaryTab('message');
              if (panel === secondaryContactDisclosure) setSecondaryTab('contact');
              announceSubmitState('Άνοιξε δευτερεύουσα επιλογή. Για ταχύτερη ανάθεση μπορείτε πάντα να επιστρέψετε στο κύριο αίτημα συνεργασίας.');
            });
          }

          for (const tab of secondaryTabButtons) {
            if (!(tab instanceof HTMLButtonElement)) continue;
            tab.addEventListener('click', () => {
              const target = tab.dataset.secondaryTabTarget === 'contact' ? 'contact' : 'message';
              setSecondaryTab(target);
            });
          }
        };
        const reviewListRoot = document.querySelector('[data-review-list-root]');
        const initialReviewListState = reviewListRoot?.getAttribute('data-review-list-initial-state') || 'ready';
        const reviewListStatusElement = document.querySelector('[data-review-list-status]');
        const reviewListStatusLabelElement = document.querySelector('[data-review-list-status-label]');
        const reviewListTrustElement = document.querySelector('[data-review-list-trust]');
        const reviewListExpectationElement = document.querySelector('[data-review-list-expectation]');
        const reviewListStateMeta = {
          ready: {
            label: 'Αξιόπιστη',
            toneClass: 'border-emerald-200 bg-emerald-50 text-emerald-800',
            trustMessage: 'Αξιοπιστία: υψηλή, με βάση εγκεκριμένες δημόσιες κριτικές.',
            expectationMessage: 'Τι να περιμένετε: νέες κριτικές εμφανίζονται μόνο μετά τον απαραίτητο έλεγχο.'
          },
          empty: {
            label: 'Χωρίς εγκεκριμένες',
            toneClass: 'border-blue-200 bg-blue-50 text-blue-800',
            trustMessage: 'Αξιοπιστία: δεν υπάρχει ακόμη δείγμα βαθμολόγησης.',
            expectationMessage: 'Τι να περιμένετε: η σύνοψη ενεργοποιείται μόλις εγκριθεί η πρώτη κριτική.'
          },
          loading: {
            label: 'Έλεγχος ενημέρωσης',
            toneClass: 'border-blue-200 bg-blue-100 text-blue-900',
            trustMessage: 'Αξιοπιστία: προσωρινά υπό ανανέωση.',
            expectationMessage: 'Τι να περιμένετε: θα εμφανιστούν τα πιο πρόσφατα εγκεκριμένα δεδομένα.'
          },
          error: {
            label: 'Προσωρινά μη διαθέσιμη',
            toneClass: 'border-slate-200 bg-slate-100 text-slate-700',
            trustMessage: 'Οι κριτικές δεν είναι προσωρινά διαθέσιμες.',
            expectationMessage: 'Δοκιμάστε ξανά σε λίγο για ενημερωμένη εικόνα.'
          }
        };
        const setReviewListState = (state) => {
          const loadingShell = document.querySelector('[data-review-loading-shell]');
          const reviewContent = document.querySelector('[data-review-content]');
          const normalizedState = Object.prototype.hasOwnProperty.call(reviewListStateMeta, state) ? state : 'error';
          const statusMeta = reviewListStateMeta[normalizedState];

          if (loadingShell) {
            loadingShell.classList.toggle('hidden', normalizedState !== 'loading');
          }

          if (reviewContent) {
            reviewContent.classList.toggle('hidden', normalizedState === 'loading');
            reviewContent.setAttribute('aria-busy', normalizedState === 'loading' ? 'true' : 'false');
          }

          if (reviewListStatusElement instanceof HTMLElement) {
            const baseClass = reviewListStatusElement.getAttribute('data-base-class') || '';
            reviewListStatusElement.className = `${baseClass} ${statusMeta.toneClass}`.trim();
          }

          if (reviewListStatusLabelElement instanceof HTMLElement) {
            reviewListStatusLabelElement.textContent = statusMeta.label;
          }
          if (reviewListTrustElement instanceof HTMLElement) {
            reviewListTrustElement.textContent = statusMeta.trustMessage;
          }
          if (reviewListExpectationElement instanceof HTMLElement) {
            reviewListExpectationElement.textContent = statusMeta.expectationMessage;
          }
        };
        const syncReviewListStateWithReviewFeedback = (status) => {
          if (status === 'loading') {
            setReviewListState('loading');
            return;
          }

          setReviewListState(initialReviewListState);
        };

        const showFeedbackStatus = (groupName, status) => {
          const group = document.querySelector(`[data-feedback-group="${groupName}"]`);
          if (!group) return;

          const allowedStatuses = feedbackStatuses[groupName] || [];
          const aliasMap = feedbackStatusAliases[groupName] || {};
          const resolvedStatus = aliasMap[status] || status;
          const normalizedStatus = allowedStatuses.includes(resolvedStatus)
            ? resolvedStatus
            : (allowedStatuses.includes('error') ? 'error' : null);
          if (!normalizedStatus) return;

          const messages = Array.from(group.querySelectorAll('[data-feedback-status]'));
          let activeMessage = null;
          let activeMessageAssertive = false;
          for (const message of messages) {
            const currentStatus = message.getAttribute('data-feedback-status');
            const isVisible = currentStatus === normalizedStatus;
            message.classList.toggle('hidden', !isVisible);
            message.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
            if (isVisible) {
              activeMessage = message;
              const assertive = normalizedStatus === 'invalid' || normalizedStatus === 'error' || normalizedStatus === 'blocked' || normalizedStatus === 'offline';
              activeMessageAssertive = assertive;
              message.setAttribute('role', assertive ? 'alert' : 'status');
              message.setAttribute('aria-live', assertive ? 'assertive' : 'polite');
              message.setAttribute('aria-atomic', 'true');
            } else {
              message.removeAttribute('role');
              message.removeAttribute('aria-live');
              message.removeAttribute('aria-atomic');
            }
          }
          if (group instanceof HTMLElement) {
            const assertiveGroup = normalizedStatus === 'invalid' || normalizedStatus === 'error' || normalizedStatus === 'blocked' || normalizedStatus === 'offline';
            group.setAttribute('role', assertiveGroup ? 'alert' : 'status');
            group.setAttribute('aria-live', assertiveGroup ? 'assertive' : 'polite');
            group.setAttribute('aria-atomic', 'true');
            group.setAttribute('aria-relevant', 'additions text');
            group.setAttribute('data-feedback-active-status', normalizedStatus);
          }
          if (activeMessage instanceof HTMLElement) {
            const plainText = (activeMessage.textContent || '').replace(/\s+/g, ' ').trim();
            if (plainText) announceSubmitState(plainText, activeMessageAssertive ? 'assertive' : 'polite');
          }

          if (groupName === 'review') {
            syncReviewListStateWithReviewFeedback(normalizedStatus);
          }
        };
        const pendingFormsByGroup = new Map();
        for (const form of pendingForms) {
          const groupName = form.getAttribute('data-feedback-group-name');
          if (groupName) pendingFormsByGroup.set(groupName, form);
        }
        const retryFeedbackSubmission = (groupName) => {
          const form = pendingFormsByGroup.get(groupName);
          if (!(form instanceof HTMLFormElement)) return;
          if (isOffline()) {
            showFeedbackStatus(groupName, 'offline');
            updateBookingStepState(form, 'Βήμα 2/3: Δεν υπάρχει σύνδεση. Θα χρειαστεί νέα προσπάθεια μόλις επανέλθει το δίκτυο.');
            announceSubmitState('Δεν υπάρχει σύνδεση. Η νέα προσπάθεια θα γίνει μόλις επανέλθει το δίκτυο.', 'assertive');
            syncOfflineAlert();
            return;
          }
          if (form.getAttribute('aria-busy') === 'true') {
            announceSubmitState('Η υποβολή βρίσκεται ήδη σε εξέλιξη.', 'polite');
            return;
          }

          if (groupName === 'booking') {
            updateTrimRequiredFields(form, true);
            updateBookingFieldValidity(form, true);
            const firstInvalid = form.querySelector(':invalid');
            if (firstInvalid instanceof HTMLElement) {
              firstInvalid.focus();
              showFeedbackStatus(groupName, 'invalid');
              updateBookingStepState(form, 'Βήμα 1/3: Διορθώστε τα πεδία και ξαναπατήστε αποστολή.');
              announceSubmitState('Ελέγξτε τα επισημασμένα πεδία πριν τη νέα προσπάθεια.', 'assertive');
              return;
            }
          }

          const submitButton = form.querySelector('button[type="submit"]');
          if (!(submitButton instanceof HTMLButtonElement)) return;
          showFeedbackStatus(groupName, 'loading');
          updateBookingStepState(form, 'Βήμα 3/3: Γίνεται νέα προσπάθεια υποβολής.');
          announceSubmitState('Γίνεται νέα προσπάθεια υποβολής.', 'polite');
          form.requestSubmit(submitButton);
        };

        const applyFeedback = (groupName, queryParam) => {
          const status = params.get(queryParam);
          if (!status) return;
          if (!hasFeedbackInteraction(groupName)) return;

          showFeedbackStatus(groupName, status);
        };

        applyFeedback('review', 'review');
        applyFeedback('booking', 'booking');
        applyFeedback('message', 'message');
        const retryButtons = Array.from(document.querySelectorAll('[data-feedback-retry]')).filter((button) => button instanceof HTMLButtonElement);
        for (const button of retryButtons) {
          const groupName = button.getAttribute('data-feedback-retry') || '';
          if (!groupName) continue;
          button.addEventListener('click', () => {
            retryFeedbackSubmission(groupName);
          });
        }
        setSecondaryTab('message');
        syncSecondaryActionsWithIntent();
        syncPrimaryCtaFocus();
        syncSecondaryAccordion();
        if (!params.get('review')) {
          setReviewListState(initialReviewListState);
        }

        const setFormPending = (form, isPending) => {
          const submitButton = form.querySelector('button[type="submit"]');
          if (!(submitButton instanceof HTMLButtonElement)) return;
          const controls = Array.from(form.querySelectorAll('button, input, select, textarea')).filter((control) => (
            !(control instanceof HTMLInputElement && control.type === 'hidden')
          ));
          clearPendingTimeout(form);

          form.setAttribute('aria-busy', isPending ? 'true' : 'false');
          form.classList.toggle('opacity-80', isPending);

          if (isPending) {
            for (const control of controls) {
              control.setAttribute('data-pending-disabled', control.disabled ? 'true' : 'false');
              control.disabled = true;
              control.setAttribute('aria-disabled', 'true');
            }
            const defaultLabel = submitButton.getAttribute('data-default-label') || submitButton.textContent || 'Αποστολή';
            const pendingLabel = submitButton.getAttribute('data-pending-label') || 'Αποστολή...';
            form.setAttribute('data-submit-label', defaultLabel);
            submitButton.textContent = pendingLabel;
            submitButton.setAttribute('aria-busy', 'true');
            const timeoutMs = Number(form.getAttribute('data-pending-timeout-ms') || '15000');
            if (Number.isFinite(timeoutMs) && timeoutMs > 0) {
              const timeoutId = window.setTimeout(() => {
                if (form.getAttribute('aria-busy') !== 'true') return;
                setFormPending(form, false);
                announceSubmitState(form.getAttribute('data-pending-timeout-label') || 'Η υποβολή καθυστέρησε. Δοκιμάστε ξανά.', 'assertive');
                const feedbackGroup = form.getAttribute('data-feedback-group-name');
                if (feedbackGroup) showFeedbackStatus(feedbackGroup, 'error');
              }, timeoutMs);
              pendingTimeouts.set(form, timeoutId);
            }
            return;
          }

          for (const control of controls) {
            const wasDisabled = control.getAttribute('data-pending-disabled') === 'true';
            control.disabled = wasDisabled;
            control.removeAttribute('data-pending-disabled');
            if (!control.disabled) control.removeAttribute('aria-disabled');
          }
          const defaultLabel = form.getAttribute('data-submit-label') || submitButton.getAttribute('data-default-label') || 'Αποστολή';
          submitButton.textContent = defaultLabel;
          submitButton.removeAttribute('aria-busy');
          if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
          syncOfflineSubmitAvailability();
        };

        const updateMessageFieldValidity = (form, forceInvalidState = false) => {
          const messageField = form.querySelector('textarea[name="message"]');
          if (!(messageField instanceof HTMLTextAreaElement)) return;
          const isValid = messageField.value.trim().length > 0;
          const touched = forceInvalidState || form.getAttribute('data-message-touched') === 'true';
          messageField.setCustomValidity(isValid ? '' : 'Συμπληρώστε μήνυμα.');
          messageField.setAttribute('aria-invalid', (!isValid && touched) ? 'true' : 'false');
        };
        const updateTrimRequiredFields = (form, forceInvalidState = false) => {
          const fields = Array.from(form.querySelectorAll('[data-trim-required]')).filter((field) => (
            field instanceof HTMLTextAreaElement || field instanceof HTMLInputElement
          ));
          for (const field of fields) {
            const isValid = field.value.trim().length > 0;
            const touched = forceInvalidState || field.getAttribute('data-trim-touched') === 'true';
            field.setCustomValidity(isValid ? '' : 'Συμπληρώστε το πεδίο.');
            field.setAttribute('aria-invalid', (!isValid && touched) ? 'true' : 'false');
          }
        };

        const bookingFieldValidators = {
          name: (value) => value.trim().length >= 2,
          phone: (value) => /^[0-9+()\-\s]{7,20}$/.test(value.trim()),
          email: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim()),
          preferredDate: (value) => value.trim() === '' || (value.trim().length >= 4 && /\d/.test(value))
        };

        const updateBookingFieldValidity = (form, forceInvalidState = false) => {
          if (!form.hasAttribute('data-booking-form')) return;
          const fields = Array.from(form.querySelectorAll('[data-booking-validate]')).filter((field) => field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement);
          const invalidRules = [];
          for (const field of fields) {
            const rule = field.getAttribute('data-booking-validate') || '';
            const validator = bookingFieldValidators[rule];
            if (!validator) continue;
            const isValid = validator(field.value || '');
            const touched = forceInvalidState || field.getAttribute('data-booking-touched') === 'true';
            const errorEl = document.getElementById(`${field.id}-error`);
            if (!isValid && touched) {
              field.setAttribute('aria-invalid', 'true');
              if (errorEl instanceof HTMLElement) errorEl.classList.remove('hidden');
            } else {
              field.setAttribute('aria-invalid', 'false');
              if (errorEl instanceof HTMLElement) errorEl.classList.add('hidden');
            }
            if (!isValid) invalidRules.push(rule);
            if (rule === 'preferredDate') {
              field.setCustomValidity(isValid ? '' : 'Προσθέστε σαφή ημέρα/ώρα.');
            } else {
              field.setCustomValidity(isValid ? '' : 'Συμπληρώστε έγκυρη τιμή.');
            }
          }

          const summary = form.querySelector('[data-booking-validation-summary]');
          if (summary instanceof HTMLElement) {
            const mapped = {
              name: 'ονοματεπώνυμο',
              phone: 'τηλέφωνο',
              email: 'email',
              preferredDate: 'προτιμώμενο πρόγραμμα'
            };
            const touchedAny = fields.some((field) => field.getAttribute('data-booking-touched') === 'true') || forceInvalidState;
            summary.classList.toggle('hidden', !touchedAny);
            if (invalidRules.length === 0) {
              summary.textContent = 'Όλα τα βασικά πεδία είναι έγκυρα. Μπορείτε να προχωρήσετε.';
            } else {
              const uniqueLabels = [...new Set(invalidRules.map((rule) => mapped[rule] || rule))];
              summary.textContent = `Χρειάζεται διόρθωση στα πεδία ${uniqueLabels.join(', ')}.`;
            }
          }
        };

        for (const form of pendingForms) {
          const feedbackGroupName = form.getAttribute('data-feedback-group-name') || '';
          const trackFeedbackInteraction = (event) => {
            if (!feedbackGroupName) return;
            if (!(event.target instanceof HTMLElement)) return;
            const isFormControl = event.target instanceof HTMLInputElement
              || event.target instanceof HTMLTextAreaElement
              || event.target instanceof HTMLSelectElement
              || event.target instanceof HTMLButtonElement;
            if (isFormControl) {
              markFeedbackInteraction(feedbackGroupName);
            }
          };
          form.addEventListener('focusin', trackFeedbackInteraction);
          form.addEventListener('input', trackFeedbackInteraction);
          form.addEventListener('change', trackFeedbackInteraction);
          updateTrimRequiredFields(form);
          updateBookingFieldValidity(form);
          form.addEventListener('input', (event) => {
            if (!(event.target instanceof HTMLElement)) return;
            if (event.target.hasAttribute('data-trim-required')) {
              event.target.setAttribute('data-trim-touched', 'true');
              updateTrimRequiredFields(form);
            }
            if (event.target.hasAttribute('data-booking-validate')) {
              event.target.setAttribute('data-booking-touched', 'true');
              const existingTimer = bookingValidationTimers.get(form);
              if (existingTimer) window.clearTimeout(existingTimer);
              const timerId = window.setTimeout(() => {
                updateBookingFieldValidity(form);
                bookingValidationTimers.delete(form);
              }, 220);
              bookingValidationTimers.set(form, timerId);
            }
          });
          form.addEventListener('blur', (event) => {
            if (!(event.target instanceof HTMLElement)) return;
            if (!event.target.hasAttribute('data-booking-validate')) return;
            event.target.setAttribute('data-booking-touched', 'true');
            updateBookingFieldValidity(form);
          }, true);
          if (form.hasAttribute('data-message-form')) {
            updateMessageFieldValidity(form);
            form.addEventListener('input', (event) => {
              if (!(event.target instanceof HTMLElement)) return;
              if (event.target.getAttribute('name') !== 'message') return;
              form.setAttribute('data-message-touched', 'true');
              updateMessageFieldValidity(form);
            });
          }
          form.addEventListener('submit', (event) => {
            if (feedbackGroupName) {
              markFeedbackInteraction(feedbackGroupName);
            }
            if (isOffline()) {
              event.preventDefault();
              if (feedbackGroupName) showFeedbackStatus(feedbackGroupName, 'offline');
              announceSubmitState('Δεν υπάρχει σύνδεση. Δοκιμάστε ξανά μόλις επανέλθει το δίκτυο.', 'assertive');
              syncOfflineAlert();
              return;
            }
            if (form.getAttribute('aria-busy') === 'true') {
              event.preventDefault();
              announceSubmitState('Η υποβολή βρίσκεται ήδη σε εξέλιξη.', 'polite');
              return;
            }

            if (form.hasAttribute('data-message-form')) {
              updateMessageFieldValidity(form, true);
            }
            updateTrimRequiredFields(form, true);
            updateBookingFieldValidity(form, true);

            if (!form.checkValidity()) {
              event.preventDefault();
              if (feedbackGroupName) showFeedbackStatus(feedbackGroupName, 'invalid');
              form.reportValidity();
              announceSubmitState('Ελέγξτε τα πεδία και δοκιμάστε ξανά.', 'assertive');
              return;
            }

            if (feedbackGroupName) {
              showFeedbackStatus(feedbackGroupName, 'loading');
            }

            announceSubmitState(form.getAttribute('data-pending-live-label') || 'Η υποβολή εκτελείται.', 'polite');
            setFormPending(form, true);
          });
        }

        window.addEventListener('pageshow', () => {
          for (const form of pendingForms) {
            setFormPending(form, false);
            updateTrimRequiredFields(form);
            updateBookingFieldValidity(form);
            if (form.hasAttribute('data-message-form')) {
              updateMessageFieldValidity(form);
            }
          }
          announceSubmitState('');
          syncOfflineAlert();
        });
        window.addEventListener('hashchange', () => {
          syncSecondaryActionsWithIntent();
        });
        window.addEventListener('online', syncOfflineAlert);
        window.addEventListener('offline', syncOfflineAlert);
        syncOfflineAlert();
      })();
    </script>
  </main>
</Layout>
