---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabase-server';
import { assertPublishedProfilesHaveValidImages, getProfessionalFallbackImage, resolveProfessionalImageSrc } from '../../lib/professional-images';

export const prerender = true;

const profilesFile = await import('../../../data/professionals.json');
const reviewBadgeCopyFile = await import('../../../data/review-verified-badge-copy.json');
const profiles = (profilesFile.default ?? profilesFile) as Array<{
  slug: string;
  name: string;
  profession: string;
  city: string;
  areasServed: string[];
  experienceYears: number;
  bio: string;
  services: string[];
  profilePhotoUrl?: string;
  portfolioPhotos?: string[];
  phone: string;
  email: string;
  approved?: boolean;
  published?: boolean;
}>;

export function getStaticPaths() {
  const profilesFile = Object.values(import.meta.glob('../../../data/professionals.json', { eager: true }))[0] as any;
  const profiles = (profilesFile.default ?? profilesFile) as Array<{ slug: string; approved?: boolean; published?: boolean }>;

  return profiles
    .filter((profile) => profile.approved === true && profile.published === true)
    .map((profile) => ({
    params: { slug: profile.slug },
    props: { profile }
  }));
}

interface ApprovedReview {
  id: string;
  reviewerName: string;
  rating: number;
  comment: string;
  verified?: boolean;
  submittedAt: string;
}

const { profile } = Astro.props as { profile: (typeof profiles)[number] };
const reviewBadgeCopy = (reviewBadgeCopyFile.default ?? reviewBadgeCopyFile) as any;
const verifiedBadgeLabel = reviewBadgeCopy?.publicBadge?.defaultLabel || 'Επιβεβαιωμένη αξιολόγηση';
const verifiedBadgeTooltip = reviewBadgeCopy?.publicBadge?.tooltip || 'Η αξιολόγηση συνδέεται με πραγματικό αίτημα υπηρεσίας μέσω Greek Handy.';
const verifiedBadgeDisclaimer = reviewBadgeCopy?.publicBadge?.disclaimer || '';

const { data: approvedRows, error: approvedRowsError } = await supabaseServer
  .from('reviews')
  .select('id, reviewer_name, rating, comment, verified, created_at')
  .eq('status', 'approved')
  .eq('service_slug', profile.slug)
  .order('created_at', { ascending: false });

if (approvedRowsError) {
  console.error('[professional-profile-reviews] fetch failed', {
    slug: profile.slug,
    error: approvedRowsError
  });
}

const approvedReviews: ApprovedReview[] = (approvedRows || []).map((row: any) => ({
  id: row.id,
  reviewerName: row.reviewer_name || 'Ανώνυμος Πελάτης',
  rating: Math.max(1, Math.min(5, Number(row.rating) || 1)),
  comment: row.comment || '',
  verified: Boolean(row.verified),
  submittedAt: row.created_at
}));

const hasApprovedReviewsError = Boolean(approvedRowsError);
const reviewsCount = approvedReviews.length;
const reviewsLabel = reviewsCount === 1 ? 'κριτική' : 'κριτικές';
type ReviewListState = 'ready' | 'empty' | 'error';
const initialReviewListState: ReviewListState = hasApprovedReviewsError
  ? 'error'
  : (reviewsCount === 0 ? 'empty' : 'ready');
const reviewListStateLabels: Record<ReviewListState, string> = {
  ready: 'Διαθέσιμες',
  empty: 'Χωρίς εγκεκριμένες',
  error: 'Προσωρινά μη διαθέσιμη'
};
const reviewListStatusTones: Record<ReviewListState, string> = {
  ready: 'border-emerald-200 bg-emerald-50 text-emerald-800',
  empty: 'border-blue-200 bg-blue-50 text-blue-800',
  error: 'border-slate-200 bg-slate-100 text-slate-700'
};
const reviewListStateTrustCopy: Record<ReviewListState, { reliability: string; expectation: string }> = {
  ready: {
    reliability: 'Αξιοπιστία: υψηλή, με βάση εγκεκριμένες δημόσιες κριτικές.',
    expectation: 'Τι να περιμένετε: νέες κριτικές εμφανίζονται μόνο μετά το moderation.'
  },
  empty: {
    reliability: 'Αξιοπιστία: δεν υπάρχει ακόμη δείγμα βαθμολόγησης.',
    expectation: 'Τι να περιμένετε: η σύνοψη ενεργοποιείται μόλις εγκριθεί η πρώτη κριτική.'
  },
  error: {
    reliability: 'Οι κριτικές δεν είναι προσωρινά διαθέσιμες.',
    expectation: 'Δοκιμάστε ξανά σε λίγο για ενημερωμένη εικόνα.'
  }
};
const initialReviewListStatusTone = reviewListStatusTones[initialReviewListState];
const initialReviewListTrustCopy = reviewListStateTrustCopy[initialReviewListState];
const reviewReloadHref = `${Astro.url.pathname}#reviews`;
const verifiedReviewsCount = approvedReviews.filter((review) => review.verified).length;
const highlightedReviews = approvedReviews.slice(0, 8);
const averageRatingValue = reviewsCount > 0
  ? approvedReviews.reduce((sum, review) => sum + review.rating, 0) / reviewsCount
  : null;
const averageRating = averageRatingValue !== null
  ? averageRatingValue.toFixed(1)
  : null;
const averageRatingStars = averageRatingValue !== null
  ? '★'.repeat(Math.round(averageRatingValue)) + '☆'.repeat(5 - Math.round(averageRatingValue))
  : '';
const ratingDistribution = [5, 4, 3, 2, 1].map((star) => {
  const count = approvedReviews.filter((review) => review.rating === star).length;
  return {
    star,
    count,
    percentage: reviewsCount > 0 ? Math.round((count / reviewsCount) * 100) : 0
  };
});
const positiveReviewsCount = approvedReviews.filter((review) => review.rating >= 4).length;
const recommendationRate = reviewsCount > 0
  ? Math.round((positiveReviewsCount / reviewsCount) * 100)
  : 0;
const recentApprovedReviewDate = approvedReviews[0]?.submittedAt
  ? new Date(approvedReviews[0].submittedAt).toLocaleDateString('el-GR', { day: '2-digit', month: 'long', year: 'numeric' })
  : null;
const averageRatingSummary = averageRatingValue === null
  ? null
  : averageRatingValue >= 4.8
    ? 'Εξαιρετική συνολική εμπειρία πελατών.'
    : averageRatingValue >= 4.4
      ? 'Πολύ υψηλή ικανοποίηση στις περισσότερες συνεργασίες.'
      : averageRatingValue >= 4
        ? 'Σταθερά θετικές αξιολογήσεις από πελάτες.'
        : averageRatingValue >= 3
          ? 'Μικτή εικόνα με περιθώριο για βελτίωση.'
          : 'Αυτή τη στιγμή οι αξιολογήσεις δείχνουν ανάγκη βελτίωσης.';
const formatReviewDate = (dateValue: string) =>
  new Date(dateValue).toLocaleDateString('el-GR', { day: '2-digit', month: 'long', year: 'numeric' });
const renderStarRating = (rating: number) => '★'.repeat(rating) + '☆'.repeat(5 - rating);
---

<Layout
  title={`${profile.name} | ${profile.profession} | GreekHandy`}
  description={`Δείτε το προφίλ του/της ${profile.name}, ${profile.profession} στη ${profile.city}.`}
>
  <main class="mx-auto max-w-4xl px-4 py-14">
    <a href="/professionals" class="text-sm font-semibold text-blue-700 hover:underline">&larr; Όλοι οι επαγγελματίες</a>

    <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-7 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-blue-700">{profile.profession}</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">{profile.name}</h1>
      <p class="mt-2 text-slate-600">{profile.city} • {profile.experienceYears} χρόνια εμπειρίας</p>

      {profile.profilePhotoUrl && <img src={profile.profilePhotoUrl} alt={`Φωτογραφία ${profile.name}`} class="mt-6 h-72 w-full rounded-xl object-cover" />}

      <p class="mt-6 leading-relaxed text-gray-700">{profile.bio}</p>

      <div class="mt-8">
        <h2 class="text-lg font-bold text-slate-900">Portfolio</h2>
        {profile.portfolioPhotos && profile.portfolioPhotos.length > 0 ? (
          <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {profile.portfolioPhotos.map((photo, index) => (
              <img src={photo} alt={`Portfolio ${profile.name} ${index + 1}`} class="h-48 w-full rounded-xl border border-slate-200 object-cover shadow-sm" loading="lazy" />
            ))}
          </div>
        ) : (
          <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
            Δεν έχουν προστεθεί ακόμη φωτογραφίες έργων.
          </div>
        )}
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-lg font-bold text-slate-900">Υπηρεσίες</h2>
          {profile.services.length > 0 ? (
            <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-700">
              {profile.services.map((service) => <li>{service}</li>)}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-slate-600">Δεν έχουν δηλωθεί υπηρεσίες ακόμη.</p>
          )}
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-lg font-bold text-slate-900">Περιοχές εξυπηρέτησης</h2>
          {profile.areasServed.length > 0 ? (
            <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-700">
              {profile.areasServed.map((area) => <li>{area}</li>)}
            </ul>
          ) : (
            <p class="mt-3 text-sm text-slate-600">Δεν έχουν δηλωθεί περιοχές εξυπηρέτησης.</p>
          )}
        </div>
      </div>

      <section
        id="reviews"
        class="mt-8 rounded-2xl border border-slate-200 bg-gradient-to-b from-white via-slate-50/60 to-white p-5 md:p-6"
        data-review-list-root
        data-review-list-initial-state={initialReviewListState}
      >
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-bold text-gray-900">Αξιολογήσεις</h2>
            <p class="mt-1 text-xs text-gray-600">Δημόσια εμφανίζονται μόνο οι κριτικές που έχουν εγκριθεί από moderation.</p>
            {verifiedBadgeDisclaimer && <p class="mt-1 text-xs text-gray-500">{verifiedBadgeDisclaimer}</p>}
          </div>
          <div class="flex flex-col items-end gap-2">
            <div class="rounded-full border border-slate-200 bg-white px-4 py-1.5 text-xs font-semibold text-slate-700 shadow-sm">
              {reviewsCount} {reviewsLabel}
            </div>
            <p
              data-review-list-status
              data-base-class="inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-semibold"
              class={`inline-flex items-center rounded-full border px-3 py-1 text-[11px] font-semibold ${initialReviewListStatusTone}`}
            >
              Κατάσταση λίστας:
              <span data-review-list-status-label class="ml-1">{reviewListStateLabels[initialReviewListState]}</span>
            </p>
            <div class="max-w-xs text-right">
              <p data-review-list-trust class="text-[11px] text-slate-600">{initialReviewListTrustCopy.reliability}</p>
              <p data-review-list-expectation class="mt-0.5 text-[11px] text-slate-500">{initialReviewListTrustCopy.expectation}</p>
            </div>
          </div>
        </div>

        {!hasApprovedReviewsError && reviewsCount > 0 && (
          <div class="mt-5 grid gap-4 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,1fr)]">
            <article class="rounded-2xl border border-amber-200 bg-white p-5 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-amber-700">Μέση βαθμολογία</p>
              <div class="mt-3 flex items-end gap-2">
                <p class="text-5xl font-bold leading-none text-amber-800">{averageRating}</p>
                <p class="pb-1 text-sm font-semibold text-amber-700">/5</p>
              </div>
              <p class="mt-2 text-base font-semibold text-amber-700">{averageRatingStars}</p>
              {averageRatingSummary && <p class="mt-3 text-sm text-slate-700">{averageRatingSummary}</p>}
              <p class="mt-2 text-xs text-slate-500">Υπολογισμός μόνο από εγκεκριμένες κριτικές (pending/rejected εξαιρούνται).</p>

              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="text-xs text-slate-500">Σύνολο</p>
                  <p class="text-sm font-semibold text-slate-900">{reviewsCount} {reviewsLabel}</p>
                </div>
                <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2">
                  <p class="text-xs text-emerald-700">Θετικές</p>
                  <p class="text-sm font-semibold text-emerald-900">{recommendationRate}% (4★+)</p>
                </div>
                <div class="rounded-xl border border-blue-200 bg-blue-50 px-3 py-2">
                  <p class="text-xs text-blue-700">Επιβεβαιωμένες</p>
                  <p class="text-sm font-semibold text-blue-900">{verifiedReviewsCount}</p>
                </div>
              </div>

              {recentApprovedReviewDate && <p class="mt-4 text-xs text-slate-500">Τελευταία δημοσίευση: {recentApprovedReviewDate}</p>}
            </article>

            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-sm font-semibold text-slate-900">Κατανομή βαθμολογιών</p>
              <div class="mt-4 space-y-2.5">
                {ratingDistribution.map((row) => (
                  <div class="flex items-center gap-3 text-xs text-slate-700">
                    <span class="w-10 font-semibold">{row.star}★</span>
                    <div class="h-2.5 flex-1 overflow-hidden rounded-full bg-slate-200">
                      <div class="h-full rounded-full bg-gradient-to-r from-amber-300 to-amber-500" style={`width: ${row.percentage}%`}></div>
                    </div>
                    <span class="w-20 text-right">{row.count} ({row.percentage}%)</span>
                  </div>
                ))}
              </div>
            </article>
          </div>
        )}

        <div data-review-loading-shell class="mt-5 hidden rounded-2xl border border-blue-200 bg-blue-50/80 p-4 text-blue-900" role="status" aria-live="polite">
          <div class="flex items-center gap-3">
            <span class="inline-block h-5 w-5 animate-spin rounded-full border-2 border-blue-300 border-t-blue-700"></span>
            <div>
              <p class="text-sm font-semibold">Φόρτωση λίστας κριτικών...</p>
              <p class="text-xs text-blue-800">Ελέγχουμε τις πιο πρόσφατες εγκεκριμένες κριτικές για αξιόπιστη εμφάνιση.</p>
            </div>
          </div>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            <div class="h-20 animate-pulse rounded-xl bg-white/90"></div>
            <div class="h-20 animate-pulse rounded-xl bg-white/90"></div>
          </div>
        </div>

        <div data-review-content class="mt-5">
          {hasApprovedReviewsError && (
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700" role="status" aria-live="polite">
              <p class="font-semibold">Οι κριτικές δεν είναι προσωρινά διαθέσιμες.</p>
              <p class="mt-1">Μπορείτε να συνεχίσετε να βλέπετε το προφίλ και να δοκιμάσετε ξανά αργότερα.</p>
              <a href={reviewReloadHref} class="mt-3 inline-flex rounded-md border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">
                Ανανέωση ενότητας
              </a>
            </div>
          )}

          {!hasApprovedReviewsError && reviewsCount === 0 && (
            <div class="rounded-2xl border border-dashed border-blue-200 bg-gradient-to-br from-blue-50 to-sky-50 px-5 py-6 text-sm text-blue-900" role="status" aria-live="polite">
              <p class="font-semibold">Δεν υπάρχουν ακόμη εγκεκριμένες δημόσιες κριτικές.</p>
              <p class="mt-1 text-blue-800">Η απουσία βαθμολογίας σημαίνει ότι δεν υπάρχει ακόμα εγκεκριμένο δείγμα και όχι απαραίτητα αρνητική εμπειρία.</p>
              <p class="mt-1 text-xs text-blue-700">Τι να περιμένετε: οι νέες κριτικές εμφανίζονται μόλις ολοκληρωθεί το moderation και τότε ενημερώνεται η σύνοψη.</p>
              <a href="#submit-review" class="mt-3 inline-flex rounded-md bg-blue-700 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-800">
                Γράψτε κριτική
              </a>
            </div>
          )}

          {!hasApprovedReviewsError && highlightedReviews.length > 0 && (
            <div class="grid gap-4 md:grid-cols-2">
              {highlightedReviews.map((review) => (
                <article class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md">
                  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-rose-200 via-amber-300 to-emerald-300"></div>
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <p class="text-sm font-semibold text-slate-900">{review.reviewerName}</p>
                      <p class="mt-1 text-sm font-semibold text-amber-700">{renderStarRating(review.rating)} <span class="text-xs font-medium text-slate-500">({review.rating}.0/5)</span></p>
                    </div>
                    {review.verified && (
                      <span
                        class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-0.5 text-[11px] font-semibold text-emerald-800"
                        title={verifiedBadgeTooltip}
                      >
                        ✓ {verifiedBadgeLabel}
                      </span>
                    )}
                  </div>
                  <p class="mt-3 text-sm leading-relaxed text-slate-700">{review.comment}</p>
                  <p class="mt-4 text-xs text-slate-500">{formatReviewDate(review.submittedAt)} • Δημοσιεύτηκε μετά από έγκριση</p>
                </article>
              ))}
            </div>
          )}
        </div>

        <form action="/api/reviews/submit" method="POST" class="mt-6 rounded-xl border border-blue-100 bg-blue-50 p-4" data-review-form id="submit-review">
          <h3 class="text-base font-bold text-gray-900">Υποβολή κριτικής</h3>
          <p class="mt-1 text-xs text-gray-600">Οι κριτικές ελέγχονται και γίνονται δημόσιες μόνο μετά από έγκριση.</p>

          <div class="mt-3 space-y-2" data-feedback-group="review" aria-live="polite">
            <p data-feedback-status="loading" class="hidden rounded-md border border-blue-200 bg-white px-3 py-2 text-sm text-blue-800">
              <span class="inline-flex items-center gap-2">
                <svg class="h-4 w-4 animate-spin text-blue-700" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" class="opacity-25" stroke="currentColor" stroke-width="3"></circle>
                  <path d="M21 12a9 9 0 0 0-9-9" class="opacity-90" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
                </svg>
                Υποβολή κριτικής...
              </span>
            </p>
            <p data-feedback-status="pending" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Ευχαριστούμε! Η κριτική σας είναι εκκρεμής (pending) για moderation και δεν επηρεάζει ακόμη τη δημόσια βαθμολογία.</p>
            <p data-feedback-status="approved" class="hidden rounded-md bg-emerald-100 px-3 py-2 text-sm text-emerald-800">Η κριτική εγκρίθηκε (approved) και υπολογίζεται πλέον στη δημόσια σύνοψη βαθμολογίας.</p>
            <p data-feedback-status="rejected" class="hidden rounded-md bg-slate-100 px-3 py-2 text-sm text-slate-800">Η κριτική απορρίφθηκε (rejected) από moderation και δεν υπολογίζεται στη δημόσια βαθμολογία. Μπορείτε να στείλετε νέα, πιο συγκεκριμένη κριτική.</p>
            <p data-feedback-status="invalid" class="hidden rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800">Συμπληρώστε βαθμολογία και σχόλιο.</p>
            <p data-feedback-status="error" class="hidden rounded-md bg-red-100 px-3 py-2 text-sm text-red-800">Παρουσιάστηκε πρόβλημα. Δοκιμάστε ξανά.</p>
          </div>

          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <div>
              <label for="reviewerName" class="mb-1 block text-sm font-semibold text-gray-800">Όνομα</label>
              <input id="reviewerName" name="reviewerName" type="text" maxlength="80" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div>
              <label for="reviewerEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email (προαιρετικό)</label>
              <input id="reviewerEmail" name="reviewerEmail" type="email" maxlength="160" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div class="md:col-span-2">
              <label for="rating" class="mb-1 block text-sm font-semibold text-gray-800">Βαθμολογία (1-5) *</label>
              <select id="rating" name="rating" required class="w-full rounded-lg border border-gray-300 px-3 py-2.5">
                <option value="">Επιλέξτε</option>
                <option value="5">5 - Εξαιρετικά</option>
                <option value="4">4 - Πολύ καλά</option>
                <option value="3">3 - Καλά</option>
                <option value="2">2 - Μέτρια</option>
                <option value="1">1 - Χρειάζεται βελτίωση</option>
              </select>
            </div>
          </div>

          <div class="mt-4">
            <label for="comment" class="mb-1 block text-sm font-semibold text-gray-800">Σχόλιο *</label>
            <textarea id="comment" name="comment" rows="4" required maxlength="1200" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>

          <button
            type="submit"
            class="mt-4 rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:cursor-not-allowed disabled:opacity-70"
            data-review-submit-button
            data-default-label="Αποστολή κριτικής"
          >
            Αποστολή κριτικής
          </button>
        </form>
      </section>

      <section class="mt-8 rounded-xl border border-blue-100 bg-blue-50 p-5">
        <h2 class="text-lg font-bold text-gray-900">Αίτημα Κράτησης</h2>
        <p class="mt-1 text-sm text-gray-600">Στείλτε αίτημα και θα επικοινωνήσουμε μαζί σας για επιβεβαίωση.</p>
        <p class="mt-2 rounded-lg border border-blue-200 bg-white px-3 py-2 text-xs text-blue-800">Lifecycle αιτήματος: <strong>pending</strong> (σε έλεγχο) → <strong>approved</strong> ή <strong>rejected</strong>. Μετά την υποβολή θα λάβετε σελίδα παρακολούθησης κατάστασης.</p>

        <div class="mt-3 space-y-2" data-feedback-group="booking" aria-live="polite">
          <p data-feedback-status="loading" class="hidden rounded-md border border-blue-200 bg-blue-50 px-3 py-2 text-sm text-blue-800">
            <span class="inline-flex items-center gap-2">
              <svg class="h-4 w-4 animate-spin text-blue-700" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="9" class="opacity-25" stroke="currentColor" stroke-width="3"></circle>
                <path d="M21 12a9 9 0 0 0-9-9" class="opacity-90" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
              </svg>
              Αποστολή αιτήματος κράτησης...
            </span>
          </p>
          <p data-feedback-status="submitted" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Το αίτημά σας καταχωρήθηκε και είναι σε αναμονή moderation (pending).</p>
          <p data-feedback-status="invalid" class="hidden rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800">Συμπληρώστε σωστά τα υποχρεωτικά πεδία (υπηρεσία, στοιχεία επικοινωνίας, μήνυμα) και δοκιμάστε ξανά.</p>
          <p data-feedback-status="error" class="hidden rounded-md bg-red-100 px-3 py-2 text-sm text-red-800">Παρουσιάστηκε πρόβλημα. Δοκιμάστε ξανά.</p>
        </div>

        <form action="/api/bookings/submit" method="POST" class="mt-4" data-pending-form data-booking-form>
          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="bookingService" class="mb-1 block text-sm font-semibold text-gray-800">Υπηρεσία *</label>
              <select id="bookingService" name="service" required class="w-full rounded-lg border border-gray-300 px-3 py-2.5">
                <option value="">Επιλέξτε υπηρεσία</option>
                {profile.services.map((service) => <option value={service}>{service}</option>)}
              </select>
            </div>
            <div>
              <label for="customerName" class="mb-1 block text-sm font-semibold text-gray-800">Ονοματεπώνυμο *</label>
              <input id="customerName" name="customerName" required maxlength="120" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div>
              <label for="bookingPhone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο *</label>
              <input id="bookingPhone" name="phone" required maxlength="40" pattern="[0-9+()\-\s]{7,20}" title="Συμπληρώστε έγκυρο τηλέφωνο (7-20 χαρακτήρες)." class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div>
              <label for="bookingEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email *</label>
              <input id="bookingEmail" name="email" type="email" required maxlength="160" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div class="md:col-span-2">
              <label for="preferredDate" class="mb-1 block text-sm font-semibold text-gray-800">Προτιμώμενο πρόγραμμα (ημερομηνία/ώρα)</label>
              <input id="preferredDate" name="preferredDate" type="text" maxlength="80" placeholder="π.χ. 12/03 απόγευμα ή Σάββατο πρωί" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
          </div>

          <div class="mt-4">
            <label for="bookingMessage" class="mb-1 block text-sm font-semibold text-gray-800">Λεπτομέρειες αιτήματος *</label>
            <textarea id="bookingMessage" name="message" rows="4" required maxlength="2000" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>

          <p class="mt-2 text-xs text-blue-700">Καταστάσεις αιτήματος: pending (σε αναμονή) → approved (εγκρίθηκε) ή rejected (απορρίφθηκε).</p>

          <button type="submit" class="mt-4 rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 disabled:cursor-not-allowed disabled:opacity-70" data-default-label="Αποστολή αιτήματος">Αποστολή αιτήματος</button>
        </form>
      </section>

      <section class="mt-8 rounded-xl border border-indigo-100 bg-indigo-50 p-5">
        <h2 class="text-lg font-bold text-gray-900">Ξεκίνα συζήτηση</h2>
        <p class="mt-1 text-sm text-gray-600">Στείλτε ένα αρχικό μήνυμα για να ανοίξει thread επικοινωνίας.</p>

        <div class="mt-3 space-y-2" data-feedback-group="message">
          <p data-feedback-status="submitted" class="hidden rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Το μήνυμά σας καταχωρήθηκε για triage.</p>
          <p data-feedback-status="invalid" class="hidden rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800">Ελέγξτε τα πεδία και δοκιμάστε ξανά.</p>
          <p data-feedback-status="blocked" class="hidden rounded-md bg-red-100 px-3 py-2 text-sm text-red-800">Αυτή η συνομιλία έχει μπλοκαριστεί από moderation.</p>
          <p data-feedback-status="error" class="hidden rounded-md bg-red-100 px-3 py-2 text-sm text-red-800">Παρουσιάστηκε πρόβλημα. Δοκιμάστε ξανά.</p>
        </div>

        <form action="/api/messages/submit" method="POST" class="mt-4" data-pending-form>
          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="recipientEmail" value={profile.email} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}`} />
          <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="senderName" class="mb-1 block text-sm font-semibold text-gray-800">Ονοματεπώνυμο *</label>
              <input id="senderName" name="senderName" required maxlength="120" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div>
              <label for="senderEmail" class="mb-1 block text-sm font-semibold text-gray-800">Email *</label>
              <input id="senderEmail" name="senderEmail" type="email" required maxlength="160" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
          </div>

          <div class="mt-4">
            <label for="senderPhone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο (προαιρετικό)</label>
            <input id="senderPhone" name="senderPhone" maxlength="40" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
          </div>

          <div class="mt-4">
            <label for="initialMessage" class="mb-1 block text-sm font-semibold text-gray-800">Μήνυμα *</label>
            <textarea id="initialMessage" name="message" rows="4" required maxlength="2000" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>

          <button type="submit" class="mt-4 rounded-lg bg-indigo-700 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-800 disabled:cursor-not-allowed disabled:opacity-70" data-default-label="Αποστολή μηνύματος">Αποστολή μηνύματος</button>
        </form>
      </section>

      <div class="mt-8 rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 to-indigo-50 p-5">
        <h2 class="text-lg font-bold text-slate-900">Στοιχεία επικοινωνίας</h2>
        <p class="mt-2 text-slate-700">Τηλέφωνο: <a href={`tel:${profile.phone}`} class="font-semibold text-blue-700">{profile.phone}</a></p>
        <p class="mt-1 text-slate-700">Email: <a href={`mailto:${profile.email}`} class="font-semibold text-blue-700">{profile.email}</a></p>
      </div>
    </section>

    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const feedbackStatuses = {
          review: ['loading', 'pending', 'approved', 'rejected', 'invalid', 'error'],
          booking: ['loading', 'submitted', 'invalid', 'error'],
          message: ['submitted', 'invalid', 'blocked', 'error']
        };
        const feedbackStatusAliases = {
          review: { submitted: 'pending' }
        };
        const reviewListRoot = document.querySelector('[data-review-list-root]');
        const initialReviewListState = reviewListRoot?.getAttribute('data-review-list-initial-state') || 'ready';
        const reviewListStatusElement = document.querySelector('[data-review-list-status]');
        const reviewListStatusLabelElement = document.querySelector('[data-review-list-status-label]');
        const reviewListTrustElement = document.querySelector('[data-review-list-trust]');
        const reviewListExpectationElement = document.querySelector('[data-review-list-expectation]');
        const reviewListStateMeta = {
          ready: {
            label: 'Αξιόπιστη',
            toneClass: 'border-emerald-200 bg-emerald-50 text-emerald-800',
            trustMessage: 'Αξιοπιστία: υψηλή, με βάση εγκεκριμένες δημόσιες κριτικές.',
            expectationMessage: 'Τι να περιμένετε: νέες κριτικές εμφανίζονται μόνο μετά το moderation.'
          },
          empty: {
            label: 'Χωρίς εγκεκριμένες',
            toneClass: 'border-blue-200 bg-blue-50 text-blue-800',
            trustMessage: 'Αξιοπιστία: δεν υπάρχει ακόμη δείγμα βαθμολόγησης.',
            expectationMessage: 'Τι να περιμένετε: η σύνοψη ενεργοποιείται μόλις εγκριθεί η πρώτη κριτική.'
          },
          loading: {
            label: 'Έλεγχος ενημέρωσης',
            toneClass: 'border-blue-200 bg-blue-100 text-blue-900',
            trustMessage: 'Αξιοπιστία: προσωρινά υπό ανανέωση.',
            expectationMessage: 'Τι να περιμένετε: θα εμφανιστούν τα πιο πρόσφατα εγκεκριμένα δεδομένα.'
          },
          error: {
            label: 'Προσωρινά μη διαθέσιμη',
            toneClass: 'border-slate-200 bg-slate-100 text-slate-700',
            trustMessage: 'Οι κριτικές δεν είναι προσωρινά διαθέσιμες.',
            expectationMessage: 'Δοκιμάστε ξανά σε λίγο για ενημερωμένη εικόνα.'
          }
        };
        const setReviewListState = (state) => {
          const loadingShell = document.querySelector('[data-review-loading-shell]');
          const reviewContent = document.querySelector('[data-review-content]');
          const normalizedState = Object.prototype.hasOwnProperty.call(reviewListStateMeta, state) ? state : 'error';
          const statusMeta = reviewListStateMeta[normalizedState];

          if (loadingShell) {
            loadingShell.classList.toggle('hidden', normalizedState !== 'loading');
          }

          if (reviewContent) {
            reviewContent.classList.toggle('hidden', normalizedState === 'loading');
            reviewContent.setAttribute('aria-busy', normalizedState === 'loading' ? 'true' : 'false');
          }

          if (reviewListStatusElement instanceof HTMLElement) {
            const baseClass = reviewListStatusElement.getAttribute('data-base-class') || '';
            reviewListStatusElement.className = `${baseClass} ${statusMeta.toneClass}`.trim();
          }

          if (reviewListStatusLabelElement instanceof HTMLElement) {
            reviewListStatusLabelElement.textContent = statusMeta.label;
          }
          if (reviewListTrustElement instanceof HTMLElement) {
            reviewListTrustElement.textContent = statusMeta.trustMessage;
          }
          if (reviewListExpectationElement instanceof HTMLElement) {
            reviewListExpectationElement.textContent = statusMeta.expectationMessage;
          }
        };
        const syncReviewListStateWithReviewFeedback = (status) => {
          if (status === 'loading') {
            setReviewListState('loading');
            return;
          }

          setReviewListState(initialReviewListState);
        };

        const showFeedbackStatus = (groupName, status) => {
          const group = document.querySelector(`[data-feedback-group="${groupName}"]`);
          if (!group) return;

          const allowedStatuses = feedbackStatuses[groupName] || [];
          const aliasMap = feedbackStatusAliases[groupName] || {};
          const resolvedStatus = aliasMap[status] || status;
          const normalizedStatus = allowedStatuses.includes(resolvedStatus)
            ? resolvedStatus
            : (allowedStatuses.includes('error') ? 'error' : null);
          if (!normalizedStatus) return;

          const messages = Array.from(group.querySelectorAll('[data-feedback-status]'));
          for (const message of messages) {
            const currentStatus = message.getAttribute('data-feedback-status');
            message.classList.toggle('hidden', currentStatus !== normalizedStatus);
          }

          if (groupName === 'review') {
            syncReviewListStateWithReviewFeedback(normalizedStatus);
          }
        };

        const applyFeedback = (groupName, queryParam) => {
          const status = params.get(queryParam);
          if (!status) return;

          if (groupName === 'review') {
            const reviewAttempted = window.sessionStorage.getItem('review-submit-attempted') === '1';
            const serverOutcomeStatuses = new Set(['pending', 'approved', 'rejected']);
            if (!reviewAttempted && !serverOutcomeStatuses.has(status)) {
              return;
            }
          }

          showFeedbackStatus(groupName, status);
        };

        applyFeedback('review', 'review');
        applyFeedback('booking', 'booking');
        applyFeedback('message', 'message');
        if (!params.get('review')) {
          setReviewListState(initialReviewListState);
        }

        const reviewForm = document.querySelector('[data-review-form]');
        if (reviewForm instanceof HTMLFormElement) {
          const markReviewInteracted = () => window.sessionStorage.setItem('review-submit-attempted', '1');
          reviewForm.addEventListener('input', markReviewInteracted, { once: true });
          reviewForm.addEventListener('submit', (event) => {
            markReviewInteracted();
            if (!reviewForm.checkValidity()) {
              event.preventDefault();
              showFeedbackStatus('review', 'invalid');
              reviewForm.reportValidity();
              return;
            }

            showFeedbackStatus('review', 'loading');

            const submitButton = reviewForm.querySelector('[data-review-submit-button]');
            if (submitButton instanceof HTMLButtonElement) {
              const defaultLabel = submitButton.getAttribute('data-default-label') || submitButton.textContent || 'Αποστολή';
              submitButton.disabled = true;
              submitButton.setAttribute('aria-busy', 'true');
              submitButton.textContent = 'Αποστολή...';

              window.setTimeout(() => {
                submitButton.disabled = false;
                submitButton.removeAttribute('aria-busy');
                submitButton.textContent = defaultLabel;
              }, 12000);
            }
          });
        }

        for (const form of document.querySelectorAll('[data-pending-form]')) {
          if (!(form instanceof HTMLFormElement)) continue;
          form.addEventListener('submit', (event) => {
            if (form.hasAttribute('data-booking-form') && !form.checkValidity()) {
              event.preventDefault();
              showFeedbackStatus('booking', 'invalid');
              form.reportValidity();
              return;
            }

            if (form.hasAttribute('data-booking-form')) {
              showFeedbackStatus('booking', 'loading');
            }

            const submitButton = form.querySelector('button[type="submit"]');
            if (!(submitButton instanceof HTMLButtonElement)) return;

            const defaultLabel = submitButton.getAttribute('data-default-label') || submitButton.textContent || 'Αποστολή';
            submitButton.disabled = true;
            submitButton.setAttribute('aria-busy', 'true');
            submitButton.textContent = 'Αποστολή...';

            window.setTimeout(() => {
              submitButton.disabled = false;
              submitButton.removeAttribute('aria-busy');
              submitButton.textContent = defaultLabel;
            }, 12000);
          });
        }
      })();
    </script>
  </main>
</Layout>
