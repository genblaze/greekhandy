---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const profilesFile = await import('../../../data/professionals.json');
const profiles = (profilesFile.default ?? profilesFile) as Array<{
  slug: string;
  name: string;
  profession: string;
  city: string;
  areasServed: string[];
  experienceYears: number;
  bio: string;
  services: string[];
  profilePhotoUrl?: string;
  portfolioPhotos?: string[];
  phone: string;
  email: string;
  approved?: boolean;
  published?: boolean;
}>;

export function getStaticPaths() {
  const profilesFile = Object.values(import.meta.glob('../../../data/professionals.json', { eager: true }))[0] as any;
  const profiles = (profilesFile.default ?? profilesFile) as Array<{ slug: string; approved?: boolean; published?: boolean }>;

  return profiles
    .filter((profile) => profile.approved === true && profile.published === true)
    .map((profile) => ({
    params: { slug: profile.slug },
    props: { profile }
  }));
}

interface ApprovedReview {
  id: string;
  professionalSlug: string;
  reviewerName: string;
  rating: number;
  comment: string;
  verified?: boolean;
  status: 'approved';
  submittedAt: string;
}

const reviewsFile = await import('../../../data/reviews.json');
const approvedReviews = ((reviewsFile.default ?? reviewsFile) as ApprovedReview[])
  .filter((review) => review.status === 'approved' && review.professionalSlug === (Astro.props as { profile: (typeof profiles)[number] }).profile.slug)
  .sort((a, b) => b.submittedAt.localeCompare(a.submittedAt));

const reviewsCount = approvedReviews.length;
const averageRating = reviewsCount > 0
  ? (approvedReviews.reduce((sum, review) => sum + review.rating, 0) / reviewsCount).toFixed(1)
  : null;

const reviewStatus = Astro.url.searchParams.get('review');
const { profile } = Astro.props as { profile: (typeof profiles)[number] };
---

<Layout
  title={`${profile.name} | ${profile.profession} | GreekHandy`}
  description={`Δείτε το προφίλ του/της ${profile.name}, ${profile.profession} στη ${profile.city}.`}
>
  <main class="mx-auto max-w-4xl px-4 py-14">
    <a href="/professionals" class="text-sm font-semibold text-blue-700 hover:underline">&larr; Όλοι οι επαγγελματίες</a>

    <section class="mt-4 rounded-2xl border border-gray-200 bg-white p-7 shadow-sm md:p-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">{profile.profession}</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{profile.name}</h1>
      <p class="mt-2 text-gray-600">{profile.city} • {profile.experienceYears} χρόνια εμπειρίας</p>

      {profile.profilePhotoUrl && <img src={profile.profilePhotoUrl} alt={`Φωτογραφία ${profile.name}`} class="mt-6 h-72 w-full rounded-xl object-cover" />}

      <p class="mt-6 leading-relaxed text-gray-700">{profile.bio}</p>

      {profile.portfolioPhotos && profile.portfolioPhotos.length > 0 && (
        <div class="mt-8">
          <h2 class="text-lg font-bold text-gray-900">Portfolio</h2>
          <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {profile.portfolioPhotos.map((photo, index) => (
              <img src={photo} alt={`Portfolio ${profile.name} ${index + 1}`} class="h-48 w-full rounded-lg border border-gray-200 object-cover" loading="lazy" />
            ))}
          </div>
        </div>
      )}

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <div>
          <h2 class="text-lg font-bold text-gray-900">Υπηρεσίες</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
            {profile.services.map((service) => <li>{service}</li>)}
          </ul>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900">Περιοχές εξυπηρέτησης</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
            {profile.areasServed.map((area) => <li>{area}</li>)}
          </ul>
        </div>
      </div>

      <section class="mt-8 rounded-xl border border-gray-200 bg-white p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-lg font-bold text-gray-900">Αξιολογήσεις</h2>
          {averageRating
            ? <p class="text-sm font-semibold text-amber-700">★ {averageRating}/5 ({reviewsCount} κριτικές)</p>
            : <p class="text-sm text-gray-500">Δεν υπάρχουν εγκεκριμένες κριτικές ακόμη.</p>}
        </div>

        <div class="mt-4 space-y-3">
          {approvedReviews.length === 0 && <p class="text-sm text-gray-600">Γίνετε ο πρώτος που θα αφήσει αξιολόγηση.</p>}
          {approvedReviews.map((review) => (
            <article class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="font-semibold text-gray-900">{review.reviewerName}</p>
                <p class="text-sm text-amber-700">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)} ({review.rating}/5)</p>
              </div>
              <p class="mt-2 text-sm text-gray-700">{review.comment}</p>
              <p class="mt-1 text-xs text-gray-500">{new Date(review.submittedAt).toLocaleDateString('el-GR')}{review.verified ? ' • Επιβεβαιωμένη' : ''}</p>
            </article>
          ))}
        </div>

        <form action="/api/reviews/submit" method="POST" class="mt-6 rounded-lg border border-blue-100 bg-blue-50 p-4">
          <h3 class="text-base font-bold text-gray-900">Υποβολή κριτικής</h3>
          <p class="mt-1 text-xs text-gray-600">Οι κριτικές περνούν πρώτα από έγκριση πριν εμφανιστούν δημόσια.</p>

          {reviewStatus === 'submitted' && <p class="mt-3 rounded-md bg-green-100 px-3 py-2 text-sm text-green-800">Ευχαριστούμε! Η κριτική σας υποβλήθηκε για έλεγχο.</p>}
          {reviewStatus === 'invalid' && <p class="mt-3 rounded-md bg-amber-100 px-3 py-2 text-sm text-amber-800">Συμπληρώστε βαθμολογία και σχόλιο.</p>}
          {reviewStatus === 'error' && <p class="mt-3 rounded-md bg-red-100 px-3 py-2 text-sm text-red-800">Παρουσιάστηκε πρόβλημα. Δοκιμάστε ξανά.</p>}

          <input type="hidden" name="professionalSlug" value={profile.slug} />
          <input type="hidden" name="returnTo" value={`/professionals/${profile.slug}`} />

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            <div>
              <label for="reviewerName" class="mb-1 block text-sm font-semibold text-gray-800">Όνομα</label>
              <input id="reviewerName" name="reviewerName" type="text" maxlength="80" class="w-full rounded-lg border border-gray-300 px-3 py-2.5" />
            </div>
            <div>
              <label for="rating" class="mb-1 block text-sm font-semibold text-gray-800">Βαθμολογία (1-5) *</label>
              <select id="rating" name="rating" required class="w-full rounded-lg border border-gray-300 px-3 py-2.5">
                <option value="">Επιλέξτε</option>
                <option value="5">5 - Εξαιρετικά</option>
                <option value="4">4 - Πολύ καλά</option>
                <option value="3">3 - Καλά</option>
                <option value="2">2 - Μέτρια</option>
                <option value="1">1 - Χρειάζεται βελτίωση</option>
              </select>
            </div>
          </div>

          <div class="mt-4">
            <label for="comment" class="mb-1 block text-sm font-semibold text-gray-800">Σχόλιο *</label>
            <textarea id="comment" name="comment" rows="4" required maxlength="1200" class="w-full rounded-lg border border-gray-300 px-3 py-2.5"></textarea>
          </div>

          <button type="submit" class="mt-4 rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Αποστολή κριτικής</button>
        </form>
      </section>

      <div class="mt-8 rounded-xl bg-blue-50 p-5">
        <h2 class="text-lg font-bold text-gray-900">Στοιχεία επικοινωνίας</h2>
        <p class="mt-2 text-gray-700">Τηλέφωνο: <a href={`tel:${profile.phone}`} class="font-semibold text-blue-700">{profile.phone}</a></p>
        <p class="mt-1 text-gray-700">Email: <a href={`mailto:${profile.email}`} class="font-semibold text-blue-700">{profile.email}</a></p>
      </div>
    </section>
  </main>
</Layout>
