---
import Layout from '../../layouts/Layout.astro';
import { readFormFlash, clearFormFlash } from '../../lib/form-flash';

const status = Astro.url.searchParams.get('status') || '';
const registerFlash = readFormFlash(Astro.cookies, 'register');
const registerValues = registerFlash.values || {};
const registerErrors = registerFlash.errors || {};

const getValue = (field: string) => registerValues[field] || '';
const getError = (field: string) => registerErrors[field] || '';

if (status === 'invalid' || status === 'error') {
  clearFormFlash(Astro.cookies, 'register');
}

