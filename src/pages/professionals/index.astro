---
import Layout from '../../layouts/Layout.astro';
import { assertPublishedProfilesHaveValidMedia, getProfessionalFallbackImage, resolveProfessionalImageForPublishedProfile } from '../../lib/professional-images';

type ProfessionalProfile = {
  slug: string;
  name: string;
  profession: string;
  city: string;
  areasServed: string[];
  experienceYears: number;
  bio: string;
  services: string[];
  profilePhotoUrl?: string;
  portfolioPhotos?: string[];
  approved?: boolean;
  published?: boolean;
};

let profiles: ProfessionalProfile[] = [];
let profilesLoadError = '';

try {
  const profilesFile = await import('../../../data/professionals.json');
  profiles = ((profilesFile.default ?? profilesFile) as ProfessionalProfile[])
    .filter((profile) => profile.approved === true && profile.published === true);
} catch {
  profilesLoadError = 'Η λίστα επαγγελματιών δεν μπόρεσε να φορτωθεί πλήρως αυτή τη στιγμή.';
}

await assertPublishedProfilesHaveValidMedia(profiles);

const fallbackProfileImage = getProfessionalFallbackImage();
type ReviewRecord = { professionalSlug?: string; status?: string; verified?: boolean };
let approvedReviewsBySlug = new Map<string, { total: number; verified: number }>();
try {
  const reviewsFile = await import('../../../data/reviews.json');
  const reviews = ((reviewsFile.default ?? reviewsFile) as ReviewRecord[])
    .filter((review) => review.status === 'approved' && typeof review.professionalSlug === 'string');
  for (const review of reviews) {
    const key = (review.professionalSlug || '').trim();
    if (!key) continue;
    const current = approvedReviewsBySlug.get(key) || { total: 0, verified: 0 };
    current.total += 1;
    if (review.verified) current.verified += 1;
    approvedReviewsBySlug.set(key, current);
  }
} catch {
  approvedReviewsBySlug = new Map();
}

const MEDIA_GRADIENTS = [
  ['#0b3b66', '#1f6da8'],
  ['#0f3d2e', '#21835f'],
  ['#4f2f18', '#a86026'],
  ['#3f2a61', '#7154b8'],
  ['#1f2937', '#4b5563']
] as const;

const hashValue = (value: string) => {
  let hash = 2166136261;
  for (const char of Array.from(value)) {
    hash ^= char.codePointAt(0) || 0;
    hash = Math.imul(hash, 16777619);
  }
  return Math.abs(hash >>> 0);
};

const escapeXml = (value: string) => value
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;')
  .replace(/'/g, '&apos;');

const getInitials = (name: string) => {
  const parts = name.trim().split(/\s+/).filter(Boolean);
  const initials = parts.slice(0, 2).map((part) => Array.from(part)[0] || '').join('').toUpperCase();
  return initials || 'GH';
};

const truncateLabel = (value: string, maxLength: number) => {
  const chars = Array.from((value || '').trim());
  if (chars.length <= maxLength) return chars.join('');
  return `${chars.slice(0, maxLength).join('')}…`;
};

const isDeterministicRealPhoto = (src: string) => {
  const clean = src.split('#')[0].split('?')[0].toLowerCase();
  if (!clean) return false;
  if (clean === fallbackProfileImage) return false;
  if (clean.startsWith('data:image/')) return !clean.startsWith('data:image/svg+xml');
  return /\.(avif|gif|jpe?g|png|webp)$/i.test(clean);
};

const buildIdentityPlaceholder = (profile: Pick<ProfessionalProfile, 'slug' | 'name' | 'profession'>) => {
  const key = `${profile.slug}|${profile.name}|${profile.profession}`;
  const [top, bottom] = MEDIA_GRADIENTS[hashValue(key) % MEDIA_GRADIENTS.length];
  const initials = escapeXml(getInitials(profile.name));
  const safeProfession = escapeXml(truncateLabel(profile.profession, 36));
  const svg = `
<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="${top}" />
      <stop offset="100%" stop-color="${bottom}" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" rx="28" fill="url(#bg)" />
  <circle cx="130" cy="130" r="66" fill="rgba(255,255,255,0.18)" />
  <text x="130" y="150" text-anchor="middle" font-family="Inter,Arial,sans-serif" font-size="56" font-weight="700" fill="#ffffff">${initials}</text>
  <rect x="44" y="430" width="292" height="38" rx="19" fill="rgba(255,255,255,0.2)" />
  <text x="190" y="455" text-anchor="middle" font-family="Inter,Arial,sans-serif" font-size="18" font-weight="700" fill="#ffffff">GreekHandy Verified</text>
  <text x="44" y="514" font-family="Inter,Arial,sans-serif" font-size="32" font-weight="700" fill="#ffffff">${safeProfession}</text>
</svg>`;
  return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg.trim())}`;
};

const profilesWithSafeImage = await Promise.all(
  profiles.map(async (profile) => {
    const reviewStats = approvedReviewsBySlug.get(profile.slug) || { total: 0, verified: 0 };
    const serviceAreas = Array.isArray(profile.areasServed) && profile.areasServed.length > 0
      ? profile.areasServed
      : [profile.city].filter(Boolean);
    const reviewsLabel = reviewStats.total === 1 ? 'κριτική' : 'κριτικές';
    const verifiedLabel = reviewStats.verified === 1 ? 'επιβεβαιωμένη' : 'επιβεβαιωμένες';
    const primaryArea = serviceAreas[0] || profile.city || 'Η περιοχή σας';
    const extraAreasCount = Math.max(serviceAreas.length - 1, 0);
    const resolvedProfileImage = await resolveProfessionalImageForPublishedProfile(profile.profilePhotoUrl);
    const brandedPlaceholderImage = buildIdentityPlaceholder(profile);
    const usesRealPhoto = isDeterministicRealPhoto(resolvedProfileImage);
    const reviewTotal = reviewStats.total;
    const verifiedJobs = reviewStats.verified;
    const verifiedCoverage = reviewTotal > 0 ? Math.round((verifiedJobs / reviewTotal) * 100) : 0;
    const imageProvenance = usesRealPhoto
      ? 'Φωτογραφία προφίλ που αποδίδεται κανονικά στην κάρτα.'
      : 'Branded verified placeholder GreekHandy, σταθερό ανά επαγγελματία.';
    const reviewProvenance = reviewTotal > 0
      ? `${reviewTotal} εγκεκριμένες κριτικές στο GreekHandy (${verifiedJobs} επιβεβαιωμένες).`
      : 'Δεν υπάρχουν ακόμη εγκεκριμένες κριτικές για δημόσια προβολή.';
    const jobsProvenance = verifiedJobs > 0
      ? `${verifiedJobs} επιβεβαιωμένα αιτήματα συνδεδεμένα με πραγματικές αναθέσεις.`
      : 'Θα εμφανιστεί μόλις εγκριθεί η πρώτη επιβεβαιωμένη αξιολόγηση.';
    const trustHeadline = verifiedJobs >= 3
      ? 'Ισχυρή απόδειξη εμπειρίας'
      : reviewTotal > 0
        ? 'Επαληθευμένη αρχική δραστηριότητα'
        : 'Δημοσιευμένο και ελεγμένο προφίλ';

    return {
      ...profile,
      reviewStats,
      serviceAreas,
      reviewsLabel,
      verifiedLabel,
      primaryArea,
      extraAreasCount,
      trustHeadline,
      verifiedJobs,
      verifiedCoverage,
      imageProvenance,
      reviewProvenance,
      jobsProvenance,
      usesRealPhoto,
      cardImageSrc: usesRealPhoto ? resolvedProfileImage : brandedPlaceholderImage,
      mediaFallbackSrc: usesRealPhoto ? brandedPlaceholderImage : fallbackProfileImage,
      mediaState: usesRealPhoto ? 'photo' : 'placeholder'
    };
  })
);

const professionOptions = Array.from(new Set(profilesWithSafeImage.map((profile) => profile.profession))).sort((a, b) => a.localeCompare(b, 'el'));
const cityOptions = Array.from(new Set(profilesWithSafeImage.map((profile) => profile.city))).sort((a, b) => a.localeCompare(b, 'el'));
---

<Layout
  title="Επαγγελματίες | GreekHandy"
  description="Γνωρίστε διαθέσιμους επαγγελματίες της GreekHandy ανά ειδικότητα και περιοχή."
>
  <main class="mx-auto max-w-6xl px-4 py-14">
    <section class="mb-10">
      <h1 class="text-3xl font-bold text-gray-900 md:text-4xl">Επαγγελματίες GreekHandy</h1>
      <p class="mt-3 max-w-3xl text-gray-700">Βρείτε επαγγελματίες με εμπειρία, δείτε βασικά στοιχεία προφίλ και επικοινωνήστε για το έργο σας.</p>
      <a href="/professionals/register" class="mt-5 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800">Είστε επαγγελματίας; Κάντε αίτηση</a>
      <p class="mt-3 text-sm text-gray-500">Διαθέσιμα προφίλ: <span class="font-semibold text-gray-700">{profiles.length}</span></p>
    </section>

    {profilesLoadError && (
      <div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert" aria-live="assertive">
        <p class="font-semibold">Μερική αστοχία φόρτωσης.</p>
        <p class="mt-1">{profilesLoadError}</p>
      </div>
    )}

    {profiles.length === 0 && (
      <section class="rounded-xl border border-slate-200 bg-white px-5 py-6 text-slate-700 shadow-sm">
        <p class="text-lg font-semibold text-slate-900">Δεν υπάρχουν ακόμη διαθέσιμα προφίλ.</p>
        <p class="mt-2 text-sm">Μπορείτε να συνεχίσετε από τις κατηγορίες υπηρεσιών ή να υποβάλετε αίτηση ως επαγγελματίας.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href="/" class="inline-flex rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">Αρχική και κατηγορίες</a>
          <a href="/professionals/register" class="inline-flex rounded-lg border border-blue-300 bg-blue-50 px-3.5 py-2 text-xs font-semibold text-blue-900 transition hover:border-blue-400 hover:bg-blue-100">Εγγραφή επαγγελματία</a>
        </div>
      </section>
    )}

    {profiles.length > 0 && (
      <section data-prof-filters class="mb-6 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="grid gap-3 md:grid-cols-3">
          <div>
            <label for="profession-search" class="text-xs font-semibold uppercase tracking-wide text-slate-600">Αναζήτηση</label>
            <input id="profession-search" data-filter-search type="search" aria-describedby="profession-search-help" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900" />
            <p id="profession-search-help" class="mt-1 text-xs text-slate-500">Αναζητήστε με όνομα, ειδικότητα ή πόλη.</p>
          </div>
          <div>
            <label for="profession-filter" class="text-xs font-semibold uppercase tracking-wide text-slate-600">Ειδικότητα</label>
            <select id="profession-filter" data-filter-profession class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900">
              <option value="all">Όλες</option>
              {professionOptions.map((profession) => <option value={profession}>{profession}</option>)}
            </select>
          </div>
          <div>
            <label for="city-filter" class="text-xs font-semibold uppercase tracking-wide text-slate-600">Πόλη</label>
            <select id="city-filter" data-filter-city class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900">
              <option value="all">Όλες</option>
              {cityOptions.map((city) => <option value={city}>{city}</option>)}
            </select>
          </div>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-2" data-active-filters aria-live="polite"></div>
        <div class="mt-3 flex items-center justify-between gap-2">
          <p data-filter-summary class="text-xs text-slate-600">Εμφανίζονται {profiles.length} από {profiles.length} επαγγελματίες.</p>
          <button type="button" data-reset-filters class="inline-flex rounded-md border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50">Καθαρισμός φίλτρων</button>
        </div>
      </section>
    )}

    <section class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3" data-profiles-grid>
      {profilesWithSafeImage.map(profile => (
        <article data-profile-card data-name={profile.name.toLowerCase()} data-profession={profile.profession} data-city={profile.city} class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm focus-within:ring-2 focus-within:ring-sky-500 md:p-5">
          <div class="mb-4 overflow-hidden rounded-lg border border-slate-200 bg-gradient-to-br from-slate-100 to-slate-200 aspect-[4/3]" data-prof-media-shell>
            <p class="absolute left-2 top-2 z-10 rounded-full border border-white/60 bg-slate-900/65 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-white">
              {profile.usesRealPhoto ? 'Φωτογραφία προφίλ' : 'Verified placeholder'}
            </p>
            <img
              src={profile.cardImageSrc}
              alt={`Φωτογραφία ${profile.name}`}
              class="h-full w-full object-cover transition-opacity duration-300"
              loading="lazy"
              decoding="async"
              data-prof-media-img
              data-fallback-src={profile.mediaFallbackSrc}
              data-media-state={profile.mediaState}
              onerror="this.onerror=null;const fallback=this.dataset.fallbackSrc||'';if(fallback){this.src=fallback;this.dataset.mediaState='placeholder';}"
            />
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <p class="rounded-full border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-800 md:rounded-none md:border-0 md:bg-transparent md:px-0 md:py-0 md:text-sm md:text-blue-700">{profile.profession}</p>
            <p class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-700 md:hidden">{profile.city}</p>
          </div>
          <h2 class="mt-2 text-xl font-bold text-gray-900">{profile.name}</h2>
          <p class="mt-1 hidden text-sm text-gray-600 md:block">{profile.city} • {profile.experienceYears} χρόνια εμπειρίας</p>
          <p class="mt-1 text-xs text-gray-600 md:hidden">{profile.experienceYears} χρόνια εμπειρίας</p>
          <p class="mt-2 text-xs font-semibold text-slate-800">{profile.trustHeadline}</p>

          <p class="mt-3 line-clamp-3 text-sm text-gray-700">{profile.bio?.trim() || 'Επαγγελματικό προφίλ διαθέσιμο για ανάθεση έργων στην περιοχή σας.'}</p>
          <div class="mt-3 flex flex-wrap gap-1.5" aria-label="Σήματα αξιοπιστίας επαγγελματία">
            <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-[11px] font-semibold text-emerald-800">
              Ταυτότητα: επαληθευμένη
            </span>
            <span class="rounded-full border border-blue-200 bg-blue-50 px-2 py-0.5 text-[11px] font-semibold text-blue-800">
              Κριτικές: {profile.reviewStats.total}
            </span>
            <span class="rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-[11px] font-semibold text-amber-800">
              Αιτήματα: {profile.verifiedJobs > 0 ? profile.verifiedJobs : 'χωρίς δημοσιευμένα'}
            </span>
            <span class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[11px] font-semibold text-slate-700">
              Επαλήθευση κριτικών: {profile.verifiedCoverage}%
            </span>
          </div>
          <div class="mt-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
            <p class="text-[11px] font-semibold uppercase tracking-wide text-slate-600">Προέλευση στοιχείων</p>
            <p class="mt-1 text-xs text-slate-700"><span class="font-semibold">Φωτογραφία:</span> {profile.imageProvenance}</p>
            <p class="mt-1 text-xs text-slate-700"><span class="font-semibold">Κριτικές:</span> {profile.reviewProvenance}</p>
            <p class="mt-1 text-xs text-slate-700"><span class="font-semibold">Ιστορικό έργων:</span> {profile.jobsProvenance}</p>
          </div>
          <p class="mt-3 text-xs uppercase tracking-wide text-gray-500">Περιοχές: {profile.serviceAreas.join(', ')}</p>
          <a href={`/professionals/${profile.slug}`} class="mt-4 inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500">Προβολή προφίλ</a>
        </article>
      ))}
    </section>

    <section data-no-results class="mt-6 hidden rounded-xl border border-dashed border-slate-300 bg-white px-5 py-6 text-slate-700" role="status" aria-live="polite">
      <p class="text-lg font-semibold text-slate-900">Δεν βρέθηκαν αποτελέσματα.</p>
      <p class="mt-1 text-sm">Δοκιμάστε λιγότερα φίλτρα ή πατήστε «Καθαρισμός φίλτρων».</p>
    </section>

    <style>
      [data-prof-media-shell] { position: relative; }
      [data-prof-media-shell]::after { content: ""; position: absolute; inset: 0; background: linear-gradient(120deg, rgba(255,255,255,0.04), rgba(255,255,255,0.3), rgba(255,255,255,0.04)); pointer-events: none; }
      [data-prof-media-img][data-media-state="fallback"] { object-fit: contain; background: linear-gradient(135deg, #e2e8f0, #f8fafc); padding: 0.75rem; }
    </style>

    <script is:inline>
      (() => {
        const root = document.querySelector('[data-prof-filters]');
        const grid = document.querySelector('[data-profiles-grid]');
        if (!(root instanceof HTMLElement) || !(grid instanceof HTMLElement)) return;

        const search = root.querySelector('[data-filter-search]');
        const profession = root.querySelector('[data-filter-profession]');
        const city = root.querySelector('[data-filter-city]');
        const reset = root.querySelector('[data-reset-filters]');
        const active = root.querySelector('[data-active-filters]');
        const summary = root.querySelector('[data-filter-summary]');
        const noResults = document.querySelector('[data-no-results]');
        const cards = Array.from(grid.querySelectorAll('[data-profile-card]'));
        const mediaImages = Array.from(grid.querySelectorAll('[data-prof-media-img]')).filter((item) => item instanceof HTMLImageElement);

        const state = { q: '', profession: 'all', city: 'all' };
        const hardenMedia = () => {
          for (const img of mediaImages) {
            if (!(img instanceof HTMLImageElement)) continue;
            const fallbackSrc = img.dataset.fallbackSrc || '';
            const ensureFallback = () => {
              if (!fallbackSrc) return;
              img.dataset.mediaState = 'fallback';
              if (img.src !== fallbackSrc) img.src = fallbackSrc;
            };
            img.addEventListener('error', ensureFallback);
            if (img.complete && (!img.naturalWidth || !img.naturalHeight)) ensureFallback();
          }
        };
        hardenMedia();


        const renderChips = () => {
          if (!(active instanceof HTMLElement)) return;
          active.innerHTML = '';
          const chips = [];
          if (state.q.trim()) chips.push(`Αναζήτηση: ${state.q.trim()}`);
          if (state.profession !== 'all') chips.push(`Ειδικότητα: ${state.profession}`);
          if (state.city !== 'all') chips.push(`Πόλη: ${state.city}`);
          chips.forEach((chip) => {
            const span = document.createElement('span');
            span.className = 'rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-semibold text-sky-900';
            span.textContent = chip;
            active.appendChild(span);
          });
        };

        const apply = () => {
          const q = state.q.trim().toLowerCase();
          let visible = 0;
          cards.forEach((card) => {
            if (!(card instanceof HTMLElement)) return;
            const name = card.dataset.name || '';
            const p = (card.dataset.profession || '').toLowerCase();
            const c = card.dataset.city || '';
            const professionValue = card.dataset.profession || '';
            const match = (state.profession === 'all' || professionValue === state.profession)
              && (state.city === 'all' || c === state.city)
              && (!q || `${name} ${p} ${c.toLowerCase()}`.includes(q));
            card.hidden = !match;
            if (match) visible += 1;
          });
          renderChips();
          if (summary instanceof HTMLElement) summary.textContent = `Εμφανίζονται ${visible} από ${cards.length} επαγγελματίες.`;
          if (noResults instanceof HTMLElement) noResults.classList.toggle('hidden', visible > 0);
        };

        search?.addEventListener('input', (e) => {
          const target = e.currentTarget;
          if (!(target instanceof HTMLInputElement)) return;
          state.q = target.value;
          apply();
        });
        profession?.addEventListener('change', (e) => {
          const target = e.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.profession = target.value;
          apply();
        });
        city?.addEventListener('change', (e) => {
          const target = e.currentTarget;
          if (!(target instanceof HTMLSelectElement)) return;
          state.city = target.value;
          apply();
        });
        reset?.addEventListener('click', () => {
          state.q = '';
          state.profession = 'all';
          state.city = 'all';
          if (search instanceof HTMLInputElement) search.value = '';
          if (profession instanceof HTMLSelectElement) profession.value = 'all';
          if (city instanceof HTMLSelectElement) city.value = 'all';
          apply();
          if (search instanceof HTMLInputElement) search.focus();
        });

        window.addEventListener('keydown', (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          if (event.key === '/' && document.activeElement !== search) {
            event.preventDefault();
            if (search instanceof HTMLInputElement) search.focus();
          }
          if (event.key === 'Escape' && document.activeElement === search) {
            state.q = '';
            if (search instanceof HTMLInputElement) search.value = '';
            apply();
          }
        });
      })();
    </script>
  </main>
</Layout>
