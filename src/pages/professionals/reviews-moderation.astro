---
import Layout from '../../layouts/Layout.astro';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

const SUBMISSIONS_FILE_PATH = resolve(process.cwd(), 'data', 'review-submissions.ndjson');
const ACTIONS_FILE_PATH = resolve(process.cwd(), 'data', 'review-moderation-actions.ndjson');

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const expectedKey = process.env.PROFESSIONAL_MODERATION_KEY ?? '';
const isAuthorized = Boolean(expectedKey && moderationKey === expectedKey);
const status = url.searchParams.get('status');

interface ReviewSubmission {
  professionalSlug: string;
  reviewerName?: string;
  rating: number;
  comment: string;
  status: 'pending';
  submittedAt: string;
}

interface ActionLog {
  reviewId: string;
  action: string;
  actedAt: string;
}

const readNdjson = async <T,>(path: string): Promise<T[]> => {
  try {
    const raw = await readFile(path, 'utf-8');
    return raw
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => JSON.parse(line) as T);
  } catch {
    return [];
  }
};

const submissions = await readNdjson<ReviewSubmission>(SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<ActionLog>(ACTIONS_FILE_PATH);

const latestActionById = new Map<string, ActionLog>();
for (const action of actions) latestActionById.set(action.reviewId, action);

const pendingReviews = submissions
  .map((review) => {
    const reviewId = `${review.professionalSlug}|${review.submittedAt}`;
    const latestAction = latestActionById.get(reviewId);
    return { review, reviewId, latestAction };
  })
  .filter((item) => !item.latestAction)
  .reverse();

const stars = (rating: number) => '★★★★★'.slice(0, rating) + '☆☆☆☆☆'.slice(0, 5 - rating);
---

<Layout title="Moderation Reviews | GreekHandy" description="Internal moderation workflow for submitted reviews.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Moderation Reviews</h1>
    <p class="mt-2 text-gray-700">Εσωτερική σελίδα έγκρισης αξιολογήσεων επαγγελματιών.</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        Μη εξουσιοδοτημένη πρόσβαση. Προσθέστε <code>?key=...</code> και ορίστε env <code>PROFESSIONAL_MODERATION_KEY</code>.
      </div>
    )}

    {isAuthorized && (
      <>
        {status === 'ok' && <p class="mt-5 rounded-lg bg-green-50 px-4 py-3 text-green-800">Η ενέργεια ολοκληρώθηκε.</p>}
        {status === 'error' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800">Προέκυψε σφάλμα κατά την επεξεργασία.</p>}

        <section class="mt-8 space-y-4">
          <h2 class="text-xl font-bold text-gray-900">Εκκρεμείς Κριτικές ({pendingReviews.length})</h2>

          {pendingReviews.length === 0 && (
            <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700">Δεν υπάρχουν εκκρεμείς κριτικές.</p>
          )}

          {pendingReviews.map(({ review, reviewId }) => (
            <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-blue-700">/{review.professionalSlug}</p>
                  <h3 class="text-lg font-bold text-gray-900">{review.reviewerName || 'Ανώνυμος Πελάτης'}</h3>
                  <p class="text-sm text-amber-700">{stars(review.rating)} ({review.rating}/5)</p>
                </div>
                <p class="text-xs text-gray-500">{new Date(review.submittedAt).toLocaleString('el-GR')}</p>
              </div>

              <p class="mt-3 text-sm text-gray-700">{review.comment}</p>

              <div class="mt-4 flex flex-wrap gap-3">
                <form action="/api/reviews/moderate" method="POST" class="space-y-3">
                  <input type="hidden" name="moderationKey" value={moderationKey} />
                  <input type="hidden" name="action" value="approve" />
                  <input type="hidden" name="reviewId" value={reviewId} />
                  <input type="hidden" name="review" value={JSON.stringify(review)} />

                  <label class="flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="verified" value="true" class="h-4 w-4 rounded border-gray-300" />
                    Επιβεβαιωμένη αξιολόγηση (συνδεδεμένη με πραγματικό αίτημα)
                  </label>

                  <button type="submit" class="rounded-lg bg-green-700 px-4 py-2 text-sm font-semibold text-white hover:bg-green-800">Approve</button>
                </form>

                <form action="/api/reviews/moderate" method="POST">
                  <input type="hidden" name="moderationKey" value={moderationKey} />
                  <input type="hidden" name="action" value="reject" />
                  <input type="hidden" name="reviewId" value={reviewId} />
                  <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800">Reject</button>
                </form>
              </div>
            </article>
          ))}
        </section>
      </>
    )}
  </main>
</Layout>
