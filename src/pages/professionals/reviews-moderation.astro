---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabase-server';
import { getAdminAuth } from '../../lib/admin-auth';

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const status = url.searchParams.get('status');
const actor = (url.searchParams.get('actor') ?? 'admin').slice(0, 120);
const result = url.searchParams.get('result');
const summary = url.searchParams.get('summary');
const verification = url.searchParams.get('verification');
const { expectedKey, token: authToken, isAuthorized } = getAdminAuth(Astro, moderationKey);

interface ModerationFeedbackView {
  toneClass: string;
  title: string;
  message: string;
  detail?: string;
}

const moderationFeedback: ModerationFeedbackView | null = (() => {
  if (!status) return null;

  const isApprovedResult = result === 'approved';
  const isRejectedResult = result === 'rejected';
  const summaryMessage = summary === 'included'
    ? 'Σύνοψη προφίλ: η κριτική υπολογίζεται πλέον στη δημόσια βαθμολογία.'
    : 'Σύνοψη προφίλ: η κριτική δεν υπολογίζεται στη δημόσια βαθμολογία.';

  if (status === 'ok' && isApprovedResult) {
    const detail = verification === 'verified'
      ? 'Κατάσταση verification: Επιβεβαιωμένη αξιολόγηση.'
      : (verification === 'requested-no-match'
        ? 'Κατάσταση verification: ζητήθηκε verified, αλλά δεν βρέθηκε αντίστοιχο lead.'
        : 'Κατάσταση verification: δημοσιεύτηκε χωρίς verified badge.');
    return {
      toneClass: 'border-green-200 bg-green-50 text-green-800',
      title: 'Η κριτική εγκρίθηκε.',
      message: summaryMessage,
      detail
    };
  }

  if (status === 'ok' && isRejectedResult) {
    return {
      toneClass: 'border-slate-300 bg-slate-100 text-slate-800',
      title: 'Η κριτική απορρίφθηκε.',
      message: summaryMessage
    };
  }

  if (status === 'already-processed') {
    const title = isApprovedResult
      ? 'Η κριτική είχε ήδη εγκριθεί από άλλο moderator.'
      : (isRejectedResult
        ? 'Η κριτική είχε ήδη απορριφθεί από άλλο moderator.'
        : 'Η κριτική έχει ήδη επεξεργαστεί από άλλο moderator.');
    return {
      toneClass: 'border-blue-200 bg-blue-50 text-blue-800',
      title,
      message: summaryMessage
    };
  }

  if (status === 'audit-error') {
    return {
      toneClass: 'border-red-200 bg-red-50 text-red-800',
      title: 'Η αλλαγή αποθηκεύτηκε, αλλά απέτυχε η καταγραφή audit.',
      message: summaryMessage,
      detail: 'Ελέγξτε τα logs για το audit trail.'
    };
  }

  if (status === 'invalid') {
    return {
      toneClass: 'border-amber-200 bg-amber-50 text-amber-800',
      title: 'Μη έγκυρο αίτημα moderation.',
      message: 'Ελέγξτε τα πεδία action/review και υποβάλετε ξανά.'
    };
  }

  if (status === 'not-found') {
    return {
      toneClass: 'border-amber-200 bg-amber-50 text-amber-800',
      title: 'Η κριτική δεν βρέθηκε.',
      message: 'Πιθανότατα έχει αφαιρεθεί ή ήδη επεξεργαστεί.'
    };
  }

  return {
    toneClass: 'border-red-200 bg-red-50 text-red-800',
    title: 'Προέκυψε σφάλμα κατά την επεξεργασία.',
    message: 'Δεν καταχωρήθηκε αξιόπιστα αποτέλεσμα moderation. Δοκιμάστε ξανά.'
  };
})();

interface PendingReview {
  id: string;
  service_slug: string;
  reviewer_name: string;
  reviewer_email?: string;
  rating: number;
  comment: string;
  created_at: string;
}

const { data } = isAuthorized
  ? await supabaseServer
      .from('reviews')
      .select('id, service_slug, reviewer_name, reviewer_email, rating, comment, created_at')
      .eq('status', 'pending')
      .order('created_at', { ascending: false })
  : { data: [] as PendingReview[] };

const pendingReviews = (data || []) as PendingReview[];
const stars = (rating: number) => '★★★★★'.slice(0, rating) + '☆☆☆☆☆'.slice(0, 5 - rating);
---

<Layout title="Moderation Reviews | GreekHandy" description="Internal moderation workflow for submitted reviews.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Moderation Reviews</h1>
    <p class="mt-2 text-gray-700">Εσωτερική σελίδα έγκρισης αξιολογήσεων επαγγελματιών.</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <p class="font-semibold">Μη εξουσιοδοτημένη πρόσβαση.</p>
        <p class="mt-1 text-sm">Συνδεθείτε με moderation key.</p>
        <form method="GET" class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input name="key" type="password" required class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-sm text-gray-900" placeholder="Moderation key" />
          <button type="submit" class="rounded-lg bg-amber-700 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-800">Σύνδεση</button>
        </form>
        {!expectedKey && <p class="mt-2 text-xs">Missing env: <code>PROFESSIONAL_MODERATION_KEY</code></p>}
      </div>
    )}

    {isAuthorized && (
      <>
        {moderationFeedback && (
          <div class={`mt-5 rounded-lg border px-4 py-3 ${moderationFeedback.toneClass}`} aria-live="polite">
            <p class="font-semibold">{moderationFeedback.title}</p>
            <p class="mt-1 text-sm">{moderationFeedback.message}</p>
            {moderationFeedback.detail && <p class="mt-1 text-xs opacity-90">{moderationFeedback.detail}</p>}
          </div>
        )}

        <section class="mt-8 space-y-4">
          <h2 class="text-xl font-bold text-gray-900">Εκκρεμείς Κριτικές ({pendingReviews.length})</h2>

          {pendingReviews.length === 0 && (
            <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700">Δεν υπάρχουν εκκρεμείς κριτικές.</p>
          )}

          {pendingReviews.map((review) => (
            <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-blue-700">/{review.service_slug}</p>
                  <h3 class="text-lg font-bold text-gray-900">{review.reviewer_name || 'Ανώνυμος Πελάτης'}</h3>
                  {review.reviewer_email && <p class="text-xs text-gray-500">{review.reviewer_email}</p>}
                  <p class="text-sm text-amber-700">{stars(review.rating)} ({review.rating}/5)</p>
                </div>
                <p class="text-xs text-gray-500">{new Date(review.created_at).toLocaleString('el-GR')}</p>
              </div>

              <p class="mt-3 text-sm text-gray-700">{review.comment}</p>

              <div class="mt-4 flex flex-wrap gap-3">
                <form action="/api/reviews/moderate" method="POST" class="space-y-3" data-review-action-form>
                  <input type="hidden" name="moderationKey" value={authToken} />
                  <input type="hidden" name="actorIdentifier" value={actor} />
                  <input type="hidden" name="action" value="approve" />
                  <input type="hidden" name="reviewId" value={review.id} />

                  <label class="flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="verified" value="true" class="h-4 w-4 rounded border-gray-300" />
                    Επιβεβαιωμένη αξιολόγηση (συνδεδεμένη με πραγματικό αίτημα)
                  </label>

                  <button type="submit" class="rounded-lg bg-green-700 px-4 py-2 text-sm font-semibold text-white hover:bg-green-800">Approve</button>
                </form>

                <form action="/api/reviews/moderate" method="POST" data-review-action-form>
                  <input type="hidden" name="moderationKey" value={authToken} />
                  <input type="hidden" name="actorIdentifier" value={actor} />
                  <input type="hidden" name="action" value="reject" />
                  <input type="hidden" name="reviewId" value={review.id} />
                  <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800">Reject</button>
                </form>
              </div>
            </article>
          ))}
        </section>
      </>
    )}
  </main>

  <script>
    const forms = Array.from(document.querySelectorAll('[data-review-action-form]'));
    for (const form of forms) {
      form.addEventListener('submit', () => {
        const controls = form.querySelectorAll('button, input, select, textarea');
        controls.forEach((el) => {
          if (el instanceof HTMLButtonElement) {
            el.disabled = true;
            el.textContent = 'Processing...';
          } else if (el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement) {
            el.disabled = true;
          }
        });
      }, { once: true });
    }
  </script>
</Layout>
