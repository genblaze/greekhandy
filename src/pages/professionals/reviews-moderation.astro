---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabase-server';
import { getAdminAuth } from '../../lib/admin-auth';

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const status = url.searchParams.get('status');
const actor = (url.searchParams.get('actor') ?? 'admin').slice(0, 120);
const { expectedKey, token: authToken, isAuthorized } = getAdminAuth(Astro, moderationKey);

interface PendingReview {
  id: string;
  service_slug: string;
  reviewer_name: string;
  reviewer_email?: string;
  rating: number;
  comment: string;
  created_at: string;
}

const { data } = isAuthorized
  ? await supabaseServer
      .from('reviews')
      .select('id, service_slug, reviewer_name, reviewer_email, rating, comment, created_at')
      .eq('status', 'pending')
      .order('created_at', { ascending: false })
  : { data: [] as PendingReview[] };

const pendingReviews = (data || []) as PendingReview[];
const stars = (rating: number) => '★★★★★'.slice(0, rating) + '☆☆☆☆☆'.slice(0, 5 - rating);
---

<Layout title="Moderation Reviews | GreekHandy" description="Internal moderation workflow for submitted reviews.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Moderation Reviews</h1>
    <p class="mt-2 text-gray-700">Εσωτερική σελίδα έγκρισης αξιολογήσεων επαγγελματιών.</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <p class="font-semibold">Μη εξουσιοδοτημένη πρόσβαση.</p>
        <p class="mt-1 text-sm">Συνδεθείτε με moderation key.</p>
        <form method="GET" class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input name="key" type="password" required class="rounded-lg border border-amber-300 bg-white px-3 py-2 text-sm text-gray-900" placeholder="Moderation key" />
          <button type="submit" class="rounded-lg bg-amber-700 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-800">Σύνδεση</button>
        </form>
        {!expectedKey && <p class="mt-2 text-xs">Missing env: <code>PROFESSIONAL_MODERATION_KEY</code></p>}
      </div>
    )}

    {isAuthorized && (
      <>
        {status === 'ok' && <p class="mt-5 rounded-lg bg-green-50 px-4 py-3 text-green-800">Η ενέργεια ολοκληρώθηκε.</p>}
        {status === 'error' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800">Προέκυψε σφάλμα κατά την επεξεργασία.</p>}

        <section class="mt-8 space-y-4">
          <h2 class="text-xl font-bold text-gray-900">Εκκρεμείς Κριτικές ({pendingReviews.length})</h2>

          {pendingReviews.length === 0 && (
            <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700">Δεν υπάρχουν εκκρεμείς κριτικές.</p>
          )}

          {pendingReviews.map((review) => (
            <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-blue-700">/{review.service_slug}</p>
                  <h3 class="text-lg font-bold text-gray-900">{review.reviewer_name || 'Ανώνυμος Πελάτης'}</h3>
                  {review.reviewer_email && <p class="text-xs text-gray-500">{review.reviewer_email}</p>}
                  <p class="text-sm text-amber-700">{stars(review.rating)} ({review.rating}/5)</p>
                </div>
                <p class="text-xs text-gray-500">{new Date(review.created_at).toLocaleString('el-GR')}</p>
              </div>

              <p class="mt-3 text-sm text-gray-700">{review.comment}</p>

              <div class="mt-4 flex flex-wrap gap-3">
                <form action="/api/reviews/moderate" method="POST" class="space-y-3">
                  <input type="hidden" name="moderationKey" value={authToken} />
                  <input type="hidden" name="actorIdentifier" value={actor} />
                  <input type="hidden" name="action" value="approve" />
                  <input type="hidden" name="reviewId" value={review.id} />

                  <label class="flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="verified" value="true" class="h-4 w-4 rounded border-gray-300" />
                    Επιβεβαιωμένη αξιολόγηση (συνδεδεμένη με πραγματικό αίτημα)
                  </label>

                  <button type="submit" class="rounded-lg bg-green-700 px-4 py-2 text-sm font-semibold text-white hover:bg-green-800">Approve</button>
                </form>

                <form action="/api/reviews/moderate" method="POST">
                  <input type="hidden" name="moderationKey" value={authToken} />
                  <input type="hidden" name="actorIdentifier" value={actor} />
                  <input type="hidden" name="action" value="reject" />
                  <input type="hidden" name="reviewId" value={review.id} />
                  <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800">Reject</button>
                </form>
              </div>
            </article>
          ))}
        </section>
      </>
    )}
  </main>
</Layout>
