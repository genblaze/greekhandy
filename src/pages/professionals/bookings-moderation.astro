---
import Layout from '../../layouts/Layout.astro';
import {
  BOOKING_ACTIONS_FILE_PATH,
  BOOKING_SUBMISSIONS_FILE_PATH,
  getLatestBookingActionById,
  getBookingId,
  getBookingStatusPath,
  readNdjson,
  resolveBookingModerationState,
  type BookingAction,
  type BookingModerationState,
  type BookingSubmission
} from '../../lib/bookings';

Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const expectedKey = process.env.PROFESSIONAL_MODERATION_KEY ?? '';
const isAuthorized = Boolean(expectedKey && moderationKey === expectedKey);
const status = url.searchParams.get('status');
const statusBookingId = (url.searchParams.get('bookingId') ?? '').trim();
const statusFrom = (url.searchParams.get('from') ?? '').trim();
const statusTo = (url.searchParams.get('to') ?? '').trim();
const statusExpected = (url.searchParams.get('expected') ?? '').trim();
const statusActual = (url.searchParams.get('actual') ?? '').trim();
const statusReason = (url.searchParams.get('reason') ?? '').trim();
const isInvalidTransitionGuardrail = statusReason === 'invalid-transition';
const isRescheduleOnlyFromApproved = statusReason === 'reschedule-request-only-from-approved';
const isInvalidRescheduleResolution = statusReason === 'invalid-reschedule-resolution';

const isAllowedTransition = (from: BookingModerationState, to: BookingModerationState) => {
  if (from === to) return true;
  if (from === 'pending') return ['approved', 'rejected', 'cancelled'].includes(to);
  if (from === 'approved') return ['reschedule_requested'].includes(to);
  if (from === 'reschedule_requested') return ['approved', 'reschedule_rejected', 'cancelled'].includes(to);
  return false;
};

const formatDateTime = (value: string | undefined) => {
  const timestamp = Date.parse(value ?? '');
  return Number.isNaN(timestamp) ? 'Μη διαθέσιμη ημερομηνία' : new Date(timestamp).toLocaleString('el-GR');
};

const safeText = (value: string | undefined, fallback = 'Δεν έχει καταχωρηθεί') => {
  const cleaned = (value ?? '').trim();
  return cleaned || fallback;
};

const submissions = await readNdjson<BookingSubmission>(BOOKING_SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<BookingAction>(BOOKING_ACTIONS_FILE_PATH);
const latestActionById = getLatestBookingActionById(actions);

const stateMeta: Record<BookingModerationState, { label: string; badge: string; timelineTitle: string }> = {
  pending: {
    label: 'Σε αναμονή',
    badge: 'border-amber-200 bg-amber-50 text-amber-900',
    timelineTitle: 'Υποβολή & Έλεγχος'
  },
  approved: {
    label: 'Εγκρίθηκε',
    badge: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    timelineTitle: 'Έγκριση & Ανάθεση'
  },
  rejected: {
    label: 'Απορρίφθηκε',
    badge: 'border-rose-200 bg-rose-50 text-rose-900',
    timelineTitle: 'Απόρριψη & Επανυποβολή'
  },
  cancelled: {
    label: 'Ακυρώθηκε',
    badge: 'border-slate-300 bg-slate-100 text-slate-800',
    timelineTitle: 'Ακύρωση από χρήστη'
  },
  reschedule_requested: {
    label: 'Αίτημα αλλαγής',
    badge: 'border-violet-200 bg-violet-50 text-violet-900',
    timelineTitle: 'Εκκρεμής αλλαγή ραντεβού'
  },
  reschedule_rejected: {
    label: 'Αλλαγή μη εγκεκριμένη',
    badge: 'border-orange-200 bg-orange-50 text-orange-900',
    timelineTitle: 'Απόρριψη αιτήματος αλλαγής'
  }
};

const transitionTargets: Array<{ state: BookingModerationState; label: string; buttonClass: string }> = [
  { state: 'approved', label: 'Έγκριση αιτήματος', buttonClass: 'bg-emerald-700 hover:bg-emerald-800 text-white' },
  { state: 'rejected', label: 'Απόρριψη αιτήματος', buttonClass: 'bg-rose-700 hover:bg-rose-800 text-white' },
  { state: 'cancelled', label: 'Ακύρωση αιτήματος', buttonClass: 'bg-slate-700 hover:bg-slate-800 text-white' },
  { state: 'reschedule_requested', label: 'Καταχώρηση αιτήματος αλλαγής', buttonClass: 'bg-violet-700 hover:bg-violet-800 text-white' },
  { state: 'reschedule_rejected', label: 'Απόρριψη αλλαγής ραντεβού', buttonClass: 'bg-orange-700 hover:bg-orange-800 text-white' },
  { state: 'pending', label: 'Επαναφορά σε Αναμονή', buttonClass: 'border border-gray-300 text-gray-700 hover:bg-gray-50' }
];

const bookings = submissions
  .map((booking) => {
    const bookingId = getBookingId(booking);
    const latestAction = latestActionById.get(bookingId);
    const resolution = resolveBookingModerationState({
      action: latestAction?.action,
      submissionStatus: booking.status
    });
    return { booking, bookingId, latestAction, resolution };
  })
  .sort((a, b) => Date.parse(b.booking.submittedAt) - Date.parse(a.booking.submittedAt));

const groupedBookings: Record<BookingModerationState, typeof bookings> = {
  pending: bookings.filter((entry) => entry.resolution.state === 'pending'),
  approved: bookings.filter((entry) => entry.resolution.state === 'approved'),
  reschedule_requested: bookings.filter((entry) => entry.resolution.state === 'reschedule_requested'),
  reschedule_rejected: bookings.filter((entry) => entry.resolution.state === 'reschedule_rejected'),
  rejected: bookings.filter((entry) => entry.resolution.state === 'rejected'),
  cancelled: bookings.filter((entry) => entry.resolution.state === 'cancelled')
};

const orderedStates: BookingModerationState[] = ['pending', 'approved', 'reschedule_requested', 'reschedule_rejected', 'rejected', 'cancelled'];
const hasAnyBookings = bookings.length > 0;
---

<Layout title="Lifecycle Moderation Κρατήσεων | GreekHandy" description="Εσωτερική σελίδα διαχείρισης και μεταβάσεων κατάστασης αιτημάτων κράτησης.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Lifecycle Moderation Αιτημάτων Κράτησης</h1>
    <p class="mt-2 text-gray-700">Ορατότητα σε όλα τα αιτήματα και έλεγχος μεταβάσεων κατάστασης (pending / approved / reschedule_requested / reschedule_rejected / rejected / cancelled).</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        Μη εξουσιοδοτημένη πρόσβαση. Προσθέστε <code>?key=...</code> και ορίστε env <code>PROFESSIONAL_MODERATION_KEY</code>.
      </div>
    )}

    {isAuthorized && (
      <>
        {status === 'updated' && (
          <p class="mt-5 rounded-lg bg-green-50 px-4 py-3 text-green-800" role="status" aria-live="polite" aria-atomic="true">
            Η μετάβαση ολοκληρώθηκε{statusBookingId ? ` για το αίτημα ${statusBookingId}` : ''}{statusFrom && statusTo ? `: ${statusFrom} → ${statusTo}` : ''}.
          </p>
        )}
        {status === 'no-change' && (
          <p class="mt-5 rounded-lg bg-blue-50 px-4 py-3 text-blue-800" role="status" aria-live="polite" aria-atomic="true">
            Δεν έγινε αλλαγή{statusBookingId ? ` για το αίτημα ${statusBookingId}` : ''}, γιατί είναι ήδη στην κατάσταση {statusActual || 'target'}.
          </p>
        )}
        {status === 'stale' && (
          <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800" role="alert" aria-live="assertive">
            Batch-safe guardrail: η κατάσταση άλλαξε πριν την καταχώρηση{statusBookingId ? ` (αίτημα ${statusBookingId})` : ''}. Αναμενόταν {statusExpected || 'unknown'}, αλλά βρέθηκε {statusActual || 'unknown'}. Κάντε ανανέωση για νέα expectedState και ξαναδοκιμάστε.
          </p>
        )}
        {status === 'guardrail' && (
          <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800" role="alert" aria-live="assertive">
            Η ενέργεια μπλοκαρίστηκε από guardrail{statusBookingId ? ` για το αίτημα ${statusBookingId}` : ''}. {isRescheduleOnlyFromApproved ? 'Αίτημα αλλαγής επιτρέπεται μόνο όταν η τρέχουσα κατάσταση είναι approved.' : isInvalidRescheduleResolution ? 'Η εκκρεμής αλλαγή κλείνει μόνο με approved, reschedule_rejected ή cancelled.' : isInvalidTransitionGuardrail ? 'Επιτρέπονται μόνο οι μεταβάσεις που ορίζονται στο lifecycle (pending→approved/rejected/cancelled, approved→reschedule_requested, reschedule_requested→approved/reschedule_rejected/cancelled).' : 'Ελέγξτε τους κανόνες μετάβασης.'}
          </p>
        )}
        {status === 'error' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800" role="alert" aria-live="assertive">Προέκυψε σφάλμα κατά την επεξεργασία.</p>}
        {status === 'invalid' && (
          <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800" role="alert" aria-live="assertive">
            Μη έγκυρα δεδομένα μετάβασης. Απαιτείται bookingId, expectedState και επιτρεπτό targetState (pending/approved/reschedule_requested/reschedule_rejected/rejected/cancelled).
            {statusReason === 'missing-or-invalid-expected-state' && ' Εντοπίστηκε κενό ή μη έγκυρο expectedState για batch-safe προστασία.'}
          </p>
        )}
        {status === 'unauthorized' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800" role="alert" aria-live="assertive">Μη εξουσιοδοτημένη ενέργεια moderation.</p>}

        <div data-booking-moderation-loading class="mt-5 hidden rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900" role="status" aria-live="polite" aria-atomic="true" aria-describedby="booking-expected-actual-guardrail">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-blue-300 border-t-blue-700"></span>
            Καταχώρηση μετάβασης κατάστασης... ενημερώνουμε το lifecycle του αιτήματος.
          </span>
        </div>

        <div id="booking-lifecycle-guardrails" class="mt-6 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700" role="note" aria-live="polite">
          <p class="font-semibold text-slate-900">Flow μεταβάσεων</p>
          <p class="mt-1">Κάθε αίτημα ξεκινά ως <strong>pending</strong> και μπορεί να μεταβεί σε <strong>approved</strong>, <strong>rejected</strong> ή <strong>cancelled</strong>. Από <strong>approved</strong> επιτρέπεται αίτημα αλλαγής (<strong>reschedule_requested</strong>), που κλείνει με <strong>approved</strong> ή <strong>reschedule_rejected</strong>.</p>
          <p id="booking-expected-actual-guardrail" class="mt-2 text-xs text-slate-600">Κανόνας ασφαλείας: αν εντοπιστεί ασυμφωνία expectedState/actualState, η ενέργεια ακυρώνεται και απαιτείται ανανέωση.</p>
          <p class="mt-1 text-xs text-slate-600">Σε edge states (reschedule_requested / cancelled) εμφανίζονται μόνο συμβατές ενέργειες για αποφυγή λανθασμένων μεταβάσεων.</p>
          <p class="mt-1 text-xs text-slate-600">Οδηγός next-step: pending → approve/reject/cancel, reschedule_requested → approve/reschedule_rejected/cancel, cancelled/rejected → καμία άμεση μετάβαση.</p>
        </div>

        <section class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {orderedStates.map((state) => (
            <div class={`rounded-xl border p-4 ${stateMeta[state].badge}`}>
              <p class="text-xs font-semibold uppercase tracking-wide opacity-80">{state}</p>
              <p class="mt-1 text-lg font-bold">{stateMeta[state].label}</p>
              <p class="mt-1 text-sm">{groupedBookings[state].length} αιτήματα</p>
            </div>
          ))}
        </section>

        {!hasAnyBookings && (
          <div class="mt-6 rounded-2xl border border-dashed border-blue-200 bg-gradient-to-br from-blue-50 to-indigo-50 p-5 text-blue-900">
            <p class="font-semibold">Δεν υπάρχουν ακόμη καταχωρημένα αιτήματα κράτησης.</p>
            <p class="mt-1 text-sm text-blue-800">Μόλις υποβληθεί το πρώτο αίτημα, θα εμφανιστεί εδώ με πλήρες lifecycle (pending/approved/reschedule_requested/reschedule_rejected/rejected/cancelled).</p>
          </div>
        )}

        {orderedStates.map((state) => (
          <section class="mt-8 space-y-4">
            <h2 class="text-xl font-bold text-gray-900">{stateMeta[state].label} ({groupedBookings[state].length})</h2>

            {groupedBookings[state].length === 0 && (
              <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700" role="status" aria-live="polite">Δεν υπάρχουν αιτήματα σε αυτή την κατάσταση. Όταν αλλάξει κάποιο αίτημα σε «{stateMeta[state].label}», θα εμφανιστεί εδώ.</p>
            )}

            {groupedBookings[state].map(({ booking, bookingId, latestAction, resolution }) => (
              <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm" role="region" aria-label={`Κάρτα moderation αιτήματος ${bookingId}`}>
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="inline-flex rounded-full border border-blue-200 bg-blue-50 px-2.5 py-0.5 text-[11px] font-semibold text-blue-800">Επαγγελματίας</span>
                      <p class="text-sm font-semibold text-blue-700">/{safeText(booking.professionalSlug)}</p>
                    </div>
                    <div class="mt-1 flex flex-wrap items-center gap-2">
                      <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-[11px] font-semibold text-slate-700">Πελάτης</span>
                      <h3 class="text-lg font-bold text-gray-900">{safeText(booking.customerName)}</h3>
                    </div>
                    <p class="mt-1 text-sm text-gray-600">{safeText(booking.email, 'Χωρίς email')} • {safeText(booking.phone, 'Χωρίς τηλέφωνο')}</p>
                    {booking.service && <p class="mt-1 text-sm text-gray-700"><strong>Υπηρεσία:</strong> {safeText(booking.service)}</p>}
                    {booking.preferredDate && <p class="mt-1 text-sm text-gray-700"><strong>Προτιμώμενο πρόγραμμα:</strong> {safeText(booking.preferredDate)}</p>}
                  </div>
                  <div class="text-right">
                    <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${stateMeta[resolution.state].badge}`}>
                      {stateMeta[resolution.state].label}
                    </span>
                    <p class="mt-2 text-xs text-gray-500">Υποβολή: {formatDateTime(booking.submittedAt)}</p>
                    {latestAction && <p class="text-xs text-gray-500">Τελευταία απόφαση: {formatDateTime(latestAction.actedAt)}</p>}
                  </div>
                </div>

                <div class="mt-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-600">Timeline (συνεπές με customer view)</p>
                  <p class="mt-1 text-sm font-semibold text-slate-800">{stateMeta[resolution.state].timelineTitle}</p>
                </div>

                <p class="mt-3 text-sm text-gray-700"><strong>Μήνυμα:</strong> {safeText(booking.message, 'Δεν υπάρχουν λεπτομέρειες αιτήματος.')}</p>
                {resolution.hasUnknownData && (
                  <p class="mt-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900" role="alert" aria-live="assertive">
                    Εντοπίστηκαν μη αναγνωρίσιμα δεδομένα κατάστασης και το αίτημα εμφανίζεται ως εκκρεμές για ασφάλεια.
                  </p>
                )}

                <div class="mt-4 flex flex-wrap items-center gap-3" role="group" aria-label={`Ενέργειες moderation για αίτημα ${bookingId}`}>
                  <a href={getBookingStatusPath(bookingId)} class="rounded-lg border border-blue-300 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-50">
                    Προβολή σελίδας κατάστασης πελάτη
                  </a>
                  <span class="text-xs font-medium text-slate-500">Τρέχουσα κατάσταση: {resolution.state}</span>
                  <span class="text-xs text-slate-500" aria-describedby="booking-expected-actual-guardrail">Επιτρεπτές ενέργειες: {resolution.state === 'pending' ? 'approved, rejected, cancelled' : resolution.state === 'approved' ? 'reschedule_requested' : resolution.state === 'reschedule_requested' ? 'approved, reschedule_rejected, cancelled' : 'καμία άμεση μετάβαση'}</span>

                  {transitionTargets
                    .filter((target) => target.state !== resolution.state && isAllowedTransition(resolution.state, target.state))
                    .map((target) => (
                      <form action="/api/bookings/moderate" method="POST" data-moderation-form data-booking-id={bookingId} data-from-state={resolution.state} data-to-state={target.state} aria-label={`Μετάβαση κράτησης ${bookingId} από ${resolution.state} σε ${target.state}`} aria-describedby="booking-lifecycle-guardrails">
                        <input type="hidden" name="moderationKey" value={moderationKey} />
                        <input type="hidden" name="bookingId" value={bookingId} />
                        <input type="hidden" name="expectedState" value={resolution.state} />
                        <input type="hidden" name="targetState" value={target.state} />
                        <button type="submit" data-default-label={target.label} aria-label={`${target.label} για αίτημα ${bookingId}`} class={`rounded-lg px-4 py-2 text-sm font-semibold ${target.buttonClass}`}>{target.label}</button>
                      </form>
                    ))}
                </div>
              </article>
            ))}
          </section>
        ))}
      </>
    )}
    <script is:inline>
      (() => {
        const loadingBanner = document.querySelector('[data-booking-moderation-loading]');
        const forms = Array.from(document.querySelectorAll('[data-moderation-form]'));
        let submissionLocked = false;

        for (const form of forms) {
          if (!(form instanceof HTMLFormElement)) continue;
          form.addEventListener('submit', (event) => {
            if (submissionLocked) {
              event.preventDefault();
              if (loadingBanner instanceof HTMLElement) {
                loadingBanner.classList.remove('hidden');
                loadingBanner.setAttribute('role', 'alert');
                loadingBanner.setAttribute('aria-live', 'assertive');
                loadingBanner.textContent = 'Υπάρχει ήδη ενέργεια σε εξέλιξη. Περιμένετε να ολοκληρωθεί πριν κάνετε νέα μετάβαση.';
              }
              return;
            }

            const clickedButton = form.querySelector('button[type="submit"]');
            const actionLabel = clickedButton instanceof HTMLButtonElement
              ? (clickedButton.getAttribute('data-default-label') || clickedButton.textContent || 'ενημέρωση')
              : 'ενημέρωση';
            const bookingId = form.getAttribute('data-booking-id') || '-';
            const fromState = form.getAttribute('data-from-state') || 'unknown';
            const toState = form.getAttribute('data-to-state') || 'unknown';

            const riskNote = (toState === 'cancelled' || toState === 'reschedule_rejected')
              ? '\nΠροσοχή: πρόκειται για αρνητική/τερματική απόφαση.'
              : '';

            if (!window.confirm(`Επιβεβαίωση ενέργειας: ${actionLabel}\nΑίτημα: ${bookingId}\nΜετάβαση: ${fromState} → ${toState}${riskNote}\n\nΠατήστε OK μόνο αν η μετάβαση είναι σωστή.`)) {
              event.preventDefault();
              if (loadingBanner instanceof HTMLElement) {
                loadingBanner.classList.remove('hidden');
                loadingBanner.setAttribute('role', 'status');
                loadingBanner.setAttribute('aria-live', 'polite');
                loadingBanner.textContent = 'Η ενέργεια ακυρώθηκε πριν την καταχώρηση. Δεν έγινε καμία αλλαγή.';
              }
              return;
            }

            if ((toState === 'cancelled' || toState === 'reschedule_rejected')
              && !window.confirm('Τελική επιβεβαίωση: συνεχίζετε με τερματική/αρνητική απόφαση;')) {
              event.preventDefault();
              if (loadingBanner instanceof HTMLElement) {
                loadingBanner.classList.remove('hidden');
                loadingBanner.setAttribute('role', 'status');
                loadingBanner.setAttribute('aria-live', 'polite');
                loadingBanner.textContent = 'Η μετάβαση ακυρώθηκε από τον χειριστή. Δεν έγινε καμία αλλαγή κατάστασης.';
              }
              return;
            }

            submissionLocked = true;
            if (loadingBanner instanceof HTMLElement) {
              loadingBanner.classList.remove('hidden');
              loadingBanner.setAttribute('role', 'status');
              loadingBanner.setAttribute('aria-live', 'polite');
              loadingBanner.setAttribute('aria-busy', 'true');
              loadingBanner.textContent = 'Καταχώρηση μετάβασης... οι υπόλοιπες ενέργειες κλειδώθηκαν προσωρινά για batch-safe αποφυγή διπλών μεταβάσεων.';
            }

            for (const candidate of forms) {
              if (!(candidate instanceof HTMLFormElement)) continue;
              const candidateButton = candidate.querySelector('button[type="submit"]');
              if (candidateButton instanceof HTMLButtonElement) {
                const defaultLabel = candidateButton.getAttribute('data-default-label') || candidateButton.textContent || 'Ενημέρωση';
                candidateButton.disabled = true;
                candidateButton.setAttribute('aria-busy', 'true');
                if (candidate === form) {
                  candidateButton.textContent = 'Ενημέρωση...';
                } else {
                  candidateButton.textContent = 'Κλείδωμα...';
                }

                window.setTimeout(() => {
                  candidateButton.disabled = false;
                  candidateButton.removeAttribute('aria-busy');
                  candidateButton.textContent = defaultLabel;
                  submissionLocked = false;
                  if (loadingBanner instanceof HTMLElement) {
                    loadingBanner.removeAttribute('aria-busy');
                  }
                }, 12000);
              }
            }
          });
        }
      })();
    </script>
  </main>
</Layout>
