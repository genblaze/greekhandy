---
import Layout from '../../layouts/Layout.astro';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

const SUBMISSIONS_FILE_PATH = resolve(process.cwd(), 'data', 'booking-submissions.ndjson');
const ACTIONS_FILE_PATH = resolve(process.cwd(), 'data', 'booking-moderation-actions.ndjson');

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const expectedKey = process.env.PROFESSIONAL_MODERATION_KEY ?? '';
const isAuthorized = Boolean(expectedKey && moderationKey === expectedKey);
const status = url.searchParams.get('status');

interface BookingSubmission {
  id?: string;
  professionalSlug: string;
  customerName: string;
  phone: string;
  email: string;
  preferredDate?: string;
  message: string;
  status: 'pending';
  submittedAt: string;
}

interface ActionLog {
  bookingId: string;
  action: string;
  actedAt: string;
}

const readNdjson = async <T,>(path: string): Promise<T[]> => {
  try {
    const raw = await readFile(path, 'utf-8');
    return raw
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => JSON.parse(line) as T);
  } catch {
    return [];
  }
};

const submissions = await readNdjson<BookingSubmission>(SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<ActionLog>(ACTIONS_FILE_PATH);

const latestActionById = new Map<string, ActionLog>();
for (const action of actions) latestActionById.set(action.bookingId, action);

const pendingBookings = submissions
  .map((booking) => {
    const bookingId = booking.id || `${booking.professionalSlug}|${booking.submittedAt}`;
    const latestAction = latestActionById.get(bookingId);
    return { booking, bookingId, latestAction };
  })
  .filter((item) => !item.latestAction)
  .reverse();
---

<Layout title="Moderation Κρατήσεων | GreekHandy" description="Internal moderation workflow for booking requests.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Moderation Αιτημάτων Κράτησης</h1>
    <p class="mt-2 text-gray-700">Εσωτερική σελίδα διαχείρισης αιτημάτων κράτησης.</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        Μη εξουσιοδοτημένη πρόσβαση. Προσθέστε <code>?key=...</code> και ορίστε env <code>PROFESSIONAL_MODERATION_KEY</code>.
      </div>
    )}

    {isAuthorized && (
      <>
        {status === 'ok' && <p class="mt-5 rounded-lg bg-green-50 px-4 py-3 text-green-800">Η ενέργεια ολοκληρώθηκε.</p>}
        {status === 'error' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800">Προέκυψε σφάλμα κατά την επεξεργασία.</p>}
        {status === 'invalid' && <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800">Μη έγκυρα δεδομένα.</p>}

        <section class="mt-8 space-y-4">
          <h2 class="text-xl font-bold text-gray-900">Εκκρεμή Αιτήματα ({pendingBookings.length})</h2>

          {pendingBookings.length === 0 && (
            <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700">Δεν υπάρχουν εκκρεμή αιτήματα.</p>
          )}

          {pendingBookings.map(({ booking, bookingId }) => (
            <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-blue-700">/{booking.professionalSlug}</p>
                  <h3 class="text-lg font-bold text-gray-900">{booking.customerName}</h3>
                  <p class="mt-1 text-sm text-gray-600">{booking.email} • {booking.phone}</p>
                  {booking.preferredDate && <p class="mt-1 text-sm text-gray-700"><strong>Προτιμώμενη ημερομηνία:</strong> {booking.preferredDate}</p>}
                </div>
                <p class="text-xs text-gray-500">{new Date(booking.submittedAt).toLocaleString('el-GR')}</p>
              </div>

              <p class="mt-3 text-sm text-gray-700"><strong>Μήνυμα:</strong> {booking.message}</p>

              <div class="mt-4 flex flex-wrap gap-3">
                <form action="/api/bookings/moderate" method="POST">
                  <input type="hidden" name="moderationKey" value={moderationKey} />
                  <input type="hidden" name="action" value="approve" />
                  <input type="hidden" name="bookingId" value={bookingId} />
                  <button type="submit" class="rounded-lg bg-green-700 px-4 py-2 text-sm font-semibold text-white hover:bg-green-800">Approve</button>
                </form>

                <form action="/api/bookings/moderate" method="POST">
                  <input type="hidden" name="moderationKey" value={moderationKey} />
                  <input type="hidden" name="action" value="reject" />
                  <input type="hidden" name="bookingId" value={bookingId} />
                  <button type="submit" class="rounded-lg bg-gray-700 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800">Reject</button>
                </form>
              </div>
            </article>
          ))}
        </section>
      </>
    )}
  </main>
</Layout>
