---
import Layout from '../../layouts/Layout.astro';
import {
  BOOKING_ACTIONS_FILE_PATH,
  BOOKING_SUBMISSIONS_FILE_PATH,
  getLatestBookingActionById,
  getBookingId,
  getBookingStatusPath,
  readNdjson,
  resolveBookingModerationState,
  type BookingAction,
  type BookingModerationState,
  type BookingSubmission
} from '../../lib/bookings';

const url = new URL(Astro.request.url);
const moderationKey = url.searchParams.get('key') ?? '';
const expectedKey = process.env.PROFESSIONAL_MODERATION_KEY ?? '';
const isAuthorized = Boolean(expectedKey && moderationKey === expectedKey);
const status = url.searchParams.get('status');
const statusBookingId = (url.searchParams.get('bookingId') ?? '').trim();
const statusFrom = (url.searchParams.get('from') ?? '').trim();
const statusTo = (url.searchParams.get('to') ?? '').trim();
const statusExpected = (url.searchParams.get('expected') ?? '').trim();
const statusActual = (url.searchParams.get('actual') ?? '').trim();

const formatDateTime = (value: string | undefined) => {
  const timestamp = Date.parse(value ?? '');
  return Number.isNaN(timestamp) ? 'Μη διαθέσιμη ημερομηνία' : new Date(timestamp).toLocaleString('el-GR');
};

const safeText = (value: string | undefined, fallback = 'Δεν έχει καταχωρηθεί') => {
  const cleaned = (value ?? '').trim();
  return cleaned || fallback;
};

const submissions = await readNdjson<BookingSubmission>(BOOKING_SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<BookingAction>(BOOKING_ACTIONS_FILE_PATH);
const latestActionById = getLatestBookingActionById(actions);

const stateMeta: Record<BookingModerationState, { label: string; badge: string }> = {
  pending: {
    label: 'Σε αναμονή',
    badge: 'border-amber-200 bg-amber-50 text-amber-900'
  },
  approved: {
    label: 'Εγκρίθηκε',
    badge: 'border-emerald-200 bg-emerald-50 text-emerald-900'
  },
  rejected: {
    label: 'Απορρίφθηκε',
    badge: 'border-rose-200 bg-rose-50 text-rose-900'
  }
};

const transitionTargets: Array<{ state: BookingModerationState; label: string; buttonClass: string }> = [
  { state: 'approved', label: 'Μετάβαση σε Εγκρίθηκε', buttonClass: 'bg-emerald-700 hover:bg-emerald-800 text-white' },
  { state: 'rejected', label: 'Μετάβαση σε Απορρίφθηκε', buttonClass: 'bg-rose-700 hover:bg-rose-800 text-white' },
  { state: 'pending', label: 'Επαναφορά σε Αναμονή', buttonClass: 'border border-gray-300 text-gray-700 hover:bg-gray-50' }
];

const bookings = submissions
  .map((booking) => {
    const bookingId = getBookingId(booking);
    const latestAction = latestActionById.get(bookingId);
    const resolution = resolveBookingModerationState({
      action: latestAction?.action,
      submissionStatus: booking.status
    });
    return { booking, bookingId, latestAction, resolution };
  })
  .sort((a, b) => Date.parse(b.booking.submittedAt) - Date.parse(a.booking.submittedAt));

const groupedBookings: Record<BookingModerationState, typeof bookings> = {
  pending: bookings.filter((entry) => entry.resolution.state === 'pending'),
  approved: bookings.filter((entry) => entry.resolution.state === 'approved'),
  rejected: bookings.filter((entry) => entry.resolution.state === 'rejected')
};

const orderedStates: BookingModerationState[] = ['pending', 'approved', 'rejected'];
const hasAnyBookings = bookings.length > 0;
---

<Layout title="Lifecycle Moderation Κρατήσεων | GreekHandy" description="Εσωτερική σελίδα διαχείρισης και μεταβάσεων κατάστασης αιτημάτων κράτησης.">
  <main class="mx-auto max-w-5xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Lifecycle Moderation Αιτημάτων Κράτησης</h1>
    <p class="mt-2 text-gray-700">Ορατότητα σε όλα τα αιτήματα και έλεγχος μεταβάσεων κατάστασης (pending / approved / rejected).</p>

    {!isAuthorized && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        Μη εξουσιοδοτημένη πρόσβαση. Προσθέστε <code>?key=...</code> και ορίστε env <code>PROFESSIONAL_MODERATION_KEY</code>.
      </div>
    )}

    {isAuthorized && (
      <>
        {status === 'updated' && (
          <p class="mt-5 rounded-lg bg-green-50 px-4 py-3 text-green-800">
            Η μετάβαση ολοκληρώθηκε{statusBookingId ? ` για το αίτημα ${statusBookingId}` : ''}{statusFrom && statusTo ? `: ${statusFrom} → ${statusTo}` : ''}.
          </p>
        )}
        {status === 'no-change' && (
          <p class="mt-5 rounded-lg bg-blue-50 px-4 py-3 text-blue-800">
            Δεν έγινε αλλαγή{statusBookingId ? ` για το αίτημα ${statusBookingId}` : ''}, γιατί είναι ήδη στην κατάσταση {statusActual || 'target'}.
          </p>
        )}
        {status === 'stale' && (
          <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800">
            Batch-safe guardrail: η κατάσταση άλλαξε πριν την καταχώρηση{statusBookingId ? ` (αίτημα ${statusBookingId})` : ''}. Αναμενόταν {statusExpected || 'unknown'}, αλλά βρέθηκε {statusActual || 'unknown'}. Κάντε ανανέωση και ξαναδοκιμάστε.
          </p>
        )}
        {status === 'error' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800">Προέκυψε σφάλμα κατά την επεξεργασία.</p>}
        {status === 'invalid' && <p class="mt-5 rounded-lg bg-amber-50 px-4 py-3 text-amber-800">Μη έγκυρα δεδομένα μετάβασης. Ελέγξτε ότι το αίτημα έχει έγκυρο bookingId και επιτρεπτό targetState (pending/approved/rejected).</p>}
        {status === 'unauthorized' && <p class="mt-5 rounded-lg bg-red-50 px-4 py-3 text-red-800">Μη εξουσιοδοτημένη ενέργεια moderation.</p>}

        <div data-booking-moderation-loading class="mt-5 hidden rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900" role="status" aria-live="polite">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-blue-300 border-t-blue-700"></span>
            Καταχώρηση μετάβασης κατάστασης... ενημερώνουμε το lifecycle του αιτήματος.
          </span>
        </div>

        <div class="mt-6 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700">
          <p class="font-semibold text-slate-900">Flow μεταβάσεων</p>
          <p class="mt-1">Κάθε αίτημα ξεκινά ως <strong>pending</strong> και μπορεί να μεταβεί σε <strong>approved</strong> ή <strong>rejected</strong>. Αν χρειαστεί διόρθωση, επιτρέπεται επαναφορά σε <strong>pending</strong>.</p>
        </div>

        <section class="mt-8 grid gap-3 sm:grid-cols-3">
          {orderedStates.map((state) => (
            <div class={`rounded-xl border p-4 ${stateMeta[state].badge}`}>
              <p class="text-xs font-semibold uppercase tracking-wide opacity-80">{state}</p>
              <p class="mt-1 text-lg font-bold">{stateMeta[state].label}</p>
              <p class="mt-1 text-sm">{groupedBookings[state].length} αιτήματα</p>
            </div>
          ))}
        </section>

        {!hasAnyBookings && (
          <div class="mt-6 rounded-2xl border border-dashed border-blue-200 bg-gradient-to-br from-blue-50 to-indigo-50 p-5 text-blue-900">
            <p class="font-semibold">Δεν υπάρχουν ακόμη καταχωρημένα αιτήματα κράτησης.</p>
            <p class="mt-1 text-sm text-blue-800">Μόλις υποβληθεί το πρώτο αίτημα, θα εμφανιστεί εδώ με πλήρες lifecycle (pending/approved/rejected).</p>
          </div>
        )}

        {orderedStates.map((state) => (
          <section class="mt-8 space-y-4">
            <h2 class="text-xl font-bold text-gray-900">{stateMeta[state].label} ({groupedBookings[state].length})</h2>

            {groupedBookings[state].length === 0 && (
              <p class="rounded-xl border border-gray-200 bg-white p-4 text-gray-700">Δεν υπάρχουν αιτήματα σε αυτή την κατάσταση.</p>
            )}

            {groupedBookings[state].map(({ booking, bookingId, latestAction, resolution }) => (
              <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <p class="text-sm font-semibold text-blue-700">/{safeText(booking.professionalSlug)}</p>
                    <h3 class="text-lg font-bold text-gray-900">{safeText(booking.customerName)}</h3>
                    <p class="mt-1 text-sm text-gray-600">{safeText(booking.email, 'Χωρίς email')} • {safeText(booking.phone, 'Χωρίς τηλέφωνο')}</p>
                    {booking.service && <p class="mt-1 text-sm text-gray-700"><strong>Υπηρεσία:</strong> {safeText(booking.service)}</p>}
                    {booking.preferredDate && <p class="mt-1 text-sm text-gray-700"><strong>Προτιμώμενο πρόγραμμα:</strong> {safeText(booking.preferredDate)}</p>}
                  </div>
                  <div class="text-right">
                    <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${stateMeta[resolution.state].badge}`}>
                      {stateMeta[resolution.state].label}
                    </span>
                    <p class="mt-2 text-xs text-gray-500">Υποβολή: {formatDateTime(booking.submittedAt)}</p>
                    {latestAction && <p class="text-xs text-gray-500">Τελευταία απόφαση: {formatDateTime(latestAction.actedAt)}</p>}
                  </div>
                </div>

                <p class="mt-3 text-sm text-gray-700"><strong>Μήνυμα:</strong> {safeText(booking.message, 'Δεν υπάρχουν λεπτομέρειες αιτήματος.')}</p>
                {resolution.hasUnknownData && (
                  <p class="mt-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900">
                    Εντοπίστηκαν μη αναγνωρίσιμα δεδομένα κατάστασης και το αίτημα εμφανίζεται ως εκκρεμές για ασφάλεια.
                  </p>
                )}

                <div class="mt-4 flex flex-wrap gap-3">
                  <a href={getBookingStatusPath(bookingId)} class="rounded-lg border border-blue-300 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-50">
                    Προβολή σελίδας κατάστασης πελάτη
                  </a>

                  {transitionTargets
                    .filter((target) => target.state !== resolution.state)
                    .map((target) => (
                      <form action="/api/bookings/moderate" method="POST" data-moderation-form>
                        <input type="hidden" name="moderationKey" value={moderationKey} />
                        <input type="hidden" name="bookingId" value={bookingId} />
                        <input type="hidden" name="expectedState" value={resolution.state} />
                        <input type="hidden" name="targetState" value={target.state} />
                        <button type="submit" data-default-label={target.label} class={`rounded-lg px-4 py-2 text-sm font-semibold ${target.buttonClass}`}>{target.label}</button>
                      </form>
                    ))}
                </div>
              </article>
            ))}
          </section>
        ))}
      </>
    )}
    <script is:inline>
      (() => {
        const loadingBanner = document.querySelector('[data-booking-moderation-loading]');
        const forms = Array.from(document.querySelectorAll('[data-moderation-form]'));
        let submissionLocked = false;

        for (const form of forms) {
          if (!(form instanceof HTMLFormElement)) continue;
          form.addEventListener('submit', (event) => {
            if (submissionLocked) {
              event.preventDefault();
              return;
            }

            const clickedButton = form.querySelector('button[type="submit"]');
            const actionLabel = clickedButton instanceof HTMLButtonElement
              ? (clickedButton.getAttribute('data-default-label') || clickedButton.textContent || 'ενημέρωση')
              : 'ενημέρωση';

            if (!window.confirm(`Επιβεβαίωση ενέργειας: ${actionLabel};`)) {
              event.preventDefault();
              return;
            }

            submissionLocked = true;
            if (loadingBanner instanceof HTMLElement) {
              loadingBanner.classList.remove('hidden');
              loadingBanner.textContent = 'Καταχώρηση μετάβασης... οι υπόλοιπες ενέργειες κλειδώθηκαν προσωρινά για batch-safe αποφυγή διπλών μεταβάσεων.';
            }

            for (const candidate of forms) {
              if (!(candidate instanceof HTMLFormElement)) continue;
              const candidateButton = candidate.querySelector('button[type="submit"]');
              if (candidateButton instanceof HTMLButtonElement) {
                const defaultLabel = candidateButton.getAttribute('data-default-label') || candidateButton.textContent || 'Ενημέρωση';
                candidateButton.disabled = true;
                candidateButton.setAttribute('aria-busy', 'true');
                if (candidate === form) {
                  candidateButton.textContent = 'Ενημέρωση...';
                } else {
                  candidateButton.textContent = 'Κλείδωμα...';
                }

                window.setTimeout(() => {
                  candidateButton.disabled = false;
                  candidateButton.removeAttribute('aria-busy');
                  candidateButton.textContent = defaultLabel;
                  submissionLocked = false;
                }, 12000);
              }
            }
          });
        }
      })();
    </script>
  </main>
</Layout>
