---
import Layout from '../../layouts/Layout.astro';
import {
  BOOKING_ACTIONS_FILE_PATH,
  BOOKING_SUBMISSIONS_FILE_PATH,
  findLatestBookingAction,
  getBookingId,
  readNdjson,
  type BookingAction,
  resolveBookingModerationState,
  type BookingModerationState,
  type BookingSubmission
} from '../../lib/bookings';

Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');

const statusParam = (Astro.url.searchParams.get('status') ?? '').trim();
const returnToParam = (Astro.url.searchParams.get('returnTo') ?? '').trim();
const returnTo = returnToParam.startsWith('/') && !returnToParam.startsWith('//') ? returnToParam : null;
const bookingId = (Astro.url.searchParams.get('bookingId') ?? '').trim();
const safeText = (value: string | undefined, fallback = 'Δεν έχει καταχωρηθεί') => {
  const cleaned = (value ?? '').trim();
  return cleaned || fallback;
};
const toDateString = (value: string | undefined) => {
  const timestamp = Date.parse(value ?? '');
  return Number.isNaN(timestamp) ? null : new Date(timestamp).toLocaleString('el-GR');
};

const submissions = await readNdjson<BookingSubmission>(BOOKING_SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<BookingAction>(BOOKING_ACTIONS_FILE_PATH);

const booking = submissions.find((entry) => getBookingId(entry) === bookingId);
if (!booking && bookingId) Astro.response.status = 404;

const latestAction = findLatestBookingAction(actions, bookingId);
const moderationResolution = resolveBookingModerationState({
  action: latestAction?.action,
  submissionStatus: booking?.status
});
const moderationState: BookingModerationState = moderationResolution.state;

const statusStyles: Record<BookingModerationState, { badge: string; tone: string; label: string; summary: string; hint: string }> = {
  pending: {
    badge: 'bg-amber-100 text-amber-900 border border-amber-200',
    tone: 'border-amber-200 bg-amber-50 text-amber-900',
    label: 'Σε αναμονή',
    summary: 'Το αίτημα έχει καταχωρηθεί και βρίσκεται σε διαδικασία ελέγχου.',
    hint: 'Μόλις ολοκληρωθεί το moderation, η κατάσταση θα ενημερωθεί αυτόματα σε αυτή τη σελίδα.'
  },
  approved: {
    badge: 'bg-emerald-100 text-emerald-900 border border-emerald-200',
    tone: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    label: 'Εγκρίθηκε',
    summary: 'Το αίτημα εγκρίθηκε. Ο επαγγελματίας θα επικοινωνήσει μαζί σας για τα επόμενα βήματα.',
    hint: 'Αν χρειάζεστε αλλαγή στο ραντεβού, χρησιμοποιήστε τα στοιχεία επικοινωνίας του επαγγελματία.'
  },
  rejected: {
    badge: 'bg-rose-100 text-rose-900 border border-rose-200',
    tone: 'border-rose-200 bg-rose-50 text-rose-900',
    label: 'Απορρίφθηκε',
    summary: 'Το αίτημα δεν εγκρίθηκε στο στάδιο moderation.',
    hint: 'Μπορείτε να υποβάλετε νέο αίτημα με πιο συγκεκριμένες λεπτομέρειες ή να επιλέξετε άλλον επαγγελματία.'
  },
  cancelled: {
    badge: 'bg-slate-100 text-slate-900 border border-slate-300',
    tone: 'border-slate-300 bg-slate-100 text-slate-900',
    label: 'Ακυρώθηκε',
    summary: 'Το αίτημα ακυρώθηκε και δεν θα προχωρήσει σε ανάθεση.',
    hint: 'Αν θέλετε, μπορείτε να δημιουργήσετε νέο αίτημα με ενημερωμένες λεπτομέρειες.'
  },
  reschedule_requested: {
    badge: 'bg-violet-100 text-violet-900 border border-violet-200',
    tone: 'border-violet-200 bg-violet-50 text-violet-900',
    label: 'Αίτημα αλλαγής',
    summary: 'Έχει καταχωρηθεί αίτημα αλλαγής ραντεβού και αναμένει απόφαση moderation.',
    hint: 'Θα ενημερωθείτε μόλις εγκριθεί ή απορριφθεί η αλλαγή.'
  },
  reschedule_rejected: {
    badge: 'bg-orange-100 text-orange-900 border border-orange-200',
    tone: 'border-orange-200 bg-orange-50 text-orange-900',
    label: 'Αλλαγή μη εγκεκριμένη',
    summary: 'Το αίτημα αλλαγής δεν εγκρίθηκε. Η προηγούμενη συμφωνία παραμένει ενεργή.',
    hint: 'Μπορείτε να στείλετε νέο αίτημα ενημέρωσης με πιο συγκεκριμένη διαθεσιμότητα.'
  }
};

const statusView = statusStyles[moderationState];
const submittedAt = booking ? toDateString(booking.submittedAt) : null;
const reviewedAt = latestAction ? toDateString(latestAction.actedAt) : null;
const bookingAgeHours = booking ? Math.floor((Date.now() - Date.parse(booking.submittedAt)) / (1000 * 60 * 60)) : null;
const isPendingLongerThanDay = moderationState === 'pending' && typeof bookingAgeHours === 'number' && bookingAgeHours >= 24;
const justSubmitted = statusParam === 'submitted';
const hasLookupError = statusParam === 'error';
const hasInvalidLookup = statusParam === 'invalid';
const hasRescheduleRequested = statusParam === 'reschedule-requested';
const hasRescheduleAlreadyRequested = statusParam === 'reschedule-already-requested';
const hasRescheduleNotAllowed = statusParam === 'reschedule-not-allowed';
const contactDetails = booking
  ? [safeText(booking.email, ''), safeText(booking.phone, '')].filter(Boolean).join(' • ') || 'Δεν έχουν καταχωρηθεί'
  : '';
const professionalSlug = booking ? safeText(booking.professionalSlug, '') : '';
const canOpenProfessionalProfile = Boolean(professionalSlug);
const statusPills: Array<{ key: BookingModerationState; label: string }> = [
  { key: 'pending', label: 'Σε αναμονή' },
  { key: 'approved', label: 'Εγκρίθηκε' },
  { key: 'reschedule_requested', label: 'Αίτημα αλλαγής' },
  { key: 'reschedule_rejected', label: 'Αλλαγή μη εγκεκριμένη' },
  { key: 'rejected', label: 'Απορρίφθηκε' },
  { key: 'cancelled', label: 'Ακυρώθηκε' }
];

const timelineSteps: Array<{ key: BookingModerationState; title: string; detail: string }> = [
  { key: 'pending', title: '1. Υποβολή & Έλεγχος', detail: 'Το αίτημα έχει ληφθεί και είναι σε moderation.' },
  { key: 'approved', title: '2A. Έγκριση', detail: 'Το αίτημα εγκρίθηκε και προχωρά σε επικοινωνία.' },
  { key: 'reschedule_requested', title: '2B. Αίτημα αλλαγής', detail: 'Ζητήθηκε αλλαγή και αναμένεται έγκριση moderation.' },
  { key: 'reschedule_rejected', title: '2C. Απόρριψη αλλαγής', detail: 'Το αίτημα αλλαγής δεν εγκρίθηκε.' },
  { key: 'rejected', title: '2D. Απόρριψη αιτήματος', detail: 'Το αρχικό αίτημα απορρίφθηκε και μπορείτε να στείλετε νέο.' },
  { key: 'cancelled', title: '2E. Ακύρωση', detail: 'Το αίτημα ακυρώθηκε με ασφάλεια και έκλεισε.' }
];
const professionalStatusBadge = moderationState === 'approved'
  ? 'Ο επαγγελματίας ενημερώθηκε'
  : moderationState === 'reschedule_requested'
    ? 'Εκκρεμεί απόφαση αλλαγής'
    : moderationState === 'reschedule_rejected'
      ? 'Η αλλαγή δεν εγκρίθηκε'
      : moderationState === 'rejected'
        ? 'Δεν προχώρησε σε επαγγελματία'
        : moderationState === 'cancelled'
          ? 'Η ανάθεση ακυρώθηκε'
          : 'Σε αναμονή επαγγελματία';
const customerStatusBadge = moderationState === 'approved'
  ? 'Πελάτης: αναμένεται επικοινωνία'
  : moderationState === 'reschedule_requested'
    ? 'Πελάτης: εκκρεμεί αλλαγή'
    : moderationState === 'reschedule_rejected'
      ? 'Πελάτης: αλλαγή μη εγκεκριμένη'
      : moderationState === 'rejected'
        ? 'Πελάτης: προτείνεται νέο αίτημα'
        : moderationState === 'cancelled'
          ? 'Πελάτης: αίτημα ακυρωμένο'
          : 'Πελάτης: αναμονή ελέγχου';
const supportMailTo = `mailto:info@greekhandy.gr?subject=${encodeURIComponent(`GreekHandy κράτηση ${bookingId || ''}`)}&body=${encodeURIComponent(`Γεια σας,\n\nΘα ήθελα ενημέρωση για το αίτημα κράτησης με κωδικό: ${bookingId || '-'}\nΚατάσταση: ${moderationState}\n\nΕυχαριστώ.`)}`;

---

<Layout title="Κατάσταση Αιτήματος Κράτησης | GreekHandy" description="Δείτε την κατάσταση moderation και τα στοιχεία του αιτήματος κράτησης σας.">
  <main class="mx-auto max-w-4xl px-4 py-14">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">GreekHandy Booking Request</p>
    <h1 class="mt-2 text-3xl font-bold text-gray-900">Κατάσταση Αιτήματος</h1>
    <p class="mt-2 text-sm text-gray-600">Σελίδα παρακολούθησης για την εξέλιξη του αιτήματός σας.</p>

    {justSubmitted && (
      <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900" role="status" aria-live="polite">
        Το αίτημά σας υποβλήθηκε επιτυχώς. Κρατήστε αυτό το link για να παρακολουθείτε την εξέλιξη.
      </div>
    )}

    {hasInvalidLookup && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900" role="alert" aria-live="assertive">
        Το αίτημα δεν περιέχει έγκυρα στοιχεία αναζήτησης. Ελέγξτε το link και δοκιμάστε ξανά.
      </div>
    )}

    {hasLookupError && (
      <div class="mt-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-900" role="alert" aria-live="assertive">
        Προέκυψε προσωρινό σφάλμα φόρτωσης της κατάστασης. Κάντε ανανέωση σε λίγα δευτερόλεπτα.
      </div>
    )}

    {hasRescheduleRequested && (
      <div class="mt-6 rounded-xl border border-violet-200 bg-violet-50 px-4 py-3 text-violet-900" role="status" aria-live="polite">
        Το αίτημα αλλαγής καταχωρήθηκε επιτυχώς και αναμένει έγκριση moderation.
      </div>
    )}

    {hasRescheduleAlreadyRequested && (
      <div class="mt-6 rounded-xl border border-violet-200 bg-violet-50 px-4 py-3 text-violet-900" role="status" aria-live="polite">
        Υπάρχει ήδη εκκρεμές αίτημα αλλαγής. Περιμένετε την απόφαση moderation πριν στείλετε νέο αίτημα.
      </div>
    )}

    {hasRescheduleNotAllowed && (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900" role="alert" aria-live="assertive">
        Η αλλαγή ραντεβού επιτρέπεται μόνο για εγκεκριμένα αιτήματα. Ελέγξτε την τρέχουσα κατάσταση πριν δοκιμάσετε ξανά.
      </div>
    )}

    {!bookingId && (
      <section class="mt-6 rounded-2xl border border-amber-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-gray-900">Λείπει ο κωδικός αιτήματος</h2>
        <p class="mt-2 text-sm text-gray-700">Ανοίξτε ξανά το link που λάβατε μετά την υποβολή για να δείτε την κατάσταση.</p>
      </section>
    )}

    {bookingId && !booking && (
      <section class="mt-6 rounded-2xl border border-amber-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-gray-900">Το αίτημα δεν βρέθηκε</h2>
        <p class="mt-2 text-sm text-gray-700">Ελέγξτε ότι το link είναι σωστό ή υποβάλετε νέο αίτημα κράτησης.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/professionals" class="inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Εύρεση επαγγελματία</a>
          <a href="/" class="inline-flex rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50">Αρχική</a>
        </div>
      </section>
    )}

    {booking && (
      <section class="mt-6 rounded-2xl border bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-gray-500">Request ID</p>
            <p class="mt-1 text-sm text-gray-700">{bookingId}</p>
          </div>
          <span class={`inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold ${statusView.badge}`}>
            {statusView.label} <span class="ml-2 rounded bg-white/70 px-1.5 py-0.5 font-mono text-xs">{moderationState}</span>
          </span>
        </div>

        <div class={`mt-4 rounded-xl px-4 py-3 text-sm ${statusView.tone}`} role="status" aria-live="polite" aria-atomic="true" aria-describedby="booking-lifecycle-guardrail-note">
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex rounded-full border border-white/70 bg-white/70 px-2.5 py-0.5 text-xs font-semibold">{customerStatusBadge}</span>
            <span class="inline-flex rounded-full border border-white/70 bg-white/70 px-2.5 py-0.5 text-xs font-semibold">{professionalStatusBadge}</span>
          </div>
          <p class="mt-2 font-semibold">{statusView.summary}</p>
          <p class="mt-1 text-xs opacity-85">{statusView.hint}</p>
          <p id="booking-lifecycle-guardrail-note" class="mt-1 text-xs opacity-85">Εμπιστοσύνη συστήματος: οι μεταβάσεις κατάστασης γίνονται με ελέγχους συνέπειας (expected/actual state) για αποφυγή λανθασμένων ενημερώσεων.</p>
          {reviewedAt && <p class="mt-1 text-xs opacity-85">Τελευταία ενημέρωση: {reviewedAt}</p>}
        </div>

        <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3" role="list" aria-label="Βήματα κύκλου ζωής αιτήματος">
          {statusPills.map((pill) => {
            const isActive = moderationState === pill.key;
            const isCompleted = pill.key === 'pending' && moderationState !== 'pending';
            const completedClasses = isCompleted ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : '';
            const activeClasses = isActive ? 'border-blue-200 bg-blue-50 text-blue-900' : '';
            return (
              <div role="listitem" aria-current={isActive ? 'step' : undefined} class={`rounded-lg border px-3 py-2 text-sm font-semibold text-gray-500 ${activeClasses} ${completedClasses}`}>
                {pill.label}
              </div>
            );
          })}
        </div>

        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4" role="region" aria-label="Χρονοδιάγραμμα κατάστασης αιτήματος" aria-describedby="booking-timeline-guardrail-help">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-600">Timeline αιτήματος</p>
          <p id="booking-timeline-guardrail-help" class="mt-1 text-xs text-slate-600">Guardrail: οι μεταβάσεις ακολουθούν αυστηρούς κανόνες για αποφυγή αντικρουόμενων ενημερώσεων.</p>
          <ol class="mt-2 space-y-2">
            {timelineSteps.map((step) => {
              const isCurrent = moderationState === step.key;
              const isPastPending = moderationState !== 'pending' && step.key === 'pending';
              const showAsDone = isCurrent || isPastPending;
              return (
                <li aria-current={isCurrent ? 'step' : undefined} class={`rounded-lg border px-3 py-2 text-sm ${showAsDone ? 'border-blue-200 bg-blue-50 text-blue-900' : 'border-slate-200 bg-white text-slate-600'}`}>
                  <p class="font-semibold">{step.title}</p>
                  <p class="text-xs opacity-85">{step.detail}</p>
                  {isCurrent && step.key !== 'pending' && reviewedAt && <p class="mt-1 text-xs opacity-85">Ολοκλήρωση: {reviewedAt}</p>}
                  {step.key === 'pending' && submittedAt && <p class="mt-1 text-xs opacity-85">Υποβολή: {submittedAt}</p>}
                </li>
              );
            })}
          </ol>
        </div>

        {isPendingLongerThanDay && (
          <div class="mt-4 rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900" role="status" aria-live="polite">
            Το αίτημα παραμένει σε αναμονή για πάνω από 24 ώρες. Αυτό συνήθως σημαίνει ότι βρίσκεται ακόμη σε έλεγχο moderation.
          </div>
        )}

        {(moderationState === 'rejected' || moderationState === 'cancelled' || moderationState === 'reschedule_rejected') && (
          <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700" role="status" aria-live="polite">
            Η κατάσταση έχει οριστικοποιηθεί. Για νέα ενέργεια, υποβάλετε νέο αίτημα κράτησης από τη σελίδα επαγγελματία.
          </div>
        )}

        {moderationState === 'reschedule_requested' && (
          <div class="mt-4 rounded-xl border border-violet-200 bg-violet-50 px-4 py-3 text-sm text-violet-900" role="status" aria-live="polite" aria-atomic="true">
            Το αίτημα αλλαγής είναι σε έλεγχο. Δεν χρειάζεται νέα ενέργεια μέχρι να ολοκληρωθεί η απόφαση moderation.
          </div>
        )}

        {moderationResolution.hasUnknownData && (
          <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert" aria-live="assertive">
            Εντοπίστηκαν μη αναγνωρίσιμα δεδομένα κατάστασης. Προβάλλουμε προσωρινά την ασφαλή ένδειξη «Σε αναμονή».
          </div>
        )}

        <dl class="mt-5 grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Επαγγελματίας</dt>
            <dd class="mt-1 text-sm text-gray-900">{professionalSlug ? `/${professionalSlug}` : 'Δεν έχει καταχωρηθεί'}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Υποβολή</dt>
            <dd class="mt-1 text-sm text-gray-900">{submittedAt || 'Μη διαθέσιμη ημερομηνία'}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Υπηρεσία</dt>
            <dd class="mt-1 text-sm text-gray-900">{safeText(booking.service, 'Δεν ορίστηκε')}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Προτιμώμενο πρόγραμμα</dt>
            <dd class="mt-1 text-sm text-gray-900">{safeText(booking.preferredDate, 'Δεν ορίστηκε')}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Ονοματεπώνυμο</dt>
            <dd class="mt-1 text-sm text-gray-900">{safeText(booking.customerName)}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Στοιχεία επικοινωνίας</dt>
            <dd class="mt-1 text-sm text-gray-900">{contactDetails}</dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Λεπτομέρειες αιτήματος</dt>
            <dd class="mt-1 whitespace-pre-wrap text-sm text-gray-900">{safeText(booking.message, 'Δεν υπάρχουν λεπτομέρειες αιτήματος.')}</dd>
          </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-3" role="group" aria-label="Ενέργειες αιτήματος κράτησης" aria-describedby="booking-actions-guardrail-help">
          {canOpenProfessionalProfile && (
            <a href={`/professionals/${professionalSlug}`} class="inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800" aria-label="Προβολή σελίδας επαγγελματία">
              Προβολή επαγγελματία
            </a>
          )}
          {returnTo && <a href={returnTo} class="inline-flex rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50" aria-label="Επιστροφή στη φόρμα κράτησης">Επιστροφή στη φόρμα</a>}
          {(moderationState === 'pending' || moderationState === 'approved') && (
            <a href={supportMailTo} class="inline-flex rounded-lg border border-blue-300 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-50" aria-label="Αποστολή αιτήματος ενημέρωσης στο GreekHandy">
              Αίτημα ενημέρωσης
            </a>
          )}
          {moderationState === 'approved' && booking && (
            <form action="/api/bookings/request-update" method="POST" class="inline-flex" aria-label={`Αίτημα αλλαγής ραντεβού για κράτηση ${bookingId}`}>
              <input type="hidden" name="bookingId" value={bookingId} />
              <input type="hidden" name="requestedAction" value="reschedule" />
              <input type="hidden" name="email" value={booking.email} />
              <input type="hidden" name="returnTo" value={`/bookings/request?bookingId=${encodeURIComponent(bookingId)}`} />
              <button type="submit" class="inline-flex rounded-lg border border-emerald-300 px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50" onclick="return window.confirm('Θέλετε να σταλεί αίτημα αλλαγής ραντεβού για moderation; Θα παραμείνει εκκρεμές μέχρι απόφαση.');">
                Αίτημα αλλαγής ραντεβού
              </button>
            </form>
          )}
        </div>
        <p id="booking-actions-guardrail-help" class="mt-2 text-xs text-slate-600">Σημείωση ασφάλειας: οι ενέργειες εμφανίζονται μόνο όταν επιτρέπεται η μετάβαση στην τρέχουσα κατάσταση.</p>
      </section>
    )}
  </main>
</Layout>
