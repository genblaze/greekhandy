---
import Layout from '../../layouts/Layout.astro';
import {
  BOOKING_ACTIONS_FILE_PATH,
  BOOKING_SUBMISSIONS_FILE_PATH,
  getBookingId,
  getBookingModerationState,
  readNdjson,
  type BookingAction,
  type BookingModerationState,
  type BookingSubmission
} from '../../lib/bookings';

const statusParam = (Astro.url.searchParams.get('status') ?? '').trim();
const returnToParam = (Astro.url.searchParams.get('returnTo') ?? '').trim();
const returnTo = returnToParam.startsWith('/') && !returnToParam.startsWith('//') ? returnToParam : null;
const bookingId = (Astro.url.searchParams.get('bookingId') ?? '').trim();

const submissions = await readNdjson<BookingSubmission>(BOOKING_SUBMISSIONS_FILE_PATH);
const actions = await readNdjson<BookingAction>(BOOKING_ACTIONS_FILE_PATH);

const booking = submissions.find((entry) => getBookingId(entry) === bookingId);
if (!booking && bookingId) Astro.response.status = 404;

let latestAction: BookingAction | null = null;
for (const action of actions) {
  if (action.bookingId !== bookingId) continue;
  if (!latestAction || action.actedAt > latestAction.actedAt) latestAction = action;
}

const moderationState: BookingModerationState = getBookingModerationState(latestAction?.action);

const statusStyles: Record<BookingModerationState, { badge: string; tone: string; label: string; summary: string }> = {
  pending: {
    badge: 'bg-amber-100 text-amber-900 border border-amber-200',
    tone: 'border-amber-200 bg-amber-50 text-amber-900',
    label: 'Σε αναμονή',
    summary: 'Το αίτημα έχει καταχωρηθεί και βρίσκεται σε διαδικασία ελέγχου.'
  },
  approved: {
    badge: 'bg-emerald-100 text-emerald-900 border border-emerald-200',
    tone: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    label: 'Εγκρίθηκε',
    summary: 'Το αίτημα εγκρίθηκε. Ο επαγγελματίας θα επικοινωνήσει μαζί σας για τα επόμενα βήματα.'
  },
  rejected: {
    badge: 'bg-rose-100 text-rose-900 border border-rose-200',
    tone: 'border-rose-200 bg-rose-50 text-rose-900',
    label: 'Απορρίφθηκε',
    summary: 'Το αίτημα δεν εγκρίθηκε στο στάδιο moderation.'
  }
};

const statusView = statusStyles[moderationState];
const submittedAt = booking ? new Date(booking.submittedAt).toLocaleString('el-GR') : '';
const reviewedAt = latestAction ? new Date(latestAction.actedAt).toLocaleString('el-GR') : '';
const justSubmitted = statusParam === 'submitted';
---

<Layout title="Κατάσταση Αιτήματος Κράτησης | GreekHandy" description="Δείτε την κατάσταση moderation και τα στοιχεία του αιτήματος κράτησης σας.">
  <main class="mx-auto max-w-4xl px-4 py-14">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">GreekHandy Booking Request</p>
    <h1 class="mt-2 text-3xl font-bold text-gray-900">Κατάσταση Αιτήματος</h1>
    <p class="mt-2 text-sm text-gray-600">Σελίδα παρακολούθησης για την εξέλιξη του αιτήματός σας.</p>

    {justSubmitted && (
      <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900">
        Το αίτημά σας υποβλήθηκε επιτυχώς.
      </div>
    )}

    {!bookingId && (
      <section class="mt-6 rounded-2xl border border-amber-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-gray-900">Λείπει ο κωδικός αιτήματος</h2>
        <p class="mt-2 text-sm text-gray-700">Ανοίξτε ξανά το link που λάβατε μετά την υποβολή για να δείτε την κατάσταση.</p>
      </section>
    )}

    {bookingId && !booking && (
      <section class="mt-6 rounded-2xl border border-amber-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-gray-900">Το αίτημα δεν βρέθηκε</h2>
        <p class="mt-2 text-sm text-gray-700">Ελέγξτε ότι το link είναι σωστό ή υποβάλετε νέο αίτημα κράτησης.</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/professionals" class="inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Εύρεση επαγγελματία</a>
          <a href="/" class="inline-flex rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50">Αρχική</a>
        </div>
      </section>
    )}

    {booking && (
      <section class="mt-6 rounded-2xl border bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold text-gray-500">Request ID</p>
            <p class="mt-1 text-sm text-gray-700">{bookingId}</p>
          </div>
          <span class={`inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold ${statusView.badge}`}>
            {statusView.label} <span class="ml-2 rounded bg-white/70 px-1.5 py-0.5 font-mono text-xs">{moderationState}</span>
          </span>
        </div>

        <div class={`mt-4 rounded-xl px-4 py-3 text-sm ${statusView.tone}`}>
          <p class="font-semibold">{statusView.summary}</p>
          {reviewedAt && <p class="mt-1 text-xs opacity-85">Ενημερώθηκε: {reviewedAt}</p>}
        </div>

        <dl class="mt-5 grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Επαγγελματίας</dt>
            <dd class="mt-1 text-sm text-gray-900">/{booking.professionalSlug}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Υποβολή</dt>
            <dd class="mt-1 text-sm text-gray-900">{submittedAt}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Υπηρεσία</dt>
            <dd class="mt-1 text-sm text-gray-900">{booking.service || 'Δεν ορίστηκε'}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Προτιμώμενο πρόγραμμα</dt>
            <dd class="mt-1 text-sm text-gray-900">{booking.preferredDate || 'Δεν ορίστηκε'}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Ονοματεπώνυμο</dt>
            <dd class="mt-1 text-sm text-gray-900">{booking.customerName}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Στοιχεία επικοινωνίας</dt>
            <dd class="mt-1 text-sm text-gray-900">{booking.email} • {booking.phone}</dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500">Λεπτομέρειες αιτήματος</dt>
            <dd class="mt-1 whitespace-pre-wrap text-sm text-gray-900">{booking.message}</dd>
          </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href={`/professionals/${booking.professionalSlug}`} class="inline-flex rounded-lg bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800">Προβολή επαγγελματία</a>
          {returnTo && <a href={returnTo} class="inline-flex rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50">Επιστροφή στη φόρμα</a>}
        </div>
      </section>
    )}
  </main>
</Layout>
