---
import BaseHead from '../components/BaseHead.astro';
import Layout from '../layouts/Layout.astro';
import electrician from '../../data/content/electrician.json';

const canonicalUrl = new URL(`/${electrician.slug}`, Astro.site).toString();
const ogImage = new URL('/favicon.svg', Astro.site).toString();
const electricianAccusative = 'ηλεκτρολόγο';
const electricianGenitive = 'ηλεκτρολόγου';

const categoryModules = import.meta.glob('../../data/content/*.json', { eager: true });
const categoryNameBySlug: Record<string, string> = {};

for (const moduleEntry of Object.values(categoryModules)) {
  const category = (moduleEntry as { default?: any }).default ?? moduleEntry;
  if (category?.slug && category?.nameGr) {
    categoryNameBySlug[category.slug] = category.nameGr;
  }
}

const relatedCategories = electrician.relatedCategories.map((slug: string) => ({
  slug,
  nameGr: categoryNameBySlug[slug] ?? slug
}));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Υπηρεσίες ${electricianGenitive}`,
  url: canonicalUrl,
  description: electrician.metaDescription,
  areaServed: ['Αθήνα', 'Θεσσαλονίκη', 'Πάτρα', 'Ηράκλειο', 'Λάρισα', 'Ελλάδα'],
  serviceType: `Υπηρεσίες ${electricianGenitive}`,
  availableLanguage: ['el-GR'],
  provider: {
    '@type': 'Organization',
    name: 'GreekHandy',
    url: new URL('/', Astro.site).toString()
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: electrician.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<Layout title={electrician.metaTitle} description={electrician.metaDescription} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <BaseHead title={electrician.metaTitle} description={electrician.metaDescription} canonicalUrl={canonicalUrl} ogImage={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main>
    <section class="bg-gradient-to-b from-blue-700 to-blue-600 text-white px-4 py-16 md:py-20">
      <div class="mx-auto max-w-5xl">
        <h1 class="text-3xl font-bold leading-tight md:text-5xl">{electrician.h1}</h1>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-blue-100">{electrician.heroText}</p>
        <a
          href="#contact"
          class="mt-8 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-blue-700 transition hover:bg-blue-50"
        >
          {electrician.cta.buttonText}
        </a>
      </div>
    </section>

    <section id="services" class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl space-y-6">
        {electrician.sections.map((section) => (
          <article class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm md:p-8">
            <h2 class="text-2xl font-bold text-gray-900">{section.heading}</h2>
            <p class="mt-4 leading-relaxed text-gray-700">{section.content}</p>
            {section.priceRange && (
              <p class="mt-4 font-medium text-gray-900">
                Ενδεικτικό εύρος τιμής: <span class="text-blue-700">{section.priceRange}</span>
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="bg-gray-50 px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">Σχετικές Κατηγορίες</h2>
        <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {relatedCategories.map((category) => (
            <li>
              <a
                href={`/${category.slug}`}
                class="block rounded-lg border border-gray-200 bg-white px-5 py-4 font-medium text-blue-700 transition hover:border-blue-300 hover:bg-blue-50"
              >
                {category.nameGr}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="faq" itemscope itemtype="https://schema.org/FAQPage" class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">Συχνές Ερωτήσεις για {electricianAccusative}</h2>
        <div class="mt-6 space-y-4">
          {electrician.faq.map((item) => (
            <article itemprop="mainEntity" itemscope itemtype="https://schema.org/Question" class="rounded-xl border border-gray-200 bg-white p-6">
              <h3 itemprop="name" class="text-lg font-semibold text-gray-900">{item.question}</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text" class="mt-3 leading-relaxed text-gray-700">{item.answer}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-blue-700 px-4 py-12 text-white md:py-16">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="text-2xl font-bold md:text-3xl">{electrician.cta.heading}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-blue-100">{electrician.cta.text}</p>
        <a
          href={`mailto:info@greekhandy.gr?subject=${encodeURIComponent(`Ζητώ προσφορά για ${electricianAccusative}`)}`}
          class="mt-6 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-blue-700 transition hover:bg-blue-50"
        >
          {electrician.cta.buttonText}
        </a>
      </div>
    </section>
  </main>
</Layout>
