---
import Layout from '../layouts/Layout.astro';

const title = 'Επικοινωνία | GreekHandy';
const description = 'Επικοινωνήστε με το GreekHandy για υποστήριξη, ερωτήσεις και βοήθεια σχετικά με υπηρεσίες και επαγγελματίες.';
---

<Layout title={title} description={description}>
  <main class="mx-auto max-w-4xl px-4 py-14">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">GreekHandy</p>
    <h1 class="mt-2 text-3xl font-bold text-slate-900">Επικοινωνία</h1>
    <p class="mt-3 text-slate-600">
      Είμαστε εδώ για να σας βοηθήσουμε με απορίες για υπηρεσίες, αιτήματα κράτησης και υποστήριξη πλατφόρμας.
    </p>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">Άμεσες επιλογές</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/#contact" class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-semibold text-blue-800 hover:bg-blue-100">
          Φόρμα Επικοινωνίας
        </a>
        <a href="mailto:info@greekhandy.gr" class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">
          info@greekhandy.gr
        </a>
        <a href="/professionals" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">
          Εύρεση Επαγγελματία
        </a>
        <a href="/bookings/request" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50">
          Έλεγχος Κατάστασης Κράτησης
        </a>
      </div>
    </section>
  </main>
</Layout>
