        <script>
          import { createClient } from '@supabase/supabase-js';
          const supabase = createClient(
            'https://rwggwqnddoturgcyluuo.supabase.co',
            'sb_publishable_tkTy4XLRcY6AP6T-PPIVNg_HDI7Z0J5'
          );
          const form = document.getElementById('contact-form');
          const submitButton = document.getElementById('form-submit');
          const loadingState = document.getElementById('form-loading');
          const successState = document.getElementById('form-success');
          const errorState = document.getElementById('form-error');
          const fieldsState = document.getElementById('form-fields');
          const validationSummary = document.getElementById('lead-validation-summary');
          const leadStepFeedback = document.getElementById('lead-step-feedback');
          const REQUEST_TIMEOUT_MS = 12000;
          let isSubmitting = false;

          const fieldRules = {
            'lead-name': (value) => value.trim().length >= 2,
            'lead-phone': (value) => /^[0-9+()\-\s]{7,20}$/.test(value.trim()),
            'lead-email': (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim()),
            'lead-description': (value) => value.trim().length >= 15,
            'lead-consent': (value) => value === true
          };

          const updateFieldState = (fieldId, isValid, touched = false) => {
            const input = document.getElementById(fieldId);
            const error = document.getElementById(`${fieldId}-error`);
            if (input instanceof HTMLElement) {
              input.setAttribute('aria-invalid', !isValid && touched ? 'true' : 'false');
            }
            if (error instanceof HTMLElement) {
              error.classList.toggle('hidden', isValid || !touched);
            }
          };

          const validateLeadForm = (forceTouched = false) => {
            const leadNameInput = document.getElementById('lead-name');
            const leadPhoneInput = document.getElementById('lead-phone');
            const leadEmailInput = document.getElementById('lead-email');
            const leadDescriptionInput = document.getElementById('lead-description');
            const leadConsentInput = document.getElementById('lead-consent');

            const values = {
              'lead-name': leadNameInput instanceof HTMLInputElement ? leadNameInput.value : '',
              'lead-phone': leadPhoneInput instanceof HTMLInputElement ? leadPhoneInput.value : '',
              'lead-email': leadEmailInput instanceof HTMLInputElement ? leadEmailInput.value : '',
              'lead-description': leadDescriptionInput instanceof HTMLTextAreaElement ? leadDescriptionInput.value : '',
              'lead-consent': leadConsentInput instanceof HTMLInputElement ? leadConsentInput.checked === true : false
            };

            const invalid = [];
            for (const [id, rule] of Object.entries(fieldRules)) {
              const touched = forceTouched || ((document.getElementById(id)?.getAttribute('data-touched') || '') === '1');
              const isValid = rule(values[id]);
              if (!isValid) invalid.push(id);
              updateFieldState(id, isValid, touched);
            }

            if (validationSummary instanceof HTMLElement) {
              const labelMap = {
                'lead-name': 'όνομα',
                'lead-phone': 'τηλέφωνο',
                'lead-email': 'email',
                'lead-description': 'περιγραφή',
                'lead-consent': 'συγκατάθεση'
              };
              validationSummary.textContent = invalid.length
                ? `Έλεγχος φόρμας: απαιτείται διόρθωση στα πεδία ${[...new Set(invalid.map((i) => labelMap[i]))].join(', ')}.`
                : 'Έλεγχος φόρμας: όλα τα υποχρεωτικά πεδία είναι έγκυρα.';
            }

            return invalid.length === 0;
          };

          const setErrorState = (message) => {
            if (!(errorState instanceof HTMLElement)) return;
            errorState.textContent = message;
            errorState.classList.remove('hidden');
            if (leadStepFeedback instanceof HTMLElement) {
              leadStepFeedback.textContent = 'Βήμα 2/3: Χρειάζονται διορθώσεις ή επανάληψη υποβολής.';
            }
          };

          ['lead-name', 'lead-phone', 'lead-email', 'lead-description', 'lead-consent'].forEach((id) => {
            const el = document.getElementById(id);
            if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement)) return;
            el.addEventListener('input', () => {
              el.setAttribute('data-touched', '1');
              validateLeadForm();
            });
            el.addEventListener('blur', () => {
              el.setAttribute('data-touched', '1');
              validateLeadForm();
            });
          });

          form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (
              !(form instanceof HTMLFormElement)
              || !(submitButton instanceof HTMLButtonElement)
            ) return;

            if (isSubmitting) return;
            const fd = new FormData(form);
            // Honeypot check
            if (fd.get('website')) return;

            const formValid = validateLeadForm(true);
            if (!formValid) {
              setErrorState('Ελέγξτε τα επισημασμένα πεδία και δοκιμάστε ξανά.');
              return;
            }

            const consentGiven = fd.get('consent') === 'on';
            if (!consentGiven) {
              setErrorState('Απαιτείται συγκατάθεση για να συνεχίσουμε με το αίτημά σας. Διαβάστε την Πολιτική Απορρήτου και δοκιμάστε ξανά.');
              return;
            }

            if (typeof navigator !== 'undefined' && navigator.onLine === false) {
              setErrorState('Δεν υπάρχει σύνδεση στο διαδίκτυο. Ελέγξτε το δίκτυο και δοκιμάστε ξανά.');
              return;
            }

            isSubmitting = true;
            submitButton.disabled = true;
            submitButton.setAttribute('aria-busy', 'true');
            submitButton.textContent = 'Αποστολή...';
            if (leadStepFeedback instanceof HTMLElement) {
              leadStepFeedback.textContent = 'Βήμα 2/3: Υποβολή σε εξέλιξη, ελέγχουμε και καταχωρούμε το αίτημα.';
            }
            if (loadingState instanceof HTMLElement) loadingState.classList.remove('hidden');
            if (errorState instanceof HTMLElement) errorState.classList.add('hidden');

            const payload = {
              name: String(fd.get('name') || '').trim(),
              phone: String(fd.get('phone') || '').trim(),
              email: String(fd.get('email') || '').trim(),
              description: String(fd.get('description') || '').trim(),
              service_slug: fd.get('serviceSlug'),
              service_name: fd.get('serviceName'),
              page_url: fd.get('pageUrl'),
            };

            try {
              const timeoutPromise = new Promise((_, reject) => {
                window.setTimeout(() => reject(new Error('request-timeout')), REQUEST_TIMEOUT_MS);
              });
              const requestPromise = supabase.from('contact_requests').insert(payload);
              const { error } = await Promise.race([requestPromise, timeoutPromise]);

              if (error) throw error;

              if (loadingState instanceof HTMLElement) loadingState.classList.add('hidden');
              if (fieldsState instanceof HTMLElement) fieldsState.classList.add('hidden');
              submitButton.classList.add('hidden');
              if (leadStepFeedback instanceof HTMLElement) {
                leadStepFeedback.textContent = 'Βήμα 3/3: Το αίτημα στάλθηκε επιτυχώς. Περιμένετε πρώτη ενημέρωση εντός 1–2 εργάσιμων ωρών.';
              }
              if (successState instanceof HTMLElement) successState.classList.remove('hidden');
            } catch {
              if (loadingState instanceof HTMLElement) loadingState.classList.add('hidden');
              setErrorState('Η υποβολή δεν ολοκληρώθηκε αυτή τη στιγμή. Δοκιμάστε ξανά σε 1-2 λεπτά ή στείλτε στο info@greekhandy.gr.');
              submitButton.disabled = false;
              submitButton.removeAttribute('aria-busy');
              submitButton.textContent = 'Αποστολή Αιτήματος';
            } finally {
              isSubmitting = false;
            }
          });
        </script>
      </div>
    </section>
  </main>
</Layout>
