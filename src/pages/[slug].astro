---
import Layout from '../layouts/Layout.astro';

export const prerender = true;

// Load all content JSONs at build time (top-level only)
const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });

// Build slug → content map
const allContent: Record<string, any> = {};
for (const [path, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) {
    allContent[data.slug] = data;
  }
}

// Load categories for navigation
let categories: any[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = catFile.default ?? catFile;
} catch {}

export function getStaticPaths() {
  const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
  const paths = [];
  for (const [, mod] of Object.entries(contentFiles)) {
    const data = (mod as any).default ?? mod;
    if (data?.slug) {
      paths.push({ params: { slug: data.slug }, props: { category: data } });
    }
  }
  return paths;
}

const { category } = Astro.props;
const canonicalUrl = new URL(`/${category.slug}`, Astro.site).toString();

// Determine if this is a job page (has categorySlug) or category page
const isJobPage = !!category.categorySlug;
const isHeatingIntentLanding = !isJobPage && category.slug === 'techniki-klimatismou';
const parentCategory = isJobPage ? categories.find((c: any) => c.id === category.categoryId || c.slug === category.categorySlug) : null;
const heatingIntentTokens = ['thermans', 'thermosifon', 'thermotit', 'levita', 'endodaped', 'kalorifer', 'thermostat'];
const isHeatingIntentJob = (job: any) => {
  const corpus = `${job.slug || ''} ${job.nameGr || ''} ${job.h1 || ''}`.toLocaleLowerCase('el-GR');
  return heatingIntentTokens.some((token) => corpus.includes(token));
};

// Find sub-jobs for category pages
const subJobs = !isJobPage
  ? Object.values(allContent)
      .filter((p: any) => p.categoryId === category.id || p.categorySlug === category.slug)
      .filter((job: any) => !isHeatingIntentLanding || isHeatingIntentJob(job))
  : [];

const pageCategory = isHeatingIntentLanding
  ? {
      ...category,
      nameGr: 'Τεχνικοί Θέρμανσης',
      h1: 'Τεχνικοί Θέρμανσης στην Ελλάδα',
      metaTitle: 'Τεχνικοί Θέρμανσης | Κόστος, συντήρηση και επισκευές',
      metaDescription: 'Υπηρεσίες θέρμανσης για λέβητες, θερμοσίφωνες, αντλίες θερμότητας και κυκλώματα καλοριφέρ. Δείτε τιμές, διάρκεια και σωστή προετοιμασία αιτήματος.',
      heroText: 'Οδηγός αποκλειστικά για ανάγκες θέρμανσης: συντήρηση και επισκευές λεβήτων, θερμοσίφωνες, αντλίες θερμότητας και ρυθμίσεις θερμοστατών, με έμφαση στην ασφάλεια και στην ενεργειακή απόδοση.',
      summary: {
        ...category.summary,
        priceRangeEUR: '50-260€ (ανά εργασία)',
        typicalDuration: '45 λεπτά - 4 ώρες'
      },
      cta: {
        heading: 'Χρειάζεστε τεχνικό θέρμανσης;',
        text: 'Στείλτε περιγραφή συστήματος και συμπτώματος για να λάβετε στοχευμένες προσφορές από διαθέσιμους τεχνικούς θέρμανσης.',
        buttonText: 'Ζητήστε προσφορά θέρμανσης'
      },
      sections: [
        {
          heading: 'Τι περιλαμβάνει η υπηρεσία θέρμανσης',
          content: 'Η κατηγορία καλύπτει λέβητες, θερμοσίφωνες, αντλίες θερμότητας, καυστήρες και κυκλώματα καλοριφέρ. Στόχος είναι ασφαλής λειτουργία, σταθερή απόδοση και σαφές πλάνο κόστους/χρόνου πριν από κάθε ανάθεση.'
        },
        {
          heading: 'Συντήρηση λέβητα και καυστήρα',
          content: 'Καθαρισμός, ρυθμίσεις καύσης, έλεγχος ασφαλιστικών διατάξεων και μετρήσεις απόδοσης πριν την έντονη χειμερινή χρήση.',
          priceRange: '60-150€'
        },
        {
          heading: 'Θερμοσίφωνες και αντλίες θερμότητας',
          content: 'Έλεγχος αντιστάσεων, βαλβίδων, ανοδίων, αυτοματισμών και βελτιστοποίηση λειτουργίας για σταθερό ζεστό νερό και χαμηλότερη κατανάλωση.',
          priceRange: '50-260€'
        },
        {
          heading: 'Πώς να προετοιμάσετε σωστά το αίτημά σας',
          content: 'Αναφέρετε τύπο συστήματος, ηλικία εγκατάστασης, περιγραφή συμπτώματος, περιοχή και επιθυμητό χρόνο επίσκεψης. Με αυτά τα στοιχεία η αρχική εκτίμηση γίνεται πιο αξιόπιστη.'
        }
      ],
      faq: [
        {
          question: 'Πόσο κοστίζουν συνήθως οι υπηρεσίες θέρμανσης;',
          answer: 'Το κόστος εξαρτάται από τον τύπο συστήματος και τη βλάβη. Συνήθεις εργασίες κινούνται ενδεικτικά μεταξύ 50€ και 260€.'
        },
        {
          question: 'Πότε απαιτείται άμεση επίσκεψη;',
          answer: 'Άμεση παρέμβαση χρειάζεται όταν υπάρχει διαρροή, έντονη οσμή, καπνός, πτώση πίεσης ή πλήρης διακοπή θέρμανσης/ζεστού νερού.'
        },
        {
          question: 'Τι πληροφορίες βοηθούν σε ακριβέστερη προσφορά;',
          answer: 'Μοντέλο και τύπος συστήματος, ηλικία εξοπλισμού, περιγραφή συμπτώματος, φωτογραφίες όπου είναι εφικτό και επιθυμητό χρονικό παράθυρο επίσκεψης.'
        }
      ]
    }
  : category;

const highVolumeFilterSlugs = new Set(['ydravlikoi', 'ilektrologoi']);
const enableAdvancedCategoryUX = !isJobPage && (highVolumeFilterSlugs.has(category.slug) || subJobs.length >= 18);
const cityTokens = ['athina', 'thessaloniki', 'patra', 'irakleio', 'larisa', 'volos', 'ioannina'];
const urgencyKeywords = ['amesi', 'ektakti', 'epeigon'];
const initialVisibleSubJobs = enableAdvancedCategoryUX ? 9 : 12;

const classifyBudget = (priceRange: string | undefined) => {
  const value = (priceRange || '').toLocaleLowerCase('el-GR');
  if (!value) return 'unknown';
  if (value.includes('€200') || value.includes('€300') || value.includes('€400') || value.includes('€500') || value.includes('€1000')) return 'high';
  if (value.includes('€80') || value.includes('€100') || value.includes('€120') || value.includes('€150')) return 'medium';
  return 'low';
};

const getJobCity = (job: any) => cityTokens.find((token) => job.slug?.endsWith(`-${token}`)) || 'all';
const isUrgentJob = (job: any) => urgencyKeywords.some((kw) => (job.slug || '').includes(kw) || (job.nameGr || '').toLocaleLowerCase('el-GR').includes(kw));
const classifyAvailability = (job: any) => {
  const duration = (job.summary?.typicalDuration || '').toLocaleLowerCase('el-GR');
  if (isUrgentJob(job) || duration.includes('άμεσα') || duration.includes('24')) return 'asap';
  if (duration.includes('ημέρ') || duration.includes('εβδομάδ')) return 'this-week';
  return 'flexible';
};

// Resolve related category names
const relatedCategories = (pageCategory.relatedCategories || []).map((slug: string) => ({
  slug,
  nameGr: allContent[slug]?.nameGr ?? slug
})).filter((r: any) => allContent[r.slug]);

// JSON-LD schemas
const siteUrl = new URL('/', Astro.site).toString();

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#service`,
  name: pageCategory.nameGr,
  url: canonicalUrl,
  description: pageCategory.metaDescription,
  areaServed: { '@type': 'Country', name: 'Greece' },
  provider: {
    '@type': 'Organization',
    '@id': `${siteUrl}#organization`,
    name: 'GreekHandy',
    url: siteUrl
  }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Αρχική',
      item: siteUrl
    },
    ...(isJobPage && parentCategory
      ? [{ '@type': 'ListItem', position: 2, name: parentCategory.nameGr, item: new URL(`/${parentCategory.slug}`, Astro.site).toString() }]
      : []),
    {
      '@type': 'ListItem',
      position: isJobPage && parentCategory ? 3 : 2,
      name: pageCategory.nameGr,
      item: canonicalUrl
    }
  ]
};

const itemListSchema = !isJobPage && subJobs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: `Υπηρεσίες κατηγορίας ${pageCategory.nameGr}`,
      itemListElement: subJobs.slice(0, 40).map((job: any, index: number) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(`/${job.slug}`, Astro.site).toString(),
        name: job.nameGr
      }))
    }
  : null;

const faqSchema = pageCategory.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageCategory.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer }
  }))
} : null;
---

<Layout title={pageCategory.metaTitle} description={pageCategory.metaDescription} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <main>
    <!-- Breadcrumbs -->
    <nav class="bg-slate-50 px-4 py-3 text-sm">
      <div class="mx-auto flex max-w-5xl items-center gap-2 text-slate-500">
        <a href="/" class="hover:text-blue-700">Αρχική</a>
        <span>&rsaquo;</span>
        {isJobPage && parentCategory ? (
          <>
            <a href={`/${parentCategory.slug}`} class="hover:text-blue-700">{parentCategory.nameGr}</a>
            <span>&rsaquo;</span>
            <span class="text-gray-900">{pageCategory.nameGr}</span>
          </>
        ) : (
          <span class="text-gray-900">{pageCategory.nameGr}</span>
        )}
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-600 px-4 py-16 text-white md:py-20">
      <div class="mx-auto max-w-5xl">
        <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-5xl">{pageCategory.h1}</h1>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-blue-100">{pageCategory.heroText}</p>
        {pageCategory.summary && (
          <div class="mt-6 flex flex-wrap gap-4 text-sm">
            {pageCategory.summary.priceRangeEUR && <span class="bg-blue-800 px-3 py-1 rounded-full">Κόστος: {pageCategory.summary.priceRangeEUR}</span>}
            {pageCategory.summary.typicalDuration && <span class="bg-blue-800 px-3 py-1 rounded-full">Διάρκεια: {pageCategory.summary.typicalDuration}</span>}
          </div>
        )}
        <a href="#contact" class="mt-8 inline-flex rounded-full bg-white px-6 py-3 font-semibold text-blue-700 shadow-sm transition hover:bg-blue-50">
          {pageCategory.cta?.buttonText || 'Ζητήστε Προσφορά'}
        </a>
      </div>
    </section>

    <!-- Content Sections -->
    <section class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl space-y-6">
        {pageCategory.sections?.length > 0 ? (
          pageCategory.sections.map((section: any) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
              <h2 class="text-2xl font-bold text-slate-900">{section.heading}</h2>
              <p class="mt-4 leading-relaxed text-slate-700">{section.content}</p>
              {section.priceRange && (
                <p class="mt-4 font-medium text-slate-900">
                  Ενδεικτικό εύρος τιμής: <span class="text-blue-700">{section.priceRange}</span>
                </p>
              )}
            </article>
          ))
        ) : (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm">
            <p class="font-semibold text-slate-900">Περισσότερες λεπτομέρειες σύντομα.</p>
            <p class="mt-1 text-sm text-slate-600">Ετοιμάζουμε αναλυτικές ενότητες για την υπηρεσία αυτή.</p>
          </div>
        )}
      </div>
    </section>

    <!-- Sub-jobs list (for category pages) -->
    {!isJobPage && (
      <section class="bg-slate-50 px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Υπηρεσίες σε αυτή την κατηγορία</h2>

          {enableAdvancedCategoryUX && subJobs.length > 0 && (
            <div class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Φίλτρα κατηγορίας</p>
              <p id="subjobs-filter-state" data-subjobs-state class="mt-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600" role="status" aria-live="polite" aria-atomic="true">
                Προετοιμασία κατάταξης υπηρεσιών...
              </p>
              <p class="mt-2 text-xs text-slate-600">Χρησιμοποιήστε τα φίλτρα για να περιορίσετε γρήγορα τις επιλογές ανά πόλη, επείγον, budget και διαθεσιμότητα.</p>
              <p class="mt-1 text-xs text-slate-500" data-active-filter-summary aria-live="polite">Ενεργά φίλτρα: κανένα (εμφανίζονται όλα).</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-5" role="group" aria-label="Φίλτρα υπηρεσιών κατηγορίας">
                <select data-filter-urgency aria-label="Φίλτρο προτεραιότητας υπηρεσίας" aria-controls="subjobs-grid" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλες οι προτεραιότητες</option>
                  <option value="urgent">Επείγον</option>
                  <option value="standard">Προγραμματισμένο</option>
                </select>
                <select data-filter-city aria-label="Φίλτρο πόλης" aria-controls="subjobs-grid" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλες οι πόλεις</option>
                  <option value="athina">Αθήνα</option>
                  <option value="thessaloniki">Θεσσαλονίκη</option>
                  <option value="patra">Πάτρα</option>
                  <option value="irakleio">Ηράκλειο</option>
                  <option value="larisa">Λάρισα</option>
                  <option value="volos">Βόλος</option>
                  <option value="ioannina">Ιωάννινα</option>
                </select>
                <select data-filter-budget aria-label="Φίλτρο budget" aria-controls="subjobs-grid" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλα τα budget</option>
                  <option value="low">Οικονομικό</option>
                  <option value="medium">Μεσαίο</option>
                  <option value="high">Αυξημένο</option>
                </select>
                <select data-filter-availability aria-label="Φίλτρο διαθεσιμότητας" aria-controls="subjobs-grid" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλη η διαθεσιμότητα</option>
                  <option value="asap">Άμεσα διαθέσιμο</option>
                  <option value="this-week">Μέσα στην εβδομάδα</option>
                  <option value="flexible">Ευέλικτο ραντεβού</option>
                </select>
                <button type="button" data-filter-reset aria-label="Καθαρισμός όλων των φίλτρων" aria-controls="subjobs-grid" class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-white">Καθαρισμός</button>
              </div>
              <p data-subjobs-active-summary class="mt-2 text-xs text-slate-500" aria-live="polite">Χωρίς ενεργά φίλτρα.</p>
            </div>
          )}

          {subJobs.length > 0 ? (
            <>
              <div class="mt-4 hidden rounded-xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-900" data-subjobs-loading role="status" aria-live="polite">
                <p class="font-semibold">Ενημέρωση λίστας υπηρεσιών...</p>
                <p class="mt-1 text-xs">Εφαρμόζουμε φίλτρα προτεραιότητας, πόλης, budget και διαθεσιμότητας.</p>
              </div>
              <div class="mt-4 hidden rounded-xl border border-orange-200 bg-orange-50 px-4 py-3 text-sm text-orange-800" data-subjobs-empty role="status" aria-live="polite">
                <p class="font-semibold text-orange-900">Δεν βρέθηκαν υπηρεσίες με αυτά τα φίλτρα.</p>
                <p class="mt-1">Καθαρίστε τα φίλτρα ή δοκιμάστε άλλη πόλη/διαθεσιμότητα. Μπορείτε επίσης να συνεχίσετε από σχετικές υπηρεσίες για να μη χαθεί η ροή ανάθεσης.</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <button type="button" data-reset-subjob-filters aria-controls="subjobs-grid" class="inline-flex rounded-full border border-orange-300 bg-white px-3 py-1.5 text-xs font-semibold text-orange-800 transition hover:bg-orange-100">Καθαρισμός φίλτρων</button>
                  <a href={`/${pageCategory.slug}`} class="inline-flex rounded-full border border-orange-300 bg-white px-3 py-1.5 text-xs font-semibold text-orange-800 transition hover:bg-orange-100">Όλες οι υπηρεσίες κατηγορίας</a>
                  <a href="#contact" class="inline-flex rounded-full border border-orange-300 bg-white px-3 py-1.5 text-xs font-semibold text-orange-800 transition hover:bg-orange-100">Ζητήστε προσφορά</a>
                </div>
              </div>
              <div class="mt-4 hidden rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800" data-subjobs-error role="alert" aria-live="assertive">
                <p class="font-semibold text-rose-900">Η κατηγοριοποίηση υπηρεσιών δεν ενημερώθηκε.</p>
                <p class="mt-1">Κάντε επανάληψη για νέα απόπειρα ή συνεχίστε κατευθείαν στην επικοινωνία.</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <button type="button" data-subjobs-retry class="inline-flex rounded-full border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-800 transition hover:bg-rose-100">Επανάληψη</button>
                  <a href="#contact" class="inline-flex rounded-full border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-800 transition hover:bg-rose-100">Επικοινωνία</a>
                </div>
              </div>
              <div id="subjobs-grid" class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-subjobs-grid>
                {subJobs.map((job: any, index: number) => (
                  <a
                    href={`/${job.slug}`}
                    data-subjob-card
                    data-visible-initial={index < initialVisibleSubJobs ? '1' : '0'}
                    data-urgency={isUrgentJob(job) ? 'urgent' : 'standard'}
                    data-city={getJobCity(job)}
                    data-budget={classifyBudget(job.summary?.priceRangeEUR)}
                    data-availability={classifyAvailability(job)}
                    class={`block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-300 hover:shadow-md ${index >= initialVisibleSubJobs ? 'hidden' : ''}`}
                  >
                    <h3 class="font-semibold text-slate-900">{job.nameGr}</h3>
                    {job.summary?.priceRangeEUR && (
                      <p class="mt-1 text-sm text-blue-700">{job.summary.priceRangeEUR}</p>
                    )}
                    {job.summary?.typicalDuration && (
                      <p class="mt-1 text-sm text-slate-500">{job.summary.typicalDuration}</p>
                    )}
                    <p class="mt-2 text-xs font-medium text-slate-600">
                      Διαθεσιμότητα: {classifyAvailability(job) === 'asap' ? 'Άμεσα' : classifyAvailability(job) === 'this-week' ? 'Μέσα στην εβδομάδα' : 'Ευέλικτο ραντεβού'}
                    </p>
                    <div class="mt-2 flex flex-wrap gap-1.5" aria-label="Σήματα εμπιστοσύνης καταχώρισης">
                      <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-[11px] font-semibold text-emerald-800">Επαληθευμένη καταχώριση</span>
                      <span class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[11px] font-semibold text-slate-700">Πηγή: GreekHandy</span>
                    </div>
                  </a>
                ))}
              </div>

              {subJobs.length > initialVisibleSubJobs && (
                <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                  <p class="text-sm text-slate-600" data-subjobs-count aria-live="polite">Εμφανίζονται {initialVisibleSubJobs} από {subJobs.length} υπηρεσίες.</p>
                  <p class="text-xs text-slate-500" data-page-indicator aria-live="polite">Σελίδα 1</p>
                  <p class="sr-only" data-subjobs-a11y-summary aria-live="polite" aria-atomic="true"></p>
                  <div class="flex items-center gap-2">
                    <button type="button" data-page-prev aria-controls="subjobs-grid" aria-label="Προβολή προηγούμενης σελίδας υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Προηγούμενα</button>
                    <button type="button" data-page-next aria-controls="subjobs-grid" aria-label="Προβολή επόμενης σελίδας υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Επόμενα</button>
                    <button type="button" data-load-more-subjobs aria-controls="subjobs-grid" aria-label="Φόρτωση περισσότερων υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Φόρτωση περισσότερων</button>
