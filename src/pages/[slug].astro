                  <div class="flex items-center gap-2">
                    <button type="button" data-page-prev aria-controls="subjobs-grid" aria-label="Προβολή προηγούμενης σελίδας υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Προηγούμενα</button>
                    <button type="button" data-page-next aria-controls="subjobs-grid" aria-label="Προβολή επόμενης σελίδας υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Επόμενα</button>
                    <button type="button" data-load-more-subjobs aria-controls="subjobs-grid" aria-expanded="false" aria-label="Φόρτωση περισσότερων υπηρεσιών" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Φόρτωση περισσότερων</button>
                  </div>
