                'lead-phone': 'τηλέφωνο',
                'lead-email': 'email',
                'lead-description': 'περιγραφή',
                'lead-consent': 'συγκατάθεση'
              };
              validationSummary.textContent = invalid.length
                ? `Έλεγχος φόρμας: απαιτείται διόρθωση στα πεδία ${[...new Set(invalid.map((i) => labelMap[i]))].join(', ')}.`
                : 'Έλεγχος φόρμας: όλα τα υποχρεωτικά πεδία είναι έγκυρα.';
            }

            return invalid.length === 0;
          };

          const setErrorState = (message) => {
            if (errorState instanceof HTMLElement) {
              errorState.textContent = message;
              errorState.classList.remove('hidden');
            }
            if (retryButton instanceof HTMLElement) {
              retryButton.classList.remove('hidden');
            }
            if (leadStepFeedback instanceof HTMLElement) {
              leadStepFeedback.textContent = 'Βήμα 2/3: Ελέγξτε τα πεδία και επαναλάβετε την υποβολή.';
            }
          };

          ['lead-name', 'lead-phone', 'lead-email', 'lead-description', 'lead-consent'].forEach((id) => {
            const el = document.getElementById(id);
            if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement)) return;
            el.addEventListener('input', () => {
              el.setAttribute('data-touched', '1');
              validateLeadForm();
            });
            el.addEventListener('blur', () => {
              el.setAttribute('data-touched', '1');
              validateLeadForm();
            });
          });

          if (retryButton instanceof HTMLButtonElement) {
            retryButton.addEventListener('click', () => {
              retryButton.classList.add('hidden');
              validateLeadForm(true);
              const firstInvalid = form instanceof HTMLFormElement ? form.querySelector(':invalid') : null;
              if (firstInvalid instanceof HTMLElement) {
                firstInvalid.focus();
              }
              if (leadStepFeedback instanceof HTMLElement) {
                leadStepFeedback.textContent = 'Βήμα 1/3: Συμπληρώστε τις διορθώσεις και ξαναστείλτε το αίτημα.';
              }
            });
          }

          form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (
              !(form instanceof HTMLFormElement)
              || !(submitButton instanceof HTMLButtonElement)
            ) return;

            if (isSubmitting) return;
            const fd = new FormData(form);
            // Honeypot check
            if (fd.get('website')) return;

            const formValid = validateLeadForm(true);
            if (!formValid) {
              setErrorState('Ελέγξτε τα επισημασμένα πεδία και δοκιμάστε ξανά.');
              return;
            }

            const consentGiven = fd.get('consent') === 'on';
            if (!consentGiven) {
              setErrorState('Απαιτείται συγκατάθεση για να συνεχίσουμε με το αίτημά σας. Διαβάστε την Πολιτική Απορρήτου και δοκιμάστε ξανά.');
              return;
            }

            if (typeof navigator !== 'undefined' && navigator.onLine === false) {
              setErrorState('Δεν υπάρχει σύνδεση στο διαδίκτυο. Ελέγξτε το δίκτυο και δοκιμάστε ξανά.');
              return;
            }

            isSubmitting = true;
            submitButton.disabled = true;
            submitButton.setAttribute('aria-busy', 'true');
            submitButton.textContent = 'Αποστολή...';
            if (loadingState instanceof HTMLElement) loadingState.classList.remove('hidden');
            if (errorState instanceof HTMLElement) errorState.classList.add('hidden');
            if (retryButton instanceof HTMLElement) retryButton.classList.add('hidden');
            if (leadStepFeedback instanceof HTMLElement) {
              leadStepFeedback.textContent = 'Βήμα 2/3: Υποβολή σε εξέλιξη, ελέγχουμε τα στοιχεία σας.';
            }

            const payload = {
              name: String(fd.get('name') || '').trim(),
              phone: String(fd.get('phone') || '').trim(),
              email: String(fd.get('email') || '').trim(),
              description: String(fd.get('description') || '').trim(),
              service_slug: fd.get('serviceSlug'),
              service_name: fd.get('serviceName'),
              page_url: fd.get('pageUrl'),
            };

            try {
              const timeoutPromise = new Promise((_, reject) => {
                window.setTimeout(() => reject(new Error('request-timeout')), REQUEST_TIMEOUT_MS);
              });
              const requestPromise = supabase.from('contact_requests').insert(payload);
              const { error } = await Promise.race([requestPromise, timeoutPromise]);

              if (error) throw error;

              if (loadingState instanceof HTMLElement) loadingState.classList.add('hidden');
              if (fieldsState instanceof HTMLElement) fieldsState.classList.add('hidden');
              submitButton.classList.add('hidden');
              if (leadStepFeedback instanceof HTMLElement) {
                leadStepFeedback.textContent = 'Βήμα 3/3: Ολοκληρώθηκε. Θα λάβετε πρώτη ενημέρωση εντός 1–2 εργάσιμων ωρών.';
              }
              if (successState instanceof HTMLElement) successState.classList.remove('hidden');
            } catch {
              if (loadingState instanceof HTMLElement) loadingState.classList.add('hidden');
              setErrorState('Η υποβολή δεν ολοκληρώθηκε αυτή τη στιγμή. Δοκιμάστε ξανά σε 1-2 λεπτά ή στείλτε στο info@greekhandy.gr.');
              submitButton.disabled = false;
              submitButton.removeAttribute('aria-busy');
              submitButton.textContent = 'Αποστολή Αιτήματος';
            } finally {
              isSubmitting = false;
            }
          });
        </script>
      </div>
    </section>
  </main>
</Layout>
