                <noscript>
                  <p class="mt-2 text-sm text-slate-600">Για πλήρη εξερεύνηση όλων των υπηρεσιών χωρίς φίλτρα JavaScript, χρησιμοποιήστε τα links της σελίδας κατηγορίας και τις επιμέρους υπηρεσίες παρακάτω.</p>
                </noscript>
              )}

              {serverRenderedSubJobsLimit < subJobs.length && (
                <p class="mt-3 text-xs text-slate-500">Για ταχύτερη φόρτωση εμφανίζεται επιλεγμένο υποσύνολο υπηρεσιών ({renderedSubJobs.length}/{subJobs.length}). Χρησιμοποιήστε τα φίλτρα για πιο στοχευμένη επιλογή.</p>
              )}

              <nav class="sr-only" aria-label="Κατάλογος βασικών υπηρεσιών για SEO crawlability">
                <ul>
                  {subJobs.slice(0, SEO_SUBJOB_LINK_COUNT).map((job: any) => (<li><a href={`/${job.slug}`}>{job.nameGr}</a></li>))}
                </ul>
              </nav>
            </>
          ) : (
            <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 text-slate-700">
              <p class="font-semibold text-slate-900">Δεν υπάρχουν ακόμα επιμέρους υπηρεσίες.</p>
              <p class="mt-1 text-sm text-slate-600">Η κατηγορία θα εμπλουτιστεί σταδιακά με επιπλέον επιλογές.</p>
            </div>
          )}
