                </div>
                <noscript>
                  <p class="mt-2 text-sm text-slate-600">Για πλήρη εξερεύνηση όλων των υπηρεσιών χωρίς φίλτρα JavaScript, χρησιμοποιήστε τα links της σελίδας κατηγορίας και τις επιμέρους υπηρεσίες παρακάτω.</p>
                </noscript>
              )}

              <nav class="sr-only" aria-label="Πλήρης κατάλογος υπηρεσιών για SEO crawlability">
                <ul>
                  {subJobs.map((job: any) => (<li><a href={`/${job.slug}`}>{job.nameGr}</a></li>))}
                </ul>
              </nav>
            </>
          ) : (
            <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 text-slate-700">
              <p class="font-semibold text-slate-900">Δεν υπάρχουν ακόμα επιμέρους υπηρεσίες.</p>
              <p class="mt-1 text-sm text-slate-600">Η κατηγορία θα εμπλουτιστεί σταδιακά με επιπλέον επιλογές.</p>
            </div>
          )}
        </div>
      </section>
    )}

    <script is:inline>
      (() => {
        const cards = Array.from(document.querySelectorAll('[data-subjob-card]'));
        if (!cards.length) return;

        const subJobsGrid = document.querySelector('[data-subjobs-grid]');
        const urgency = document.querySelector('[data-filter-urgency]');
        const city = document.querySelector('[data-filter-city]');
        const budget = document.querySelector('[data-filter-budget]');
        const availability = document.querySelector('[data-filter-availability]');
        const resetFilters = document.querySelector('[data-filter-reset]');
        const resetFromEmpty = document.querySelector('[data-reset-subjob-filters]');
        const loadMore = document.querySelector('[data-load-more-subjobs]');
        const pagePrev = document.querySelector('[data-page-prev]');
        const pageNext = document.querySelector('[data-page-next]');
        const counter = document.querySelector('[data-subjobs-count]');
        const pageIndicator = document.querySelector('[data-page-indicator]');
        const a11ySummary = document.querySelector('[data-subjobs-a11y-summary]');
        const filterState = document.querySelector('[data-subjobs-state]');
        const filterSummary = document.querySelector('[data-active-filter-summary]');
        const activeFiltersSummary = document.querySelector('[data-subjobs-active-summary]');
        const loadingState = document.querySelector('[data-subjobs-loading]');
        const emptyState = document.querySelector('[data-subjobs-empty]');
        const errorState = document.querySelector('[data-subjobs-error]');
        const retryState = document.querySelector('[data-subjobs-retry]');
        const initialLimit = cards.filter((card) => card.getAttribute('data-visible-initial') === '1').length || 12;
        let visibleLimit = initialLimit;
        let pageStart = 0;
        let filterTimer = null;

        const setBusyState = (isBusy) => {
          if (subJobsGrid instanceof HTMLElement) {
            subJobsGrid.setAttribute('aria-busy', isBusy ? 'true' : 'false');
          }
          if (loadingState instanceof HTMLElement) {
            loadingState.classList.toggle('hidden', !isBusy);
          }
          if (isBusy && filterState instanceof HTMLElement) {
            filterState.dataset.state = 'loading';
            filterState.textContent = 'Ενημερώνουμε τη λίστα υπηρεσιών με βάση τα φίλτρα...';
          }
        };

        const setFilterState = (tone, message) => {
          if (!(filterState instanceof HTMLElement)) return;
          filterState.dataset.state = tone;
          filterState.textContent = message;
        };

        const hideErrorState = () => {
          if (errorState instanceof HTMLElement) errorState.classList.add('hidden');
        };

        const applyFilters = () => {
          try {
            hideErrorState();
            const urgencyValue = urgency instanceof HTMLSelectElement ? urgency.value : 'all';
            const cityValue = city instanceof HTMLSelectElement ? city.value : 'all';
            const budgetValue = budget instanceof HTMLSelectElement ? budget.value : 'all';
            const availabilityValue = availability instanceof HTMLSelectElement ? availability.value : 'all';
            const hasActiveFilters = urgencyValue !== 'all' || cityValue !== 'all' || budgetValue !== 'all' || availabilityValue !== 'all';

            if (filterSummary instanceof HTMLElement) {
              const labels = [];
              if (urgencyValue !== 'all') labels.push(`προτεραιότητα: ${urgencyValue === 'urgent' ? 'επείγον' : 'προγραμματισμένο'}`);
              const cityLabelMap = {
                athina: 'Αθήνα',
                thessaloniki: 'Θεσσαλονίκη',
                patra: 'Πάτρα',
                irakleio: 'Ηράκλειο',
                larisa: 'Λάρισα',
                volos: 'Βόλος',
                ioannina: 'Ιωάννινα'
              };
              if (cityValue !== 'all') labels.push(`πόλη: ${cityLabelMap[cityValue] || cityValue}`);
              if (budgetValue !== 'all') labels.push(`budget: ${budgetValue}`);
              if (availabilityValue !== 'all') labels.push(`διαθεσιμότητα: ${availabilityValue}`);
              filterSummary.textContent = labels.length ? `Ενεργά φίλτρα: ${labels.join(', ')}` : 'Ενεργά φίλτρα: κανένα (εμφανίζονται όλα).';
            }
            const activeFilterLabels: string[] = [];
            if (urgencyValue !== 'all') activeFilterLabels.push(`Προτεραιότητα: ${urgencyValue === 'urgent' ? 'Επείγον' : 'Προγραμματισμένο'}`);
            if (cityValue !== 'all') activeFilterLabels.push(`Πόλη: ${cityValue}`);
            if (budgetValue !== 'all') activeFilterLabels.push(`Budget: ${budgetValue}`);
            if (availabilityValue !== 'all') {
              const availabilityLabel = availabilityValue === 'asap'
                ? 'Άμεσα διαθέσιμο'
                : availabilityValue === 'this-week'
                  ? 'Μέσα στην εβδομάδα'
                  : 'Ευέλικτο ραντεβού';
              activeFilterLabels.push(`Διαθεσιμότητα: ${availabilityLabel}`);
            }
            if (activeFiltersSummary instanceof HTMLElement) {
              activeFiltersSummary.textContent = activeFilterLabels.length > 0
                ? `Ενεργά φίλτρα: ${activeFilterLabels.join(' · ')}.`
                : 'Χωρίς ενεργά φίλτρα.';
            }

            const filteredCards = cards.filter((card) => {
              return (urgencyValue === 'all' || card.getAttribute('data-urgency') === urgencyValue)
                && (cityValue === 'all' || card.getAttribute('data-city') === cityValue)
                && (budgetValue === 'all' || card.getAttribute('data-budget') === budgetValue)
                && (availabilityValue === 'all' || card.getAttribute('data-availability') === availabilityValue);
            });

            const matched = filteredCards.length;
            const pageSize = visibleLimit;
            if (pageStart >= matched) pageStart = 0;
            const pageEnd = Math.min(pageStart + pageSize, matched);

            cards.forEach((card) => card.classList.add('hidden'));
            filteredCards.slice(pageStart, pageEnd).forEach((card) => card.classList.remove('hidden'));

            if (counter instanceof HTMLElement) {
              counter.textContent = matched === 0
                ? 'Δεν υπάρχουν υπηρεσίες με αυτά τα φίλτρα.'
                : `Εμφανίζονται ${pageStart + 1}-${pageEnd} από ${matched} υπηρεσίες.`;
            }
            if (pageIndicator instanceof HTMLElement) {
              const pageNumber = matched === 0 ? 0 : Math.floor(pageStart / pageSize) + 1;
              const totalPages = matched === 0 ? 0 : Math.ceil(matched / pageSize);
              pageIndicator.textContent = matched === 0 ? 'Σελίδα 0' : `Σελίδα ${pageNumber} από ${totalPages}`;
            }
            if (a11ySummary instanceof HTMLElement) {
              const pageMessage = matched === 0
                ? 'Καμία υπηρεσία για τα τρέχοντα φίλτρα.'
                : `Προβολή ${pageStart + 1}-${pageEnd} από ${matched} υπηρεσίες.`;
              a11ySummary.textContent = activeFilterLabels.length > 0
                ? `${pageMessage} Ενεργά φίλτρα: ${activeFilterLabels.join(', ')}.`
                : pageMessage;
            }
            if (loadMore instanceof HTMLButtonElement) {
              loadMore.classList.toggle('hidden', matched <= pageSize || matched === 0);
            }
            if (pagePrev instanceof HTMLButtonElement) {
              pagePrev.disabled = pageStart === 0 || matched === 0;
              pagePrev.setAttribute('aria-disabled', pagePrev.disabled ? 'true' : 'false');
              pagePrev.classList.toggle('opacity-50', pagePrev.disabled);
            }
            if (pageNext instanceof HTMLButtonElement) {
              pageNext.disabled = pageEnd >= matched || matched === 0;
              pageNext.setAttribute('aria-disabled', pageNext.disabled ? 'true' : 'false');
              pageNext.classList.toggle('opacity-50', pageNext.disabled);
            }
            if (emptyState instanceof HTMLElement) {
              emptyState.classList.toggle('hidden', matched > 0 || !hasActiveFilters);
            }

            if (matched === 0 && hasActiveFilters) {
              setFilterState('no-match', 'Δεν υπάρχουν υπηρεσίες με τον τρέχοντα συνδυασμό φίλτρων.');
            } else if (matched === 0) {
              setFilterState('empty', 'Δεν υπάρχουν διαθέσιμες υπηρεσίες προς εμφάνιση αυτή τη στιγμή.');
            } else if (hasActiveFilters) {
              setFilterState('filtered', `Φιλτραρισμένη προβολή: ${pageStart + 1}-${pageEnd} από ${matched} υπηρεσίες.`);
            } else {
              setFilterState('ready', `Κανονική προβολή: ${pageStart + 1}-${pageEnd} από ${matched} υπηρεσίες.`);
            }
          } catch {
            if (errorState instanceof HTMLElement) errorState.classList.remove('hidden');
            setFilterState('error', 'Η κατηγοριοποίηση υπηρεσιών δεν ενημερώθηκε. Δοκιμάστε επανάληψη.');
          } finally {
            setBusyState(false);
          }
        };

        const runFilters = () => {
          setBusyState(true);
          if (filterTimer) window.clearTimeout(filterTimer);
          filterTimer = window.setTimeout(applyFilters, 90);
        };

        const resetAllFilters = () => {
          if (urgency instanceof HTMLSelectElement) urgency.value = 'all';
          if (city instanceof HTMLSelectElement) city.value = 'all';
          if (budget instanceof HTMLSelectElement) budget.value = 'all';
          if (availability instanceof HTMLSelectElement) availability.value = 'all';
          visibleLimit = initialLimit;
          pageStart = 0;
          runFilters();
        };

        [urgency, city, budget, availability].forEach((el) => {
          if (el instanceof HTMLSelectElement) {
            el.addEventListener('change', () => {
              visibleLimit = initialLimit;
              pageStart = 0;
              runFilters();
            });
          }
        });

        [resetFilters, resetFromEmpty].forEach((el) => {
          if (el instanceof HTMLButtonElement) {
            el.addEventListener('click', resetAllFilters);
          }
        });

        if (loadMore instanceof HTMLButtonElement) {
          loadMore.addEventListener('click', () => {
            visibleLimit += initialLimit;
            runFilters();
          });
        }

        if (pagePrev instanceof HTMLButtonElement) {
          pagePrev.addEventListener('click', () => {
            pageStart = Math.max(0, pageStart - visibleLimit);
            runFilters();
          });
        }

        if (pageNext instanceof HTMLButtonElement) {
          pageNext.addEventListener('click', () => {
            pageStart += visibleLimit;
            runFilters();
          });
        }

        if (retryState instanceof HTMLButtonElement) {
          retryState.addEventListener('click', () => {
            visibleLimit = initialLimit;
            pageStart = 0;
            runFilters();
          });
        }

        runFilters();
      })();
    </script>

