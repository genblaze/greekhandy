---
import Layout from '../layouts/Layout.astro';

export const prerender = true;

// Load all content JSONs at build time (top-level only)
const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });

// Build slug → content map
const allContent: Record<string, any> = {};
for (const [path, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) {
    allContent[data.slug] = data;
  }
}

// Load categories for navigation
let categories: any[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = catFile.default ?? catFile;
} catch {}

export function getStaticPaths() {
  const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
  const paths = [];
  for (const [, mod] of Object.entries(contentFiles)) {
    const data = (mod as any).default ?? mod;
    if (data?.slug) {
      paths.push({ params: { slug: data.slug }, props: { category: data } });
    }
  }
  return paths;
}

const { category } = Astro.props;
const canonicalUrl = new URL(`/${category.slug}`, Astro.site).toString();

// Determine if this is a job page (has categorySlug) or category page
const isJobPage = !!category.categorySlug;
const parentCategory = isJobPage ? categories.find((c: any) => c.id === category.categoryId || c.slug === category.categorySlug) : null;

// Find sub-jobs for category pages
const subJobs = !isJobPage ? Object.values(allContent).filter((p: any) => p.categoryId === category.id || p.categorySlug === category.slug) : [];

const highVolumeFilterSlugs = new Set(['ydravlikoi']);
const enableAdvancedCategoryUX = !isJobPage && (highVolumeFilterSlugs.has(category.slug) || subJobs.length >= 18);
const cityTokens = ['athina', 'thessaloniki', 'patra', 'irakleio', 'larisa', 'volos', 'ioannina'];
const urgencyKeywords = ['amesi', 'ektakti', 'epeigon'];
const initialVisibleSubJobs = 12;

const classifyBudget = (priceRange: string | undefined) => {
  const value = (priceRange || '').toLocaleLowerCase('el-GR');
  if (!value) return 'unknown';
  if (value.includes('€200') || value.includes('€300') || value.includes('€400') || value.includes('€500') || value.includes('€1000')) return 'high';
  if (value.includes('€80') || value.includes('€100') || value.includes('€120') || value.includes('€150')) return 'medium';
  return 'low';
};

const getJobCity = (job: any) => cityTokens.find((token) => job.slug?.endsWith(`-${token}`)) || 'all';
const isUrgentJob = (job: any) => urgencyKeywords.some((kw) => (job.slug || '').includes(kw) || (job.nameGr || '').toLocaleLowerCase('el-GR').includes(kw));

// Resolve related category names
const relatedCategories = (category.relatedCategories || []).map((slug: string) => ({
  slug,
  nameGr: allContent[slug]?.nameGr ?? slug
})).filter((r: any) => allContent[r.slug]);

// JSON-LD schemas
const siteUrl = new URL('/', Astro.site).toString();

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#service`,
  name: category.nameGr,
  url: canonicalUrl,
  description: category.metaDescription,
  areaServed: { '@type': 'Country', name: 'Greece' },
  provider: {
    '@type': 'Organization',
    '@id': `${siteUrl}#organization`,
    name: 'GreekHandy',
    url: siteUrl
  }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Αρχική',
      item: siteUrl
    },
    ...(isJobPage && parentCategory
      ? [{ '@type': 'ListItem', position: 2, name: parentCategory.nameGr, item: new URL(`/${parentCategory.slug}`, Astro.site).toString() }]
      : []),
    {
      '@type': 'ListItem',
      position: isJobPage && parentCategory ? 3 : 2,
      name: category.nameGr,
      item: canonicalUrl
    }
  ]
};

const itemListSchema = !isJobPage && subJobs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: `Υπηρεσίες κατηγορίας ${category.nameGr}`,
      itemListElement: subJobs.slice(0, 40).map((job: any, index: number) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(`/${job.slug}`, Astro.site).toString(),
        name: job.nameGr
      }))
    }
  : null;

const faqSchema = category.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: category.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer }
  }))
} : null;
---

<Layout title={category.metaTitle} description={category.metaDescription} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <main>
    <!-- Breadcrumbs -->
    <nav class="bg-slate-50 px-4 py-3 text-sm">
      <div class="mx-auto flex max-w-5xl items-center gap-2 text-slate-500">
        <a href="/" class="hover:text-blue-700">Αρχική</a>
        <span>&rsaquo;</span>
        {isJobPage && parentCategory ? (
          <>
            <a href={`/${parentCategory.slug}`} class="hover:text-blue-700">{parentCategory.nameGr}</a>
            <span>&rsaquo;</span>
            <span class="text-gray-900">{category.nameGr}</span>
          </>
        ) : (
          <span class="text-gray-900">{category.nameGr}</span>
        )}
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-600 px-4 py-16 text-white md:py-20">
      <div class="mx-auto max-w-5xl">
        <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-5xl">{category.h1}</h1>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-blue-100">{category.heroText}</p>
        {category.summary && (
          <div class="mt-6 flex flex-wrap gap-4 text-sm">
            {category.summary.priceRangeEUR && <span class="bg-blue-800 px-3 py-1 rounded-full">Κόστος: {category.summary.priceRangeEUR}</span>}
            {category.summary.typicalDuration && <span class="bg-blue-800 px-3 py-1 rounded-full">Διάρκεια: {category.summary.typicalDuration}</span>}
          </div>
        )}
        <a href="#contact" class="mt-8 inline-flex rounded-full bg-white px-6 py-3 font-semibold text-blue-700 shadow-sm transition hover:bg-blue-50">
          {category.cta?.buttonText || 'Ζητήστε Προσφορά'}
        </a>
      </div>
    </section>

    <!-- Content Sections -->
    <section class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl space-y-6">
        {category.sections?.length > 0 ? (
          category.sections.map((section: any) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
              <h2 class="text-2xl font-bold text-slate-900">{section.heading}</h2>
              <p class="mt-4 leading-relaxed text-slate-700">{section.content}</p>
              {section.priceRange && (
                <p class="mt-4 font-medium text-slate-900">
                  Ενδεικτικό εύρος τιμής: <span class="text-blue-700">{section.priceRange}</span>
                </p>
              )}
            </article>
          ))
        ) : (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm">
            <p class="font-semibold text-slate-900">Περισσότερες λεπτομέρειες σύντομα.</p>
            <p class="mt-1 text-sm text-slate-600">Ετοιμάζουμε αναλυτικές ενότητες για την υπηρεσία αυτή.</p>
          </div>
        )}
      </div>
    </section>

    <!-- Sub-jobs list (for category pages) -->
    {!isJobPage && (
      <section class="bg-slate-50 px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Υπηρεσίες σε αυτή την κατηγορία</h2>

          {enableAdvancedCategoryUX && subJobs.length > 0 && (
            <div class="mt-4 rounded-xl border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Φίλτρα κατηγορίας</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-3">
                <select data-filter-urgency class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλες οι προτεραιότητες</option>
                  <option value="urgent">Επείγον</option>
                  <option value="standard">Προγραμματισμένο</option>
                </select>
                <select data-filter-city class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλες οι πόλεις</option>
                  <option value="athina">Αθήνα</option>
                  <option value="thessaloniki">Θεσσαλονίκη</option>
                  <option value="patra">Πάτρα</option>
                  <option value="irakleio">Ηράκλειο</option>
                  <option value="larisa">Λάρισα</option>
                  <option value="volos">Βόλος</option>
                  <option value="ioannina">Ιωάννινα</option>
                </select>
                <select data-filter-budget class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
                  <option value="all">Όλα τα budget</option>
                  <option value="low">Οικονομικό</option>
                  <option value="medium">Μεσαίο</option>
                  <option value="high">Αυξημένο</option>
                </select>
              </div>
            </div>
          )}

          {subJobs.length > 0 ? (
            <>
              <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-subjobs-grid>
                {subJobs.map((job: any, index: number) => (
                  <a
                    href={`/${job.slug}`}
                    data-subjob-card
                    data-visible-initial={index < initialVisibleSubJobs ? '1' : '0'}
                    data-urgency={isUrgentJob(job) ? 'urgent' : 'standard'}
                    data-city={getJobCity(job)}
                    data-budget={classifyBudget(job.summary?.priceRangeEUR)}
                    class={`block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-300 hover:shadow-md ${index >= initialVisibleSubJobs ? 'hidden' : ''}`}
                  >
                    <h3 class="font-semibold text-slate-900">{job.nameGr}</h3>
                    {job.summary?.priceRangeEUR && (
                      <p class="mt-1 text-sm text-blue-700">{job.summary.priceRangeEUR}</p>
                    )}
                    {job.summary?.typicalDuration && (
                      <p class="mt-1 text-sm text-slate-500">{job.summary.typicalDuration}</p>
                    )}
                  </a>
                ))}
              </div>

              {subJobs.length > initialVisibleSubJobs && (
                <div class="mt-4 flex items-center justify-between gap-3">
                  <p class="text-sm text-slate-600" data-subjobs-count>Εμφανίζονται {initialVisibleSubJobs} από {subJobs.length} υπηρεσίες.</p>
                  <button type="button" data-load-more-subjobs class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Φόρτωση περισσότερων</button>
                </div>
              )}

              <nav class="sr-only" aria-label="Πλήρης κατάλογος υπηρεσιών για SEO crawlability">
                <ul>
                  {subJobs.map((job: any) => (<li><a href={`/${job.slug}`}>{job.nameGr}</a></li>))}
                </ul>
              </nav>
            </>
          ) : (
            <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 text-slate-700">
              <p class="font-semibold text-slate-900">Δεν υπάρχουν ακόμα επιμέρους υπηρεσίες.</p>
              <p class="mt-1 text-sm text-slate-600">Η κατηγορία θα εμπλουτιστεί σταδιακά με επιπλέον επιλογές.</p>
            </div>
          )}
        </div>
      </section>
    )}

    <script is:inline>
      (() => {
        const cards = Array.from(document.querySelectorAll('[data-subjob-card]'));
        if (!cards.length) return;

        const urgency = document.querySelector('[data-filter-urgency]');
        const city = document.querySelector('[data-filter-city]');
        const budget = document.querySelector('[data-filter-budget]');
        const loadMore = document.querySelector('[data-load-more-subjobs]');
        const counter = document.querySelector('[data-subjobs-count]');
        let visibleLimit = cards.filter((c) => c.getAttribute('data-visible-initial') === '1').length || 12;

        const applyFilters = () => {
          const urgencyValue = urgency instanceof HTMLSelectElement ? urgency.value : 'all';
          const cityValue = city instanceof HTMLSelectElement ? city.value : 'all';
          const budgetValue = budget instanceof HTMLSelectElement ? budget.value : 'all';

          let matched = 0;
          cards.forEach((card) => {
            const matches = (urgencyValue === 'all' || card.getAttribute('data-urgency') === urgencyValue)
              && (cityValue === 'all' || card.getAttribute('data-city') === cityValue)
              && (budgetValue === 'all' || card.getAttribute('data-budget') === budgetValue);

            if (!matches) {
              card.classList.add('hidden');
              return;
            }

            matched += 1;
            const shouldShow = matched <= visibleLimit;
            card.classList.toggle('hidden', !shouldShow);
          });

          if (counter instanceof HTMLElement) {
            counter.textContent = `Εμφανίζονται ${Math.min(matched, visibleLimit)} από ${matched} υπηρεσίες.`;
          }
          if (loadMore instanceof HTMLButtonElement) {
            loadMore.classList.toggle('hidden', matched <= visibleLimit);
          }
        };

        [urgency, city, budget].forEach((el) => {
          if (el instanceof HTMLSelectElement) {
            el.addEventListener('change', () => {
              visibleLimit = 12;
              applyFilters();
            });
          }
        });

        if (loadMore instanceof HTMLButtonElement) {
          loadMore.addEventListener('click', () => {
            visibleLimit += 12;
            applyFilters();
          });
        }

        applyFilters();
      })();
    </script>

    <!-- Related Categories -->
    <section class="bg-slate-50 px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Σχετικές Υπηρεσίες</h2>
        {relatedCategories.length > 0 ? (
          <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {relatedCategories.map((rel: any) => (
              <li>
                <a href={`/${rel.slug}`} class="block rounded-xl border border-slate-200 bg-white px-5 py-4 font-medium text-blue-700 shadow-sm transition hover:border-blue-300 hover:shadow-md">
                  {rel.nameGr}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 text-slate-700">
            <p class="font-semibold text-slate-900">Δεν υπάρχουν σχετικές υπηρεσίες για την ώρα.</p>
            <p class="mt-1 text-sm text-slate-600">Μπορείτε να συνεχίσετε από την αρχική σελίδα για περισσότερες επιλογές.</p>
          </div>
        )}
      </div>
    </section>

    <!-- FAQ -->
    {category.faq?.length > 0 && (
      <section id="faq" class="px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Συχνές Ερωτήσεις</h2>
          <div class="mt-6 space-y-4">
            {category.faq.map((item: any) => (
              <details class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-blue-200">
                <summary class="cursor-pointer text-lg font-semibold text-slate-900 marker:text-blue-700">{item.question}</summary>
                <p class="mt-3 leading-relaxed text-slate-700">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Contact Form MVP -->
    <section id="contact" class="bg-blue-700 px-4 py-12 text-white md:py-16">
      <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-2 lg:items-start">
        <div>
          <h2 class="text-2xl font-bold md:text-3xl">{category.cta?.heading || 'Χρειάζεστε Επαγγελματία;'}</h2>
          <p class="mt-4 max-w-2xl text-blue-100">{category.cta?.text || 'Στείλτε μας το αίτημά σας και λάβετε δωρεάν προσφορές.'}</p>
          <ul class="mt-6 space-y-2 text-sm text-blue-100">
            <li>✓ Δωρεάν αίτημα προσφοράς</li>
            <li>✓ Επικοινωνία από την ομάδα GreekHandy</li>
            <li>✓ Χωρίς δέσμευση</li>
          </ul>
        </div>

        <form id="contact-form" class="rounded-2xl bg-white p-6 text-gray-900 shadow-xl md:p-8">
          <input type="hidden" name="serviceSlug" value={category.slug} />
          <input type="hidden" name="serviceName" value={category.nameGr} />
          <input type="hidden" name="pageUrl" value={canonicalUrl} />

          <h3 class="text-xl font-bold text-gray-900">{category.cta?.buttonText || 'Ζητήστε Προσφορά'}</h3>
          <p class="mt-1 text-sm text-gray-600">Συμπληρώστε τα στοιχεία σας και θα σας καλέσουμε σύντομα.</p>

          <div id="form-loading" class="hidden rounded-lg border border-blue-200 bg-blue-50 p-4 text-blue-800">
            <p class="font-semibold">Επεξεργασία αιτήματος...</p>
            <p class="mt-1 text-sm">Ελέγχουμε τα στοιχεία σας και αποθηκεύουμε το αίτημα.</p>
          </div>
          <div id="form-success" class="hidden rounded-lg border border-green-200 bg-green-50 p-4 text-green-800">
            <p class="font-semibold">Ευχαριστούμε!</p>
            <p class="mt-1 text-sm">Το αίτημά σας καταχωρήθηκε. Θα επικοινωνήσουμε σύντομα.</p>
          </div>
          <div id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>

          <div id="form-fields" class="mt-5 grid gap-4">
            <div>
              <label for="lead-name" class="mb-1 block text-sm font-semibold text-gray-800">Όνομα *</label>
              <input id="lead-name" name="name" type="text" required class="w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            </div>
            <div>
              <label for="lead-phone" class="mb-1 block text-sm font-semibold text-gray-800">Τηλέφωνο *</label>
              <input id="lead-phone" name="phone" type="tel" required pattern="[0-9+()\-\s]{7,20}" title="Χρησιμοποιήστε έγκυρο αριθμό τηλεφώνου" class="w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            </div>
            <div>
              <label for="lead-email" class="mb-1 block text-sm font-semibold text-gray-800">Email *</label>
              <input id="lead-email" name="email" type="email" required autocomplete="email" class="w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
            </div>
            <div>
              <label for="lead-description" class="mb-1 block text-sm font-semibold text-gray-800">Περιγραφή εργασίας *</label>
              <textarea id="lead-description" name="description" rows="4" minlength="15" required class="w-full rounded-lg border border-gray-300 px-3 py-2.5 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" placeholder="Περιγράψτε συνοπτικά τι χρειάζεστε..."></textarea>
            </div>

            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>
          </div>

          <button id="form-submit" type="submit" class="mt-5 w-full rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800">
            Αποστολή Αιτήματος
          </button>
          <p class="mt-2 text-xs text-gray-500">Με την αποστολή αποδέχεστε να επικοινωνήσουμε μαζί σας για το συγκεκριμένο αίτημα.</p>
        </form>

        <script>
          import { createClient } from '@supabase/supabase-js';
          const supabase = createClient(
            'https://rwggwqnddoturgcyluuo.supabase.co',
            'sb_publishable_tkTy4XLRcY6AP6T-PPIVNg_HDI7Z0J5'
          );
          const form = document.getElementById('contact-form');
          form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const fd = new FormData(form as HTMLFormElement);
            // Honeypot check
            if (fd.get('website')) return;
            const btn = document.getElementById('form-submit') as HTMLButtonElement;
            const loadingState = document.getElementById('form-loading');
            const errorState = document.getElementById('form-error');
            btn.disabled = true;
            btn.setAttribute('aria-busy', 'true');
            btn.textContent = 'Αποστολή...';
            loadingState?.classList.remove('hidden');
            errorState?.classList.add('hidden');

            const { error } = await supabase.from('contact_requests').insert({
              name: fd.get('name'),
              phone: fd.get('phone'),
              email: fd.get('email'),
              description: fd.get('description'),
              service_slug: fd.get('serviceSlug'),
              service_name: fd.get('serviceName'),
              page_url: fd.get('pageUrl'),
            });
            if (error) {
              loadingState?.classList.add('hidden');
              document.getElementById('form-error')!.textContent = 'Κάτι πήγε στραβά. Δοκιμάστε ξανά.';
              document.getElementById('form-error')!.classList.remove('hidden');
              btn.disabled = false;
              btn.removeAttribute('aria-busy');
              btn.textContent = 'Αποστολή Αιτήματος';
            } else {
              loadingState?.classList.add('hidden');
              document.getElementById('form-fields')!.classList.add('hidden');
              btn.classList.add('hidden');
              document.getElementById('form-success')!.classList.remove('hidden');
            }
          });
        </script>
      </div>
    </section>
  </main>
</Layout>
