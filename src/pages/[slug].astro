---
import BaseHead from '../components/BaseHead.astro';
import Layout from '../layouts/Layout.astro';

// Load all content JSONs at build time (top-level only)
const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });

// Build slug → content map
const allContent: Record<string, any> = {};
for (const [path, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) {
    allContent[data.slug] = data;
  }
}

// Load categories for navigation
let categories: any[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = catFile.default ?? catFile;
} catch {}

export function getStaticPaths() {
  const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
  const paths = [];
  for (const [, mod] of Object.entries(contentFiles)) {
    const data = (mod as any).default ?? mod;
    if (data?.slug) {
      paths.push({ params: { slug: data.slug }, props: { category: data } });
    }
  }
  return paths;
}

const { category } = Astro.props;
const canonicalUrl = new URL(`/${category.slug}`, Astro.site).toString();

// Determine if this is a job page (has categorySlug) or category page
const isJobPage = !!category.categorySlug;
const parentCategory = isJobPage ? categories.find((c: any) => c.id === category.categoryId || c.slug === category.categorySlug) : null;

// Find sub-jobs for category pages
const subJobs = !isJobPage ? Object.values(allContent).filter((p: any) => p.categoryId === category.id || p.categorySlug === category.slug) : [];

// Resolve related category names
const relatedCategories = (category.relatedCategories || []).map((slug: string) => ({
  slug,
  nameGr: allContent[slug]?.nameGr ?? slug
})).filter((r: any) => allContent[r.slug]);

// JSON-LD schemas
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: category.nameGr,
  url: canonicalUrl,
  description: category.metaDescription,
  areaServed: { '@type': 'Country', name: 'Greece' },
  provider: {
    '@type': 'Organization',
    name: 'GreekHandy',
    url: new URL('/', Astro.site).toString()
  }
};

const faqSchema = category.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: category.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer }
  }))
} : null;
---

<Layout title={category.metaTitle} description={category.metaDescription} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <BaseHead title={category.metaTitle} description={category.metaDescription} canonicalUrl={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <main>
    <!-- Breadcrumbs -->
    <nav class="bg-gray-50 px-4 py-3 text-sm">
      <div class="mx-auto max-w-5xl flex items-center gap-2 text-gray-500">
        <a href="/" class="hover:text-blue-700">Αρχική</a>
        <span>&rsaquo;</span>
        {isJobPage && parentCategory ? (
          <>
            <a href={`/${parentCategory.slug}`} class="hover:text-blue-700">{parentCategory.nameGr}</a>
            <span>&rsaquo;</span>
            <span class="text-gray-900">{category.nameGr}</span>
          </>
        ) : (
          <span class="text-gray-900">{category.nameGr}</span>
        )}
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-b from-blue-700 to-blue-600 text-white px-4 py-16 md:py-20">
      <div class="mx-auto max-w-5xl">
        <h1 class="text-3xl font-bold leading-tight md:text-5xl">{category.h1}</h1>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-blue-100">{category.heroText}</p>
        {category.summary && (
          <div class="mt-6 flex flex-wrap gap-4 text-sm">
            {category.summary.priceRangeEUR && <span class="bg-blue-800 px-3 py-1 rounded-full">Κόστος: {category.summary.priceRangeEUR}</span>}
            {category.summary.typicalDuration && <span class="bg-blue-800 px-3 py-1 rounded-full">Διάρκεια: {category.summary.typicalDuration}</span>}
          </div>
        )}
        <a href="#contact" class="mt-8 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-blue-700 transition hover:bg-blue-50">
          {category.cta?.buttonText || 'Ζητήστε Προσφορά'}
        </a>
      </div>
    </section>

    <!-- Content Sections -->
    {category.sections?.length > 0 && (
      <section class="px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl space-y-6">
          {category.sections.map((section: any) => (
            <article class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm md:p-8">
              <h2 class="text-2xl font-bold text-gray-900">{section.heading}</h2>
              <p class="mt-4 leading-relaxed text-gray-700">{section.content}</p>
              {section.priceRange && (
                <p class="mt-4 font-medium text-gray-900">
                  Ενδεικτικό εύρος τιμής: <span class="text-blue-700">{section.priceRange}</span>
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Sub-jobs list (for category pages) -->
    {subJobs.length > 0 && (
      <section class="bg-gray-50 px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">Υπηρεσίες σε αυτή την κατηγορία</h2>
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {subJobs.map((job: any) => (
              <a href={`/${job.slug}`} class="block rounded-lg border border-gray-200 bg-white p-4 hover:border-blue-300 hover:bg-blue-50 transition">
                <h3 class="font-semibold text-gray-900">{job.nameGr}</h3>
                {job.summary?.priceRangeEUR && (
                  <p class="mt-1 text-sm text-blue-600">{job.summary.priceRangeEUR}</p>
                )}
                {job.summary?.typicalDuration && (
                  <p class="mt-1 text-sm text-gray-500">{job.summary.typicalDuration}</p>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Related Categories -->
    {relatedCategories.length > 0 && (
      <section class="bg-gray-50 px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">Σχετικές Υπηρεσίες</h2>
          <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {relatedCategories.map((rel: any) => (
              <li>
                <a href={`/${rel.slug}`} class="block rounded-lg border border-gray-200 bg-white px-5 py-4 font-medium text-blue-700 transition hover:border-blue-300 hover:bg-blue-50">
                  {rel.nameGr}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- FAQ -->
    {category.faq?.length > 0 && (
      <section id="faq" class="px-4 py-12 md:py-16">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">Συχνές Ερωτήσεις</h2>
          <div class="mt-6 space-y-4">
            {category.faq.map((item: any) => (
              <details class="rounded-xl border border-gray-200 bg-white p-6">
                <summary class="text-lg font-semibold text-gray-900 cursor-pointer">{item.question}</summary>
                <p class="mt-3 leading-relaxed text-gray-700">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section id="contact" class="bg-blue-700 px-4 py-12 text-white md:py-16">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="text-2xl font-bold md:text-3xl">{category.cta?.heading || 'Χρειάζεστε Επαγγελματία;'}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-blue-100">{category.cta?.text || 'Στείλτε μας το αίτημά σας και λάβετε δωρεάν προσφορές.'}</p>
        <a href={`mailto:info@greekhandy.gr?subject=${encodeURIComponent(category.nameGr)}`} class="mt-6 inline-flex rounded-lg bg-white px-6 py-3 font-semibold text-blue-700 transition hover:bg-blue-50">
          {category.cta?.buttonText || 'Ζητήστε Προσφορά'}
        </a>
      </div>
    </section>
  </main>
</Layout>
