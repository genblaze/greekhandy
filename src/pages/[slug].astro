---
import Layout from '../layouts/Layout.astro';

export const prerender = true;

// Load all content JSONs at build time (top-level only)
const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });

// Build slug → content map
const allContent: Record<string, any> = {};
for (const [path, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) {
    allContent[data.slug] = data;
  }
}

// Load categories for navigation
let categories: any[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = catFile.default ?? catFile;
} catch {}

export function getStaticPaths() {
  const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
  const paths = [];
  for (const [, mod] of Object.entries(contentFiles)) {
    const data = (mod as any).default ?? mod;
    if (data?.slug) {
      paths.push({ params: { slug: data.slug }, props: { category: data } });
    }
  }
  return paths;
}

const { category } = Astro.props;
const canonicalUrl = new URL(`/${category.slug}`, Astro.site).toString();

// Determine if this is a job page (has categorySlug) or category page
const isJobPage = !!category.categorySlug;
const isHeatingIntentLanding = !isJobPage && category.slug === 'techniki-klimatismou';
const parentCategory = isJobPage ? categories.find((c: any) => c.id === category.categoryId || c.slug === category.categorySlug) : null;
const heatingIntentTokens = ['thermans', 'thermosifon', 'thermotit', 'levita', 'endodaped', 'kalorifer', 'thermostat'];
const isHeatingIntentJob = (job: any) => {
  const corpus = `${job.slug || ''} ${job.nameGr || ''} ${job.h1 || ''}`.toLocaleLowerCase('el-GR');
  return heatingIntentTokens.some((token) => corpus.includes(token));
};

// Find sub-jobs for category pages
const subJobs = !isJobPage
  ? Object.values(allContent)
      .filter((p: any) => p.categoryId === category.id || p.categorySlug === category.slug)
      .filter((job: any) => !isHeatingIntentLanding || isHeatingIntentJob(job))
  : [];

const pageCategory = isHeatingIntentLanding
  ? {
      ...category,
      nameGr: 'Τεχνικοί Θέρμανσης',
      h1: 'Τεχνικοί Θέρμανσης στην Ελλάδα',
      metaTitle: 'Τεχνικοί Θέρμανσης | Κόστος, συντήρηση και επισκευές',
      metaDescription: 'Υπηρεσίες θέρμανσης για λέβητες, θερμοσίφωνες, αντλίες θερμότητας και κυκλώματα καλοριφέρ. Δείτε τιμές, διάρκεια και σωστή προετοιμασία αιτήματος.',
      heroText: 'Οδηγός αποκλειστικά για ανάγκες θέρμανσης: συντήρηση και επισκευές λεβήτων, θερμοσίφωνες, αντλίες θερμότητας και ρυθμίσεις θερμοστατών, με έμφαση στην ασφάλεια και στην ενεργειακή απόδοση.',
      summary: {
        ...category.summary,
        priceRangeEUR: '50-260€ (ανά εργασία)',
        typicalDuration: '45 λεπτά - 4 ώρες'
      },
      cta: {
        heading: 'Χρειάζεστε τεχνικό θέρμανσης;',
        text: 'Στείλτε περιγραφή συστήματος και συμπτώματος για να λάβετε στοχευμένες προσφορές από διαθέσιμους τεχνικούς θέρμανσης.',
        buttonText: 'Ζητήστε προσφορά θέρμανσης'
      },
      sections: [
        {
          heading: 'Τι περιλαμβάνει η υπηρεσία θέρμανσης',
          content: 'Η κατηγορία καλύπτει λέβητες, θερμοσίφωνες, αντλίες θερμότητας, καυστήρες και κυκλώματα καλοριφέρ. Στόχος είναι ασφαλής λειτουργία, σταθερή απόδοση και σαφές πλάνο κόστους/χρόνου πριν από κάθε ανάθεση.'
        },
        {
          heading: 'Συντήρηση λέβητα και καυστήρα',
          content: 'Καθαρισμός, ρυθμίσεις καύσης, έλεγχος ασφαλιστικών διατάξεων και μετρήσεις απόδοσης πριν την έντονη χειμερινή χρήση.',
          priceRange: '60-150€'
        },
        {
          heading: 'Θερμοσίφωνες και αντλίες θερμότητας',
          content: 'Έλεγχος αντιστάσεων, βαλβίδων, ανοδίων, αυτοματισμών και βελτιστοποίηση λειτουργίας για σταθερό ζεστό νερό και χαμηλότερη κατανάλωση.',
          priceRange: '50-260€'
        },
        {
          heading: 'Πώς να προετοιμάσετε σωστά το αίτημά σας',
          content: 'Αναφέρετε τύπο συστήματος, ηλικία εγκατάστασης, περιγραφή συμπτώματος, περιοχή και επιθυμητό χρόνο επίσκεψης. Με αυτά τα στοιχεία η αρχική εκτίμηση γίνεται πιο αξιόπιστη.'
        }
      ],
      faq: [
        {
          question: 'Πόσο κοστίζουν συνήθως οι υπηρεσίες θέρμανσης;',
          answer: 'Το κόστος εξαρτάται από τον τύπο συστήματος και τη βλάβη. Συνήθεις εργασίες κινούνται ενδεικτικά μεταξύ 50€ και 260€.'
        },
        {
          question: 'Πότε απαιτείται άμεση επίσκεψη;',
          answer: 'Άμεση παρέμβαση χρειάζεται όταν υπάρχει διαρροή, έντονη οσμή, καπνός, πτώση πίεσης ή πλήρης διακοπή θέρμανσης/ζεστού νερού.'
        },
        {
          question: 'Τι πληροφορίες βοηθούν σε ακριβέστερη προσφορά;',
          answer: 'Μοντέλο και τύπος συστήματος, ηλικία εξοπλισμού, περιγραφή συμπτώματος, φωτογραφίες όπου είναι εφικτό και επιθυμητό χρονικό παράθυρο επίσκεψης.'
        }
      ]
    }
  : category;

const collapseDuplicateLocationPhrase = (input?: string) => {
  if (!input) return '';
  let text = input.replace(/\s+/g, ' ').trim();
  const pattern = /(στην|στη|στον|στο|σε)\s+([A-Za-zΑ-ΩΆ-Ώα-ωά-ώ0-9\-]+(?:\s+[A-Za-zΑ-ΩΆ-Ώα-ωά-ώ0-9\-]+){0,2})\s+\1\s+\2/giu;
  for (let i = 0; i < 4; i += 1) {
    const next = text.replace(pattern, '$1 $2');
    if (next === text) break;
    text = next;
  }
  return text;
};

const normalizedPageCategory = {
  ...pageCategory,
  nameGr: collapseDuplicateLocationPhrase(pageCategory.nameGr),
  h1: collapseDuplicateLocationPhrase(pageCategory.h1),
  heroText: collapseDuplicateLocationPhrase(pageCategory.heroText),
  metaTitle: collapseDuplicateLocationPhrase(pageCategory.metaTitle),
  metaDescription: collapseDuplicateLocationPhrase(pageCategory.metaDescription)
};

const trustDecisionCategorySlugs = new Set(['ydravlikoi', 'ilektrologoi']);
const highVolumeFilterSlugs = new Set(['ydravlikoi', 'ilektrologoi']);
const enableAdvancedCategoryUX = !isJobPage && (highVolumeFilterSlugs.has(category.slug) || subJobs.length >= 18);
const enableTrustDecisionCardUX = !isJobPage && trustDecisionCategorySlugs.has(category.slug);
const cityTokens = ['athina', 'thessaloniki', 'patra', 'irakleio', 'larisa', 'volos', 'ioannina'];
const cityLabelMap: Record<string, string> = {
  athina: 'Αθήνα',
  thessaloniki: 'Θεσσαλονίκη',
  patra: 'Πάτρα',
  irakleio: 'Ηράκλειο',
  larisa: 'Λάρισα',
  volos: 'Βόλος',
  ioannina: 'Ιωάννινα',
  all: 'Ελλάδα'
};
const cityServiceAreaMap: Record<string, string> = {
  athina: 'Αθήνα και όμοροι δήμοι',
  thessaloniki: 'Θεσσαλονίκη και κοντινές περιοχές',
  patra: 'Πάτρα και ευρύτερη Αχαΐα',
  irakleio: 'Ηράκλειο και γειτονικές περιοχές',
  larisa: 'Λάρισα και κοντινοί οικισμοί',
  volos: 'Βόλος και Μαγνησία',
  ioannina: 'Ιωάννινα και περιφερειακές περιοχές',
  all: 'Τοπική κάλυψη κατόπιν διαθεσιμότητας'
};
const budgetLabelMap: Record<string, string> = {
  low: 'Οικονομικό',
  medium: 'Μεσαίο',
  high: 'Αυξημένο',
  unknown: 'Κατόπιν διάγνωσης'
};
const availabilityLabelMap: Record<string, string> = {
  asap: 'Άμεσα διαθέσιμο',
  'this-week': 'Μέσα στην εβδομάδα',
  flexible: 'Ευέλικτο ραντεβού'
};
const urgencyKeywords = ['amesi', 'ektakti', 'epeigon'];
const initialVisibleContentSections = 4;
const initialVisibleRelatedCategories = 8;
const initialVisibleFaqItems = 6;
const initialVisibleSubJobs = enableAdvancedCategoryUX ? 6 : 12;
const serverRenderedSubJobsLimit = enableAdvancedCategoryUX ? 40 : subJobs.length;
const renderedSubJobs = subJobs.slice(0, serverRenderedSubJobsLimit);
type TrustDecisionCardVariant = {
  frameClass: string;
  headingClass: string;
  snippetClass: string;
  snippetHeading: string;
  laneLabel: string;
  metricOrder: Array<CardMetricKey>;
  decisionHeading: string;
  decisionHint: string;
};
type CardMetricKey = 'cost' | 'duration' | 'availability' | 'area';
type CardMetric = { key: CardMetricKey; label: string; value: string };

const trustDecisionVariantMap = {
  ydravlikoi: [
    {
      frameClass: 'border-sky-200 bg-sky-50/40 hover:border-sky-300',
      headingClass: 'border-sky-200 bg-sky-100 text-sky-900',
      snippetClass: 'border-sky-200 bg-white',
      snippetHeading: 'Ticket αιτήματος υδραυλικού',
      laneLabel: 'Ροή διαρροής / αποκατάστασης',
      metricOrder: ['availability', 'cost', 'duration', 'area'],
      decisionHeading: 'Έλεγχος πριν την επίσκεψη',
      decisionHint: 'Επιβεβαιώστε προσβασιμότητα, πιθανή διακοπή νερού και αν χρειάζονται ανταλλακτικά.'
    },
    {
      frameClass: 'border-cyan-200 bg-cyan-50/50 hover:border-cyan-300',
      headingClass: 'border-cyan-200 bg-cyan-100/80 text-cyan-900',
      snippetClass: 'border-cyan-200 bg-white',
      snippetHeading: 'Brief εγκατάστασης/αντικατάστασης',
      laneLabel: 'Ροή εγκατάστασης',
      metricOrder: ['cost', 'area', 'duration', 'availability'],
      decisionHeading: 'Πώς να συγκρίνετε σωστά',
      decisionHint: 'Συγκρίνετε κόστος μαζί με υλικά που περιλαμβάνονται και επιβεβαιωμένη περιοχή κάλυψης.'
    },
    {
      frameClass: 'border-teal-200 bg-teal-50/40 hover:border-teal-300',
      headingClass: 'border-teal-200 bg-teal-100/80 text-teal-900',
      snippetClass: 'border-teal-200 bg-white',
      snippetHeading: 'Σημείωμα συντήρησης δικτύου',
      laneLabel: 'Ροή συντήρησης',
      metricOrder: ['duration', 'cost', 'availability', 'area'],
      decisionHeading: 'Σήμα αξιοπιστίας',
      decisionHint: 'Δώστε σαφή περιγραφή συμπτωμάτων για ρεαλιστική αρχική διάγνωση και σωστή προτεραιότητα.'
    }
  ],
  ilektrologoi: [
    {
      frameClass: 'border-amber-200 bg-amber-50/50 hover:border-amber-300',
      headingClass: 'border-amber-200 bg-amber-100/80 text-amber-900',
      snippetClass: 'border-amber-200 bg-white',
      snippetHeading: 'Ticket βλάβης ηλεκτρολόγου',
      laneLabel: 'Ροή βλάβης κυκλώματος',
      metricOrder: ['availability', 'area', 'cost', 'duration'],
      decisionHeading: 'Πριν κλείσετε ηλεκτρολόγο',
      decisionHint: 'Δηλώστε αν υπάρχει διακοπή ρεύματος, πίνακας που πέφτει ή οσμή καμένου για σωστή προτεραιοποίηση.'
    },
    {
      frameClass: 'border-indigo-200 bg-indigo-50/45 hover:border-indigo-300',
      headingClass: 'border-indigo-200 bg-indigo-100/75 text-indigo-900',
      snippetClass: 'border-indigo-200 bg-white',
      snippetHeading: 'Brief πίνακα / αναβάθμισης',
      laneLabel: 'Ροή αναβάθμισης εγκατάστασης',
      metricOrder: ['cost', 'duration', 'area', 'availability'],
      decisionHeading: 'Σημεία σύγκρισης προσφορών',
      decisionHint: 'Συγκρίνετε τύπο εργασίας, εκτιμώμενη διάρκεια και εύρος κόστους πριν την τελική επιλογή.'
    },
    {
      frameClass: 'border-emerald-200 bg-emerald-50/40 hover:border-emerald-300',
      headingClass: 'border-emerald-200 bg-emerald-100/75 text-emerald-900',
      snippetClass: 'border-emerald-200 bg-white',
      snippetHeading: 'Σενάριο ελέγχου ασφάλειας',
      laneLabel: 'Ροή προληπτικού ελέγχου',
      metricOrder: ['duration', 'area', 'availability', 'cost'],
      decisionHeading: 'Κριτήριο αξιοπιστίας',
      decisionHint: 'Η πιο ασφαλής απόφαση βασίζεται σε συνδυασμό διαθεσιμότητας, τεκμηρίωσης και σαφούς εύρους κόστους.'
    }
  ]
} as const satisfies Record<'ydravlikoi' | 'ilektrologoi', readonly TrustDecisionCardVariant[]>;

const trustDecisionReviewContextMap = {
  ydravlikoi: [
    'Οι αξιολογήσεις δημοσιεύονται αφού περάσουν moderation στο GreekHandy.',
    'Για υδραυλικά αιτήματα ζητήστε πρόσφατα παραδείγματα σε παρόμοια βλάβη.',
    'Στα επείγοντα συγκρίνετε πρώτα χρόνο απόκρισης και μετά τιμή.'
  ],
  ilektrologoi: [
    'Οι αξιολογήσεις συνεργατών περνούν έλεγχο πριν εμφανιστούν.',
    'Σε ηλεκτρολογικές εργασίες ζητήστε αντίστοιχα παραδείγματα σε ίδιο τύπο πίνακα/κυκλώματος.',
    'Η τελική επιλογή είναι ισχυρότερη όταν συνδυάζετε ασφάλεια, διαθεσιμότητα και κόστος.'
  ]
} as const satisfies Record<'ydravlikoi' | 'ilektrologoi', readonly string[]>;

const trustDecisionVariants = trustDecisionVariantMap[category.slug as keyof typeof trustDecisionVariantMap] || trustDecisionVariantMap.ydravlikoi;
const trustDecisionReviewContexts = trustDecisionReviewContextMap[category.slug as keyof typeof trustDecisionReviewContextMap] || trustDecisionReviewContextMap.ydravlikoi;
const SEO_SUBJOB_LINK_COUNT = 16;

const classifyBudget = (priceRange: string | undefined) => {
  const value = (priceRange || '').toLocaleLowerCase('el-GR');
  if (!value) return 'unknown';
  if (value.includes('€200') || value.includes('€300') || value.includes('€400') || value.includes('€500') || value.includes('€1000')) return 'high';
  if (value.includes('€80') || value.includes('€100') || value.includes('€120') || value.includes('€150')) return 'medium';
  return 'low';
};

const getJobCity = (job: any) => cityTokens.find((token) => job.slug?.endsWith(`-${token}`)) || 'all';
const isUrgentJob = (job: any) => urgencyKeywords.some((kw) => (job.slug || '').includes(kw) || (job.nameGr || '').toLocaleLowerCase('el-GR').includes(kw));
const classifyAvailability = (job: any) => {
  const duration = (job.summary?.typicalDuration || '').toLocaleLowerCase('el-GR');
  if (isUrgentJob(job) || duration.includes('άμεσα') || duration.includes('24')) return 'asap';
  if (duration.includes('ημέρ') || duration.includes('εβδομάδ')) return 'this-week';
  return 'flexible';
};
const cleanSnippetText = (value: string | undefined) => (value || '').replace(/\s+/g, ' ').trim();
const ensureTerminalPunctuation = (value: string) => (/[.!;…]$/.test(value) ? value : `${value}.`);
const buildDecisionSnippet = (job: any) => {
  const fallback = 'Περιγράψτε σύμπτωμα, πρόσβαση και χρόνο επίσκεψης για πιο στοχευμένη εκτίμηση.';
  const source = [
    cleanSnippetText(job.summary?.intent),
    cleanSnippetText(job.metaDescription),
    cleanSnippetText(job.heroText),
    cleanSnippetText(job.sections?.[0]?.content),
    cleanSnippetText(job.sections?.[1]?.content)
  ].find(Boolean);

  if (!source) return fallback;
  const clipped = source.length > 170
    ? `${source.slice(0, 166).replace(/[,:;]?\s+\S*$/, '').trim()}...`
    : source;
  return clipped;
};
const formatDecisionSnippetLines = (job: any, cityLabel: string, availabilityLabel: string, urgency: string, laneLabel: string) => {
  const plain = buildDecisionSnippet(job).replace(/^["«]+|["»]+$/g, '').trim();
  const requestLine = ensureTerminalPunctuation(plain);
  const urgencyLabel = urgency === 'urgent' ? ' (επείγον)' : '';
  return [
    `[${laneLabel}]`,
    `Αίτημα: ${requestLine}`,
    `Περιοχή: ${cityLabel}`,
    `Χρόνος: ${availabilityLabel}${urgencyLabel}`
  ];
};
const getCardProofContext = (job: any, availability: string, budget: string) => {
  if (availability === 'asap' || isUrgentJob(job)) return 'Κατάλληλη για αιτήματα άμεσης επέμβασης με σαφή περιγραφή βλάβης.';
  if (budget === 'high') return 'Το τελικό κόστος επηρεάζεται κυρίως από υλικά, πρόσβαση και πολυπλοκότητα.';
  return 'Περιλαμβάνει ενδεικτικό εύρος κόστους και διάρκεια για αρχική σύγκριση επιλογών.';
};

// Resolve related category names
const relatedCategories = (pageCategory.relatedCategories || []).map((slug: string) => ({
  slug,
  nameGr: allContent[slug]?.nameGr ?? slug
})).filter((r: any) => allContent[r.slug]);

// JSON-LD schemas
const siteUrl = new URL('/', Astro.site).toString();

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#service`,
  name: normalizedPageCategory.nameGr,
  url: canonicalUrl,
  description: normalizedPageCategory.metaDescription,
  areaServed: { '@type': 'Country', name: 'Greece' },
  provider: {
    '@type': 'Organization',
    '@id': `${siteUrl}#organization`,
    name: 'GreekHandy',
    url: siteUrl
  }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Αρχική',
      item: siteUrl
    },
    ...(isJobPage && parentCategory
      ? [{ '@type': 'ListItem', position: 2, name: parentCategory.nameGr, item: new URL(`/${parentCategory.slug}`, Astro.site).toString() }]
      : []),
    {
      '@type': 'ListItem',
      position: isJobPage && parentCategory ? 3 : 2,
      name: normalizedPageCategory.nameGr,
      item: canonicalUrl
    }
  ]
};

const itemListSchema = !isJobPage && subJobs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: `Υπηρεσίες κατηγορίας ${normalizedPageCategory.nameGr}`,
      itemListElement: subJobs.slice(0, 40).map((job: any, index: number) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: new URL(`/${job.slug}`, Astro.site).toString(),
        name: job.nameGr
      }))
    }
  : null;

const faqSchema = pageCategory.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageCategory.faq.map((item: any) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer }
  }))
} : null;
---

<Layout title={normalizedPageCategory.metaTitle} description={normalizedPageCategory.metaDescription} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <main>
    <!-- Breadcrumbs -->
    <nav class="bg-slate-50 px-4 py-3 text-sm">
      <div class="mx-auto flex max-w-5xl items-center gap-2 text-slate-500">
        <a href="/" class="hover:text-blue-700">Αρχική</a>
        <span>&rsaquo;</span>
        {isJobPage && parentCategory ? (
          <>
            <a href={`/${parentCategory.slug}`} class="hover:text-blue-700">{parentCategory.nameGr}</a>
            <span>&rsaquo;</span>
            <span class="text-gray-900">{normalizedPageCategory.nameGr}</span>
          </>
        ) : (
          <span class="text-gray-900">{normalizedPageCategory.nameGr}</span>
        )}
      </div>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-600 px-4 py-16 text-white md:py-20">
      <div class="mx-auto max-w-5xl">
        <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-5xl">{normalizedPageCategory.h1}</h1>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-blue-100">{normalizedPageCategory.heroText}</p>
        {pageCategory.summary && (
          <div class="mt-6 flex flex-wrap gap-4 text-sm">
            {pageCategory.summary.priceRangeEUR && <span class="bg-blue-800 px-3 py-1 rounded-full">Κόστος: {pageCategory.summary.priceRangeEUR}</span>}
            {pageCategory.summary.typicalDuration && <span class="bg-blue-800 px-3 py-1 rounded-full">Διάρκεια: {pageCategory.summary.typicalDuration}</span>}
          </div>
        )}
        <a href="#contact" class="mt-8 inline-flex rounded-full bg-white px-6 py-3 font-semibold text-blue-700 shadow-sm transition hover:bg-blue-50">
          {pageCategory.cta?.buttonText || 'Ζητήστε Προσφορά'}
        </a>
      </div>
    </section>

    <!-- Content Sections -->
    <section class="px-4 py-12 md:py-16">
      <div id="content-sections-list" class="mx-auto max-w-5xl space-y-6">
        {pageCategory.sections?.length > 0 ? (
          pageCategory.sections.map((section: any, index: number) => (
            <article
              data-progressive-item="content-sections"
