---
import Layout from '../layouts/Layout.astro';

const canonicalUrl = new URL('/thermansi', Astro.site).toString();
const title = 'Τεχνικοί Θέρμανσης | Κόστος, συντήρηση και επισκευές στην Ελλάδα';
const description = 'Βρείτε τεχνικούς θέρμανσης για λέβητα, αντλία θερμότητας, θερμοσίφωνα και θερμοστάτες. Δείτε εύρος τιμών, πρακτικά βήματα και τρόπους ασφαλούς ανάθεσης.';

const heatingKeywords = [
  'thermans',
  'thermosifon',
  'thermotit',
  'levita',
  'endodaped',
  'kalorifer',
  'thermostat'
];

const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
const heatingJobs: Array<{ slug: string; nameGr: string; summary?: { priceRangeEUR?: string; typicalDuration?: string } }> = [];

for (const [, mod] of Object.entries(contentFiles)) {
  const entry = (mod as any).default ?? mod;
  if (!entry?.slug || entry.slug === 'techniki-klimatismou') continue;
  const categoryMatch = entry.categorySlug === 'techniki-klimatismou' || entry.categoryId === 'hvac-technicians';
  if (!categoryMatch) continue;
  const searchCorpus = `${entry.slug} ${entry.nameGr ?? ''} ${entry.h1 ?? ''}`.toLocaleLowerCase('el-GR');
  const hasHeatingIntent = heatingKeywords.some((token) => searchCorpus.includes(token));
  if (!hasHeatingIntent) continue;
  heatingJobs.push({
    slug: entry.slug,
    nameGr: entry.nameGr,
    summary: entry.summary
  });
}

heatingJobs.sort((a, b) => a.nameGr.localeCompare(b.nameGr, 'el'));
const featuredHeatingJobs = heatingJobs.slice(0, 12);

const faq = [
  {
    question: 'Ποιες εργασίες καλύπτουν οι τεχνικοί θέρμανσης;',
    answer: 'Καλύπτουν συντήρηση και ρύθμιση λέβητα, ελέγχους καυστήρα, εγκαταστάσεις/ρυθμίσεις αντλιών θερμότητας, εργασίες σε θερμοσίφωνες και εξισορρόπηση κυκλωμάτων θέρμανσης.'
  },
  {
    question: 'Πότε χρειάζεται άμεση επίσκεψη τεχνικού;',
    answer: 'Όταν υπάρχει διαρροή, πτώση πίεσης, ασυνήθιστη οσμή, καπνός, θόρυβος καυστήρα ή αδυναμία θέρμανσης χώρου/νερού. Σε τέτοιες περιπτώσεις προτεραιότητα είναι η ασφάλεια του χώρου.'
  },
  {
    question: 'Τι να γράψω για να πάρω πιο ακριβή προσφορά;',
    answer: 'Αναφέρετε τύπο συστήματος (λέβητας, αντλία θερμότητας, θερμοσίφωνας), σύμπτωμα, περιοχή, ηλικία εξοπλισμού και φωτογραφίες όπου γίνεται. Έτσι ο επαγγελματίας εκτιμά καλύτερα χρόνο και κόστος.'
  }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#service`,
  name: 'Τεχνικοί Θέρμανσης',
  serviceType: 'Heating service',
  url: canonicalUrl,
  description,
  areaServed: { '@type': 'Country', name: 'Greece' },
  provider: {
    '@type': 'Organization',
    name: 'GreekHandy',
    url: new URL('/', Astro.site).toString()
  }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Αρχική', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Θέρμανση', item: canonicalUrl }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main>
    <nav class="bg-slate-50 px-4 py-3 text-sm">
      <div class="mx-auto flex max-w-5xl items-center gap-2 text-slate-500">
        <a href="/" class="hover:text-blue-700">Αρχική</a>
        <span>&rsaquo;</span>
        <span class="text-slate-900">Θέρμανση</span>
      </div>
    </nav>

    <section class="bg-gradient-to-br from-amber-700 via-orange-600 to-rose-600 px-4 py-16 text-white md:py-20">
      <div class="mx-auto max-w-5xl">
        <p class="inline-flex rounded-full border border-white/35 bg-black/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em]">GreekHandy Heating</p>
        <h1 class="mt-4 text-3xl font-bold leading-tight tracking-tight md:text-5xl">Τεχνικοί Θέρμανσης στην Ελλάδα</h1>
        <p class="mt-5 max-w-4xl text-lg leading-relaxed text-orange-100">
          Η σελίδα αυτή είναι αποκλειστικά για ανάγκες θέρμανσης: λέβητες, θερμοσίφωνες, αντλίες θερμότητας,
          κυκλώματα καλοριφέρ και ρυθμίσεις θερμοστατών. Το περιεχόμενο, οι τίτλοι και τα προτεινόμενα βήματα
          παραμένουν σταθερά σε heating intent χωρίς ανάμειξη με ψύξη/AC branding.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#contact" class="inline-flex rounded-full bg-white px-6 py-3 font-semibold text-orange-700 shadow-sm transition hover:bg-orange-50">Ζητήστε προσφορά θέρμανσης</a>
          <a href="/techniki-klimatismou" class="inline-flex rounded-full border border-white/45 bg-black/20 px-6 py-3 font-semibold text-white transition hover:bg-black/30">Μετάβαση σε κλιματισμό (ψύξη)</a>
        </div>
      </div>
    </section>

    <section class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl space-y-5">
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h2 class="text-2xl font-bold text-slate-900">Τι περιλαμβάνει η κατηγορία θέρμανσης</h2>
          <p class="mt-3 leading-relaxed text-slate-700">
            Συντήρηση λεβήτων, έλεγχος καυστήρα, ρύθμιση πίεσης, καθαρισμός κυκλωμάτων, βελτιστοποίηση αντλιών θερμότητας
            και επισκευές θερμοσιφώνων. Στόχος είναι ασφαλής λειτουργία, σταθερή απόδοση και προβλέψιμο κόστος για κατοικίες
            και επαγγελματικούς χώρους.
          </p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h2 class="text-2xl font-bold text-slate-900">Ενδεικτικά εύρη τιμών και διάρκειας</h2>
          <ul class="mt-3 grid gap-3 text-sm text-slate-700 md:grid-cols-3">
            <li class="rounded-xl border border-slate-200 bg-slate-50 p-4"><p class="font-semibold text-slate-900">Συντήρηση λέβητα</p><p class="mt-1">60-150€ · 1-2 ώρες</p></li>
            <li class="rounded-xl border border-slate-200 bg-slate-50 p-4"><p class="font-semibold text-slate-900">Έλεγχος/ρύθμιση θερμοσίφωνα</p><p class="mt-1">50-130€ · 45-90 λεπτά</p></li>
            <li class="rounded-xl border border-slate-200 bg-slate-50 p-4"><p class="font-semibold text-slate-900">Ρύθμιση αντλίας θερμότητας</p><p class="mt-1">90-260€ · 1.5-4 ώρες</p></li>
          </ul>
          <p class="mt-3 text-xs text-slate-500">Τα ποσά είναι ενδεικτικά και μεταβάλλονται ανά περιοχή, εξοπλισμό και πολυπλοκότητα έργου.</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h2 class="text-2xl font-bold text-slate-900">Πριν στείλετε αίτημα</h2>
          <p class="mt-3 leading-relaxed text-slate-700">
            Καταγράψτε μοντέλο συστήματος, έτος εγκατάστασης, το βασικό σύμπτωμα και φωτογραφίες όπου είναι εφικτό.
            Αυτή η πληροφορία μειώνει καθυστερήσεις και βοηθά σε πιο αξιόπιστη αρχική εκτίμηση.
          </p>
        </article>
      </div>
    </section>

    <section class="bg-slate-50 px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Σχετικές υπηρεσίες θέρμανσης</h2>
        {featuredHeatingJobs.length > 0 ? (
          <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {featuredHeatingJobs.map((job) => (
              <li>
                <a href={`/${job.slug}`} class="block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-orange-300 hover:shadow-md">
                  <p class="font-semibold text-slate-900">{job.nameGr}</p>
                  {job.summary?.priceRangeEUR && <p class="mt-2 text-sm text-orange-700">{job.summary.priceRangeEUR}</p>}
                  {job.summary?.typicalDuration && <p class="mt-1 text-sm text-slate-500">{job.summary.typicalDuration}</p>}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 text-slate-700">
            <p class="font-semibold text-slate-900">Οι επιμέρους υπηρεσίες θέρμανσης ενημερώνονται.</p>
            <p class="mt-1 text-sm text-slate-600">Μπορείτε να συνεχίσετε με αίτημα προσφοράς για εξατομικευμένη καθοδήγηση.</p>
          </div>
        )}
      </div>
    </section>

    <section id="contact" class="bg-orange-700 px-4 py-12 text-white md:py-16">
      <div class="mx-auto max-w-5xl rounded-3xl border border-white/20 bg-black/15 p-6 md:p-8">
        <h2 class="text-2xl font-bold md:text-3xl">Χρειάζεστε τεχνικό θέρμανσης;</h2>
        <p class="mt-3 max-w-3xl text-orange-100">
          Στείλτε περιγραφή του αιτήματος και προτεραιότητα επέμβασης. Η ομάδα GreekHandy σας καθοδηγεί σε επόμενο βήμα με
          σαφήνεια για χρόνο απόκρισης και εύρος κόστους.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/epikoinonia" class="inline-flex rounded-full bg-white px-6 py-3 font-semibold text-orange-700 transition hover:bg-orange-50">Επικοινωνία για θέρμανση</a>
          <a href="/professionals" class="inline-flex rounded-full border border-white/40 bg-black/20 px-6 py-3 font-semibold text-white transition hover:bg-black/30">Δείτε επαγγελματίες</a>
        </div>
      </div>
    </section>

    <section id="faq" class="px-4 py-12 md:py-16">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Συχνές ερωτήσεις για θέρμανση</h2>
        <div class="mt-6 space-y-4">
          {faq.map((item) => (
            <details class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-orange-200">
              <summary class="cursor-pointer text-lg font-semibold text-slate-900 marker:text-orange-700">{item.question}</summary>
              <p class="mt-3 leading-relaxed text-slate-700">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
