---
import Layout from '../layouts/Layout.astro';

interface Category {
  id: string;
  slug: string;
  nameGr: string;
  description?: string;
  priority?: number;
  icon?: string;
  cities?: string[];
}

interface ContentPage {
  slug: string;
  nameGr: string;
  nameEn?: string;
  h1?: string;
  heroText?: string;
  metaDescription?: string;
  summary?: {
    intent?: string;
    priceRangeEUR?: string;
  };
  sections?: { heading?: string; content?: string }[];
  categoryId?: string;
  categorySlug?: string;
  categoryNameGr?: string;
}

interface ProfessionalProfile {
  slug: string;
  name: string;
  profession: string;
  city?: string;
  areasServed?: string[];
  experienceYears?: number;
  bio?: string;
  services?: string[];
  approved?: boolean;
  published?: boolean;
}

interface SearchItem {
  href: string;
  nameGr: string;
  description: string;
  priceRange?: string;
  typeLabel: string;
  categoryName: string;
  cities: string[];
  searchText: string;
  icon: string;
}

const majorCities = [
  { value: 'athina', label: 'Αθήνα' },
  { value: 'thessaloniki', label: 'Θεσσαλονίκη' },
  { value: 'patra', label: 'Πάτρα' },
  { value: 'irakleio', label: 'Ηράκλειο' },
  { value: 'larisa', label: 'Λάρισα' },
  { value: 'volos', label: 'Βόλος' },
  { value: 'ioannina', label: 'Ιωάννινα' }
];

const cityLabelByValue = Object.fromEntries(majorCities.map(city => [city.value, city.label]));
const majorCityValues = new Set(majorCities.map(city => city.value));

const fallbackIconsBySlug: Record<string, string> = {
  ilektrologoi: '⚡',
  ydravlikoi: '🚰',
  elaiokhrwmatistes: '🎨',
  katharismoi: '🧽',
  'techniki-klimatismou': '❄️'
};

const normalizeText = (value = '') => value
  .toLocaleLowerCase('el-GR')
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .replace(/ς/g, 'σ')
  .replace(/\s+/g, ' ')
  .trim();

const cityValueByNormalizedLabel = new Map(majorCities.map(city => [normalizeText(city.label), city.value]));

const getCityValuesFromText = (cities: string[] = []) => {
  const resolvedCities = new Set<string>();

  for (const city of cities) {
    const normalizedCity = normalizeText(city);
    if (!normalizedCity) continue;
    if (majorCityValues.has(normalizedCity)) {
      resolvedCities.add(normalizedCity);
      continue;
    }
    const matchedCity = cityValueByNormalizedLabel.get(normalizedCity);
    if (matchedCity) resolvedCities.add(matchedCity);
  }

  return [...resolvedCities];
};

const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
const allPages: ContentPage[] = [];
for (const [, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) allPages.push(data as ContentPage);
}

let categories: Category[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = ((catFile.default ?? catFile) as Category[])
    .slice()
    .sort((a, b) => (a.priority ?? 999) - (b.priority ?? 999));
} catch {}

const categorySlugs = new Set(categories.map(cat => cat.slug));
const categoryPages = allPages.filter(page => categorySlugs.has(page.slug));
const jobPages = allPages.filter(page => !categorySlugs.has(page.slug));

const categoriesById = new Map(categories.map(cat => [cat.id, cat]));
const categoriesBySlug = new Map(categories.map(cat => [cat.slug, cat]));

const getCategoryForPage = (page: ContentPage) => {
  if (categorySlugs.has(page.slug)) return categoriesBySlug.get(page.slug);
  return categoriesById.get(page.categoryId ?? '') ?? categoriesBySlug.get(page.categorySlug ?? '');
};

const getCategoryIcon = (category?: Category) => {
  if (category?.icon) return category.icon;
  if (category?.slug && fallbackIconsBySlug[category.slug]) return fallbackIconsBySlug[category.slug];
  return '🛠️';
};

const getCitiesForCategory = (category?: Category) => {
  const filteredCities = (category?.cities ?? []).filter(city => majorCities.some(option => option.value === city));
  return filteredCities.length > 0 ? filteredCities : majorCities.map(city => city.value);
};

const jobsByCategory: Record<string, ContentPage[]> = {};
for (const job of jobPages) {
  const category = getCategoryForPage(job);
  const categoryKey = category?.id ?? job.categoryId ?? job.categorySlug ?? 'other';
  if (!jobsByCategory[categoryKey]) jobsByCategory[categoryKey] = [];
  jobsByCategory[categoryKey].push(job);
}

for (const key of Object.keys(jobsByCategory)) {
  jobsByCategory[key].sort((a, b) => a.nameGr.localeCompare(b.nameGr, 'el'));
}

let professionalProfiles: ProfessionalProfile[] = [];
try {
  const profilesFile = await import('../../data/professionals.json');
  professionalProfiles = ((profilesFile.default ?? profilesFile) as ProfessionalProfile[])
    .filter(profile => profile.approved === true && profile.published === true);
} catch {}

const pageSearchItems: SearchItem[] = [...categoryPages, ...jobPages]
  .map(page => {
    const category = getCategoryForPage(page);
    const cityValues = getCitiesForCategory(category);

    const searchableText = normalizeText([
      page.nameGr,
      page.nameEn,
      page.h1,
      page.metaDescription,
      page.heroText,
      page.summary?.intent,
      page.categoryNameGr,
      category?.nameGr,
      page.sections?.map(section => `${section.heading ?? ''} ${section.content ?? ''}`).join(' ')
    ].filter(Boolean).join(' '));

    const isCategoryPage = categorySlugs.has(page.slug);
    const typeLabel = isCategoryPage ? 'Κατηγορία' : 'Υπηρεσία';

    return {
      href: `/${page.slug}`,
      nameGr: page.nameGr,
      description: page.summary?.intent ?? page.metaDescription ?? category?.description ?? '',
      priceRange: page.summary?.priceRangeEUR,
      typeLabel,
      categoryName: isCategoryPage ? '' : (page.categoryNameGr ?? category?.nameGr ?? ''),
      cities: cityValues,
      searchText: searchableText,
      icon: getCategoryIcon(category)
    };
  });

const professionalSearchItems: SearchItem[] = professionalProfiles.map(profile => {
  const cityValues = getCityValuesFromText([profile.city ?? '', ...(profile.areasServed ?? [])]);
  const searchText = normalizeText([
    profile.name,
    profile.profession,
    profile.city,
    profile.bio,
    profile.services?.join(' '),
    profile.areasServed?.join(' ')
  ].filter(Boolean).join(' '));

  return {
    href: `/professionals/${profile.slug}`,
    nameGr: profile.name,
    description: profile.bio ?? '',
    typeLabel: 'Επαγγελματίας',
    categoryName: profile.profession,
    cities: cityValues,
    searchText,
    icon: '👤'
  };
});

const searchItems = [...pageSearchItems, ...professionalSearchItems]
  .sort((a, b) => a.nameGr.localeCompare(b.nameGr, 'el'));

const availableCityValues = new Set(searchItems.flatMap(item => item.cities));
const cityOptions = majorCities.filter(city => availableCityValues.has(city.value));

const totalServices = jobPages.length;
const categoriesWithJobs = categories
  .map(category => ({
    category,
    jobs: jobsByCategory[category.id] ?? []
  }))
  .filter(entry => entry.jobs.length > 0);
---

<Layout
  title="GreekHandy - Βρείτε Αξιόπιστους Επαγγελματίες | Ελλάδα"
  description="Βρείτε τον καλύτερο επαγγελματία για κάθε εργασία στην Ελλάδα. Ηλεκτρολόγοι, υδραυλικοί, ελαιοχρωματιστές και πολλοί ακόμα. Δωρεάν προσφορές."
>
  <section class="relative overflow-hidden bg-slate-950 px-4 py-24 text-white">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.32),_transparent_58%)]"></div>
    <div class="relative mx-auto max-w-5xl text-center">
      <p class="mb-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs font-medium uppercase tracking-[0.16em] text-slate-200">GreekHandy • Επιλεγμένη πλατφόρμα οικιακών υπηρεσιών</p>
      <h1 class="mb-6 text-4xl font-semibold tracking-tight md:text-6xl">Βρείτε τον κατάλληλο επαγγελματία για κάθε εργασία</h1>
      <p class="mx-auto mb-8 max-w-3xl text-lg text-slate-200 md:text-xl">Το GreekHandy σας συνδέει με αξιόπιστους τεχνικούς σε όλη την Ελλάδα, με γρήγορη εξυπηρέτηση και καθαρή διαδικασία προσφοράς.</p>
      <a href="#search-browse" class="inline-flex items-center rounded-full bg-white px-8 py-3 font-semibold text-slate-900 transition hover:bg-slate-100">
        Αναζήτηση Υπηρεσιών
      </a>
      <p class="mt-4 text-sm text-slate-300">{totalServices} υπηρεσίες σε {categoriesWithJobs.length} κατηγορίες</p>
    </div>
  </section>

  <section id="search-browse" class="mx-auto max-w-6xl px-4 py-16 md:px-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_24px_70px_-32px_rgba(15,23,42,0.35)] md:p-10">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900">Αναζήτηση με λέξη-κλειδί</h2>
      <p class="mt-2 text-slate-600">Βρείτε γρήγορα υπηρεσίες, κατηγορίες ή προφίλ επαγγελματιών και φιλτράρετε ανά πόλη.</p>

      <form class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-12" role="search" aria-label="Αναζήτηση υπηρεσιών, κατηγοριών και επαγγελματιών">
        <div class="md:col-span-6">
          <label for="search-keyword" class="mb-2 block text-sm font-semibold text-gray-800">Λέξη-κλειδί</label>
          <input
            id="search-keyword"
            name="search-keyword"
            type="search"
            placeholder="π.χ. επισκευή διαρροής, εγκατάσταση κλιματιστικού"
            autocomplete="off"
            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200"
            data-search-input
          />
        </div>

        <div class="md:col-span-4">
          <label for="search-city" class="mb-2 block text-sm font-semibold text-gray-800">Πόλη</label>
          <select
            id="search-city"
            name="search-city"
            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200"
            data-city-filter
          >
            <option value="">Όλες οι πόλεις</option>
            {cityOptions.map(city => (
              <option value={city.value}>{city.label}</option>
            ))}
          </select>
        </div>

        <div class="md:col-span-2 md:self-end">
          <button
            type="button"
            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 font-semibold text-slate-700 transition hover:bg-slate-100"
            data-reset-filters
          >
            Καθαρισμός
          </button>
        </div>
      </form>

      <p class="mt-4 text-sm text-slate-700" data-results-count aria-live="polite"></p>

      <div class="mt-5 hidden rounded-2xl border border-blue-200 bg-blue-50/70 p-4 text-blue-900" data-search-loading>
        <p class="text-sm font-semibold">Φόρτωση αποτελεσμάτων...</p>
        <p class="mt-1 text-xs text-blue-800">Συνδυάζουμε υπηρεσίες, κατηγορίες και επαγγελματίες.</p>
      </div>

      <ul class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2" data-results-list aria-busy="false">
        {searchItems.map(item => (
          <li
            data-search-item
            data-search-text={item.searchText}
            data-cities={item.cities.join('|')}
            class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md"
          >
            <a href={item.href} class="block rounded-md focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2">
              <div class="flex items-start gap-3">
                <span class="text-2xl" aria-hidden="true">{item.icon}</span>
                <div>
                  <p class="font-semibold text-gray-900">{item.nameGr}</p>
                  <p class="mt-1 text-xs font-medium uppercase tracking-wide text-blue-700">
                    {item.typeLabel}{item.categoryName ? ` • ${item.categoryName}` : ''}
                  </p>
                  {item.description && <p class="mt-2 text-sm text-gray-600">{item.description}</p>}
                  {item.priceRange && <p class="mt-2 text-sm font-medium text-blue-700">Ενδεικτικό κόστος: {item.priceRange}</p>}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-4 hidden rounded-xl border border-orange-200 bg-orange-50 px-4 py-3 text-sm text-orange-800" data-empty-state>
        <p class="font-semibold text-orange-900">Δεν βρέθηκαν αποτελέσματα με αυτά τα φίλτρα.</p>
        <p class="mt-1">Δοκιμάστε άλλη λέξη ή πόλη για περισσότερες επιλογές.</p>
      </div>
    </div>
  </section>

  <section id="services" class="mx-auto max-w-6xl px-4 py-14 md:px-6">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-slate-900">Κατηγορίες Υπηρεσιών</h2>
        <p class="mt-2 text-sm text-slate-600">Δημοφιλείς κατηγορίες με συνεπή δομή, υψηλού επιπέδου παρουσίαση και γρήγορη πρόσβαση.</p>
      </div>
      <a href="#search-browse" class="inline-flex rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Προηγμένη αναζήτηση</a>
    </div>

    {categories.length === 0 && (
      <div class="rounded-2xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm">
        <p class="font-semibold text-slate-900">Δεν υπάρχουν διαθέσιμες κατηγορίες αυτή τη στιγμή.</p>
        <p class="mt-1 text-sm text-slate-600">Δοκιμάστε ξανά σύντομα ή χρησιμοποιήστε την αναζήτηση για συγκεκριμένη υπηρεσία.</p>
      </div>
    )}

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map(cat => {
        const catJobs = jobsByCategory[cat.id] || [];
        const cityLabels = getCitiesForCategory(cat).map(city => cityLabelByValue[city]).filter(Boolean);
        return (
          <a href={`/${cat.slug}`} class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg">
            <span class="text-3xl" aria-hidden="true">{getCategoryIcon(cat)}</span>
            <h3 class="mt-3 text-xl font-bold text-slate-900">{cat.nameGr}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{cat.description}</p>
            {cityLabels.length > 0 && (
              <p class="mt-3 text-xs uppercase tracking-wide text-gray-500">Πόλεις: {cityLabels.join(', ')}</p>
            )}
            <p class="mt-3 text-sm font-medium text-blue-700 transition group-hover:translate-x-0.5">{catJobs.length} υπηρεσίες &rarr;</p>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8 md:px-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_18px_46px_-28px_rgba(15,23,42,0.45)] md:p-8">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">Κατάλογος Υπηρεσιών</h2>
          <p class="mt-2 text-sm text-slate-600">Ανοίξτε μόνο την κατηγορία που σας ενδιαφέρει και δείτε άμεσα τις σχετικές υπηρεσίες.</p>
        </div>
        <p class="text-sm font-medium text-slate-500">{totalServices} υπηρεσίες συνολικά</p>
      </div>

      {categoriesWithJobs.length > 0 && (
        <nav class="mt-6 flex flex-wrap gap-2" aria-label="Γρήγορη πλοήγηση κατηγοριών">
          {categoriesWithJobs.map(({ category, jobs }) => (
            <a
              href={`#catalog-${category.slug}`}
              class="inline-flex rounded-full border border-slate-300 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-white"
            >
              {category.nameGr} ({jobs.length})
            </a>
          ))}
        </nav>
      )}

      <div class="mt-6 space-y-4">
        {categoriesWithJobs.map(({ category, jobs }, index) => {
          const defaultOpen = index === 0;
          return (
            <details id={`catalog-${category.slug}`} class="group rounded-2xl border border-slate-200 bg-slate-50/50 p-5 transition open:border-slate-300 open:bg-white" open={defaultOpen}>
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 [&::-webkit-details-marker]:hidden">
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Κατηγορία</p>
                  <h3 class="mt-1 text-xl font-semibold text-slate-900">
                    <a href={`/${category.slug}`} class="rounded-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2">{category.nameGr}</a>
                  </h3>
                  {category.description && <p class="mt-2 text-sm leading-6 text-slate-600">{category.description}</p>}
                </div>
                <div class="shrink-0 text-right">
                  <p class="text-sm font-semibold text-blue-700">{jobs.length} υπηρεσίες</p>
                  <span class="mt-2 inline-flex items-center rounded-full border border-slate-300 bg-white px-3 py-1 text-xs font-semibold text-slate-700">
                    Προβολή
                    <span class="ml-2 inline-block transition group-open:rotate-180" aria-hidden="true">⌄</span>
                  </span>
                </div>
              </summary>

              <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {jobs.map(job => (
                  <a href={`/${job.slug}`} class="block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-300 hover:shadow-md">
                    <h4 class="font-semibold text-slate-900">{job.nameGr}</h4>
                    {job.summary?.priceRangeEUR ? (
                      <p class="mt-1 text-sm font-medium text-blue-700">{job.summary.priceRangeEUR}</p>
                    ) : (
                      <p class="mt-1 text-sm text-slate-500">Επικοινωνήστε για εκτίμηση κόστους.</p>
                    )}
                  </a>
                ))}
              </div>
            </details>
          );
        })}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-6 md:px-6">
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-900 to-slate-800 p-6 text-white md:p-10">
      <h2 class="text-2xl font-semibold md:text-3xl">Βασικά Προφίλ Επαγγελματιών</h2>
      <p class="mt-3 max-w-3xl text-slate-200">Γνωρίστε διαθέσιμους επαγγελματίες με ειδικότητα, εμπειρία και περιοχές εξυπηρέτησης.</p>
      <a href="/professionals" class="mt-5 inline-flex rounded-full bg-white px-5 py-3 font-semibold text-slate-900 transition hover:bg-slate-100">Δείτε προφίλ επαγγελματιών</a>
    </div>
  </section>

  <section class="mt-8 bg-white px-4 py-16">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="mb-12 text-3xl font-bold">Πώς Λειτουργεί</h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div>
          <div class="mb-4 text-4xl font-bold text-blue-600">1</div>
          <h3 class="mb-2 text-xl font-semibold">Επιλέξτε Υπηρεσία</h3>
          <p class="text-gray-600">Βρείτε την υπηρεσία που χρειάζεστε από τον κατάλογό μας.</p>
        </div>
        <div>
          <div class="mb-4 text-4xl font-bold text-blue-600">2</div>
          <h3 class="mb-2 text-xl font-semibold">Ζητήστε Προσφορά</h3>
          <p class="text-gray-600">Περιγράψτε τις ανάγκες σας και λάβετε προσφορές.</p>
        </div>
        <div>
          <div class="mb-4 text-4xl font-bold text-blue-600">3</div>
          <h3 class="mb-2 text-xl font-semibold">Επιλέξτε Επαγγελματία</h3>
          <p class="text-gray-600">Συγκρίνετε και επιλέξτε τον κατάλληλο επαγγελματία.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const normalizeText = (value = '') => value
        .toLocaleLowerCase('el-GR')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/ς/g, 'σ')
        .replace(/\s+/g, ' ')
        .trim();

      const searchInput = document.querySelector('[data-search-input]');
      const cityFilter = document.querySelector('[data-city-filter]');
      const resetButton = document.querySelector('[data-reset-filters]');
      const resultCards = Array.from(document.querySelectorAll('[data-search-item]'));
      const resultsCount = document.querySelector('[data-results-count]');
      const emptyState = document.querySelector('[data-empty-state]');
      const loadingState = document.querySelector('[data-search-loading]');
      const resultsList = document.querySelector('[data-results-list]');

      if (!searchInput || !cityFilter || !resetButton || !resultsCount || !emptyState || !resultsList) return;

      const getCityLabel = () => {
        const selectedOption = cityFilter.options[cityFilter.selectedIndex];
        return selectedOption ? selectedOption.textContent : '';
      };

      const updateResults = () => {
        const keyword = normalizeText(searchInput.value);
        const selectedCity = cityFilter.value;

        if (loadingState) loadingState.classList.add('hidden');
        resultsList.setAttribute('aria-busy', 'true');

        let visibleItems = 0;

        resultCards.forEach(card => {
          const searchText = card.dataset.searchText || '';
          const cities = (card.dataset.cities || '').split('|').filter(Boolean);

          const keywordMatch = !keyword || searchText.includes(keyword);
          const cityMatch = !selectedCity || cities.includes(selectedCity);
          const isVisible = keywordMatch && cityMatch;

          card.classList.toggle('hidden', !isVisible);
          if (isVisible) visibleItems += 1;
        });

        const cityLabel = selectedCity ? getCityLabel() : '';
        if (!keyword && !selectedCity) {
          resultsCount.textContent = `Εμφανίζονται ${visibleItems} διαθέσιμες υπηρεσίες, κατηγορίες και επαγγελματίες.`;
        } else if (cityLabel && keyword) {
          resultsCount.textContent = `${visibleItems} αποτελέσματα για «${searchInput.value.trim()}» στην ${cityLabel}.`;
        } else if (cityLabel) {
          resultsCount.textContent = `${visibleItems} αποτελέσματα στην ${cityLabel}.`;
        } else {
          resultsCount.textContent = `${visibleItems} αποτελέσματα για «${searchInput.value.trim()}».`;
        }

        emptyState.classList.toggle('hidden', visibleItems > 0);
        resultsList.setAttribute('aria-busy', 'false');
      };

      if (loadingState) loadingState.classList.remove('hidden');

      searchInput.addEventListener('input', updateResults);
      cityFilter.addEventListener('change', updateResults);
      resetButton.addEventListener('click', () => {
        searchInput.value = '';
        cityFilter.value = '';
        updateResults();
        searchInput.focus();
      });

      updateResults();
    })();
  </script>
</Layout>
