---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_TRIAGE_ACTIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  clean,
  getMessageThreadId,
  readNdjson,
  writeNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const threadId = clean(url.searchParams.get('threadId'));
const viewerEmail = clean(url.searchParams.get('viewerEmail')).toLowerCase();
const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const hasViewerEmail = viewerEmail.length > 0;
const hasValidViewerEmail = EMAIL_PATTERN.test(viewerEmail);
const hasInvalidViewerEmail = hasViewerEmail && !hasValidViewerEmail;
const hasThreadId = threadId.length > 0;
const canLoadThreadData = hasThreadId && hasValidViewerEmail;
const status = clean(url.searchParams.get('status'));
const messageStatus = clean(url.searchParams.get('message'));
const knownThreadStatuses = new Set(['', 'reported', 'report-error', 'report-invalid', 'report-forbidden', 'loading']);
const knownMessageStatuses = new Set(['', 'submitted', 'invalid', 'error', 'blocked', 'loading']);
const showLoadingState = status === 'loading' || messageStatus === 'loading';
const THREAD_LOADING_SKELETON_ROWS = [1, 2, 3];
const hasUnknownStatus = status !== '' && !knownThreadStatuses.has(status);
const hasUnknownMessageStatus = messageStatus !== '' && !knownMessageStatuses.has(messageStatus);
const formatDateTime = (value: string) => new Date(value).toLocaleString('el-GR');
const formatDayLabel = (value: string) => new Date(value).toLocaleDateString('el-GR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
const toDomId = (value: string, fallback: string) => {
  const normalized = value.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  const fallbackNormalized = fallback.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  return normalized || fallbackNormalized || 'item';
};

let threadLoadError = '';
const safeReadNdjson = async <T,>(path: string, label: string): Promise<T[]> => {
  try {
    return await readNdjson<T>(path);
  } catch {
    if (!threadLoadError) threadLoadError = `Δεν ήταν δυνατή η φόρτωση δεδομένων (${label}).`;
    return [];
  }
};

const allMessages = canLoadThreadData
  ? await safeReadNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH, 'μηνύματα')
  : [];
const visibilityActions = canLoadThreadData
  ? await safeReadNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH, 'ορατότητα')
  : [];
const triageActions = canLoadThreadData
  ? await safeReadNdjson<{ threadId?: string; action?: string }>(MESSAGE_TRIAGE_ACTIONS_FILE_PATH, 'moderation')
  : [];

const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const latestTriageActionByThread = new Map<string, string>();
for (const entry of triageActions) {
  if (entry.threadId && entry.action) latestTriageActionByThread.set(entry.threadId, entry.action);
}

const threadMessages = allMessages
  .filter((message) => getMessageThreadId(message) === threadId)
  .sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));

const isParticipant = threadMessages.some(
  (message) => message.senderEmail.toLowerCase() === viewerEmail || message.recipientEmail.toLowerCase() === viewerEmail
);

let readStateWriteError = '';
if (canLoadThreadData && isParticipant && !showLoadingState) {
  try {
    const states = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
    const next = states.filter((entry) => !(entry.threadId === threadId && entry.viewerEmail === viewerEmail));
    const lastReadAt = threadMessages.at(-1)?.submittedAt || new Date().toISOString();
    next.push({ threadId, viewerEmail, lastReadAt });
    await writeNdjson(MESSAGE_READ_STATE_FILE_PATH, next);
  } catch {
    readStateWriteError = 'Δεν ήταν δυνατή η ενημέρωση της κατάστασης ανάγνωσης.';
  }
}

const latestThreadAction = threadId ? (latestTriageActionByThread.get(threadId) || '') : '';
const threadBlockedByModeration = messageStatus === 'blocked' || latestThreadAction === 'block';
const threadReviewedByModeration = latestThreadAction === 'review';
const threadRejectedByModeration = latestThreadAction === 'reject';

const hiddenMessagesCount = threadMessages.filter((message) => hiddenMessageIds.has(message.id)).length;
const visibleMessagesCount = Math.max(0, threadMessages.length - hiddenMessagesCount);
const threadHasAdminHidden = hiddenMessagesCount > 0;
const threadMutedByModeration = threadMessages.length > 0 && hiddenMessagesCount === threadMessages.length;
const threadUnderModeration = threadBlockedByModeration || threadReviewedByModeration || threadRejectedByModeration || threadHasAdminHidden;
const threadModerationTone = threadBlockedByModeration
  ? 'blocked'
  : threadHasAdminHidden
    ? 'hidden'
    : threadReviewedByModeration
      ? 'reported'
      : threadRejectedByModeration
        ? 'rejected'
        : 'active';

const threadModerationLabel = threadModerationTone === 'blocked'
  ? 'Μπλοκαρισμένη συνομιλία'
  : threadModerationTone === 'hidden'
    ? 'Κρυφό περιεχόμενο'
    : threadModerationTone === 'reported'
      ? 'Αναφορά σε έλεγχο'
      : threadModerationTone === 'rejected'
        ? 'Αναφορά χωρίς περιορισμό'
        : 'Ενεργή συνομιλία';

const threadModerationDescription = threadModerationTone === 'blocked'
  ? 'Η συνομιλία έχει μπλοκαριστεί από moderation. Μπορείτε να διαβάζετε το ιστορικό, αλλά δεν επιτρέπεται νέα αποστολή.'
  : threadModerationTone === 'hidden'
    ? threadMutedByModeration
      ? 'Όλα τα μηνύματα είναι κρυφά από moderation. Η απάντηση είναι προσωρινά απενεργοποιημένη.'
      : `Μέρος της συνομιλίας έχει κρυφτεί από moderation (κρυφά: ${hiddenMessagesCount}/${threadMessages.length}).`
    : threadModerationTone === 'reported'
      ? 'Η συνομιλία έχει αναφερθεί και βρίσκεται σε ενεργό έλεγχο moderation.'
      : threadModerationTone === 'rejected'
        ? 'Η τελευταία αναφορά έκλεισε χωρίς πρόσθετο περιορισμό. Το thread παραμένει ενεργό.'
        : 'Δεν υπάρχει ενεργός περιορισμός moderation.';
const threadModerationImpactLabel = threadModerationTone === 'blocked'
  ? 'Αποστολή απενεργοποιημένη'
  : threadModerationTone === 'hidden'
    ? 'Περιορισμένη ορατότητα'
    : threadModerationTone === 'reported'
      ? 'Έλεγχος αναφοράς σε εξέλιξη'
      : threadModerationTone === 'rejected'
        ? 'Η αναφορά έχει κλείσει'
        : 'Καμία επίπτωση';
const threadModerationActionLabel = threadBlockedByModeration
  ? 'Αναμονή για άρση περιορισμού'
  : threadMutedByModeration
    ? 'Αναμονή μέχρι επαναφορά ορατότητας'
    : threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration
      ? 'Μπορείτε να απαντήσετε τώρα'
      : 'Ελέγξτε τη διαμόρφωση thread';

const threadModerationBannerClass = threadModerationTone === 'blocked'
  ? 'border-rose-300 bg-gradient-to-r from-rose-50/95 via-white to-rose-50/80 text-rose-900'
  : threadModerationTone === 'hidden'
    ? 'border-orange-300 bg-gradient-to-r from-orange-50/95 via-white to-amber-50/80 text-orange-900'
    : threadModerationTone === 'reported'
      ? 'border-sky-300 bg-gradient-to-r from-sky-50/95 via-white to-sky-50/80 text-sky-900'
      : threadModerationTone === 'rejected'
        ? 'border-amber-300 bg-gradient-to-r from-amber-50/95 via-white to-amber-50/80 text-amber-900'
        : 'border-emerald-300 bg-gradient-to-r from-emerald-50/95 via-white to-emerald-50/80 text-emerald-900';
const moderationSeverityLabel = threadModerationTone === 'blocked'
  ? 'Κρίσιμος περιορισμός'
  : threadModerationTone === 'hidden'
    ? 'Ενισχυμένος έλεγχος περιεχομένου'
    : threadModerationTone === 'reported'
      ? 'Ενεργός έλεγχος αναφοράς'
      : threadModerationTone === 'rejected'
        ? 'Καταγεγραμμένη αναφορά'
        : 'Κανονική λειτουργία';

const canReply = threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration;
const showReportedConversationBanner = !threadBlockedByModeration && (threadReviewedByModeration || threadRejectedByModeration);
const reportedConversationBannerTitle = threadReviewedByModeration
  ? 'Αναφερόμενη συνομιλία σε έλεγχο'
  : 'Αναφερόμενη συνομιλία με ολοκληρωμένο έλεγχο';
const reportedConversationBannerDescription = threadReviewedByModeration
  ? 'Η ομάδα moderation αξιολογεί το thread. Η αποστολή παραμένει διαθέσιμη μέχρι να επιβληθεί διαφορετικός περιορισμός.'
  : 'Η αναφορά εξετάστηκε και έκλεισε χωρίς μπλοκάρισμα ή νέα απόκρυψη περιεχομένου.';
const moderationReplyGuidance = canReply
  ? 'Μπορείτε να συνεχίσετε με απάντηση σε αυτό το thread.'
  : threadBlockedByModeration
    ? 'Η αποστολή νέου μηνύματος είναι απενεργοποιημένη.'
    : threadMutedByModeration
      ? 'Η απάντηση είναι απενεργοποιημένη μέχρι να αρθεί η απόκρυψη.'
      : 'Το composer δεν είναι διαθέσιμο σε αυτή την κατάσταση.';
const latest = threadMessages.at(-1);
const recipientForReply = latest
  ? latest.senderEmail.toLowerCase() === viewerEmail
    ? latest.recipientEmail
    : latest.senderEmail
  : '';
const professionalSlug = latest?.professionalSlug ?? '';
const hasMissingParams = !hasThreadId || !hasViewerEmail;
const hasViewerParamIssue = hasMissingParams || hasInvalidViewerEmail;
const hasAccessIssue = !hasViewerParamIssue && !isParticipant && !threadLoadError;
const composerInitialState = messageStatus === 'submitted'
  ? 'success'
  : messageStatus === 'invalid' || messageStatus === 'error' || messageStatus === 'blocked'
    ? 'error'
    : 'idle';
const composerInitialStateLabel = composerInitialState === 'success'
  ? 'Το τελευταίο μήνυμα στάλθηκε επιτυχώς.'
  : composerInitialState === 'error'
    ? 'Η τελευταία αποστολή απέτυχε. Ελέγξτε το κείμενο και δοκιμάστε ξανά.'
    : 'Το composer είναι έτοιμο για αποστολή.';
const composerDraftStorageKey = canLoadThreadData ? `gh:thread-composer-draft:${threadId}:${viewerEmail}` : '';
const shouldClearComposerDraftOnLoad = messageStatus === 'submitted';

const participants = new Set<string>();
for (const message of threadMessages) {
  participants.add(message.senderEmail.toLowerCase());
  participants.add(message.recipientEmail.toLowerCase());
}
const counterpartEmail = [...participants].find((email) => email !== viewerEmail) || recipientForReply.toLowerCase();
const threadListHref = hasValidViewerEmail ? `/messages?viewerEmail=${encodeURIComponent(viewerEmail)}` : '/messages';
const threadViewHref = canLoadThreadData
  ? `/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`
  : '/messages/thread';
const incomingMessagesCount = threadMessages.filter((message) => message.senderEmail.toLowerCase() !== viewerEmail).length;
const outgoingMessagesCount = Math.max(0, threadMessages.length - incomingMessagesCount);
const reportableIncomingCount = threadMessages.filter((message) => message.senderEmail.toLowerCase() !== viewerEmail && !hiddenMessageIds.has(message.id)).length;
const latestVisibleMessage = [...threadMessages].reverse().find((message) => !hiddenMessageIds.has(message.id)) || null;
const latestVisibleMessageAnchor = latestVisibleMessage
  ? `message-${toDomId(latestVisibleMessage.id, `message-${latestVisibleMessage.submittedAt}`)}`
  : '';
const latestVisibleMessageHref = latestVisibleMessageAnchor ? `#${latestVisibleMessageAnchor}` : '#thread-history';
const moderationSendStateLabel = threadBlockedByModeration
  ? 'Κλειδωμένη αποστολή'
  : threadMutedByModeration
    ? 'Προσωρινά ανενεργή'
    : canReply
      ? 'Διαθέσιμη αποστολή'
      : 'Χωρίς διαθέσιμη αποστολή';
const moderationVisibilityStateLabel = threadHasAdminHidden
  ? `Περιορισμένη (${hiddenMessagesCount}/${threadMessages.length})`
  : 'Πλήρης προβολή';
const moderationReviewStateLabel = threadReviewedByModeration
  ? 'Σε ενεργό έλεγχο'
  : threadRejectedByModeration
    ? 'Έλεγχος ολοκληρωμένος'
    : 'Χωρίς ενεργή αναφορά';
const triagePrimaryActionLabel = threadBlockedByModeration
  ? 'Ελέγξτε ιστορικό και περιμένετε άρση μπλοκαρίσματος.'
  : canReply
    ? 'Απαντήστε στο thread από το composer.'
    : threadReviewedByModeration
      ? 'Παρακολουθήστε την αναφορά μέχρι να ολοκληρωθεί.'
      : threadMessages.length === 0
        ? 'Στείλτε το πρώτο μήνυμα για εκκίνηση ροής.'
        : 'Ελέγξτε visibility και κατάσταση thread.';
const triagePrimaryActionHint = latestVisibleMessage
  ? `Τελευταίο ορατό μήνυμα: ${formatDateTime(latestVisibleMessage.submittedAt)}.`
  : 'Δεν υπάρχει ακόμη ορατό μήνυμα στο thread.';
const triagePrimaryActionHref = canReply ? '#thread-interaction' : '#thread-history';
const threadTriageTier = threadBlockedByModeration
  ? 'critical'
  : threadReviewedByModeration || threadHasAdminHidden || (canReply && incomingMessagesCount > 0)
    ? 'high'
    : threadRejectedByModeration || threadMessages.length === 0
      ? 'medium'
      : 'normal';
const threadTriageTierLabel = threadTriageTier === 'critical'
  ? 'Κρίσιμη προτεραιότητα'
  : threadTriageTier === 'high'
    ? 'Υψηλή προτεραιότητα'
    : threadTriageTier === 'medium'
      ? 'Μεσαία προτεραιότητα'
      : 'Κανονική ροή';
const threadTriageTierClass = threadTriageTier === 'critical'
  ? 'border-rose-300 bg-rose-100 text-rose-900'
  : threadTriageTier === 'high'
    ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
    : threadTriageTier === 'medium'
      ? 'border-sky-300 bg-sky-100 text-sky-900'
      : 'border-emerald-300 bg-emerald-100 text-emerald-900';
const hasPartialThreadHistory = Boolean(threadLoadError) && threadMessages.length > 0;
const historyStateSummary = showLoadingState
  ? 'Η συνομιλία φορτώνει. Το ιστορικό ενημερώνεται.'
  : threadLoadError
    ? hasPartialThreadHistory
      ? `Υπάρχει σφάλμα φόρτωσης, αλλά εμφανίζονται ${threadMessages.length} διαθέσιμα μηνύματα.`
      : 'Υπάρχει σφάλμα φόρτωσης και δεν εμφανίζεται ιστορικό.'
    : threadMessages.length === 0
      ? 'Δεν υπάρχουν μηνύματα ακόμη σε αυτό το thread.'
      : `Το ιστορικό περιλαμβάνει ${threadMessages.length} μηνύματα.`;
const historyStateTitle = showLoadingState
  ? 'Συγχρονισμός ιστορικού σε εξέλιξη'
  : threadLoadError
    ? 'Αστοχία φόρτωσης ιστορικού'
    : threadMessages.length === 0
      ? 'Το thread δεν έχει ακόμη μηνύματα'
      : 'Το ιστορικό είναι διαθέσιμο';
const historyStateToneClass = showLoadingState
  ? 'border-sky-200 bg-sky-50/80 text-sky-900'
  : threadLoadError
    ? 'border-rose-200 bg-rose-50/80 text-rose-900'
    : threadMessages.length === 0
      ? 'border-slate-200 bg-slate-50/80 text-slate-700'
      : 'border-emerald-200 bg-emerald-50/80 text-emerald-900';
const historyStateActionLabel = showLoadingState
  ? 'Αναμονή συγχρονισμού'
  : threadLoadError
    ? 'Επανάληψη φόρτωσης'
    : threadMessages.length === 0
      ? 'Μετάβαση στις ενέργειες thread'
      : 'Μετάβαση στο τελευταίο ορατό';
const historyStateActionHref = showLoadingState
  ? '#thread-history'
  : threadLoadError
    ? threadViewHref
    : threadMessages.length === 0
      ? '#thread-interaction'
      : latestVisibleMessageHref;
const historyStateFocusLabel = showLoadingState
  ? 'Συγχρονισμός'
  : threadLoadError
    ? 'Επαναφορά ιστορικού'
    : threadMessages.length === 0
      ? 'Εκκίνηση συνομιλίας'
      : 'Ανάγνωση/triage';
const historyStateSupportHint = threadLoadError
  ? 'Μπορεί να λείπουν moderation ενδείξεις ή τμήματα ιστορικού μέχρι να επανέλθει η φόρτωση.'
  : threadMessages.length === 0
    ? 'Μόλις σταλεί το πρώτο μήνυμα, θα εμφανιστούν αυτόματα ροή, badges και διαθέσιμες ενέργειες moderation.'
    : `Ορατά: ${visibleMessagesCount} · Κρυφά: ${hiddenMessagesCount} · Εισερχόμενα reportable: ${reportableIncomingCount}.`;
const historyStateRecoveryHint = showLoadingState
  ? 'Αν η φόρτωση καθυστερεί, δοκιμάστε άμεση επαναφόρτωση του thread.'
  : threadLoadError
    ? 'Προβάλλεται ό,τι ήταν διαθέσιμο. Κάντε retry για να ανακτηθεί πλήρες ιστορικό.'
    : threadMessages.length === 0
      ? 'Το composer παραμένει διαθέσιμο για εκκίνηση της συνομιλίας όταν επιτρέπεται αποστολή.'
      : 'Η ανάγνωση ιστορικού είναι σταθερή και έτοιμη για επόμενο triage βήμα.';
const historyStateAriaRole = threadLoadError && !hasPartialThreadHistory ? 'alert' : 'status';
const historyStateAriaLive = threadLoadError && !hasPartialThreadHistory ? 'assertive' : 'polite';
const threadStatePrimaryActionLabel = hasViewerParamIssue
  ? 'Επιστροφή στη λίστα'
  : hasAccessIssue
    ? 'Άνοιγμα προσβάσιμου thread'
    : threadLoadError
      ? 'Επανάληψη φόρτωσης'
      : '';
const threadStatePrimaryActionHref = hasViewerParamIssue
  ? threadListHref
  : hasAccessIssue
    ? threadListHref
    : threadLoadError
      ? threadViewHref
      : '';
const moderationConsequences: string[] = [];
if (threadBlockedByModeration) moderationConsequences.push('Δεν επιτρέπεται αποστολή νέου μηνύματος μέχρι να αρθεί το μπλοκάρισμα.');
if (threadMutedByModeration) moderationConsequences.push('Η ορατότητα του περιεχομένου είναι πλήρως περιορισμένη και το composer παραμένει κλειστό.');
if (!threadMutedByModeration && threadHasAdminHidden) moderationConsequences.push(`Μερικά μηνύματα είναι κρυφά (${hiddenMessagesCount}/${threadMessages.length}).`);
if (threadReviewedByModeration) moderationConsequences.push('Υπάρχει ενεργή αναφορά και απαιτείται παρακολούθηση κατάστασης.');
if (threadRejectedByModeration) moderationConsequences.push('Η αναφορά έχει κλείσει χωρίς επιπλέον περιορισμό.');
if (moderationConsequences.length === 0) moderationConsequences.push('Δεν υπάρχει ενεργός περιορισμός στη ροή του thread.');
const threadReadinessLabel = showLoadingState
  ? 'Thread σε συγχρονισμό'
  : threadBlockedByModeration
    ? 'Thread με κλειδωμένη αποστολή'
    : threadMutedByModeration
      ? 'Thread με πλήρη περιορισμό ορατότητας'
      : threadReviewedByModeration
        ? 'Thread σε ενεργό moderation έλεγχο'
        : canReply
          ? 'Thread έτοιμο για απάντηση'
          : 'Thread με περιορισμένη αλληλεπίδραση';
const threadReadinessClass = showLoadingState
  ? 'border-sky-300 bg-sky-100 text-sky-900'
  : threadBlockedByModeration
    ? 'border-rose-300 bg-rose-100 text-rose-900'
    : threadMutedByModeration || threadHasAdminHidden
      ? 'border-orange-300 bg-orange-100 text-orange-900'
      : threadReviewedByModeration
        ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
        : canReply
          ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
          : 'border-amber-300 bg-amber-100 text-amber-900';
const threadReadinessHint = showLoadingState
  ? 'Γίνεται ανάκτηση ιστορικού και κατάστασης moderation.'
  : threadBlockedByModeration
    ? 'Απαιτείται ανάγνωση ιστορικού μέχρι να αρθεί ο περιορισμός αποστολής.'
    : threadMutedByModeration
      ? 'Το περιεχόμενο είναι πλήρως κρυφό και το composer παραμένει ανενεργό.'
      : threadReviewedByModeration
        ? 'Η αναφορά είναι σε εξέλιξη, ενώ η αποστολή παραμένει διαθέσιμη.'
        : canReply
          ? 'Η συνομιλία είναι ενεργή και μπορείτε να απαντήσετε άμεσα.'
          : 'Ελέγξτε παραλήπτη/παραμέτρους πριν τη συνέχεια.';
const messageOrderById = new Map<string, number>();
threadMessages.forEach((message, index) => {
  messageOrderById.set(message.id, index + 1);
});

type ThreadHistoryEntry =
  | { kind: 'day'; dayKey: string; dayLabel: string }
  | { kind: 'message'; message: MessageSubmission };

const threadHistory: ThreadHistoryEntry[] = [];
let lastDayKey = '';
for (const message of threadMessages) {
  const dayKey = message.submittedAt.slice(0, 10);
  if (dayKey !== lastDayKey) {
    threadHistory.push({ kind: 'day', dayKey, dayLabel: formatDayLabel(message.submittedAt) });
    lastDayKey = dayKey;
  }
  threadHistory.push({ kind: 'message', message });
}
---

<Layout title="Συνομιλία μηνυμάτων | GreekHandy" description="Αναλυτική προβολή thread με moderation badges, reporting εργαλεία και κατάσταση απάντησης.">
  <main class="thread-shell mx-auto max-w-6xl px-4 py-10 md:py-14">
    <a href="#thread-history" class="thread-skip-link thread-skip-link--history">Μετάβαση στο ιστορικό</a>
    <a href="#thread-moderation-state" class="thread-skip-link thread-skip-link--moderation">Μετάβαση σε moderation status</a>
    <a href="#thread-interaction" class="thread-skip-link thread-skip-link--interaction">Μετάβαση στις ενέργειες thread</a>
    <a
      href={threadListHref}
      class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-50"
    >
      <span aria-hidden="true">←</span>
      Επιστροφή στις συνομιλίες
    </a>

    <section class="mt-4 overflow-hidden rounded-[2rem] border border-slate-200/80 bg-gradient-to-br from-[#f8fbff] via-white to-[#f3f7fc] p-6 shadow-[0_14px_42px_-28px_rgba(15,23,42,0.42)] md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">GreekHandy Συνομιλία</p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">Συνομιλία</h1>
