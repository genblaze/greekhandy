          ? 'Filtered'
          : 'Ready';
const historyStatePhaseClass = showLoadingState
  ? 'border-sky-300 bg-sky-100 text-sky-900'
  : threadLoadError
    ? hasPartialThreadHistory
      ? 'border-amber-300 bg-amber-100 text-amber-900'
      : 'border-rose-300 bg-rose-100 text-rose-900'
    : showHistoryNoMatchState
      ? 'border-amber-300 bg-amber-100 text-amber-900'
      : threadMessages.length === 0
        ? 'border-slate-300 bg-slate-100 text-slate-700'
        : hasThreadFilters
          ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
          : 'border-emerald-300 bg-emerald-100 text-emerald-900';
const threadStatePrimaryActionLabel = hasViewerParamIssue
  ? threadListBackLabel
  : hasAccessIssue
    ? 'Άνοιγμα προσβάσιμου thread'
    : threadLoadError
      ? 'Επανάληψη φόρτωσης'
      : '';
const threadStatePrimaryActionHref = hasViewerParamIssue
  ? threadListHref
  : hasAccessIssue
    ? threadListHref
    : threadLoadError
      ? threadRetryHref
      : '';
const hasThreadEntryIssue = hasViewerParamIssue || hasAccessIssue;
const threadEntryGuidanceToneClass = hasThreadEntryIssue
  ? 'border-rose-200 bg-rose-50/80 text-rose-900'
  : threadLoadError
    ? 'border-amber-200 bg-amber-50/80 text-amber-900'
    : threadMessages.length === 0
      ? 'border-slate-200 bg-slate-50/80 text-slate-700'
      : 'border-sky-200 bg-sky-50/80 text-sky-900';
const threadEntryGuidanceTitle = hasViewerParamIssue
  ? 'Ο σύνδεσμος εισόδου thread χρειάζεται διόρθωση.'
  : hasAccessIssue
    ? 'Το thread δεν είναι προσβάσιμο από αυτό το email προβολής.'
    : threadLoadError
      ? 'Η είσοδος thread είναι διαθέσιμη, αλλά η φόρτωση δεν ολοκληρώθηκε πλήρως.'
      : threadMessages.length === 0
        ? 'Η είσοδος ολοκληρώθηκε, αλλά δεν υπάρχει ακόμη ιστορικό.'
        : 'Η είσοδος thread ολοκληρώθηκε με πλήρες context.';
const threadEntryGuidanceDescription = hasViewerParamIssue
  ? 'Ανοίξτε ξανά τη συνομιλία από το inbox ώστε να περάσουν σωστά τα στοιχεία threadId και viewerEmail.'
  : hasAccessIssue
    ? 'Χρησιμοποιήστε thread στο οποίο συμμετέχετε ή επιστρέψτε στο inbox για νέα επιλογή.'
    : threadLoadError
      ? 'Μπορείτε να δοκιμάσετε άμεση επανάληψη φόρτωσης χωρίς να χαθεί το context του thread.'
      : threadMessages.length === 0
        ? 'Το ιστορικό θα εμφανιστεί αυτόματα με το πρώτο μήνυμα στο ίδιο thread.'
        : 'Μπορείτε να προχωρήσετε σε ιστορικό, moderation έλεγχο ή αποστολή απάντησης.';
const threadEntryChecklist: string[] = [];
threadEntryChecklist.push(hasValidViewerEmail ? `Viewer email: ${viewerEmail}` : 'Viewer email: μη έγκυρο ή λείπει.');
threadEntryChecklist.push(hasThreadId ? `Thread ID: ${threadId}` : 'Thread ID: δεν δόθηκε.');
threadEntryChecklist.push(hasListContext ? `Inbox context: ${listContextSummaryLabel}` : 'Inbox context: χωρίς ενεργά φίλτρα.');
const threadEntryPrimaryHref = threadStatePrimaryActionHref || threadListHref;
const threadEntryPrimaryLabel = threadStatePrimaryActionLabel || threadListBackLabel;
const threadEntryRole = hasThreadEntryIssue ? 'alert' : 'status';
const threadEntryLive = hasThreadEntryIssue ? 'assertive' : 'polite';
const moderationConsequences: string[] = [];
if (threadBlockedByModeration) moderationConsequences.push('Δεν επιτρέπεται αποστολή νέου μηνύματος μέχρι να αρθεί το μπλοκάρισμα.');
if (threadMutedByModeration) moderationConsequences.push('Η ορατότητα του περιεχομένου είναι πλήρως περιορισμένη και το composer παραμένει κλειστό.');
if (!threadMutedByModeration && threadHasAdminHidden) moderationConsequences.push(`Μερικά μηνύματα είναι κρυφά (${hiddenMessagesCount}/${threadMessages.length}).`);
if (threadReviewedByModeration) moderationConsequences.push('Υπάρχει ενεργή αναφορά και απαιτείται παρακολούθηση κατάστασης.');
if (threadRejectedByModeration) moderationConsequences.push('Η αναφορά έχει κλείσει χωρίς επιπλέον περιορισμό.');
if (moderationConsequences.length === 0) moderationConsequences.push('Δεν υπάρχει ενεργός περιορισμός στη ροή του thread.');
const threadReadinessLabel = showLoadingState
  ? 'Thread σε συγχρονισμό'
  : threadBlockedByModeration
    ? 'Thread με κλειδωμένη αποστολή'
    : threadMutedByModeration
      ? 'Thread με πλήρη περιορισμό ορατότητας'
      : threadReviewedByModeration
        ? 'Thread σε ενεργό moderation έλεγχο'
        : canReply
          ? 'Thread έτοιμο για απάντηση'
          : 'Thread με περιορισμένη αλληλεπίδραση';
const threadReadinessClass = showLoadingState
  ? 'border-sky-300 bg-sky-100 text-sky-900'
  : threadBlockedByModeration
    ? 'border-rose-300 bg-rose-100 text-rose-900'
    : threadMutedByModeration || threadHasAdminHidden
      ? 'border-orange-300 bg-orange-100 text-orange-900'
      : threadReviewedByModeration
        ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
        : canReply
          ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
          : 'border-amber-300 bg-amber-100 text-amber-900';
const threadReadinessHint = showLoadingState
  ? 'Γίνεται ανάκτηση ιστορικού και κατάστασης moderation.'
  : threadBlockedByModeration
    ? 'Απαιτείται ανάγνωση ιστορικού μέχρι να αρθεί ο περιορισμός αποστολής.'
    : threadMutedByModeration
      ? 'Το περιεχόμενο είναι πλήρως κρυφό και το composer παραμένει ανενεργό.'
      : threadReviewedByModeration
        ? 'Η αναφορά είναι σε εξέλιξη, ενώ η αποστολή παραμένει διαθέσιμη.'
        : canReply
          ? 'Η συνομιλία είναι ενεργή και μπορείτε να απαντήσετε άμεσα.'
          : 'Ελέγξτε παραλήπτη/παραμέτρους πριν τη συνέχεια.';
const messageOrderById = new Map<string, number>();
threadMessages.forEach((message, index) => {
  messageOrderById.set(message.id, index + 1);
});

type ThreadHistoryEntry =
  | { kind: 'day'; dayKey: string; dayLabel: string }
  | { kind: 'message'; message: MessageSubmission };

const filteredThreadHistory: ThreadHistoryEntry[] = [];
const latestHistoryMessage = filteredThreadMessages.at(-1) || null;
let lastDayKey = '';
for (const message of filteredThreadMessages) {
  const dayKey = message.submittedAt.slice(0, 10);
  if (dayKey !== lastDayKey) {
    filteredThreadHistory.push({ kind: 'day', dayKey, dayLabel: formatDayLabel(message.submittedAt) });
    lastDayKey = dayKey;
  }
  filteredThreadHistory.push({ kind: 'message', message });
}
