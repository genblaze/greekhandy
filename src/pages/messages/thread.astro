---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_TRIAGE_ACTIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  clean,
  getMessageThreadId,
  readNdjson,
  writeNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const threadId = clean(url.searchParams.get('threadId'));
const viewerEmail = clean(url.searchParams.get('viewerEmail')).toLowerCase();
const status = clean(url.searchParams.get('status'));
const messageStatus = clean(url.searchParams.get('message'));
const showLoadingState = status === 'loading' || messageStatus === 'loading';
const formatDateTime = (value: string) => new Date(value).toLocaleString('el-GR');

const allMessages = await readNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH);
const visibilityActions = await readNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH);
const triageActions = await readNdjson<{ threadId?: string; action?: string }>(MESSAGE_TRIAGE_ACTIONS_FILE_PATH);

const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const latestTriageActionByThread = new Map<string, string>();
for (const entry of triageActions) {
  if (entry.threadId && entry.action) latestTriageActionByThread.set(entry.threadId, entry.action);
}

const threadMessages = allMessages
  .filter((message) => getMessageThreadId(message) === threadId)
  .sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));

const isParticipant = threadMessages.some(
  (message) => message.senderEmail.toLowerCase() === viewerEmail || message.recipientEmail.toLowerCase() === viewerEmail
);

if (threadId && viewerEmail && isParticipant && !showLoadingState) {
  const states = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
  const next = states.filter((entry) => !(entry.threadId === threadId && entry.viewerEmail === viewerEmail));
  const lastReadAt = threadMessages.at(-1)?.submittedAt || new Date().toISOString();
  next.push({ threadId, viewerEmail, lastReadAt });
  await writeNdjson(MESSAGE_READ_STATE_FILE_PATH, next);
}

const latestThreadAction = threadId ? (latestTriageActionByThread.get(threadId) || '') : '';
const threadBlockedByModeration = messageStatus === 'blocked' || latestThreadAction === 'block';
const threadReviewedByModeration = latestThreadAction === 'review';
const threadRejectedByModeration = latestThreadAction === 'reject';

const hiddenMessagesCount = threadMessages.filter((message) => hiddenMessageIds.has(message.id)).length;
const visibleMessagesCount = Math.max(0, threadMessages.length - hiddenMessagesCount);
const threadHasAdminHidden = hiddenMessagesCount > 0;
const threadMutedByModeration = threadMessages.length > 0 && hiddenMessagesCount === threadMessages.length;
const threadUnderModeration = threadBlockedByModeration || threadReviewedByModeration || threadRejectedByModeration || threadHasAdminHidden;

const canReply = threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration;
const latest = threadMessages.at(-1);
const recipientForReply = latest
  ? latest.senderEmail.toLowerCase() === viewerEmail
    ? latest.recipientEmail
    : latest.senderEmail
  : '';
const professionalSlug = latest?.professionalSlug ?? '';
const hasMissingParams = !threadId || !viewerEmail;
const hasAccessIssue = !hasMissingParams && !isParticipant;

const participants = new Set<string>();
for (const message of threadMessages) {
  participants.add(message.senderEmail.toLowerCase());
  participants.add(message.recipientEmail.toLowerCase());
}
const counterpartEmail = [...participants].find((email) => email !== viewerEmail) || recipientForReply.toLowerCase();
---

<Layout title="Συνομιλία μηνυμάτων | GreekHandy" description="Αναλυτική προβολή thread με moderation badges, reporting εργαλεία και κατάσταση απάντησης.">
  <main class="mx-auto max-w-5xl px-4 py-12 md:py-14">
    <a
      href={`/messages?viewerEmail=${encodeURIComponent(viewerEmail)}`}
      class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
    >
      <span aria-hidden="true">←</span>
      Επιστροφή στις συνομιλίες
    </a>

    <section class="mt-4 rounded-3xl border border-slate-200 bg-gradient-to-br from-white via-slate-50 to-sky-50 p-6 shadow-sm md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Thread</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Συνομιλία</h1>
          <p class="mt-2 text-sm leading-6 text-slate-600">Αναλυτική προβολή μηνυμάτων με σαφή κατάσταση moderation και ενέργειες αναφοράς.</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white/90 px-4 py-3 text-right shadow-sm">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Προβολή ως</p>
          <p class="mt-1 text-sm font-semibold text-slate-900">{viewerEmail || 'Άγνωστος χρήστης'}</p>
        </div>
      </div>

      {threadId && (
        <p class="mt-4 rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-600">
          Κωδικός thread: <span class="font-mono text-slate-800">{threadId}</span>
        </p>
      )}
    </section>

    {hasMissingParams && (
      <div class="mt-5 rounded-xl border border-amber-200 bg-amber-50 px-4 py-4 text-amber-950">
        <p class="font-semibold">Δεν μπορέσαμε να ανοίξουμε τη συνομιλία.</p>
        <p class="mt-1 text-sm">Λείπουν τα απαραίτητα στοιχεία <code>threadId</code> ή <code>viewerEmail</code>.</p>
      </div>
    )}

    {hasAccessIssue && (
      <div class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-4 text-rose-900">
        <p class="font-semibold">Δεν έχετε πρόσβαση σε αυτό το thread.</p>
        <p class="mt-1 text-sm">Επιστρέψτε στη λίστα συνομιλιών και επιλέξτε thread όπου συμμετέχετε.</p>
      </div>
    )}

    {threadId && viewerEmail && isParticipant && (
      <>
        {messageStatus === 'submitted' && <p class="mt-5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-900">Το μήνυμα στάλθηκε επιτυχώς.</p>}
        {messageStatus === 'invalid' && <p class="mt-5 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-900">Μη έγκυρα στοιχεία μηνύματος. Ελέγξτε το περιεχόμενο και προσπαθήστε ξανά.</p>}
        {messageStatus === 'error' && <p class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-900">Δεν ήταν δυνατή η αποστολή μηνύματος. Προσπαθήστε ξανά σε λίγο.</p>}
        {messageStatus === 'blocked' && <p class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-900">Η αποστολή σε αυτό το thread έχει μπλοκαριστεί από moderation.</p>}

        {status === 'reported' && <p class="mt-5 rounded-xl border border-sky-200 bg-gradient-to-br from-sky-50 to-white px-4 py-3 text-sm font-medium text-sky-900">Η αναφορά καταχωρήθηκε και θα εξεταστεί από την ομάδα moderation.</p>}
        {status === 'report-error' && <p class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-900">Δεν ήταν δυνατή η αποστολή της αναφοράς.</p>}
        {status === 'report-invalid' && <p class="mt-5 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-900">Μη έγκυρα στοιχεία αναφοράς.</p>}
        {status === 'report-forbidden' && <p class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-900">Δεν έχετε πρόσβαση για αναφορά αυτού του μηνύματος.</p>}
        {showLoadingState && (
          <p class="mt-5 flex items-center gap-2 rounded-xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm font-medium text-sky-900">
            <span class="h-3 w-3 animate-spin rounded-full border-2 border-sky-300 border-t-sky-700"></span>
            Φόρτωση συνομιλίας...
          </p>
        )}

        {threadBlockedByModeration && (
          <div class="mt-5 rounded-xl border border-rose-300 bg-gradient-to-br from-rose-50 to-white px-4 py-4 text-rose-900">
            <p class="font-semibold">Κατάσταση thread: Μπλοκαρισμένο</p>
            <p class="mt-1 text-sm">Η αποστολή νέου μηνύματος είναι απενεργοποιημένη από moderation.</p>
          </div>
        )}

        {!threadBlockedByModeration && threadHasAdminHidden && (
          <div class="mt-5 rounded-xl border border-orange-300 bg-gradient-to-br from-orange-50 to-white px-4 py-4 text-orange-900">
            <p class="font-semibold">Κατάσταση thread: Απόκρυψη από διαχείριση</p>
            <p class="mt-1 text-sm">Μέρος της συνομιλίας έχει κρυφτεί από διαχείριση για λόγους ασφάλειας.</p>
          </div>
        )}

        {!threadBlockedByModeration && !threadHasAdminHidden && threadReviewedByModeration && (
          <div class="mt-5 rounded-xl border border-sky-300 bg-gradient-to-br from-sky-50 to-white px-4 py-4 text-sky-900">
            <p class="font-semibold">Κατάσταση thread: Σε αναφορά</p>
            <p class="mt-1 text-sm">Η συνομιλία βρίσκεται σε επανεξέταση από moderation.</p>
          </div>
        )}

        {!threadBlockedByModeration && !threadHasAdminHidden && threadRejectedByModeration && (
          <div class="mt-5 rounded-xl border border-amber-300 bg-gradient-to-br from-amber-50 to-white px-4 py-4 text-amber-900">
            <p class="font-semibold">Κατάσταση thread: Αναφορά απορρίφθηκε</p>
            <p class="mt-1 text-sm">Η τελευταία αναφορά έκλεισε χωρίς επιπλέον περιορισμό.</p>
          </div>
        )}

        <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm md:p-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Λεπτομέρειες συνομιλίας</h2>
              <p class="mt-1 text-sm text-slate-600">Συμμετέχων: <span class="font-medium text-slate-900">{counterpartEmail || 'Μη διαθέσιμος'}</span></p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              {threadBlockedByModeration && <span class="rounded-full border border-rose-300 bg-rose-100 px-2.5 py-1 text-[11px] font-semibold text-rose-900">Μπλοκαρισμένη</span>}
              {!threadBlockedByModeration && threadHasAdminHidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Απόκρυψη διαχείρισης</span>}
              {!threadBlockedByModeration && !threadHasAdminHidden && threadReviewedByModeration && <span class="rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 text-[11px] font-semibold text-sky-900">Αναφορά σε εξέλιξη</span>}
              {!threadBlockedByModeration && !threadHasAdminHidden && threadRejectedByModeration && <span class="rounded-full border border-amber-300 bg-amber-100 px-2.5 py-1 text-[11px] font-semibold text-amber-900">Αναφορά απορρίφθηκε</span>}
              {!threadBlockedByModeration && threadMutedByModeration && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Σε σίγαση</span>}
              {!threadUnderModeration && <span class="rounded-full border border-emerald-300 bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-900">Ενεργή</span>}
            </div>
          </div>

          <div class="mt-4 flex flex-wrap gap-2 text-xs">
            <span class="rounded-full border border-slate-300 bg-slate-50 px-3 py-1 font-semibold text-slate-700">Μηνύματα: {threadMessages.length}</span>
            <span class="rounded-full border border-slate-300 bg-slate-50 px-3 py-1 font-semibold text-slate-700">Ορατά: {visibleMessagesCount}</span>
            <span class="rounded-full border border-slate-300 bg-slate-50 px-3 py-1 font-semibold text-slate-700">Κρυφά: {hiddenMessagesCount}</span>
            {threadReviewedByModeration && <span class="rounded-full border border-sky-300 bg-sky-100 px-3 py-1 font-semibold text-sky-900">Επανεξέταση</span>}
            {threadRejectedByModeration && <span class="rounded-full border border-amber-300 bg-amber-100 px-3 py-1 font-semibold text-amber-900">Απορριφθείσα αναφορά</span>}
          </div>
        </section>

        <section class="mt-5 space-y-3">
          {showLoadingState && [1, 2, 3].map((item) => (
            <article class="animate-pulse rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="h-3 w-24 rounded bg-slate-200"></div>
              <div class="mt-3 h-3 w-full rounded bg-slate-100"></div>
              <div class="mt-2 h-3 w-5/6 rounded bg-slate-100"></div>
            </article>
          ))}

          {!showLoadingState && threadMessages.length === 0 && (
            <div class="rounded-2xl border border-slate-200 bg-white px-5 py-6 shadow-sm">
              <p class="text-lg font-semibold text-slate-900">Δεν υπάρχουν μηνύματα ακόμη.</p>
              <p class="mt-1 text-sm text-slate-600">Στείλτε το πρώτο μήνυμα για να ξεκινήσει η συνομιλία.</p>
            </div>
          )}

          {!showLoadingState && threadMessages.map((message) => {
            const own = message.senderEmail.toLowerCase() === viewerEmail;
            const hidden = hiddenMessageIds.has(message.id);
            return (
              <div class={`flex ${own ? 'justify-end' : 'justify-start'}`}>
                <article class={`w-full max-w-3xl rounded-2xl border p-4 shadow-sm md:p-5 ${
                  hidden
                    ? 'border-orange-300 bg-gradient-to-br from-orange-50 via-white to-amber-50/50'
                    : own
                      ? 'border-sky-200 bg-gradient-to-br from-sky-50 to-white'
                      : 'border-slate-200 bg-white'
                }`}>
                  <div class="flex flex-wrap items-start justify-between gap-2">
                    <p class="text-xs font-medium text-slate-500">
                      {own ? 'Εσείς' : (message.senderName || 'Συνεργάτης')} • {formatDateTime(message.submittedAt)}
                    </p>
                    <div class="flex flex-wrap gap-1.5">
                      {own && <span class="rounded-full border border-sky-300 bg-sky-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-sky-900">Αποστολή</span>}
                      {!own && <span class="rounded-full border border-slate-300 bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-700">Εισερχόμενο</span>}
                      {hidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-orange-900">Κρυφό από διαχείριση</span>}
                    </div>
                  </div>

                  <p class={`mt-2 text-sm leading-7 ${hidden ? 'font-medium text-orange-900' : 'whitespace-pre-wrap text-slate-800'}`}>
                    {hidden ? 'Το μήνυμα έχει αποκρυφτεί από moderation.' : message.message}
                  </p>

                  {hidden && <p class="mt-2 text-xs font-semibold text-orange-900">Η προβολή του περιεχομένου είναι περιορισμένη από την ομάδα moderation.</p>}

                  {!hidden && !own && (
                    <details class="mt-3 rounded-xl border border-amber-200 bg-gradient-to-br from-amber-50/80 to-white p-3">
                      <summary class="cursor-pointer text-xs font-semibold text-amber-900">Αναφορά μηνύματος στη διαχείριση</summary>
                      <form action="/api/messages/report" method="POST" class="js-pending-form mt-3 space-y-2">
                        <input type="hidden" name="threadId" value={threadId} />
                        <input type="hidden" name="messageId" value={message.id} />
                        <input type="hidden" name="senderEmail" value={viewerEmail} />
                        <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />

                        <label class="block text-xs font-medium text-amber-900">
                          Αιτία αναφοράς
                          <select name="reason" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800">
                            <option value="spam">Spam</option>
                            <option value="abuse">Κακοποίηση</option>
                            <option value="harassment">Παρενόχληση</option>
                            <option value="other" selected>Άλλο</option>
                          </select>
                        </label>

                        <label class="block text-xs font-medium text-amber-900">
                          Σχόλιο (προαιρετικό)
                          <input type="text" name="details" maxlength="400" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800" placeholder="Περιγράψτε σύντομα το θέμα" />
                        </label>

                        <button type="submit" data-default-label="Υποβολή αναφοράς" class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-65">Υποβολή αναφοράς</button>
                      </form>
                    </details>
                  )}
                </article>
              </div>
            );
          })}
        </section>

        {!canReply && threadBlockedByModeration && (
          <div class="mt-6 rounded-xl border border-rose-200 bg-rose-50 px-4 py-4 text-rose-900">
            <p class="font-semibold">Το thread είναι περιορισμένο.</p>
            <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων έχει απενεργοποιηθεί από την ομάδα moderation.</p>
          </div>
        )}

        {!threadBlockedByModeration && threadMutedByModeration && (
          <div class="mt-6 rounded-xl border border-orange-200 bg-orange-50 px-4 py-4 text-orange-900">
            <p class="font-semibold">Η συνομιλία βρίσκεται σε κατάσταση σίγασης.</p>
            <p class="mt-1 text-sm">Τα μηνύματα είναι κρυφά από moderation. Δεν μπορείτε να στείλετε νέο μήνυμα όσο ισχύει ο περιορισμός.</p>
          </div>
        )}

        {canReply && (
          <form action="/api/messages/submit" method="POST" class="js-pending-form mt-6 rounded-2xl border border-sky-200 bg-gradient-to-br from-sky-50 to-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Νέο μήνυμα</h2>
            <p class="mt-1 text-sm text-slate-600">Απάντηση μέσα στο ίδιο thread με αυτόματη ενημέρωση στη λίστα συνομιλιών.</p>
            <input type="hidden" name="professionalSlug" value={professionalSlug} />
            <input type="hidden" name="threadId" value={threadId} />
            <input type="hidden" name="senderName" value="Participant" />
            <input type="hidden" name="senderEmail" value={viewerEmail} />
            <input type="hidden" name="recipientEmail" value={recipientForReply} />
            <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />
            <textarea name="message" rows="4" required maxlength="2000" class="mt-3 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm leading-6 text-slate-900" placeholder="Γράψτε το μήνυμά σας"></textarea>
            <button type="submit" data-default-label="Αποστολή" class="mt-3 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:opacity-65">Αποστολή</button>
          </form>
        )}
      </>
    )}
  </main>

  <script is:inline>
    for (const form of document.querySelectorAll('.js-pending-form')) {
      form.addEventListener('submit', () => {
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;
        submitButton.disabled = true;
        const defaultLabel = submitButton.dataset.defaultLabel || submitButton.textContent || 'Υποβολή';
        submitButton.textContent = 'Επεξεργασία...';
        submitButton.setAttribute('aria-busy', 'true');
        form.classList.add('opacity-80');
        form.setAttribute('data-submit-label', defaultLabel);
      }, { once: true });
    }
  </script>
</Layout>
