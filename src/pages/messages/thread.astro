---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_TRIAGE_ACTIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  clean,
  getMessageThreadId,
  readNdjson,
  writeNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const threadId = clean(url.searchParams.get('threadId'));
const viewerEmail = clean(url.searchParams.get('viewerEmail')).toLowerCase();
const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const hasViewerEmail = viewerEmail.length > 0;
const hasValidViewerEmail = EMAIL_PATTERN.test(viewerEmail);
const hasInvalidViewerEmail = hasViewerEmail && !hasValidViewerEmail;
const hasThreadId = threadId.length > 0;
const canLoadThreadData = hasThreadId && hasValidViewerEmail;
const status = clean(url.searchParams.get('status'));
const messageStatus = clean(url.searchParams.get('message'));
const threadSearchQueryRaw = clean(url.searchParams.get('q'));
const threadSearchQuery = threadSearchQueryRaw.toLowerCase();
const listSearchQueryRaw = clean(url.searchParams.get('listQ'));
const requestedListSortMode = clean(url.searchParams.get('listSort')).toLowerCase();
const listSortMode = requestedListSortMode === 'unread' ? 'unread' : 'recent';
const listUnreadOnly = clean(url.searchParams.get('listUnread')) === '1';
const listBlockedOnly = clean(url.searchParams.get('listBlocked')) === '1';
const listReportedOnly = clean(url.searchParams.get('listReported')) === '1';
type ThreadVisibilityFilter = 'all' | 'visible' | 'hidden' | 'reportable';
const isThreadVisibilityFilter = (value: string): value is ThreadVisibilityFilter => (
  value === 'all' || value === 'visible' || value === 'hidden' || value === 'reportable'
);
const requestedThreadVisibilityFilter = clean(url.searchParams.get('visibility')).toLowerCase();
const threadVisibilityFilter: ThreadVisibilityFilter = isThreadVisibilityFilter(requestedThreadVisibilityFilter)
  ? requestedThreadVisibilityFilter
  : 'all';
const hasUnknownThreadVisibilityFilter = requestedThreadVisibilityFilter !== '' && !isThreadVisibilityFilter(requestedThreadVisibilityFilter);
const knownThreadStatuses = new Set(['', 'reported', 'report-error', 'report-invalid', 'report-forbidden', 'loading']);
const knownMessageStatuses = new Set(['', 'submitted', 'invalid', 'error', 'blocked', 'loading']);
const showLoadingState = status === 'loading' || messageStatus === 'loading';
const THREAD_LOADING_SKELETON_ROWS = [1, 2, 3];
const hasUnknownStatus = status !== '' && !knownThreadStatuses.has(status);
const hasUnknownMessageStatus = messageStatus !== '' && !knownMessageStatuses.has(messageStatus);
const formatDateTime = (value: string) => new Date(value).toLocaleString('el-GR');
const formatDayLabel = (value: string) => new Date(value).toLocaleDateString('el-GR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
const toDomId = (value: string, fallback: string) => {
  const normalized = value.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  const fallbackNormalized = fallback.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  return normalized || fallbackNormalized || 'item';
};
const getMessageAnchorHref = (message: MessageSubmission | null) => (
  message ? `#message-${toDomId(message.id, `message-${message.submittedAt}`)}` : '#thread-history'
);

let threadLoadError = '';
const safeReadNdjson = async <T,>(path: string, label: string): Promise<T[]> => {
  try {
    return await readNdjson<T>(path);
  } catch {
    if (!threadLoadError) threadLoadError = `Δεν ήταν δυνατή η φόρτωση δεδομένων (${label}).`;
    return [];
  }
};

const allMessages = canLoadThreadData
  ? await safeReadNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH, 'μηνύματα')
  : [];
const visibilityActions = canLoadThreadData
  ? await safeReadNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH, 'ορατότητα')
  : [];
const triageActions = canLoadThreadData
  ? await safeReadNdjson<{ threadId?: string; action?: string }>(MESSAGE_TRIAGE_ACTIONS_FILE_PATH, 'moderation')
  : [];

const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const latestTriageActionByThread = new Map<string, string>();
for (const entry of triageActions) {
  if (entry.threadId && entry.action) latestTriageActionByThread.set(entry.threadId, entry.action);
}

const threadMessages = allMessages
  .filter((message) => getMessageThreadId(message) === threadId)
  .sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));

const isParticipant = threadMessages.some(
  (message) => message.senderEmail.toLowerCase() === viewerEmail || message.recipientEmail.toLowerCase() === viewerEmail
);

let readStateWriteError = '';
if (canLoadThreadData && isParticipant && !showLoadingState) {
  try {
    const states = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
    const next = states.filter((entry) => !(entry.threadId === threadId && entry.viewerEmail === viewerEmail));
    const lastReadAt = threadMessages.at(-1)?.submittedAt || new Date().toISOString();
    next.push({ threadId, viewerEmail, lastReadAt });
    await writeNdjson(MESSAGE_READ_STATE_FILE_PATH, next);
  } catch {
    readStateWriteError = 'Δεν ήταν δυνατή η ενημέρωση της κατάστασης ανάγνωσης.';
  }
}

const latestThreadAction = threadId ? (latestTriageActionByThread.get(threadId) || '') : '';
const threadBlockedByModeration = messageStatus === 'blocked' || latestThreadAction === 'block';
const threadReviewedByModeration = latestThreadAction === 'review';
const threadRejectedByModeration = latestThreadAction === 'reject';

const hiddenMessagesCount = threadMessages.filter((message) => hiddenMessageIds.has(message.id)).length;
const visibleMessagesCount = Math.max(0, threadMessages.length - hiddenMessagesCount);
const threadHasAdminHidden = hiddenMessagesCount > 0;
const threadMutedByModeration = threadMessages.length > 0 && hiddenMessagesCount === threadMessages.length;
const threadUnderModeration = threadBlockedByModeration || threadReviewedByModeration || threadRejectedByModeration || threadHasAdminHidden;
const threadModerationTone = threadBlockedByModeration
  ? 'blocked'
  : threadHasAdminHidden
    ? 'hidden'
    : threadReviewedByModeration
      ? 'reported'
      : threadRejectedByModeration
        ? 'rejected'
        : 'active';

const threadModerationLabel = threadModerationTone === 'blocked'
  ? 'Μπλοκαρισμένη συνομιλία'
  : threadModerationTone === 'hidden'
    ? 'Κρυφό περιεχόμενο'
    : threadModerationTone === 'reported'
      ? 'Αναφορά σε έλεγχο'
      : threadModerationTone === 'rejected'
        ? 'Αναφορά χωρίς περιορισμό'
        : 'Ενεργή συνομιλία';

const threadModerationDescription = threadModerationTone === 'blocked'
  ? 'Η συνομιλία έχει μπλοκαριστεί από moderation. Μπορείτε να διαβάζετε το ιστορικό, αλλά δεν επιτρέπεται νέα αποστολή.'
  : threadModerationTone === 'hidden'
    ? threadMutedByModeration
      ? 'Όλα τα μηνύματα είναι κρυφά από moderation. Η απάντηση είναι προσωρινά απενεργοποιημένη.'
      : `Μέρος της συνομιλίας έχει κρυφτεί από moderation (κρυφά: ${hiddenMessagesCount}/${threadMessages.length}).`
    : threadModerationTone === 'reported'
      ? 'Η συνομιλία έχει αναφερθεί και βρίσκεται σε ενεργό έλεγχο moderation.'
      : threadModerationTone === 'rejected'
        ? 'Η τελευταία αναφορά έκλεισε χωρίς πρόσθετο περιορισμό. Το thread παραμένει ενεργό.'
        : 'Δεν υπάρχει ενεργός περιορισμός moderation.';
const threadModerationImpactLabel = threadModerationTone === 'blocked'
  ? 'Αποστολή απενεργοποιημένη'
  : threadModerationTone === 'hidden'
    ? 'Περιορισμένη ορατότητα'
    : threadModerationTone === 'reported'
      ? 'Έλεγχος αναφοράς σε εξέλιξη'
      : threadModerationTone === 'rejected'
        ? 'Η αναφορά έχει κλείσει'
        : 'Καμία επίπτωση';
const threadModerationActionLabel = threadBlockedByModeration
  ? 'Αναμονή για άρση περιορισμού'
  : threadMutedByModeration
    ? 'Αναμονή μέχρι επαναφορά ορατότητας'
    : threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration
      ? 'Μπορείτε να απαντήσετε τώρα'
      : 'Ελέγξτε τη διαμόρφωση thread';

const threadModerationBannerClass = threadModerationTone === 'blocked'
  ? 'border-rose-300 bg-gradient-to-r from-rose-50/95 via-white to-rose-50/80 text-rose-900'
  : threadModerationTone === 'hidden'
    ? 'border-orange-300 bg-gradient-to-r from-orange-50/95 via-white to-amber-50/80 text-orange-900'
    : threadModerationTone === 'reported'
      ? 'border-sky-300 bg-gradient-to-r from-sky-50/95 via-white to-sky-50/80 text-sky-900'
      : threadModerationTone === 'rejected'
        ? 'border-amber-300 bg-gradient-to-r from-amber-50/95 via-white to-amber-50/80 text-amber-900'
        : 'border-emerald-300 bg-gradient-to-r from-emerald-50/95 via-white to-emerald-50/80 text-emerald-900';
const moderationSeverityLabel = threadModerationTone === 'blocked'
  ? 'Κρίσιμος περιορισμός'
  : threadModerationTone === 'hidden'
    ? 'Ενισχυμένος έλεγχος περιεχομένου'
    : threadModerationTone === 'reported'
      ? 'Ενεργός έλεγχος αναφοράς'
      : threadModerationTone === 'rejected'
        ? 'Καταγεγραμμένη αναφορά'
        : 'Κανονική λειτουργία';

const canReply = threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration;
const showReportedConversationBanner = !threadBlockedByModeration && (threadReviewedByModeration || threadRejectedByModeration);
const reportedConversationBannerTitle = threadReviewedByModeration
  ? 'Αναφερόμενη συνομιλία σε έλεγχο'
  : 'Αναφερόμενη συνομιλία με ολοκληρωμένο έλεγχο';
const reportedConversationBannerDescription = threadReviewedByModeration
  ? 'Η ομάδα moderation αξιολογεί το thread. Η αποστολή παραμένει διαθέσιμη μέχρι να επιβληθεί διαφορετικός περιορισμός.'
  : 'Η αναφορά εξετάστηκε και έκλεισε χωρίς μπλοκάρισμα ή νέα απόκρυψη περιεχομένου.';
const moderationReplyGuidance = canReply
  ? 'Μπορείτε να συνεχίσετε με απάντηση σε αυτό το thread.'
  : threadBlockedByModeration
    ? 'Η αποστολή νέου μηνύματος είναι απενεργοποιημένη.'
  : threadMutedByModeration
      ? 'Η απάντηση είναι απενεργοποιημένη μέχρι να αρθεί η απόκρυψη.'
      : 'Η φόρμα απάντησης δεν είναι διαθέσιμη σε αυτή την κατάσταση.';
const latest = threadMessages.at(-1);
const recipientForReply = latest
  ? latest.senderEmail.toLowerCase() === viewerEmail
    ? latest.recipientEmail
    : latest.senderEmail
  : '';
const professionalSlug = latest?.professionalSlug ?? '';
const hasMissingParams = !hasThreadId || !hasViewerEmail;
const hasViewerParamIssue = hasMissingParams || hasInvalidViewerEmail;
const hasAccessIssue = !hasViewerParamIssue && !isParticipant && !threadLoadError;
const hasFailedSendStatus = messageStatus === 'invalid' || messageStatus === 'error';
const composerInitialState = messageStatus === 'submitted'
  ? 'success'
  : messageStatus === 'invalid' || messageStatus === 'error' || messageStatus === 'blocked'
    ? 'error'
    : 'idle';
const composerInitialStateLabel = messageStatus === 'submitted'
  ? 'Το τελευταίο μήνυμα στάλθηκε επιτυχώς.'
  : messageStatus === 'invalid'
    ? 'Η αποστολή απέτυχε λόγω μη έγκυρου περιεχομένου. Το πρόχειρο διατηρήθηκε για διόρθωση στη φόρμα απάντησης.'
    : messageStatus === 'error'
      ? 'Η αποστολή δεν ολοκληρώθηκε. Το πρόχειρο σώθηκε ώστε να συνεχίσετε από το ίδιο σημείο χωρίς απώλεια κειμένου.'
      : messageStatus === 'blocked'
        ? 'Η αποστολή απενεργοποιήθηκε από moderation.'
        : 'Η φόρμα απάντησης είναι έτοιμη.';
const composerDraftStorageKey = canLoadThreadData ? `gh:thread-composer-draft:${threadId}:${viewerEmail}` : '';
const shouldClearComposerDraftOnLoad = messageStatus === 'submitted';
const composerRetryPanelTitle = messageStatus === 'invalid'
  ? 'Η αποστολή διακόπηκε: χρειάζεται διόρθωση περιεχομένου'
  : 'Η αποστολή διακόπηκε προσωρινά';
const composerRetryPanelDescription = messageStatus === 'invalid'
  ? 'Διορθώστε το μήνυμα και ξαναστείλτε το από τη φόρμα απάντησης.'
  : 'Συνεχίστε από τη φόρμα απάντησης, αφού ελέγξετε σύνδεση και περιεχόμενο.';
const composerRetryPanelToneClass = messageStatus === 'invalid'
  ? 'border-amber-300 bg-amber-50 text-amber-900'
  : 'border-rose-300 bg-rose-50 text-rose-900';
const composerAriaDescribedBy = [
  'thread-composer-description',
  'composer-state',
  'composer-shortcuts',
  'composer-error',
  'composer-count',
  'composer-live',
  'composer-feedback',
  'composer-submit-live',
  'thread-offline-alert',
  hasFailedSendStatus ? 'composer-retry-panel' : ''
]
  .filter(Boolean)
  .join(' ');

const participants = new Set<string>();
for (const message of threadMessages) {
  participants.add(message.senderEmail.toLowerCase());
  participants.add(message.recipientEmail.toLowerCase());
}
const counterpartEmail = [...participants].find((email) => email !== viewerEmail) || recipientForReply.toLowerCase();
const hasListContext = Boolean(listSearchQueryRaw) || listUnreadOnly || listBlockedOnly || listReportedOnly || listSortMode === 'unread';
const listContextSummaryParts: string[] = [];
if (listSearchQueryRaw) listContextSummaryParts.push(`Αναζήτηση: "${listSearchQueryRaw}"`);
if (listUnreadOnly) listContextSummaryParts.push('Μόνο μη αναγνωσμένα');
if (listBlockedOnly) listContextSummaryParts.push('Μόνο μπλοκαρισμένα');
if (listReportedOnly) listContextSummaryParts.push('Μόνο αναφερόμενα');
if (listSortMode === 'unread') listContextSummaryParts.push('Sort: μη αναγνωσμένα πρώτα');
const listContextSummaryLabel = listContextSummaryParts.length > 0
  ? listContextSummaryParts.join(' · ')
  : 'Χωρίς ενεργά φίλτρα inbox.';
const threadListBackLabel = hasListContext ? 'Επιστροφή στη φιλτραρισμένη λίστα' : 'Επιστροφή στις συνομιλίες';
const appendListContextParams = (params: URLSearchParams) => {
  if (listSearchQueryRaw) params.set('listQ', listSearchQueryRaw);
  if (listUnreadOnly) params.set('listUnread', '1');
  if (listBlockedOnly) params.set('listBlocked', '1');
  if (listReportedOnly) params.set('listReported', '1');
  if (listSortMode === 'unread') params.set('listSort', 'unread');
};
const buildThreadListHref = () => {
  const params = new URLSearchParams();
  if (hasValidViewerEmail) params.set('viewerEmail', viewerEmail);
  if (listSearchQueryRaw) params.set('q', listSearchQueryRaw);
  if (listUnreadOnly) params.set('unread', '1');
  if (listBlockedOnly) params.set('blocked', '1');
  if (listReportedOnly) params.set('reported', '1');
  if (listSortMode === 'unread') params.set('sort', 'unread');
  const query = params.toString();
  return query ? `/messages?${query}` : '/messages';
};
const threadListHref = buildThreadListHref();

const buildThreadHref = (options: { q?: string; visibility?: string; status?: 'loading' } = {}) => {
  const params = new URLSearchParams();
  if (threadId) params.set('threadId', threadId);
  if (viewerEmail) params.set('viewerEmail', viewerEmail);
  const nextQuery = typeof options.q === 'string' ? options.q.trim() : threadSearchQueryRaw;
  if (nextQuery) params.set('q', nextQuery);
  const requestedVisibility = typeof options.visibility === 'string' ? options.visibility.trim().toLowerCase() : threadVisibilityFilter;
  const nextVisibility = isThreadVisibilityFilter(requestedVisibility) ? requestedVisibility : 'all';
  if (nextVisibility !== 'all') params.set('visibility', nextVisibility);
  if (options.status === 'loading') params.set('status', 'loading');
  appendListContextParams(params);
  const query = params.toString();
  return query ? `/messages/thread?${query}` : '/messages/thread';
};

const threadViewHref = canLoadThreadData ? buildThreadHref() : '/messages/thread';
const threadRetryHref = canLoadThreadData ? buildThreadHref({ status: 'loading' }) : threadViewHref;
const incomingMessagesCount = threadMessages.filter((message) => message.senderEmail.toLowerCase() !== viewerEmail).length;
const outgoingMessagesCount = Math.max(0, threadMessages.length - incomingMessagesCount);
const isMessageHidden = (message: MessageSubmission) => hiddenMessageIds.has(message.id);
const isIncomingMessage = (message: MessageSubmission) => message.senderEmail.toLowerCase() !== viewerEmail;
const isReportableMessage = (message: MessageSubmission) => isIncomingMessage(message) && !isMessageHidden(message);
const reportableIncomingCount = threadMessages.filter((message) => isReportableMessage(message)).length;
const latestVisibleMessage = [...threadMessages].reverse().find((message) => !hiddenMessageIds.has(message.id)) || null;
const latestVisibleMessageHref = getMessageAnchorHref(latestVisibleMessage);

const matchesThreadVisibilityFilter = (message: MessageSubmission) => {
  if (threadVisibilityFilter === 'visible') return !isMessageHidden(message);
  if (threadVisibilityFilter === 'hidden') return isMessageHidden(message);
  if (threadVisibilityFilter === 'reportable') return isReportableMessage(message);
  return true;
};
const matchesThreadSearchQuery = (message: MessageSubmission) => {
  if (!threadSearchQuery) return true;
  const searchIndex = [
    message.message,
    message.senderName,
    message.senderEmail,
    message.recipientEmail,
    message.submittedAt,
    getMessageThreadId(message)
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();
  return searchIndex.includes(threadSearchQuery);
};
const filteredThreadMessages = threadMessages.filter((message) => (
  matchesThreadVisibilityFilter(message) && matchesThreadSearchQuery(message)
));
const filteredIncomingMessagesCount = filteredThreadMessages.filter((message) => isIncomingMessage(message)).length;
const filteredOutgoingMessagesCount = Math.max(0, filteredThreadMessages.length - filteredIncomingMessagesCount);
const filteredHiddenMessagesCount = filteredThreadMessages.filter((message) => isMessageHidden(message)).length;
const filteredVisibleMessagesCount = Math.max(0, filteredThreadMessages.length - filteredHiddenMessagesCount);
const filteredReportableIncomingCount = filteredThreadMessages.filter((message) => isReportableMessage(message)).length;
const latestFilteredVisibleMessage = [...filteredThreadMessages].reverse().find((message) => !hiddenMessageIds.has(message.id)) || null;
const latestFilteredVisibleMessageHref = getMessageAnchorHref(latestFilteredVisibleMessage);
const threadFilterCounts = {
  all: threadMessages.length,
  visible: visibleMessagesCount,
  hidden: hiddenMessagesCount,
  reportable: reportableIncomingCount
};
const threadFilterChips: Array<{ value: ThreadVisibilityFilter; label: string; count: number }> = [
  { value: 'all', label: 'Όλα', count: threadFilterCounts.all },
  { value: 'visible', label: 'Ορατά', count: threadFilterCounts.visible },
  { value: 'hidden', label: 'Κρυφά', count: threadFilterCounts.hidden },
  { value: 'reportable', label: 'Αναφέρσιμα', count: threadFilterCounts.reportable }
];
const threadVisibilityFilterLabel = threadVisibilityFilter === 'visible'
  ? 'Ορατά'
  : threadVisibilityFilter === 'hidden'
    ? 'Κρυφά'
    : threadVisibilityFilter === 'reportable'
      ? 'Αναφέρσιμα'
      : 'Όλα';
const hasThreadFilters = Boolean(threadSearchQueryRaw) || threadVisibilityFilter !== 'all';
const threadFilterScopeParts: string[] = [];
if (threadVisibilityFilter !== 'all') threadFilterScopeParts.push(`Scope: ${threadVisibilityFilterLabel}`);
if (threadSearchQueryRaw) threadFilterScopeParts.push(`Αναζήτηση: "${threadSearchQueryRaw}"`);
const threadFilterScopeLabel = threadFilterScopeParts.length > 0
  ? threadFilterScopeParts.join(' · ')
  : 'Scope: Όλα τα μηνύματα χωρίς επιπλέον φίλτρο';
const showHistoryNoMatchState = !showLoadingState && threadMessages.length > 0 && filteredThreadMessages.length === 0 && hasThreadFilters;
const threadFilterResetHref = buildThreadHref({ q: '', visibility: 'all' });
const threadFilterSummary = showLoadingState
  ? 'Τα φίλτρα θα ενημερωθούν μόλις ολοκληρωθεί ο συγχρονισμός.'
  : showHistoryNoMatchState
    ? `Δεν υπάρχουν αποτελέσματα για τα φίλτρα (${threadVisibilityFilterLabel}${threadSearchQueryRaw ? ` · αναζήτηση: "${threadSearchQueryRaw}"` : ''}).`
    : hasThreadFilters
      ? `Ενεργά φίλτρα: ${filteredThreadMessages.length}/${threadMessages.length} μηνύματα.`
      : 'Δεν υπάρχουν ενεργά φίλτρα thread.';
const threadHistoryVisibleMessage = hasThreadFilters ? latestFilteredVisibleMessage : latestVisibleMessage;
const threadHistoryVisibleMessageHref = hasThreadFilters ? latestFilteredVisibleMessageHref : latestVisibleMessageHref;
const threadHistoryMessageCountLabel = hasThreadFilters
  ? `${filteredThreadMessages.length} από ${threadMessages.length} μηνύματα`
  : `${threadMessages.length} μηνύματα`;
const threadHistoryIncomingLabel = hasThreadFilters
  ? `${filteredIncomingMessagesCount} (σύνολο ${incomingMessagesCount})`
  : `${incomingMessagesCount}`;
const threadHistoryOutgoingLabel = hasThreadFilters
  ? `${filteredOutgoingMessagesCount} (σύνολο ${outgoingMessagesCount})`
  : `${outgoingMessagesCount}`;
const threadHistoryReportableLabel = hasThreadFilters
  ? `${filteredReportableIncomingCount} (σύνολο ${reportableIncomingCount})`
  : `${reportableIncomingCount}`;
const moderationSendStateLabel = threadBlockedByModeration
  ? 'Κλειδωμένη αποστολή'
  : threadMutedByModeration
    ? 'Προσωρινά ανενεργή'
    : canReply
      ? 'Διαθέσιμη αποστολή'
      : 'Χωρίς διαθέσιμη αποστολή';
const moderationVisibilityStateLabel = threadHasAdminHidden
  ? `Περιορισμένη (${hiddenMessagesCount}/${threadMessages.length})`
  : 'Πλήρης προβολή';
const moderationReviewStateLabel = threadReviewedByModeration
  ? 'Σε ενεργό έλεγχο'
  : threadRejectedByModeration
    ? 'Έλεγχος ολοκληρωμένος'
    : 'Χωρίς ενεργή αναφορά';
const triagePrimaryActionLabel = threadBlockedByModeration
  ? 'Ελέγξτε ιστορικό και περιμένετε άρση μπλοκαρίσματος.'
  : canReply
    ? 'Απαντήστε στο thread από το composer.'
    : threadReviewedByModeration
      ? 'Παρακολουθήστε την αναφορά μέχρι να ολοκληρωθεί.'
      : threadMessages.length === 0
        ? 'Στείλτε το πρώτο μήνυμα για εκκίνηση ροής.'
        : 'Ελέγξτε visibility και κατάσταση thread.';
const triagePrimaryActionHint = latestVisibleMessage
  ? `Τελευταίο ορατό μήνυμα: ${formatDateTime(latestVisibleMessage.submittedAt)}.`
  : 'Δεν υπάρχει ακόμη ορατό μήνυμα στο thread.';
const triagePrimaryActionHref = canReply ? '#thread-interaction' : '#thread-history';
const threadTriageTier = threadBlockedByModeration
  ? 'critical'
  : threadReviewedByModeration || threadHasAdminHidden || (canReply && incomingMessagesCount > 0)
    ? 'high'
    : threadRejectedByModeration || threadMessages.length === 0
      ? 'medium'
      : 'normal';
const threadTriageTierLabel = threadTriageTier === 'critical'
  ? 'Κρίσιμη προτεραιότητα'
  : threadTriageTier === 'high'
    ? 'Υψηλή προτεραιότητα'
    : threadTriageTier === 'medium'
      ? 'Μεσαία προτεραιότητα'
      : 'Κανονική ροή';
const threadTriageTierClass = threadTriageTier === 'critical'
  ? 'border-rose-300 bg-rose-100 text-rose-900'
  : threadTriageTier === 'high'
    ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
