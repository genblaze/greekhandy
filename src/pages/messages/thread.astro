<Layout title="Συνομιλία μηνυμάτων | GreekHandy" description="Αναλυτική προβολή thread με moderation badges, reporting εργαλεία και κατάσταση απάντησης.">
  <main
    class="thread-shell mx-auto max-w-6xl px-4 py-10 md:py-14"
    data-thread-id={threadId || null}
    data-thread-viewer-email={viewerEmail || null}
    data-thread-counterpart-email={counterpartEmail || null}
    data-thread-professional-slug={professionalSlug || null}
    data-thread-list-href={threadListHref}
    data-thread-list-context={listContextSummaryLabel}
  >
    <a href="#thread-history" class="thread-skip-link thread-skip-link--history">Μετάβαση στο ιστορικό</a>
    <a href="#thread-moderation-state" class="thread-skip-link thread-skip-link--moderation">Μετάβαση σε moderation status</a>
    <a href="#thread-interaction" class="thread-skip-link thread-skip-link--interaction">Μετάβαση στις ενέργειες thread</a>
    <a
      href={threadListHref}
      class="thread-touch-target inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-50"
    >
      <span aria-hidden="true">←</span>
      {threadListBackLabel}
    </a>
    {hasListContext && (
      <p class="mt-2 rounded-xl border border-indigo-200 bg-indigo-50/80 px-3 py-2 text-[11px] text-indigo-900">
        Ενεργό context λίστας: <span class="font-semibold">{listContextSummaryLabel}</span>
      </p>
    )}

    <section class="mt-4 overflow-hidden rounded-[2rem] border border-slate-200/80 bg-gradient-to-br from-[#f8fbff] via-white to-[#f3f7fc] p-6 shadow-[0_14px_42px_-28px_rgba(15,23,42,0.42)] md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">GreekHandy Συνομιλία</p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">Συνομιλία</h1>
          <p class="mt-3 text-sm leading-6 text-slate-600">Πλήρες ιστορικό μηνυμάτων με ενισχυμένη ανάγνωση context και εμφανή moderation κατάσταση.</p>
        </div>

        <div class="rounded-2xl border border-sky-200/70 bg-white/90 px-4 py-3 text-right shadow-[0_12px_34px_-24px_rgba(2,132,199,0.5)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-sky-700">Προβολή ως</p>
          <p class="mt-1 break-all text-sm font-semibold text-slate-900">{viewerEmail || 'Άγνωστος χρήστης'}</p>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-2xl border border-slate-200 bg-white/90 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Μηνύματα</p>
          <p class="mt-1 text-xl font-bold text-slate-900">{threadMessages.length}</p>
          <p class="text-xs text-slate-500">στο ίδιο thread</p>
        </article>
        <article class="rounded-2xl border border-emerald-300 bg-emerald-50/75 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-emerald-800">Ορατά</p>
          <p class="mt-1 text-xl font-bold text-emerald-900">{visibleMessagesCount}</p>
          <p class="text-xs text-emerald-800">άμεσα διαθέσιμα</p>
        </article>
        <article class="rounded-2xl border border-orange-300 bg-orange-50/80 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-orange-800">Κρυφά</p>
          <p class="mt-1 text-xl font-bold text-orange-900">{hiddenMessagesCount}</p>
          <p class="text-xs text-orange-800">από moderation</p>
        </article>
        <article class={`rounded-2xl border px-4 py-3 ${threadUnderModeration ? 'border-amber-300 bg-amber-50/80' : 'border-sky-300 bg-sky-50/80'}`}>
          <p class={`text-[11px] font-semibold uppercase tracking-[0.12em] ${threadUnderModeration ? 'text-amber-800' : 'text-sky-800'}`}>Κατάσταση</p>
          <p class={`mt-1 text-xl font-bold ${threadUnderModeration ? 'text-amber-900' : 'text-sky-900'}`}>{threadModerationLabel}</p>
          <p class={`text-xs ${threadUnderModeration ? 'text-amber-800' : 'text-sky-800'}`}>{moderationSeverityLabel}</p>
        </article>
      </div>

      {threadId && (
        <p class="mt-4 rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-600">
          Κωδικός thread: <span class="font-mono text-slate-800">{threadId}</span>
        </p>
      )}
      <p class="mt-2 text-xs text-slate-500">Με το άνοιγμα του thread, τα τρέχοντα μηνύματα σημειώνονται ως διαβασμένα για τον χρήστη προβολής.</p>

      <div class="mt-4 grid gap-3 lg:grid-cols-3">
        <article class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-xs text-slate-700">
          <p class="font-semibold uppercase tracking-[0.1em] text-slate-500">Triage επόμενο βήμα</p>
          <p class={`mt-1 inline-flex rounded-full border px-2 py-0.5 text-[10px] font-semibold ${threadTriageTierClass}`}>{threadTriageTierLabel}</p>
          <p class="mt-1 text-sm font-semibold text-slate-900">{triagePrimaryActionLabel}</p>
          <p class="mt-1 text-slate-600">{triagePrimaryActionHint}</p>
          <a href={triagePrimaryActionHref} class="mt-2 inline-flex rounded-md border border-slate-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
            Μετάβαση
          </a>
        </article>
        <article class="rounded-xl border border-indigo-200 bg-indigo-50 px-3 py-3 text-xs text-indigo-900">
          <p class="font-semibold uppercase tracking-[0.1em]">Ροή μηνυμάτων</p>
          <p class="mt-1">Εισερχόμενα: <span class="font-bold">{incomingMessagesCount}</span></p>
          <p class="mt-1">Εξερχόμενα: <span class="font-bold">{outgoingMessagesCount}</span></p>
          <p class="mt-1">Reportable εισερχόμενα: <span class="font-bold">{reportableIncomingCount}</span></p>
        </article>
        <article class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-3 text-xs text-amber-900">
          <p class="font-semibold uppercase tracking-[0.1em]">Πίνακας moderation</p>
          <p class="mt-1">Αποστολή: <span class="font-bold">{moderationSendStateLabel}</span></p>
          <p class="mt-1">Ορατότητα: <span class="font-bold">{moderationVisibilityStateLabel}</span></p>
          <p class="mt-1">Αναφορές: <span class="font-bold">{moderationReviewStateLabel}</span></p>
          <p class={`mt-2 inline-flex rounded-full border px-2 py-0.5 text-[10px] font-semibold ${threadReadinessClass}`}>{threadReadinessLabel}</p>
          <p class="mt-1 text-[11px]">{threadReadinessHint}</p>
        </article>
      </div>
    </section>

    {hasViewerParamIssue && (
      <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert" aria-live="assertive" aria-atomic="true">
        <p class="font-semibold">Ο σύνδεσμος συνομιλίας δεν είναι πλήρης.</p>
        <p class="mt-1">Επιστρέψτε στη λίστα συνομιλιών και ανοίξτε ξανά τη συνομιλία.</p>
      </div>
    )}
    <section id="thread-entry-guidance" class={`mt-4 rounded-2xl border px-4 py-4 text-sm ${threadEntryGuidanceToneClass}`} role={threadEntryRole} aria-live={threadEntryLive} aria-atomic="true" aria-labelledby="thread-entry-guidance-title" aria-describedby="thread-entry-guidance-description thread-entry-guidance-context">
      <p id="thread-entry-guidance-title" class="font-semibold">{threadEntryGuidanceTitle}</p>
      <p id="thread-entry-guidance-description" class="mt-1">{threadEntryGuidanceDescription}</p>
      <ul id="thread-entry-guidance-context" class="mt-3 grid gap-2 text-xs sm:grid-cols-3" aria-label="Checklist εισόδου thread">
        {threadEntryChecklist.map((item, index) => (
          <li class="flex items-start gap-2 rounded-lg border border-current/20 bg-white/80 px-3 py-2">
            <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-current/30 text-[11px] font-semibold">{index + 1}</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <a href={threadEntryPrimaryHref} class="thread-touch-target inline-flex rounded-lg border border-current/30 bg-white/85 px-3 py-1.5 text-xs font-semibold transition hover:bg-white">
          {threadEntryPrimaryLabel}
        </a>
        <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση επανάληψης φόρτωσης από τον οδηγό εισόδου thread." class="thread-touch-target inline-flex rounded-lg border border-current/30 bg-white/85 px-3 py-1.5 text-xs font-semibold transition hover:bg-white">
          Επαλήθευση φόρτωσης
        </a>
        <a href={threadListHref} data-thread-filter-action="Επιστροφή στο inbox από οδηγό εισόδου thread." class="thread-touch-target inline-flex rounded-lg border border-current/30 bg-white/85 px-3 py-1.5 text-xs font-semibold transition hover:bg-white">
          Πίσω στο inbox
        </a>
      </div>
    </section>

    <section class="thread-toast-stack" aria-label="Καταστάσεις συνομιλίας">
      {messageStatus === 'submitted' && (
        <div class="thread-toast thread-toast--emerald js-thread-toast" role="status" aria-live="polite" tabindex="-1" data-focus-on-load="true" data-autohide-ms="5600">
