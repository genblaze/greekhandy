              <p class="mt-1 text-[11px] text-slate-500">Reportable: {reportableIncomingCount}</p>
              {latestVisibleMessage && (
                <a href={latestVisibleMessageHref} class="mt-2 inline-flex rounded-md border border-indigo-300 bg-indigo-50 px-2 py-1 text-[11px] font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
                  Μετάβαση στο τελευταίο ορατό
                </a>
              )}
            </div>
          </div>
          <div class="thread-history-summary mt-3" role="status" aria-live="polite" aria-atomic="true">
            <p class="font-semibold text-slate-800">Ανάγνωση ιστορικού: {threadMessages.length} συνολικά</p>
            <p class="mt-0.5 text-slate-600">Moderation: {threadModerationLabel} · {moderationSeverityLabel}</p>
            <p class="mt-0.5 text-slate-600">Επόμενο triage: {triagePrimaryActionLabel}</p>
            <div class="mt-2 grid gap-2 text-[11px] sm:grid-cols-3">
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αποστολή</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationSendStateLabel}</p>
              </div>
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Ορατότητα</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationVisibilityStateLabel}</p>
              </div>
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αναφορές</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationReviewStateLabel}</p>
              </div>
            </div>
          </div>
          <div class="thread-history-legend mt-3 flex flex-wrap items-center gap-2 text-[11px]" aria-label="Υπόμνημα ιστορικού">
            <span class="rounded-full border border-slate-300 bg-slate-100 px-2.5 py-1 font-semibold text-slate-700">Εισερχόμενο</span>
            <span class="rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 font-semibold text-sky-900">Εξερχόμενο</span>
            <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 font-semibold text-orange-900">Περιορισμένη προβολή</span>
            <span class="rounded-full border border-indigo-300 bg-indigo-100 px-2.5 py-1 font-semibold text-indigo-900">Τελευταίο μήνυμα</span>
          </div>
          <p id="thread-history-state" class="sr-only" aria-live="polite" aria-atomic="true">{historyStateSummary}</p>
          <div class={`mt-3 rounded-xl border px-3 py-3 text-xs ${historyStateToneClass}`} role={historyStateAriaRole} aria-live={historyStateAriaLive} aria-atomic="true" aria-labelledby="thread-history-state-title" aria-describedby="thread-history-state-summary thread-history-state-support thread-history-state-recovery">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <p id="thread-history-state-title" class="font-semibold uppercase tracking-[0.1em] opacity-80">Κατάσταση ιστορικού</p>
              <p class="rounded-full border border-current/30 bg-white/70 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em]">Focus: {historyStateFocusLabel}</p>
            </div>
            <p class="mt-1 text-sm font-semibold">{historyStateTitle}</p>
            <p id="thread-history-state-summary" class="mt-1">{historyStateSummary}</p>
            <p id="thread-history-state-support" class="mt-1 text-[11px] font-medium opacity-90">{historyStateSupportHint}</p>
            <p id="thread-history-state-recovery" class="mt-1 text-[11px] opacity-90">{historyStateRecoveryHint}</p>
            {!showLoadingState && (
              <a href={historyStateActionHref} class="mt-2 inline-flex rounded-md border border-current/30 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white">
                {historyStateActionLabel}
              </a>
            )}
            {showLoadingState && <p class="mt-2 text-[11px] font-semibold uppercase tracking-[0.08em]">Αναμονή συγχρονισμού</p>}
          </div>

          <div class="mt-4 space-y-3" aria-describedby="thread-history-description" role="region" aria-label="Ροή ιστορικού και καταστάσεων thread">
            {showLoadingState && (
              <div class="rounded-xl border border-sky-200 bg-sky-50/80 px-4 py-3 text-xs text-sky-900" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-loading-title" aria-describedby="thread-history-loading-description">
                <p id="thread-history-loading-title" class="font-semibold">Το ιστορικό συγχρονίζεται αυτή τη στιγμή.</p>
                <p id="thread-history-loading-description" class="mt-1">Αν η φόρτωση παραμείνει στάσιμη, επαναφορτώστε το thread για νέα απόπειρα ανάκτησης.</p>
                <a href={threadViewHref} class="mt-2 inline-flex rounded-md border border-sky-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                  Επαναφόρτωση thread
                </a>
              </div>
            )}
            {showLoadingState && (
              <div class="space-y-3" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-skeleton-title" aria-describedby="thread-history-skeleton-description">
                <p id="thread-history-skeleton-title" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate-500">Προσωρινά μηνύματα φόρτωσης</p>
                <p id="thread-history-skeleton-description" class="text-xs text-slate-500">Τα placeholders θα αντικατασταθούν αυτόματα μόλις έρθει το ιστορικό.</p>
                {THREAD_LOADING_SKELETON_ROWS.map((item) => (
                  <article class="thread-loading-card rounded-2xl border border-slate-200 bg-white p-4 shadow-sm" aria-hidden="true">
                    <div class="h-3 w-24 rounded bg-slate-200"></div>
                    <div class="mt-3 h-3 w-full rounded bg-slate-100"></div>
                    <div class="mt-2 h-3 w-5/6 rounded bg-slate-100"></div>
                    <p class="mt-3 text-[11px] text-slate-400">Φόρτωση μηνύματος {item}...</p>
                  </article>
                ))}
              </div>
            )}

            {!showLoadingState && hasPartialThreadHistory && (
              <div class="rounded-2xl border border-amber-200 bg-amber-50/80 px-4 py-3 text-sm text-amber-900" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-partial-title" aria-describedby="thread-history-partial-description">
                <p id="thread-history-partial-title" class="font-semibold">Το ιστορικό φορτώθηκε μερικώς.</p>
                <p id="thread-history-partial-description" class="mt-1 text-xs">Ορισμένα μηνύματα ή moderation στοιχεία μπορεί να λείπουν μέχρι να ολοκληρωθεί επιτυχής επανάκτηση.</p>
                <a href={threadViewHref} class="mt-2 inline-flex rounded-md border border-amber-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-amber-900 transition hover:border-amber-400 hover:bg-amber-100">
                  Επανάληψη φόρτωσης ιστορικού
                </a>
              </div>
            )}

            {!showLoadingState && !threadLoadError && threadMessages.length === 0 && (
              <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 px-5 py-6 shadow-sm" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-empty-title" aria-describedby="thread-history-empty-description thread-history-empty-support">
                <p id="thread-history-empty-title" class="text-lg font-semibold text-slate-900">Δεν υπάρχουν μηνύματα ακόμη.</p>
                <p id="thread-history-empty-description" class="mt-1 text-sm text-slate-600">Στείλτε το πρώτο μήνυμα για να ξεκινήσει η συνομιλία.</p>
                <p id="thread-history-empty-support" class="mt-2 text-xs text-slate-500">Οι καταστάσεις αναφοράς, μπλοκαρίσματος και απόκρυψης εμφανίζονται αυτόματα όταν υπάρξει activity.</p>
                <p class={`mt-1 text-xs font-semibold ${canReply ? 'text-emerald-800' : 'text-amber-800'}`}>
                  {canReply ? 'Το composer είναι διαθέσιμο για το πρώτο μήνυμα.' : `Το composer δεν είναι διαθέσιμο: ${moderationSendStateLabel}.`}
                </p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <a href={threadListHref} class="inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Επιστροφή στη λίστα
                  </a>
                  <a href="#thread-interaction" class="inline-flex rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Μετάβαση στο composer
                  </a>
                </div>
              </div>
            )}
            {!showLoadingState && threadLoadError && threadMessages.length === 0 && (
              <div class="rounded-2xl border border-rose-200 bg-rose-50/80 px-5 py-6 text-rose-900 shadow-sm" role="alert" aria-live="assertive" aria-labelledby="thread-history-error-title" aria-describedby="thread-history-error-description">
                <p id="thread-history-error-title" class="text-lg font-semibold">Το ιστορικό δεν είναι διαθέσιμο αυτή τη στιγμή.</p>
                <p id="thread-history-error-description" class="mt-1 text-sm">Δεν ήταν δυνατή η ανάκτηση μηνυμάτων για το thread.</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <a href={threadViewHref} class="inline-flex rounded-lg border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:bg-rose-100">
                    Επανάληψη φόρτωσης
                  </a>
                  <a href={threadListHref} class="inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Πίσω στη λίστα
                  </a>
                </div>
              </div>
            )}

            {!showLoadingState && threadHistory.map((entry) => {
              if (entry.kind === 'day') {
                return (
                  <div class="thread-day-divider" role="separator" aria-label={`Ημερομηνία ${entry.dayLabel}`}>
                    <span>{entry.dayLabel}</span>
                  </div>
                );
              }

              const message = entry.message;
              const own = message.senderEmail.toLowerCase() === viewerEmail;
              const hidden = hiddenMessageIds.has(message.id);
              const messageIdToken = toDomId(message.id, `message-${message.submittedAt}`);
              const reasonId = `report-reason-${messageIdToken}`;
              const detailsId = `report-details-${messageIdToken}`;
              const reportHintId = `report-hint-${messageIdToken}`;
              const messageAnchorId = `message-${messageIdToken}`;
              const messageHeadingId = `message-heading-${messageIdToken}`;
              const messageMetaId = `message-meta-${messageIdToken}`;
              const messageStatusId = `message-status-${messageIdToken}`;
              const messageBodyId = `message-body-${messageIdToken}`;
              const messageDirectionId = `message-direction-${messageIdToken}`;
              const reportSummaryId = `report-summary-${messageIdToken}`;
              const isLatestMessage = latest?.id === message.id;
              const messageOrder = messageOrderById.get(message.id) ?? 0;
              const messageSenderLabel = own ? 'Εσείς' : (message.senderName || 'Συνεργάτης');
              const messageVisibilityLabel = hidden ? 'Περιορισμένη προβολή moderation' : 'Πλήρως ορατό μήνυμα';
              const messageDirectionLabel = own ? 'Εξερχόμενο μήνυμα' : 'Εισερχόμενο μήνυμα';
              const messageDirectionClass = own ? 'text-sky-700' : 'text-slate-600';
              const messageA11yLabel = `Μήνυμα ${messageOrder || 'χωρίς σειρά'} από ${threadMessages.length}, αποστολέας ${messageSenderLabel}. ${messageVisibilityLabel}.`;
              return (
                <div class={`flex ${own ? 'justify-end' : 'justify-start'}`} role="none">
                  <article
                    id={messageAnchorId}
                    role="article"
                    tabindex="-1"
                    aria-labelledby={messageHeadingId}
                    aria-describedby={`${messageMetaId} ${messageDirectionId} ${messageStatusId} ${messageBodyId}`}
                    aria-label={messageA11yLabel}
                    class={`thread-message w-full max-w-3xl ${
                    hidden
                      ? 'thread-message--hidden'
                      : own
                        ? 'thread-message--own'
                        : 'thread-message--incoming'
                  }`}
                  >
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div>
                        <h3 id={messageHeadingId} class="text-sm font-semibold text-slate-800">{messageSenderLabel}</h3>
                        <p id={messageMetaId} class="thread-message__meta mt-0.5 text-xs text-slate-500">
                          #{messageOrder || '–'} · <time datetime={message.submittedAt}>{formatDateTime(message.submittedAt)}</time>
                        </p>
                        <p id={messageDirectionId} class={`thread-message__direction mt-0.5 text-[11px] font-semibold ${messageDirectionClass}`}>{messageDirectionLabel}</p>
                        <div id={messageStatusId} class="thread-message__status mt-1 flex flex-wrap items-center gap-1.5 text-[11px]" role="status" aria-live="polite" aria-atomic="true">
                          <span class={`rounded-full border px-2 py-0.5 font-semibold ${
                            hidden
                              ? 'border-orange-300 bg-orange-100 text-orange-900'
                              : 'border-emerald-300 bg-emerald-100 text-emerald-900'
                          }`}>{messageVisibilityLabel}</span>
                          <span class={`rounded-full border px-2 py-0.5 font-semibold ${
                            own
                              ? 'border-sky-300 bg-sky-100 text-sky-900'
                              : 'border-slate-300 bg-slate-100 text-slate-700'
                          }`}>{own ? 'Εξερχόμενο' : 'Εισερχόμενο'}</span>
                        </div>
                      </div>
                      <div class="flex flex-wrap gap-1.5">
                        {isLatestMessage && <span class="rounded-full border border-indigo-300 bg-indigo-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900">Τελευταίο</span>}
                        <a href={`#${messageAnchorId}`} class="thread-message__anchor rounded-full border border-slate-300 bg-white px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-600 transition hover:border-slate-400 hover:bg-slate-50" aria-label={`Σύνδεσμος μηνύματος ${messageOrder || ''}`} aria-current={isLatestMessage ? 'location' : undefined}>
                          Σύνδεσμος
                        </a>
                        {hidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-orange-900">Κρυφό περιεχόμενο</span>}
                      </div>
                    </div>

                    <p id={messageBodyId} class={`thread-message__body mt-2 text-sm leading-7 ${hidden ? 'font-semibold text-orange-900' : 'whitespace-pre-wrap break-words text-slate-800'}`}>
                      {hidden ? 'Το μήνυμα έχει αποκρυφτεί από moderation.' : message.message}
                    </p>

                    {hidden && <p class="mt-2 rounded-lg border border-orange-200 bg-orange-50 px-2.5 py-2 text-xs font-semibold text-orange-900">Η προβολή του περιεχομένου είναι περιορισμένη από moderation. Το μήνυμα παραμένει διαθέσιμο μόνο ως metadata στο ιστορικό.</p>}

                    {!hidden && !own && (
                      <details class="thread-report mt-3 rounded-xl border border-amber-200 bg-gradient-to-br from-amber-50/80 to-white p-3" aria-labelledby={reportSummaryId}>
                        <summary id={reportSummaryId} class="cursor-pointer text-xs font-semibold text-amber-900">Αναφορά μηνύματος στη διαχείριση</summary>
                        <form
                          action="/api/messages/report"
                          method="POST"
                          class="js-pending-form mt-3 space-y-2"
                          data-pending-live-label="Η αναφορά υποβάλλεται."
                          data-pending-timeout-label="Η υποβολή αναφοράς καθυστέρησε. Ελέγξτε τη σύνδεση και δοκιμάστε ξανά."
                          data-pending-timeout-ms="16000"
                          aria-describedby={`${reportHintId} thread-submit-live`}
                        >
                          <input type="hidden" name="threadId" value={threadId} />
                          <input type="hidden" name="messageId" value={message.id} />
                          <input type="hidden" name="senderEmail" value={viewerEmail} />
                          <input type="hidden" name="returnTo" value={threadViewHref} />

                          <label class="block text-xs font-medium text-amber-900">
                            Αιτία αναφοράς
                            <select id={reasonId} name="reason" required class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800">
                              <option value="spam">Spam</option>
                              <option value="abuse">Κακοποίηση</option>
                              <option value="harassment">Παρενόχληση</option>
                              <option value="other" selected>Άλλο</option>
                            </select>
                          </label>

                          <label class="block text-xs font-medium text-amber-900">
                            Σχόλιο (προαιρετικό)
                            <input id={detailsId} type="text" name="details" maxlength="400" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800" placeholder="Περιγράψτε σύντομα το θέμα" aria-describedby={reportHintId} />
                          </label>

                          <p id={reportHintId} class="text-[11px] text-amber-900">Η αναφορά αποστέλλεται στη διαχείριση χωρίς να αλλάζει άμεσα η ροή της συνομιλίας.</p>
                          <button type="submit" data-default-label="Υποβολή αναφοράς" data-pending-label="Υποβολή..." class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-65">
                            Υποβολή αναφοράς
                          </button>
                        </form>
                      </details>
                    )}
                  </article>
                </div>
              );
            })}
          </div>
        </section>

        <section id="thread-interaction" class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_16px_42px_-30px_rgba(15,23,42,0.5)] md:p-6" aria-labelledby="thread-interaction-title" tabindex="-1">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 id="thread-interaction-title" class="text-lg font-semibold text-slate-900">Ενέργειες thread</h2>
              <p class="mt-1 text-sm text-slate-600">Composer αποστολής με ασφαλή pending states και έλεγχο σύνδεσης για αποφυγή άσκοπων retries.</p>
            </div>
            <span class={`rounded-full border px-2.5 py-1 text-[11px] font-semibold ${canReply ? 'border-emerald-300 bg-emerald-100 text-emerald-900' : 'border-amber-300 bg-amber-100 text-amber-900'}`}>
              {canReply ? 'Composer ενεργό' : 'Composer ανενεργό'}
            </span>
          </div>
          <p class="mt-3 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700">{moderationReplyGuidance}</p>
          <div class="mt-3 rounded-xl border border-sky-200 bg-sky-50/70 px-3 py-2 text-xs text-sky-900">
            <p class="font-semibold">Ιεραρχία ενεργειών</p>
            <p class="mt-1">Primary CTA: αποστολή απάντησης από τον composer. Secondary CTA: έλεγχος ιστορικού/αναφορών πριν από νέα αποστολή.</p>
          </div>
          <div class="thread-interaction-snapshot mt-3 grid gap-2 text-xs sm:grid-cols-3">
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αποστολή</p>
              <p class="mt-1 font-semibold text-slate-900">{moderationSendStateLabel}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Ορατότητα</p>
              <p class="mt-1 font-semibold text-slate-900">{moderationVisibilityStateLabel}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αναφορές</p>
              <p class="mt-1 font-semibold text-slate-900">{moderationReviewStateLabel}</p>
            </div>
          </div>

          {!canReply && threadBlockedByModeration && (
            <div class="thread-alert thread-alert--rose mt-4" role="alert">
              <p class="font-semibold">Το thread είναι περιορισμένο.</p>
              <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων έχει απενεργοποιηθεί από την ομάδα moderation.</p>
            </div>
          )}
          {!threadBlockedByModeration && threadMutedByModeration && (
            <div class="thread-alert thread-alert--orange mt-4" role="alert">
              <p class="font-semibold">Η συνομιλία βρίσκεται σε κατάσταση σίγασης.</p>
              <p class="mt-1 text-sm">Τα μηνύματα είναι κρυφά από moderation. Δεν μπορείτε να στείλετε νέο μήνυμα όσο ισχύει ο περιορισμός.</p>
            </div>
          )}
          {!canReply && !threadBlockedByModeration && !threadMutedByModeration && (
            <div class="thread-alert thread-alert--amber mt-4" role="alert">
              <p class="font-semibold">Δεν είναι διαθέσιμο το composer.</p>
