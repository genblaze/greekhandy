            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Ορατότητα</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">Ορατά {visibleMessagesCount} / Κρυφά {hiddenMessagesCount}</p>
              <p class="mt-0.5 text-xs text-slate-600">Σύνολο μηνυμάτων: {threadMessages.length}</p>
            </article>
            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Τελευταία δραστηριότητα</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">{latest ? formatDateTime(latest.submittedAt) : 'Δεν υπάρχει activity'}</p>
              <p class="mt-0.5 text-xs text-slate-600">Παραλήπτης απάντησης: {recipientForReply || 'Μη διαθέσιμος'}</p>
            </article>
          </div>

          <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50/80 px-3 py-2 text-xs text-slate-600">
            Ενέργειες moderation: <span class="font-semibold text-sky-800">αναφορά</span> · <span class="font-semibold text-rose-800">μπλοκάρισμα</span> · <span class="font-semibold text-orange-800">απόκρυψη</span>
          </div>
        </section>

        <section id="thread-history" class="mt-5 rounded-2xl border border-slate-200 bg-white/70 px-4 py-4 shadow-sm md:px-5" aria-labelledby="thread-history-title" aria-describedby="thread-history-description thread-history-state" aria-busy={showLoadingState ? 'true' : 'false'} tabindex="-1">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 id="thread-history-title" class="text-lg font-semibold text-slate-900">Ιστορικό μηνυμάτων</h2>
              <p id="thread-history-description" class="mt-1 text-sm text-slate-600">Προβολή όλων των μηνυμάτων του thread με άμεσες ενέργειες αναφοράς στα εισερχόμενα.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-right">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Ροή</p>
              <p class="mt-1 text-xs font-semibold text-slate-700">{threadHistoryMessageCountLabel}</p>
              <p class="mt-1 text-[11px] text-slate-500">Εισερχόμενα: {threadHistoryIncomingLabel} · Εξερχόμενα: {threadHistoryOutgoingLabel}</p>
              <p class="mt-1 text-[11px] text-slate-500">Reportable: {threadHistoryReportableLabel}</p>
              {threadHistoryVisibleMessage && (
                <a href={threadHistoryVisibleMessageHref} class="mt-2 inline-flex rounded-md border border-indigo-300 bg-indigo-50 px-2 py-1 text-[11px] font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
                  Μετάβαση στο τελευταίο ορατό
                </a>
              )}
            </div>
          </div>
          <form
            id="thread-filter-controls"
            class="mt-3 rounded-xl border border-slate-200 bg-white/95 px-3 py-3 shadow-sm"
            method="GET"
            action="/messages/thread"
            aria-labelledby="thread-filter-title"
            aria-describedby="thread-filter-help thread-filter-live"
            data-thread-filter-controls
          >
            <input type="hidden" name="threadId" value={threadId} />
            <input type="hidden" name="viewerEmail" value={viewerEmail} />
            {listSearchQueryRaw && <input type="hidden" name="listQ" value={listSearchQueryRaw} />}
            {listUnreadOnly && <input type="hidden" name="listUnread" value="1" />}
            {listBlockedOnly && <input type="hidden" name="listBlocked" value="1" />}
            {listReportedOnly && <input type="hidden" name="listReported" value="1" />}
            {listSortMode === 'unread' && <input type="hidden" name="listSort" value="unread" />}
            <div class="flex flex-wrap items-end justify-between gap-3">
              <div class="min-w-[16rem] flex-1">
                <p id="thread-filter-title" class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Αναζήτηση στο thread</p>
                <label for="thread-filter-query" class="sr-only">Αναζήτηση σε σώμα μηνύματος, αποστολέα ή email</label>
                  <input
                    id="thread-filter-query"
                    name="q"
                  type="search"
                  value={threadSearchQueryRaw}
                  maxlength="200"
                  inputmode="search"
                  autocomplete="off"
                  class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900"
                  placeholder="Αναζήτηση σε σώμα μηνύματος, αποστολέα ή email"
                    aria-label="Αναζήτηση σε μηνύματα thread"
                    aria-keyshortcuts="Slash Escape"
                  />
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <button type="submit" data-thread-filter-action="Εφαρμογή φίλτρων thread." class="thread-touch-target inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Εφαρμογή φίλτρων
                  </button>
                  <a href={threadFilterResetHref} data-thread-filter-action="Καθαρισμός φίλτρων thread." class="thread-touch-target inline-flex rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
                    Καθαρισμός
                  </a>
                </div>
              </div>
            <fieldset class="mt-3">
              <legend class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Κατάσταση μηνυμάτων</legend>
              <div class="mt-2 flex flex-wrap gap-2" role="radiogroup" aria-label="Επιλογή ορατότητας μηνυμάτων thread">
                {threadFilterChips.map((chip) => (
                  <label class={`thread-filter-chip ${threadVisibilityFilter === chip.value ? 'thread-filter-chip--active' : ''}`}>
                    <input
                      type="radio"
                      name="visibility"
                      value={chip.value}
                      checked={threadVisibilityFilter === chip.value}
                      class="thread-filter-chip__input"
                    />
                    <span class="thread-filter-chip__label">{chip.label} <span aria-hidden="true">({chip.count})</span></span>
                  </label>
                ))}
              </div>
            </fieldset>
            <p id="thread-filter-help" class="mt-2 text-[11px] text-slate-500">
              Συντόμευση πληκτρολογίου: πατήστε <span class="font-semibold text-slate-700">/</span> για εστίαση στην αναζήτηση και <span class="font-semibold text-slate-700">Esc</span> για καθαρισμό.
            </p>
            <p class="mt-1 text-[11px] text-slate-500">{threadFilterScopeLabel}</p>
          </form>
          <div class="thread-history-summary mt-3" role="status" aria-live="polite" aria-atomic="true">
            <p class="font-semibold text-slate-800">Ανάγνωση ιστορικού: {hasThreadFilters ? `${filteredThreadMessages.length}/${threadMessages.length}` : threadMessages.length} μηνύματα</p>
            <p class="mt-0.5 text-slate-600">Moderation: {threadModerationLabel} · {moderationSeverityLabel}</p>
            <p class="mt-0.5 text-slate-600">Επόμενο triage: {triagePrimaryActionLabel}</p>
            <p class="mt-0.5 text-slate-600">Φίλτρο: {threadVisibilityFilterLabel}{threadSearchQueryRaw ? ` · Αναζήτηση: "${threadSearchQueryRaw}"` : ''}</p>
            <div class="mt-2 grid gap-2 text-[11px] sm:grid-cols-3">
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αποστολή</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationSendStateLabel}</p>
              </div>
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Ορατότητα</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationVisibilityStateLabel}</p>
              </div>
              <div class="rounded-md border border-slate-200 bg-white/90 px-2.5 py-1.5">
                <p class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αναφορές</p>
                <p class="mt-0.5 font-semibold text-slate-800">{moderationReviewStateLabel}</p>
              </div>
            </div>
          </div>
          <div class="thread-history-legend mt-3 flex flex-wrap items-center gap-2 text-[11px]" aria-label="Υπόμνημα ιστορικού">
            <span class="rounded-full border border-slate-300 bg-slate-100 px-2.5 py-1 font-semibold text-slate-700">Εισερχόμενο</span>
            <span class="rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 font-semibold text-sky-900">Εξερχόμενο</span>
            <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 font-semibold text-orange-900">Περιορισμένη προβολή</span>
            <span class="rounded-full border border-indigo-300 bg-indigo-100 px-2.5 py-1 font-semibold text-indigo-900">Τελευταίο μήνυμα</span>
          </div>
          <p id="thread-history-state" class="sr-only" aria-live="polite" aria-atomic="true">{historyStateSummary}</p>
          <div class={`mt-3 rounded-xl border px-3 py-3 text-xs ${historyStateToneClass}`} role={historyStateAriaRole} aria-live={historyStateAriaLive} aria-atomic="true" aria-labelledby="thread-history-state-title" aria-describedby="thread-history-state-summary thread-history-state-support thread-history-state-recovery">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <p id="thread-history-state-title" class="font-semibold uppercase tracking-[0.1em] opacity-80">Κατάσταση προβολής</p>
              <div class="flex flex-wrap items-center gap-1.5">
                <p class={`rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em] ${historyStatePhaseClass}`}>{historyStatePhaseLabel}</p>
                <p class="rounded-full border border-current/30 bg-white/70 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em]">Focus: {historyStateFocusLabel}</p>
              </div>
            </div>
            <p class="mt-1 text-sm font-semibold">{historyStateTitle}</p>
            <p id="thread-history-state-summary" class="mt-1">{historyStateSummary}</p>
            <p id="thread-history-state-support" class="mt-1 text-[11px] font-medium opacity-90">{historyStateSupportHint}</p>
            <p class="mt-1 text-[11px] font-medium opacity-90">{threadFilterScopeLabel}</p>
            <p id="thread-history-state-recovery" class="mt-1 text-[11px] opacity-90">{historyStateRecoveryHint}</p>
            <div class="thread-state-actions" role="group" aria-label="Ενέργειες αξιοπιστίας ιστορικού">
              <a href={threadRetryHref} data-thread-retry-now aria-keyshortcuts="R" data-thread-filter-action="Εκκίνηση άμεσης επανάληψης φόρτωσης ιστορικού thread." class="thread-touch-target inline-flex rounded-md border border-current/30 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white">
                Επανάληψη τώρα
              </a>
              {!showLoadingState && historyStateActionHref !== threadRetryHref && (
                <a href={historyStateActionHref} data-thread-filter-action={historyStateActionLabel} class="thread-touch-target inline-flex rounded-md border border-current/30 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white">
                  {historyStateActionLabel}
                </a>
              )}
              {hasThreadFilters && historyStateActionHref !== threadFilterResetHref && (
                <a href={threadFilterResetHref} data-thread-filter-action="Καθαρισμός φίλτρων thread από κάρτα κατάστασης." class="thread-touch-target inline-flex rounded-md border border-current/30 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white">
                  Καθαρισμός φίλτρων
                </a>
              )}
            </div>
            {showLoadingState && <p class="mt-1 text-[11px] font-semibold uppercase tracking-[0.08em]">Αναμονή συγχρονισμού</p>}
          </div>

          <div class="mt-4 space-y-3" aria-describedby="thread-history-description" role="region" aria-label="Ροή ιστορικού και καταστάσεων thread">
            {showLoadingState && (
              <div class="rounded-xl border border-sky-200 bg-sky-50/80 px-4 py-3 text-xs text-sky-900" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-loading-title" aria-describedby="thread-history-loading-description">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-sky-800">Κατάσταση προβολής · Loading</p>
                <p id="thread-history-loading-title" class="font-semibold">Το ιστορικό συγχρονίζεται αυτή τη στιγμή.</p>
                <p id="thread-history-loading-description" class="mt-1">Αν η φόρτωση παραμείνει στάσιμη, επαναφορτώστε το thread για νέα απόπειρα ανάκτησης.</p>
                <p class="mt-1 text-[11px] font-medium">{threadFilterScopeLabel}</p>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                  <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση άμεσης επανάληψης φόρτωσης κατά την κατάσταση loading." class="thread-touch-target inline-flex rounded-md border border-sky-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Επανάληψη τώρα
                  </a>
                  <a href="#thread-entry-guidance" data-thread-filter-action="Μετάβαση στον οδηγό εισόδου thread από loading κατάσταση." class="thread-touch-target inline-flex rounded-md border border-slate-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Οδηγός εισόδου
                  </a>
                </div>
              </div>
            )}
            {showLoadingState && (
              <div class="space-y-3" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-skeleton-title" aria-describedby="thread-history-skeleton-description">
                <p id="thread-history-skeleton-title" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-slate-500">Προσωρινά μηνύματα φόρτωσης</p>
                <p id="thread-history-skeleton-description" class="text-xs text-slate-500">Τα placeholders θα αντικατασταθούν αυτόματα μόλις έρθει το ιστορικό.</p>
                {THREAD_LOADING_SKELETON_ROWS.map((item) => (
                  <article class="thread-loading-card rounded-2xl border border-slate-200 bg-white p-4 shadow-sm" aria-hidden="true">
                    <div class="h-3 w-24 rounded bg-slate-200"></div>
                    <div class="mt-3 h-3 w-full rounded bg-slate-100"></div>
                    <div class="mt-2 h-3 w-5/6 rounded bg-slate-100"></div>
                    <p class="mt-3 text-[11px] text-slate-400">Φόρτωση μηνύματος {item}...</p>
                  </article>
                ))}
              </div>
            )}

            {!showLoadingState && hasPartialThreadHistory && (
              <div class="rounded-2xl border border-amber-200 bg-amber-50/80 px-4 py-3 text-sm text-amber-900" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-partial-title" aria-describedby="thread-history-partial-description">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-amber-800">Κατάσταση προβολής · Partial</p>
                <p id="thread-history-partial-title" class="font-semibold">Το ιστορικό φορτώθηκε μερικώς.</p>
                <p id="thread-history-partial-description" class="mt-1 text-xs">Ορισμένα μηνύματα ή moderation στοιχεία μπορεί να λείπουν μέχρι να ολοκληρωθεί επιτυχής επανάκτηση.</p>
                <p class="mt-1 text-[11px] font-medium">{threadFilterScopeLabel}</p>
                <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση άμεσης επανάληψης φόρτωσης thread μετά από μερικό αποτέλεσμα." class="thread-touch-target mt-2 inline-flex rounded-md border border-amber-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-amber-900 transition hover:border-amber-400 hover:bg-amber-100">
                  Επανάληψη φόρτωσης ιστορικού
                </a>
              </div>
            )}

            {!showLoadingState && !threadLoadError && threadMessages.length === 0 && (
              <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 px-5 py-6 shadow-sm" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-empty-title" aria-describedby="thread-history-empty-description thread-history-empty-support">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Κατάσταση προβολής · Empty</p>
                <p id="thread-history-empty-title" class="text-lg font-semibold text-slate-900">Δεν υπάρχουν μηνύματα ακόμη.</p>
                <p id="thread-history-empty-description" class="mt-1 text-sm text-slate-600">Στείλτε το πρώτο μήνυμα για να ξεκινήσει η συνομιλία.</p>
                <p id="thread-history-empty-support" class="mt-2 text-xs text-slate-500">Οι καταστάσεις αναφοράς, μπλοκαρίσματος και απόκρυψης εμφανίζονται αυτόματα όταν υπάρξει activity.</p>
                <p class={`mt-1 text-xs font-semibold ${canReply ? 'text-emerald-800' : 'text-amber-800'}`}>
                  {canReply ? 'Το composer είναι διαθέσιμο για το πρώτο μήνυμα.' : `Το composer δεν είναι διαθέσιμο: ${moderationSendStateLabel}.`}
                </p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση ανανέωσης thread από empty state." class="thread-touch-target inline-flex rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Ανανέωση thread
                  </a>
                  <a href="#thread-entry-guidance" data-thread-filter-action="Μετάβαση στον οδηγό εισόδου thread από empty κατάσταση." class="thread-touch-target inline-flex rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
                    Οδηγός εισόδου
                  </a>
                  <a href={threadListHref} data-thread-filter-action="Επιστροφή στη λίστα συνομιλιών." class="thread-touch-target inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Επιστροφή στη λίστα
                  </a>
                  <a href="#thread-interaction" data-thread-filter-action="Μετάβαση στις ενέργειες thread από empty state." class="thread-touch-target inline-flex rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Μετάβαση στο composer
                  </a>
                </div>
              </div>
            )}
            {!showLoadingState && showHistoryNoMatchState && (
              <div class="rounded-2xl border border-amber-200 bg-amber-50/80 px-5 py-6 text-amber-900 shadow-sm" role="status" aria-live="polite" aria-atomic="true" aria-labelledby="thread-history-no-match-title" aria-describedby="thread-history-no-match-description">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-amber-800">Κατάσταση προβολής · Filtered</p>
                <p id="thread-history-no-match-title" class="text-lg font-semibold">Δεν βρέθηκαν μηνύματα με αυτά τα φίλτρα.</p>
                <p id="thread-history-no-match-description" class="mt-1 text-sm">
                  Scope: <span class="font-semibold">{threadVisibilityFilterLabel}</span>{threadSearchQueryRaw ? <> · Αναζήτηση: <span class="font-semibold">"{threadSearchQueryRaw}"</span></> : ''}.
                </p>
                <p class="mt-1 text-[11px] font-medium">{threadFilterScopeLabel}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση άμεσης επανάληψης φόρτωσης με τα τρέχοντα φίλτρα thread." class="thread-touch-target inline-flex rounded-lg border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Επανάληψη τώρα
                  </a>
                  <a href={threadFilterResetHref} data-thread-filter-action="Καθαρισμός φίλτρων για εμφάνιση όλων των μηνυμάτων." class="thread-touch-target inline-flex rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:border-amber-400 hover:bg-amber-100">
                    Καθαρισμός φίλτρων
                  </a>
                  <a href="#thread-filter-controls" data-thread-filter-action="Μεταφορά στα φίλτρα thread για νέα αναζήτηση." class="thread-touch-target inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Επιστροφή στα φίλτρα
                  </a>
                </div>
              </div>
            )}
            {!showLoadingState && threadLoadError && threadMessages.length === 0 && (
              <div class="rounded-2xl border border-rose-200 bg-rose-50/80 px-5 py-6 text-rose-900 shadow-sm" role="alert" aria-live="assertive" aria-labelledby="thread-history-error-title" aria-describedby="thread-history-error-description">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-rose-700">Κατάσταση προβολής · Προσωρινή δυσκολία</p>
                <p id="thread-history-error-title" class="text-lg font-semibold">Το ιστορικό δεν είναι διαθέσιμο αυτή τη στιγμή.</p>
                <p id="thread-history-error-description" class="mt-1 text-sm">Δεν ήταν δυνατή η ανάκτηση μηνυμάτων για το thread.</p>
                <p class="mt-1 text-[11px] font-medium">{threadFilterScopeLabel}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <a href={threadRetryHref} data-thread-retry-now data-thread-filter-action="Εκκίνηση άμεσης επανάληψης φόρτωσης ιστορικού μετά από σφάλμα." class="thread-touch-target inline-flex rounded-lg border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:bg-rose-100">
                    Επανάληψη φόρτωσης
                  </a>
                  <a href="#thread-entry-guidance" data-thread-filter-action="Μετάβαση στον οδηγό εισόδου thread μετά από σφάλμα ιστορικού." class="thread-touch-target inline-flex rounded-lg border border-amber-300 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:border-amber-400 hover:bg-amber-100">
                    Οδηγός εισόδου
                  </a>
                  <a href={threadListHref} data-thread-filter-action="Επιστροφή στη λίστα συνομιλιών." class="thread-touch-target inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                    Πίσω στη λίστα
                  </a>
                </div>
              </div>
            )}

            {!showLoadingState && filteredThreadHistory.map((entry) => {
              if (entry.kind === 'day') {
                return (
                  <div class="thread-day-divider" role="separator" aria-label={`Ημερομηνία ${entry.dayLabel}`}>
                    <span>{entry.dayLabel}</span>
                  </div>
                );
              }

              const message = entry.message;
              const own = message.senderEmail.toLowerCase() === viewerEmail;
              const hidden = hiddenMessageIds.has(message.id);
              const messageIdToken = toDomId(message.id, `message-${message.submittedAt}`);
              const reasonId = `report-reason-${messageIdToken}`;
              const detailsId = `report-details-${messageIdToken}`;
              const reportHintId = `report-hint-${messageIdToken}`;
              const messageAnchorId = `message-${messageIdToken}`;
              const messageHeadingId = `message-heading-${messageIdToken}`;
              const messageMetaId = `message-meta-${messageIdToken}`;
              const messageStatusId = `message-status-${messageIdToken}`;
              const messageBodyId = `message-body-${messageIdToken}`;
              const messageDirectionId = `message-direction-${messageIdToken}`;
              const reportSummaryId = `report-summary-${messageIdToken}`;
              const reportFeedbackId = `report-feedback-${messageIdToken}`;
              const isLatestMessage = latestHistoryMessage?.id === message.id;
              const messageOrder = messageOrderById.get(message.id) ?? 0;
              const messageSenderLabel = own ? 'Εσείς' : (message.senderName || 'Συνεργάτης');
              const messageVisibilityLabel = hidden ? 'Περιορισμένη προβολή moderation' : 'Πλήρως ορατό μήνυμα';
              const messageDirectionLabel = own ? 'Εξερχόμενο μήνυμα' : 'Εισερχόμενο μήνυμα';
              const messageDirectionClass = own ? 'text-sky-700' : 'text-slate-600';
              const messageA11yLabel = `Μήνυμα ${messageOrder || 'χωρίς σειρά'} από ${threadMessages.length}, αποστολέας ${messageSenderLabel}. ${messageVisibilityLabel}.${hasThreadFilters ? ` Προβάλλεται σε φιλτραρισμένη λίστα (${filteredThreadMessages.length}/${threadMessages.length}).` : ''}`;
              return (
                <div class={`flex ${own ? 'justify-end' : 'justify-start'}`} role="none">
                  <article
                    id={messageAnchorId}
                    role="article"
                    tabindex="-1"
                    aria-labelledby={messageHeadingId}
                    aria-describedby={`${messageMetaId} ${messageDirectionId} ${messageStatusId} ${messageBodyId}`}
                    aria-label={messageA11yLabel}
                    class={`thread-message w-full max-w-3xl ${
                    hidden
                      ? 'thread-message--hidden'
                      : own
                        ? 'thread-message--own'
                        : 'thread-message--incoming'
                  }`}
                  >
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div>
                        <h3 id={messageHeadingId} class="text-sm font-semibold text-slate-800">{messageSenderLabel}</h3>
                        <p id={messageMetaId} class="thread-message__meta mt-0.5 text-xs text-slate-500">
                          #{messageOrder || '–'} · <time datetime={message.submittedAt}>{formatDateTime(message.submittedAt)}</time>
                        </p>
                        <p id={messageDirectionId} class={`thread-message__direction mt-0.5 text-[11px] font-semibold ${messageDirectionClass}`}>{messageDirectionLabel}</p>
                        <div id={messageStatusId} class="thread-message__status mt-1 flex flex-wrap items-center gap-1.5 text-[11px]" role="status" aria-live="polite" aria-atomic="true">
                          <span class={`rounded-full border px-2 py-0.5 font-semibold ${
                            hidden
                              ? 'border-orange-300 bg-orange-100 text-orange-900'
                              : 'border-emerald-300 bg-emerald-100 text-emerald-900'
                          }`}>{messageVisibilityLabel}</span>
                          <span class={`rounded-full border px-2 py-0.5 font-semibold ${
                            own
                              ? 'border-sky-300 bg-sky-100 text-sky-900'
                              : 'border-slate-300 bg-slate-100 text-slate-700'
                          }`}>{own ? 'Εξερχόμενο' : 'Εισερχόμενο'}</span>
                        </div>
                      </div>
                      <div class="flex flex-wrap gap-1.5">
                        {isLatestMessage && <span class="rounded-full border border-indigo-300 bg-indigo-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900">Τελευταίο</span>}
                        <a href={`#${messageAnchorId}`} class="thread-message__anchor rounded-full border border-slate-300 bg-white px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-600 transition hover:border-slate-400 hover:bg-slate-50" aria-label={`Σύνδεσμος μηνύματος ${messageOrder || ''}`} aria-current={isLatestMessage ? 'location' : undefined}>
                          Σύνδεσμος
                        </a>
                        {hidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-orange-900">Κρυφό περιεχόμενο</span>}
                      </div>
                    </div>

                    <p id={messageBodyId} class={`thread-message__body mt-2 text-sm leading-7 ${hidden ? 'font-semibold text-orange-900' : 'whitespace-pre-wrap break-words text-slate-800'}`}>
                      {hidden ? 'Το μήνυμα έχει αποκρυφτεί από moderation.' : message.message}
                    </p>

                    {hidden && <p class="mt-2 rounded-lg border border-orange-200 bg-orange-50 px-2.5 py-2 text-xs font-semibold text-orange-900">Η προβολή του περιεχομένου είναι περιορισμένη από moderation. Το μήνυμα παραμένει διαθέσιμο μόνο ως metadata στο ιστορικό.</p>}

                    {!hidden && !own && (
                      <details class="thread-report mt-3 rounded-xl border border-amber-200 bg-gradient-to-br from-amber-50/80 to-white p-3" aria-labelledby={reportSummaryId}>
                        <summary id={reportSummaryId} class="cursor-pointer text-xs font-semibold text-amber-900">Αναφορά μηνύματος στη διαχείριση</summary>
                        <form
                          action="/api/messages/report"
                          method="POST"
                          class="js-pending-form mt-3 space-y-2"
                          data-pending-live-label="Η αναφορά υποβάλλεται."
                          data-pending-timeout-label="Η υποβολή αναφοράς καθυστέρησε. Ελέγξτε τη σύνδεση και δοκιμάστε ξανά."
                          data-pending-idle-label="Έτοιμη αναφορά για υποβολή."
                          data-pending-recovery-label="Η φόρμα αναφοράς επανήλθε. Μπορείτε να δοκιμάσετε ξανά."
                          data-pending-timeout-ms="16000"
                          aria-describedby={`${reportHintId} ${reportFeedbackId} thread-submit-live`}
                        >
                          <input type="hidden" name="threadId" value={threadId} />
                          <input type="hidden" name="messageId" value={message.id} />
                          <input type="hidden" name="senderEmail" value={viewerEmail} />
                          <input type="hidden" name="returnTo" value={threadViewHref} />

                          <label class="block text-xs font-medium text-amber-900">
                            Αιτία αναφοράς
                            <select id={reasonId} name="reason" required class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800">
                              <option value="spam">Spam</option>
                              <option value="abuse">Κακοποίηση</option>
                              <option value="harassment">Παρενόχληση</option>
                              <option value="other" selected>Άλλο</option>
                            </select>
                          </label>

                          <label class="block text-xs font-medium text-amber-900">
                            Σχόλιο (προαιρετικό)
                            <input id={detailsId} type="text" name="details" maxlength="400" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800" placeholder="Περιγράψτε σύντομα το θέμα" aria-describedby={reportHintId} />
                          </label>

                          <p id={reportHintId} class="text-[11px] text-amber-900">Η αναφορά αποστέλλεται στη διαχείριση χωρίς να αλλάζει άμεσα η ροή της συνομιλίας.</p>
                          <button type="submit" data-default-label="Υποβολή αναφοράς" data-pending-label="Υποβολή..." class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-65">
                            Υποβολή αναφοράς
                          </button>
                          <p id={reportFeedbackId} data-form-feedback class="text-[11px] text-amber-900" role="status" aria-live="polite" aria-atomic="true">Έτοιμη αναφορά για υποβολή.</p>
                        </form>
                      </details>
                    )}
                  </article>
                </div>
              );
            })}
          </div>
        </section>

        <section id="thread-interaction" class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_16px_42px_-30px_rgba(15,23,42,0.5)] md:p-6" aria-labelledby="thread-interaction-title" tabindex="-1">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 id="thread-interaction-title" class="text-lg font-semibold text-slate-900">Ενέργειες thread</h2>
                  <p class="mt-1 text-sm text-slate-600">Φόρμα αποστολής με ασφαλείς ενδείξεις υποβολής και έλεγχο σύνδεσης για αποφυγή άσκοπων επαναλήψεων.</p>
                </div>
                <span class={`rounded-full border px-2.5 py-1 text-[11px] font-semibold ${canReply ? 'border-emerald-300 bg-emerald-100 text-emerald-900' : 'border-amber-300 bg-amber-100 text-amber-900'}`}>
              {canReply ? 'Απάντηση ενεργή' : 'Απάντηση ανενεργή'}
            </span>
          </div>
          <p class="mt-3 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700">{moderationReplyGuidance}</p>
          <div class="mt-3 rounded-xl border border-sky-200 bg-sky-50/70 px-3 py-2 text-xs text-sky-900">
            <p class="font-semibold">Ιεραρχία ενεργειών</p>
            <p class="mt-1">Κύρια ενέργεια: αποστολή απάντησης από τη φόρμα. Δευτερεύουσα ενέργεια: έλεγχος ιστορικού/αναφορών πριν από νέα αποστολή.</p>
          </div>
          <dl class="thread-interaction-snapshot mt-3 grid gap-2 text-xs sm:grid-cols-3" aria-label="Τρέχουσα κατάσταση moderation για ενέργειες">
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <dt class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αποστολή</dt>
              <dd class="mt-1 font-semibold text-slate-900">{moderationSendStateLabel}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <dt class="font-semibold uppercase tracking-[0.08em] text-slate-500">Ορατότητα</dt>
              <dd class="mt-1 font-semibold text-slate-900">{moderationVisibilityStateLabel}</dd>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white px-3 py-2">
              <dt class="font-semibold uppercase tracking-[0.08em] text-slate-500">Αναφορές</dt>
              <dd class="mt-1 font-semibold text-slate-900">{moderationReviewStateLabel}</dd>
            </div>
          </dl>

          {!canReply && threadBlockedByModeration && (
            <div class="thread-alert thread-alert--rose mt-4" role="alert">
              <p class="font-semibold">Το thread είναι περιορισμένο.</p>
              <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων έχει απενεργοποιηθεί από την ομάδα moderation.</p>
            </div>
          )}
          {!threadBlockedByModeration && threadMutedByModeration && (
            <div class="thread-alert thread-alert--orange mt-4" role="alert">
              <p class="font-semibold">Η συνομιλία βρίσκεται σε κατάσταση σίγασης.</p>
              <p class="mt-1 text-sm">Τα μηνύματα είναι κρυφά από moderation. Δεν μπορείτε να στείλετε νέο μήνυμα όσο ισχύει ο περιορισμός.</p>
            </div>
          )}
          {!canReply && !threadBlockedByModeration && !threadMutedByModeration && (
            <div class="thread-alert thread-alert--amber mt-4" role="alert">
              <p class="font-semibold">Η φόρμα απάντησης δεν είναι διαθέσιμη.</p>
              <p class="mt-1 text-sm">Ελέγξτε ότι υπάρχει έγκυρος παραλήπτης και ότι το thread είναι ενεργό.</p>
            </div>
          )}

          {canReply && (
            <form
              id="thread-composer"
              action="/api/messages/submit"
              method="POST"
              class="js-pending-form js-composer-form mt-4 rounded-2xl border border-sky-200 bg-gradient-to-br from-sky-50 to-white p-5 shadow-[0_16px_42px_-30px_rgba(14,116,144,0.45)]"
              data-composer-state={composerInitialState}
              data-focus-composer={messageStatus === 'invalid' || messageStatus === 'error' ? 'true' : 'false'}
              data-composer-draft-key={composerDraftStorageKey}
              data-composer-thread-id={threadId}
              data-composer-viewer-email={viewerEmail}
              data-clear-composer-draft-on-load={shouldClearComposerDraftOnLoad ? 'true' : 'false'}
              data-pending-live-label="Η αποστολή μηνύματος εκτελείται."
              data-pending-timeout-label="Η αποστολή καθυστέρησε. Ελέγξτε το δίκτυο και δοκιμάστε ξανά."
              data-pending-idle-label="Η φόρμα απάντησης είναι έτοιμη."
              data-pending-recovery-label="Η αποστολή επανήλθε. Ελέγξτε το μήνυμα και προσπαθήστε ξανά."
              data-pending-timeout-ms="18000"
              aria-labelledby="thread-composer-title"
              aria-describedby={composerAriaDescribedBy}
            >
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 id="thread-composer-title" class="text-lg font-semibold text-slate-900">Φόρμα απάντησης</h3>
                  <p id="thread-composer-description" class="mt-1 text-sm text-slate-600">Απάντηση μέσα στο ίδιο thread με αυτόματη ενημέρωση στη λίστα συνομιλιών.</p>
                </div>
                <span id="composer-state" class={`inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold ${
                  composerInitialState === 'success'
                    ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
                    : composerInitialState === 'error'
                      ? 'border-rose-300 bg-rose-100 text-rose-900'
                      : 'border-sky-300 bg-sky-100 text-sky-900'
                }`} role="status" aria-live="polite">
                  {composerInitialStateLabel}
                </span>
              </div>
              {hasFailedSendStatus && (
                <div id="composer-retry-panel" class={`mt-3 rounded-xl border px-3 py-3 text-xs ${composerRetryPanelToneClass}`} role="status" aria-live="polite" aria-atomic="true">
                  <p class="font-semibold">{composerRetryPanelTitle}</p>
                  <p class="mt-1">{composerRetryPanelDescription}</p>
                  <p class="mt-1 text-[11px] font-medium">Το πρόχειρο αποθηκεύεται αυτόματα ανά thread και επαναφέρεται μετά από ανανέωση.</p>
                  <p id="composer-retry-actions-hint" class="mt-1 text-[11px]">Η επανάληψη χρησιμοποιεί το τρέχον κείμενο ή το αποθηκευμένο πρόχειρο αν το πεδίο είναι κενό.</p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <button
                      type="button"
                      data-retry-send
                      aria-controls="composer-message"
                      aria-describedby="composer-retry-actions-hint composer-submit-live"
                      class="thread-touch-target inline-flex rounded-md border border-current/40 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white"
                    >
                      Επανάληψη αποστολής
                    </button>
                    <button
                      type="button"
                      data-restore-draft
                      aria-controls="composer-message"
                      aria-describedby="composer-retry-actions-hint composer-submit-live"
                      class="thread-touch-target inline-flex rounded-md border border-current/40 bg-white/80 px-2.5 py-1 text-[11px] font-semibold transition hover:bg-white"
                    >
                      Επαναφορά πρόχειρου
                    </button>
                  </div>
                </div>
              )}
              <input type="hidden" name="professionalSlug" value={professionalSlug} />
              <input type="hidden" name="threadId" value={threadId} />
              <input type="hidden" name="senderName" value="Participant" />
              <input type="hidden" name="senderEmail" value={viewerEmail} />
              <input type="hidden" name="recipientEmail" value={recipientForReply} />
              <input type="hidden" name="returnTo" value={threadViewHref} />
              <label for="composer-message" class="mt-3 block text-xs font-semibold uppercase tracking-[0.12em] text-slate-600">Κείμενο απάντησης</label>
              <textarea
                id="composer-message"
                name="message"
                rows="4"
                required
                maxlength="2000"
                minlength="1"
                aria-describedby={composerAriaDescribedBy}
                aria-keyshortcuts="Control+Enter Meta+Enter"
                aria-invalid="false"
                class="mt-3 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm leading-6 text-slate-900 focus:border-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-100"
                placeholder="Γράψτε το μήνυμά σας"
                spellcheck="true"
              ></textarea>
              <p id="composer-shortcuts" class="mt-2 text-xs text-slate-500">Συντόμευση πληκτρολογίου: <span class="font-semibold text-slate-700">Ctrl+Enter</span> (ή <span class="font-semibold text-slate-700">Cmd+Enter</span> σε Mac) για αποστολή.</p>
              <div class="mt-2 flex items-center justify-between text-xs">
                <p id="composer-error" class="hidden font-medium text-rose-700" role="alert">Το μήνυμα δεν μπορεί να είναι κενό.</p>
                <p id="composer-count" class="text-slate-500">0 / 2000</p>
              </div>
              <p id="composer-live" class="mt-1 text-xs font-medium text-slate-600" aria-live="polite" aria-atomic="true"></p>
              <p id="composer-submit-live" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
              <button type="submit" data-default-label="Αποστολή" data-pending-label="Αποστολή..." disabled class="thread-touch-target mt-3 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:opacity-65">Αποστολή</button>
              <p id="composer-feedback" data-form-feedback class="mt-2 text-[11px] text-slate-600" role="status" aria-live="polite" aria-atomic="true">Η φόρμα απάντησης είναι έτοιμη.</p>
            </form>
          )}
        </section>
      </>
    )}
  </main>

  <style>
    .thread-skip-link {
      position: absolute;
      left: 1rem;
      top: 0.35rem;
      z-index: 80;
      transform: translateY(-160%);
      border-radius: 9999px;
      border: 1px solid rgb(14 116 144);
      background: rgb(255 255 255);
      padding: 0.4rem 0.7rem;
      font-size: 0.72rem;
      font-weight: 700;
      color: rgb(12 74 110);
      box-shadow: 0 8px 18px -12px rgba(15, 23, 42, 0.6);
      transition: transform 140ms ease;
    }

    .thread-skip-link:focus-visible {
      transform: translateY(0);
    }

    .thread-skip-link--history {
      top: 0.35rem;
    }

    .thread-skip-link--moderation {
      top: 2.45rem;
    }

    .thread-skip-link--interaction {
      top: 4.55rem;
    }

    .thread-shell {
      position: relative;
      isolation: isolate;
    }

    .thread-shell::before {
      content: '';
      position: absolute;
      inset: 2rem -1rem auto -1rem;
      height: 12rem;
      background:
        radial-gradient(circle at 12% 28%, rgba(14, 116, 144, 0.13) 0, transparent 56%),
        radial-gradient(circle at 88% 18%, rgba(245, 158, 11, 0.14) 0, transparent 52%);
      z-index: -1;
      pointer-events: none;
    }

    .thread-shell :where(a, button, input, select, textarea, summary):focus-visible {
      outline: 3px solid rgba(14, 116, 144, 0.4);
      outline-offset: 3px;
      box-shadow: 0 0 0 4px rgba(14, 116, 144, 0.12);
    }

    .thread-toast-stack {
      position: fixed;
      top: max(1rem, calc(env(safe-area-inset-top) + 0.5rem));
      right: max(1rem, calc(env(safe-area-inset-right) + 0.5rem));
      z-index: 70;
      display: grid;
      width: min(28rem, calc(100vw - 2rem));
      gap: 0.6rem;
      pointer-events: none;
    }

    .thread-toast {
      pointer-events: auto;
      border-radius: 0.95rem;
      border: 1px solid rgb(203 213 225);
      background: rgb(248 250 252);
      padding: 0.75rem 0.85rem;
      color: rgb(51 65 85);
      box-shadow: 0 18px 36px -24px rgba(15, 23, 42, 0.6);
      transition: opacity 140ms ease, transform 140ms ease;
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .thread-toast.is-dismissing {
      opacity: 0;
      transform: translateX(10px);
    }

    .thread-toast--sky {
      border-color: rgb(186 230 253);
      background: rgb(240 249 255);
      color: rgb(12 74 110);
    }

    .thread-toast--emerald {
      border-color: rgb(167 243 208);
      background: rgb(236 253 245);
      color: rgb(6 95 70);
    }

    .thread-toast--amber {
      border-color: rgb(253 230 138);
      background: rgb(255 251 235);
      color: rgb(146 64 14);
    }

    .thread-toast--rose {
      border-color: rgb(254 205 211);
      background: rgb(255 241 242);
      color: rgb(136 19 55);
    }

    .thread-toast--slate {
      border-color: rgb(203 213 225);
      background: rgb(248 250 252);
      color: rgb(51 65 85);
    }

    .thread-toast__dismiss {
      flex-shrink: 0;
      border-radius: 0.6rem;
      border: 1px solid currentColor;
      background: rgba(255, 255, 255, 0.72);
      padding: 0.45rem 0.7rem;
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1;
      min-height: 2.35rem;
      touch-action: manipulation;
    }

    .thread-toast__dismiss:hover {
      background: rgba(255, 255, 255, 0.92);
    }

    .thread-alert {
      border-radius: 0.85rem;
      border: 1px solid rgb(203 213 225);
      background: rgb(248 250 252);
      padding: 0.75rem 1rem;
      color: rgb(51 65 85);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .thread-alert--sky {
      border-color: rgb(186 230 253);
      background: rgb(240 249 255);
      color: rgb(12 74 110);
    }

    .thread-alert--emerald {
      border-color: rgb(167 243 208);
      background: rgb(236 253 245);
      color: rgb(6 95 70);
    }

    .thread-alert--amber {
      border-color: rgb(253 230 138);
      background: rgb(255 251 235);
      color: rgb(146 64 14);
    }

    .thread-alert--orange {
      border-color: rgb(254 215 170);
      background: rgb(255 247 237);
      color: rgb(154 52 18);
    }

    .thread-alert--rose {
      border-color: rgb(254 205 211);
      background: rgb(255 241 242);
      color: rgb(136 19 55);
    }

    .thread-history-summary {
      border: 1px solid rgb(226 232 240);
      border-radius: 0.85rem;
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.9));
      padding: 0.65rem 0.85rem;
      font-size: 0.74rem;
      line-height: 1.45;
    }

    .thread-state-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.65rem;
    }

    #thread-entry-guidance {
      scroll-margin-top: 6rem;
    }

    .thread-mobile-dock {
      display: none;
    }

    .thread-mobile-dock__action {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.75rem;
      border: 1px solid rgb(148 163 184);
      background: rgb(255 255 255 / 0.92);
      padding: 0.55rem 0.65rem;
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1.2;
      color: rgb(30 41 59);
      text-decoration: none;
      touch-action: manipulation;
    }

    .thread-mobile-dock__action:hover {
      border-color: rgb(71 85 105);
      background: rgb(255 255 255);
    }

    .thread-history-legend {
      border: 1px dashed rgb(203 213 225);
      border-radius: 0.8rem;
      background: rgb(255 255 255 / 0.9);
      padding: 0.5rem 0.65rem;
    }

    .thread-filter-chip {
      position: relative;
      display: inline-flex;
      align-items: center;
      border-radius: 9999px;
      border: 1px solid rgb(203 213 225);
      background: rgb(255 255 255);
      color: rgb(51 65 85);
      font-size: 0.72rem;
      font-weight: 700;
      line-height: 1;
      transition: border-color 140ms ease, background-color 140ms ease, color 140ms ease;
    }

    .thread-filter-chip__input {
      position: absolute;
      inset: 0;
      margin: 0;
      opacity: 0;
      cursor: pointer;
    }

    .thread-filter-chip__label {
      padding: 0.45rem 0.7rem;
      border-radius: 9999px;
      user-select: none;
    }

    .thread-filter-chip--active {
      border-color: rgb(125 211 252);
      background: rgb(224 242 254);
      color: rgb(12 74 110);
      box-shadow: 0 0 0 1px rgba(14, 116, 144, 0.12);
    }

    .thread-filter-chip:focus-within {
      border-color: rgb(14 116 144);
      box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.14);
    }

    .thread-loading-card {
      position: relative;
      overflow: hidden;
      animation: thread-card-pulse 1.4s ease-in-out infinite;
    }

    .thread-loading-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 10%, rgba(255, 255, 255, 0.62) 48%, transparent 82%);
      transform: translateX(-100%);
      animation: thread-loading-shimmer 1.5s ease-in-out infinite;
      pointer-events: none;
    }

    .thread-message {
      border-radius: 1rem;
      border: 1px solid rgb(226 232 240);
      background: white;
      padding: 1rem;
      scroll-margin-top: 6rem;
      box-shadow: 0 14px 32px -28px rgba(15, 23, 42, 0.5);
      transition: border-color 160ms ease, box-shadow 160ms ease;
    }

    .thread-message__anchor {
      text-decoration: none;
      line-height: 1.1;
    }

    .thread-message__meta {
      letter-spacing: 0.01em;
    }

    .thread-message__direction {
      letter-spacing: 0.01em;
    }

    .thread-message__status {
      min-height: 1.45rem;
    }

    .thread-message__body {
      word-break: break-word;
    }

    .thread-day-divider {
      position: relative;
      text-align: center;
      margin: 0.35rem 0 0.1rem;
    }

    .thread-day-divider::before {
      content: '';
      position: absolute;
      inset: 50% 0 auto;
      border-top: 1px solid rgb(226 232 240);
      transform: translateY(-50%);
      z-index: 0;
    }

    .thread-day-divider > span {
      position: relative;
      z-index: 1;
      display: inline-flex;
      border-radius: 9999px;
      border: 1px solid rgb(203 213 225);
      background: rgb(248 250 252);
      padding: 0.25rem 0.65rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: rgb(71 85 105);
    }

    .thread-message:focus-within {
      border-color: rgb(125 211 252);
      box-shadow:
        0 0 0 3px rgba(14, 116, 144, 0.14),
        0 14px 32px -28px rgba(15, 23, 42, 0.5);
    }

    .thread-message--incoming {
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.9));
    }

    .thread-message--own {
      border-color: rgb(186 230 253);
      background: linear-gradient(145deg, rgba(240, 249, 255, 0.95), rgba(255, 255, 255, 0.95));
    }

    .thread-message--hidden {
      border-color: rgb(253 186 116);
      background: linear-gradient(145deg, rgba(255, 247, 237, 0.95), rgba(255, 255, 255, 0.95));
    }

    .thread-report[open] {
      border-color: rgb(252 211 77);
      box-shadow: 0 10px 30px -24px rgba(180, 83, 9, 0.55);
    }

    .thread-message--highlight {
      border-color: rgb(56 189 248);
      box-shadow:
        0 0 0 3px rgba(14, 116, 144, 0.16),
        0 14px 32px -28px rgba(15, 23, 42, 0.5);
      animation: thread-message-highlight-fade 1.6s ease;
    }

    @keyframes thread-message-highlight-fade {
      0% {
        box-shadow:
          0 0 0 5px rgba(14, 116, 144, 0.24),
          0 14px 32px -28px rgba(15, 23, 42, 0.5);
      }
      100% {
        box-shadow:
          0 0 0 3px rgba(14, 116, 144, 0.12),
          0 14px 32px -28px rgba(15, 23, 42, 0.5);
      }
    }

    @keyframes thread-card-pulse {
      0%, 100% {
        opacity: 0.92;
      }
      50% {
        opacity: 1;
      }
    }

    @keyframes thread-loading-shimmer {
      100% {
        transform: translateX(100%);
      }
    }

    .js-composer-form[data-composer-state='error'] {
      border-color: rgb(253 164 175);
      box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.12);
    }

    .js-composer-form[data-composer-state='success'] {
      border-color: rgb(110 231 183);
      box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.14);
    }

    .js-composer-form[data-composer-state='submitting'] {
      border-color: rgb(125 211 252);
      box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.16);
    }

    .js-pending-form[aria-busy='true'] {
      opacity: 0.8;
    }

    .js-pending-form[aria-busy='true'] :where(input:not([type='hidden']), textarea, select, button) {
      cursor: wait;
    }

    .composer-count--warning {
      color: rgb(161 98 7);
      font-weight: 600;
    }

    .composer-count--limit {
      color: rgb(190 24 93);
      font-weight: 700;
    }

    @media (max-width: 640px) {
      .thread-shell {
        padding-bottom: calc(7.6rem + env(safe-area-inset-bottom));
      }

      .thread-toast-stack {
        top: max(0.75rem, calc(env(safe-area-inset-top) + 0.35rem));
        left: max(0.75rem, calc(env(safe-area-inset-left) + 0.35rem));
        right: max(0.75rem, calc(env(safe-area-inset-right) + 0.35rem));
        width: auto;
      }

      .thread-touch-target,
      #thread-composer :where(button, a),
      #thread-entry-guidance :where(a, button),
      #thread-filter-controls :where(button, a),
      #thread-history :where(button, a, summary) {
        min-height: 2.75rem;
        touch-action: manipulation;
      }

      #composer-retry-panel .thread-touch-target {
        width: 100%;
        justify-content: center;
      }

      .thread-state-actions {
        width: 100%;
      }

      .thread-state-actions > .thread-touch-target {
        width: 100%;
        justify-content: center;
      }

      .thread-toast {
        padding: 0.85rem;
      }

      .thread-skip-link--moderation {
        top: 2.1rem;
      }

      .thread-skip-link--interaction {
        top: 3.85rem;
      }

      .thread-mobile-dock {
        position: fixed;
        left: max(0.6rem, calc(env(safe-area-inset-left) + 0.35rem));
        right: max(0.6rem, calc(env(safe-area-inset-right) + 0.35rem));
        bottom: max(0.55rem, calc(env(safe-area-inset-bottom) + 0.3rem));
        z-index: 68;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.45rem;
        border-radius: 1rem;
        border: 1px solid rgb(203 213 225 / 0.95);
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(255, 255, 255, 0.98));
        padding: 0.45rem;
        box-shadow: 0 16px 30px -20px rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(6px);
      }

      .thread-mobile-dock__action {
        min-height: 2.7rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .thread-skip-link {
        transition: none;
      }

      .thread-loading-card,
      .thread-loading-card::after,
      .thread-message--highlight {
        animation: none;
      }

      .thread-mobile-dock {
        backdrop-filter: none;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const toasts = Array.from(document.querySelectorAll('.js-thread-toast'));
      const focusLiveRegion = document.querySelector('#thread-focus-live');
      const filterLiveRegion = document.querySelector('#thread-filter-live');
      const threadFilterForm = document.querySelector('#thread-filter-controls');
      const threadFilterQuery = document.querySelector('#thread-filter-query');
      const threadFilterActions = Array.from(document.querySelectorAll('[data-thread-filter-action]')).filter((item) => item instanceof HTMLElement);
      const threadRetryLinks = Array.from(document.querySelectorAll('[data-thread-retry-now]')).filter((item) => item instanceof HTMLAnchorElement);
      const threadShell = document.querySelector('.thread-shell');
      const isCompactViewport = () => typeof window.matchMedia === 'function' && window.matchMedia('(max-width: 640px)').matches;
      const getSafeThreadStorage = () => {
        try {
          const storage = window.localStorage;
          const probeKey = '__gh_thread_resume_probe__';
          storage.setItem(probeKey, '1');
          storage.removeItem(probeKey);
          return storage;
        } catch {
          return null;
        }
      };
      const threadVisitStorage = getSafeThreadStorage();
      const persistLastVisitedThread = () => {
        if (!(threadShell instanceof HTMLElement) || !threadVisitStorage) return;
        const persistedThreadId = threadShell.dataset.threadId || '';
        const persistedViewerEmail = (threadShell.dataset.threadViewerEmail || '').toLowerCase();
        if (!persistedThreadId || !persistedViewerEmail) return;
        const payload = {
          href: `${window.location.pathname}${window.location.search}`,
          listHref: threadShell.dataset.threadListHref || '',
          threadId: persistedThreadId,
          slug: threadShell.dataset.threadProfessionalSlug || '',
          counterpartEmail: threadShell.dataset.threadCounterpartEmail || '',
          savedAt: Date.now(),
          viewerEmail: persistedViewerEmail
        };
        try {
          threadVisitStorage.setItem(`gh:last-thread-visit:${persistedViewerEmail}`, JSON.stringify(payload));
        } catch {
          // Ignore storage write failures to avoid interrupting thread interactions.
        }
      };
      persistLastVisitedThread();
      window.addEventListener('pagehide', persistLastVisitedThread);
      const announceFocusState = (message) => {
        if (focusLiveRegion instanceof HTMLElement) focusLiveRegion.textContent = message;
      };
      const announceThreadFilterState = (message) => {
        if (filterLiveRegion instanceof HTMLElement) filterLiveRegion.textContent = message;
      };
      const focusElement = (element, options = {}) => {
        if (!(element instanceof HTMLElement)) return;
        const preventScroll = options.preventScroll === true;
        if (typeof element.focus === 'function') {
          try {
            element.focus({ preventScroll });
          } catch {
            element.focus();
          }
        }
        if (!preventScroll && isCompactViewport() && typeof element.scrollIntoView === 'function') {
          element.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
        if (typeof options.announcement === 'string' && options.announcement) {
          announceFocusState(options.announcement);
        }
      };
      const isVisibleRetryLink = (link) => (
        link instanceof HTMLAnchorElement
        && !link.hidden
        && link.offsetParent !== null
      );
      const getFirstVisibleRetryLink = () => (
        threadRetryLinks.find((link) => isVisibleRetryLink(link)) || null
      );
      const dismissToast = (toast) => {
        if (!(toast instanceof HTMLElement) || toast.dataset.removed === 'true') return;
        toast.dataset.removed = 'true';
        const focusFallback = toast.contains(document.activeElement)
          ? (document.querySelector('#composer-message') || document.querySelector('#thread-history') || document.querySelector('#thread-moderation-state'))
          : null;
        toast.classList.add('is-dismissing');
        window.setTimeout(() => {
          toast.remove();
          if (focusFallback instanceof HTMLElement) {
            focusElement(focusFallback, {
              preventScroll: isCompactViewport(),
              announcement: 'Η εστίαση επέστρεψε στην κύρια ενότητα thread.'
            });
          }
        }, 150);
      };

      for (const toast of toasts) {
        const dismissButton = toast.querySelector('[data-toast-dismiss]');
        if (dismissButton instanceof HTMLButtonElement) {
          dismissButton.addEventListener('click', () => dismissToast(toast));
        }
        toast.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          event.preventDefault();
          dismissToast(toast);
        });
        const autoHideMs = Number(toast.getAttribute('data-autohide-ms') || '0');
        if (Number.isFinite(autoHideMs) && autoHideMs > 0) {
          window.setTimeout(() => dismissToast(toast), autoHideMs);
        }
      }

      const focusToast = document.querySelector('.js-thread-toast[data-focus-on-load="true"]');
      if (focusToast instanceof HTMLElement) {
        const shouldMoveFocus = focusToast.getAttribute('role') === 'alert' || !isCompactViewport();
        if (shouldMoveFocus) {
          requestAnimationFrame(() => focusElement(focusToast, {
            preventScroll: isCompactViewport(),
            announcement: 'Εστίαση στην τελευταία ειδοποίηση συνομιλίας.'
          }));
        }
      }
      if (threadFilterQuery instanceof HTMLInputElement) {
        threadFilterQuery.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          if (!threadFilterQuery.value) return;
          event.preventDefault();
          threadFilterQuery.value = '';
          announceThreadFilterState('Το πεδίο αναζήτησης καθαρίστηκε. Πατήστε Εφαρμογή φίλτρων για νέα προβολή.');
        });
      }
      if (threadFilterForm instanceof HTMLFormElement) {
        threadFilterForm.addEventListener('submit', () => {
          announceThreadFilterState('Η προβολή thread ενημερώνεται με τα τρέχοντα φίλτρα.');
        });
      }
      for (const action of threadFilterActions) {
        if (!(action instanceof HTMLElement)) continue;
        action.addEventListener('click', () => {
          const message = action.dataset.threadFilterAction || 'Η προβολή thread ενημερώνεται.';
          announceThreadFilterState(message);
        });
      }
      for (const retryLink of threadRetryLinks) {
        if (!(retryLink instanceof HTMLAnchorElement)) continue;
        retryLink.addEventListener('click', (event) => {
          if (isOffline()) {
            event.preventDefault();
            announceThreadFilterState('Δεν υπάρχει σύνδεση. Η επανάληψη φόρτωσης thread θα ενεργοποιηθεί μόλις επανέλθει το δίκτυο.');
            return;
          }
          announceThreadFilterState(retryLink.dataset.threadFilterAction || 'Εκκίνηση άμεσης επανάληψης φόρτωσης thread.');
        });
      }
      window.addEventListener('keydown', (event) => {
        if (event.defaultPrevented || event.key !== '/') return;
        if (!(threadFilterQuery instanceof HTMLInputElement)) return;
        const target = event.target;
        const isEditableTarget = target instanceof HTMLInputElement
          || target instanceof HTMLTextAreaElement
          || target instanceof HTMLSelectElement
          || (target instanceof HTMLElement && target.isContentEditable);
        if (isEditableTarget) return;
        event.preventDefault();
        focusElement(threadFilterQuery, {
          preventScroll: isCompactViewport(),
          announcement: 'Η εστίαση μεταφέρθηκε στην αναζήτηση thread.'
        });
        threadFilterQuery.select();
      });
      window.addEventListener('keydown', (event) => {
        if (event.defaultPrevented || event.key.toLowerCase() !== 'r') return;
        if (event.metaKey || event.ctrlKey || event.altKey) return;
        const target = event.target;
        const isEditableTarget = target instanceof HTMLInputElement
          || target instanceof HTMLTextAreaElement
          || target instanceof HTMLSelectElement
          || (target instanceof HTMLElement && target.isContentEditable);
        if (isEditableTarget) return;
        const retryLink = getFirstVisibleRetryLink();
        if (!(retryLink instanceof HTMLAnchorElement)) return;
        event.preventDefault();
        retryLink.click();
      });

      const highlightMessageFromHash = () => {
        const hash = window.location.hash;
        if (!hash || !hash.startsWith('#message-')) return;
        const target = document.querySelector(hash);
        if (!(target instanceof HTMLElement) || !target.classList.contains('thread-message')) return;
        target.classList.remove('thread-message--highlight');
        requestAnimationFrame(() => {
          target.classList.add('thread-message--highlight');
        });
      };

      highlightMessageFromHash();
      window.addEventListener('hashchange', highlightMessageFromHash);

      const pendingForms = Array.from(document.querySelectorAll('.js-pending-form')).filter((form) => form instanceof HTMLFormElement);
      const globalSubmitLive = document.querySelector('#thread-submit-live');
      const draftLiveRegion = document.querySelector('#thread-draft-live');
      const offlineAlert = document.querySelector('#thread-offline-alert');
      const pendingTimeouts = new WeakMap();
      const isOffline = () => typeof navigator !== 'undefined' && navigator.onLine === false;
      const getSafeStorage = (storageName) => {
        try {
          const storage = window[storageName];
          if (!storage) return null;
          storage.getItem('__gh_draft_probe__');
          return storage;
        } catch {
          return null;
        }
      };
      const draftStores = [
        getSafeStorage('localStorage'),
        getSafeStorage('sessionStorage')
      ].filter((storage) => storage !== null);
      const normalizeDraftRecord = (rawValue) => {
        if (typeof rawValue !== 'string' || rawValue.length === 0) {
          return { value: '', updatedAt: 0, threadId: '', viewerEmail: '' };
        }
        try {
          const parsed = JSON.parse(rawValue);
          if (!parsed || typeof parsed !== 'object') throw new Error('Invalid draft payload.');
          const value = typeof parsed.value === 'string' ? parsed.value : '';
          const updatedAt = Number.isFinite(parsed.updatedAt) ? parsed.updatedAt : 0;
          const threadId = typeof parsed.threadId === 'string' ? parsed.threadId : '';
          const viewerEmail = typeof parsed.viewerEmail === 'string' ? parsed.viewerEmail : '';
          return { value, updatedAt, threadId, viewerEmail };
        } catch {
          return { value: rawValue, updatedAt: 0, threadId: '', viewerEmail: '' };
        }
      };
      const getDraftRecord = (key) => {
        if (!key) return { value: '', updatedAt: 0, threadId: '', viewerEmail: '' };
        let latestRecord = { value: '', updatedAt: 0, threadId: '', viewerEmail: '' };
        for (const storage of draftStores) {
          try {
            const rawValue = storage.getItem(key);
            if (!rawValue) continue;
            const candidate = normalizeDraftRecord(rawValue);
            if (!candidate.value) continue;
            if (candidate.updatedAt >= latestRecord.updatedAt) latestRecord = candidate;
          } catch {
            // Ignore per-storage failures and continue with fallback storage.
          }
        }
        return latestRecord;
      };
      const setDraftRecord = (key, value, metadata = {}) => {
        if (!key) return;
        const normalizedValue = typeof value === 'string' ? value : '';
        for (const storage of draftStores) {
          try {
            if (!normalizedValue.trim()) {
              storage.removeItem(key);
              continue;
            }
            const payload = JSON.stringify({
              value: normalizedValue,
              updatedAt: Date.now(),
              threadId: metadata.threadId || '',
              viewerEmail: metadata.viewerEmail || ''
            });
            storage.setItem(key, payload);
          } catch {
            // Ignore storage failures to avoid submit regressions.
          }
        }
      };
      const syncOfflineSubmitAvailability = () => {
        const offline = isOffline();
        for (const form of pendingForms) {
          const submitButton = form.querySelector('button[type="submit"]');
          if (!(submitButton instanceof HTMLButtonElement)) continue;
          if (form.getAttribute('aria-busy') === 'true') continue;
          if (form.classList.contains('js-composer-form')) continue;
          if (offline) {
            submitButton.setAttribute('data-offline-disabled', submitButton.disabled ? 'true' : 'false');
            submitButton.disabled = true;
            submitButton.setAttribute('aria-disabled', 'true');
            continue;
          }
          const wasDisabled = submitButton.getAttribute('data-offline-disabled') === 'true';
          submitButton.removeAttribute('data-offline-disabled');
          submitButton.disabled = wasDisabled;
          if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
        }
      };
      const refreshComposerAvailability = () => {
        for (const form of pendingForms) {
          if (!form.classList.contains('js-composer-form')) continue;
          const textarea = form.querySelector('textarea[name="message"]');
          if (textarea instanceof HTMLTextAreaElement) {
            textarea.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }
      };
      const clearPendingTimeout = (form) => {
        const timer = pendingTimeouts.get(form);
        if (typeof timer === 'number') {
          window.clearTimeout(timer);
        }
        pendingTimeouts.delete(form);
      };
      const announcePendingState = (form, message, politeness = 'polite') => {
        const scopedLiveRegion = form.querySelector('#composer-submit-live');
        const role = politeness === 'assertive' ? 'alert' : 'status';
        if (scopedLiveRegion instanceof HTMLElement) {
          scopedLiveRegion.setAttribute('role', role);
          scopedLiveRegion.setAttribute('aria-live', politeness === 'assertive' ? 'assertive' : 'polite');
          scopedLiveRegion.textContent = message;
        }
        if (globalSubmitLive instanceof HTMLElement) {
          globalSubmitLive.setAttribute('role', role);
          globalSubmitLive.setAttribute('aria-live', politeness === 'assertive' ? 'assertive' : 'polite');
          globalSubmitLive.textContent = message;
        }
      };
      const setFormFeedback = (form, message, tone = 'neutral') => {
        const feedback = form.querySelector('[data-form-feedback]');
        if (!(feedback instanceof HTMLElement)) return;
        const neutralToneClass = form.classList.contains('js-composer-form') ? 'text-slate-600' : 'text-amber-900';
        const toneClass = tone === 'error'
          ? 'text-rose-700'
          : tone === 'pending'
            ? 'text-sky-700'
            : neutralToneClass;
        const assertive = tone === 'error';
        feedback.className = `text-[11px] ${toneClass}`;
        feedback.setAttribute('role', assertive ? 'alert' : 'status');
        feedback.setAttribute('aria-live', assertive ? 'assertive' : 'polite');
        feedback.setAttribute('aria-atomic', 'true');
        feedback.textContent = message;
      };
      const resetFormFeedback = (form) => {
        const idleLabel = form.getAttribute('data-pending-idle-label') || 'Έτοιμο για υποβολή.';
        setFormFeedback(form, idleLabel, 'neutral');
      };
      const syncOfflineAlert = () => {
        if (!(offlineAlert instanceof HTMLElement)) return;
        const offline = isOffline();
        offlineAlert.classList.toggle('hidden', !offline);
        syncOfflineSubmitAvailability();
        refreshComposerAvailability();
        if (!offline) {
          for (const form of pendingForms) {
            if (form.getAttribute('aria-busy') === 'true') continue;
            const feedback = form.querySelector('[data-form-feedback]');
            if (!(feedback instanceof HTMLElement)) continue;
            if (typeof feedback.textContent !== 'string' || !feedback.textContent.includes('Δεν υπάρχει σύνδεση')) continue;
            resetFormFeedback(form);
          }
          if (
            globalSubmitLive instanceof HTMLElement
            && typeof globalSubmitLive.textContent === 'string'
            && globalSubmitLive.textContent.includes('Δεν υπάρχει σύνδεση')
          ) globalSubmitLive.textContent = '';
          return;
        }
        for (const form of pendingForms) {
          announcePendingState(form, 'Δεν υπάρχει σύνδεση. Οι υποβολές είναι προσωρινά ανενεργές.', 'assertive');
          if (form.getAttribute('aria-busy') !== 'true') {
            setFormFeedback(form, 'Δεν υπάρχει σύνδεση. Η φόρμα θα ενεργοποιηθεί όταν επανέλθει το δίκτυο.', 'error');
          }
        }
      };
      const setFormPending = (form, isPending) => {
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;
        const controls = Array.from(form.querySelectorAll('button, input, select, textarea')).filter((control) => (
          !(control instanceof HTMLInputElement && control.type === 'hidden')
        ));
        clearPendingTimeout(form);

        form.setAttribute('aria-busy', isPending ? 'true' : 'false');
        form.classList.toggle('opacity-80', isPending);

        if (isPending) {
          for (const control of controls) {
            control.setAttribute('data-pending-disabled', control.disabled ? 'true' : 'false');
            control.disabled = true;
            control.setAttribute('aria-disabled', 'true');
          }
          const defaultLabel = submitButton.dataset.defaultLabel || submitButton.textContent || 'Υποβολή';
          const pendingLabel = submitButton.dataset.pendingLabel || 'Επεξεργασία...';
          form.setAttribute('data-submit-label', defaultLabel);
          submitButton.textContent = pendingLabel;
          submitButton.setAttribute('aria-busy', 'true');
          setFormFeedback(form, form.getAttribute('data-pending-live-label') || 'Η υποβολή εκτελείται.', 'pending');
          const timeoutMs = Number(form.getAttribute('data-pending-timeout-ms') || '15000');
          if (Number.isFinite(timeoutMs) && timeoutMs > 0) {
            const timeoutId = window.setTimeout(() => {
              if (form.getAttribute('aria-busy') !== 'true') return;
              setFormPending(form, false);
              const timeoutLabel = form.getAttribute('data-pending-timeout-label') || 'Η υποβολή καθυστέρησε. Δοκιμάστε ξανά.';
              const recoveryLabel = form.getAttribute('data-pending-recovery-label') || 'Η φόρμα επανήλθε. Μπορείτε να δοκιμάσετε ξανά.';
              announcePendingState(form, timeoutLabel, 'assertive');
              setFormFeedback(form, `${timeoutLabel} ${recoveryLabel}`, 'error');
              if (form.classList.contains('js-composer-form')) {
                const composerState = form.querySelector('#composer-state');
                if (composerState instanceof HTMLElement) {
                  composerState.className = 'inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold border-rose-300 bg-rose-100 text-rose-900';
                  composerState.textContent = 'Η αποστολή έληξε χρονικά. Δοκιμάστε ξανά.';
                }
                const composerLive = form.querySelector('#composer-live');
                if (composerLive instanceof HTMLElement) composerLive.textContent = 'Η αποστολή έληξε χρονικά. Δοκιμάστε ξανά.';
                const composerTextarea = form.querySelector('textarea[name="message"]');
                if (composerTextarea instanceof HTMLTextAreaElement) {
                  focusElement(composerTextarea, {
                    preventScroll: isCompactViewport(),
                    announcement: 'Η αποστολή καθυστέρησε και η εστίαση επέστρεψε στο πεδίο μηνύματος.'
                  });
                }
              } else {
                focusElement(submitButton, {
                  preventScroll: isCompactViewport(),
                  announcement: 'Η φόρμα επανήλθε μετά από καθυστέρηση και είναι ξανά διαθέσιμη.'
                });
              }
            }, timeoutMs);
            pendingTimeouts.set(form, timeoutId);
          }
          return;
        }

        for (const control of controls) {
          const wasDisabled = control.getAttribute('data-pending-disabled') === 'true';
          control.disabled = wasDisabled;
          control.removeAttribute('data-pending-disabled');
          if (!control.disabled) control.removeAttribute('aria-disabled');
        }
        const defaultLabel = submitButton.dataset.defaultLabel || form.getAttribute('data-submit-label') || submitButton.textContent || 'Υποβολή';
        submitButton.textContent = defaultLabel;
        submitButton.removeAttribute('aria-busy');
        if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
        syncOfflineSubmitAvailability();
        if (form.classList.contains('js-composer-form')) refreshComposerAvailability();
      };

      for (const form of pendingForms) {
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) continue;

        const isComposerForm = form.classList.contains('js-composer-form');
        const textarea = isComposerForm ? form.querySelector('textarea[name="message"]') : null;
        const counter = isComposerForm ? form.querySelector('#composer-count') : null;
        const error = isComposerForm ? form.querySelector('#composer-error') : null;
        const live = isComposerForm ? form.querySelector('#composer-live') : null;
        const composerState = isComposerForm ? form.querySelector('#composer-state') : null;
        const retrySendButton = isComposerForm ? form.querySelector('[data-retry-send]') : null;
        const restoreDraftButton = isComposerForm ? form.querySelector('[data-restore-draft]') : null;
        const draftKey = isComposerForm ? (form.getAttribute('data-composer-draft-key') || '') : '';
        const composerThreadId = isComposerForm ? (form.getAttribute('data-composer-thread-id') || '') : '';
        const composerViewerEmail = isComposerForm ? (form.getAttribute('data-composer-viewer-email') || '') : '';
        const clearDraftOnLoad = isComposerForm && form.getAttribute('data-clear-composer-draft-on-load') === 'true';
        const maxLength = textarea instanceof HTMLTextAreaElement && textarea.maxLength > 0 ? textarea.maxLength : 2000;
        let preserveInitialComposerFeedback = isComposerForm && ['success', 'error'].includes(form.getAttribute('data-composer-state') || '');
        const persistDraft = (value) => {
          setDraftRecord(draftKey, value, {
            threadId: composerThreadId,
            viewerEmail: composerViewerEmail
          });
        };
        const restoreDraft = (options = {}) => {
          if (!(textarea instanceof HTMLTextAreaElement)) return false;
          const storedDraft = getDraftRecord(draftKey);
          if (!storedDraft.value.trim()) {
            if (options.announceMissing && draftLiveRegion instanceof HTMLElement) {
              draftLiveRegion.textContent = 'Δεν υπάρχει αποθηκευμένο πρόχειρο για αυτό το thread.';
            }
            return false;
          }
          if (options.force !== true && textarea.value.trim()) return false;
          textarea.value = storedDraft.value;
          if (draftLiveRegion instanceof HTMLElement) draftLiveRegion.textContent = 'Επαναφέρθηκε πρόχειρο μηνύματος.';
          return true;
        };

        const setComposerState = (state, message) => {
          if (!(composerState instanceof HTMLElement)) return;
          const toneClass = state === 'success'
            ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
            : state === 'error'
              ? 'border-rose-300 bg-rose-100 text-rose-900'
              : state === 'submitting'
                ? 'border-slate-300 bg-slate-200 text-slate-800'
                : 'border-sky-300 bg-sky-100 text-sky-900';
          composerState.className = `inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold ${toneClass}`;
          composerState.textContent = message;
          form.setAttribute('data-composer-state', state);
        };
        const syncComposerRetryActions = () => {
          if (!isComposerForm) return;
          const isBusy = form.getAttribute('aria-busy') === 'true';
          const offline = isOffline();
          const textValue = textarea instanceof HTMLTextAreaElement ? textarea.value.trim() : '';
          const storedDraft = getDraftRecord(draftKey).value.trim();
          const hasRetrySource = textValue.length > 0 || storedDraft.length > 0;
          if (retrySendButton instanceof HTMLButtonElement) {
            retrySendButton.disabled = isBusy || offline || !hasRetrySource;
            retrySendButton.setAttribute('aria-disabled', retrySendButton.disabled ? 'true' : 'false');
          }
          if (restoreDraftButton instanceof HTMLButtonElement) {
            restoreDraftButton.disabled = isBusy || offline || storedDraft.length === 0;
            restoreDraftButton.setAttribute('aria-disabled', restoreDraftButton.disabled ? 'true' : 'false');
          }
        };

        const syncComposer = () => {
          if (!(textarea instanceof HTMLTextAreaElement)) return;
          const length = textarea.value.trim().length;
          const remaining = maxLength - length;
          const isBusy = form.getAttribute('aria-busy') === 'true';
          const offline = isOffline();
          textarea.setCustomValidity(length === 0 ? 'Συμπληρώστε μήνυμα.' : '');
          submitButton.disabled = length === 0 || isBusy || offline;
          submitButton.setAttribute('aria-disabled', submitButton.disabled ? 'true' : 'false');
          if (!isBusy) {
            persistDraft(textarea.value);
          }
          if (counter) {
            counter.textContent = `${length} / ${maxLength}`;
            counter.classList.toggle('composer-count--warning', length > 0 && remaining <= 200 && remaining > 0);
            counter.classList.toggle('composer-count--limit', remaining <= 0);
          }
          if (error) error.classList.toggle('hidden', length > 0);
          textarea.setAttribute('aria-invalid', length === 0 ? 'true' : 'false');

          if (!isBusy) {
            if (length > 0) {
              preserveInitialComposerFeedback = false;
              setComposerState('idle', 'Η φόρμα απάντησης είναι έτοιμη.');
            } else if (!preserveInitialComposerFeedback) {
              setComposerState('idle', 'Η φόρμα απάντησης είναι έτοιμη.');
            }
          }

          if (live) {
            if (length === 0 && live.textContent === 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».') return;
            if (remaining <= 200 && length > 0) {
              live.textContent = remaining === 0 ? 'Φτάσατε το όριο χαρακτήρων.' : `Απομένουν ${remaining} χαρακτήρες.`;
              return;
            }
            if (live.textContent.startsWith('Απομένουν') || live.textContent === 'Φτάσατε το όριο χαρακτήρων.') {
              live.textContent = '';
            }
          }
          syncComposerRetryActions();
        };

        if (textarea instanceof HTMLTextAreaElement) {
          if (clearDraftOnLoad) {
            persistDraft('');
          } else if (!textarea.value.trim()) {
            restoreDraft();
          }
          textarea.addEventListener('input', syncComposer);
          textarea.addEventListener('blur', () => {
            syncComposer();
            persistDraft(textarea.value);
          });
          window.addEventListener('pagehide', () => {
            if (form.getAttribute('aria-busy') === 'true') return;
            persistDraft(textarea.value);
          });
          textarea.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              if (error) error.classList.add('hidden');
              if (live) live.textContent = '';
              return;
            }
            if (event.key !== 'Enter' || (!event.ctrlKey && !event.metaKey)) return;
            event.preventDefault();
            if (form.getAttribute('aria-busy') === 'true') return;
            const length = textarea.value.trim().length;
            if (length === 0) {
              if (error) error.classList.remove('hidden');
              if (live) live.textContent = 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».';
              submitButton.disabled = true;
              textarea.setAttribute('aria-invalid', 'true');
              setComposerState('error', 'Δεν ήταν δυνατή η αποστολή: κενό μήνυμα.');
              announcePendingState(form, 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».');
              setFormFeedback(form, 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».', 'error');
              textarea.reportValidity();
              focusElement(textarea, {
                preventScroll: isCompactViewport(),
                announcement: 'Η εστίαση μεταφέρθηκε στο πεδίο μηνύματος.'
              });
              return;
            }
            setComposerState('submitting', 'Αποστολή μηνύματος σε εξέλιξη...');
            if (live) live.textContent = 'Αποστολή μηνύματος...';
            persistDraft(textarea.value);
            form.requestSubmit(submitButton);
          });
          if (retrySendButton instanceof HTMLButtonElement) {
            retrySendButton.addEventListener('click', () => {
              if (form.getAttribute('aria-busy') === 'true') return;
              if (isOffline()) {
                announcePendingState(form, 'Δεν υπάρχει σύνδεση. Περιμένετε επαναφορά δικτύου για επανάληψη.', 'assertive');
                setFormFeedback(form, 'Δεν υπάρχει σύνδεση. Η επανάληψη θα είναι διαθέσιμη όταν επανέλθει το δίκτυο.', 'error');
                setComposerState('error', 'Δεν υπάρχει σύνδεση για επανάληψη αποστολής.');
                if (live) live.textContent = 'Δεν υπάρχει σύνδεση. Περιμένετε επαναφορά δικτύου.';
                return;
              }
              if (textarea.value.trim().length === 0) {
                const restored = restoreDraft({ force: true });
                if (restored) {
                  syncComposer();
                  if (textarea.value.trim().length > 0) {
                    setComposerState('submitting', 'Επανάληψη αποστολής σε εξέλιξη...');
                    if (live) live.textContent = 'Επανάληψη αποστολής...';
                    persistDraft(textarea.value);
                    form.requestSubmit(submitButton);
                    return;
                  }
                  if (live) live.textContent = 'Επαναφέρθηκε πρόχειρο. Μπορείτε να το ελέγξετε πριν την αποστολή.';
                } else {
                  if (error) error.classList.remove('hidden');
                  setComposerState('error', 'Δεν υπάρχει διαθέσιμο πρόχειρο για επανάληψη.');
                  if (live) live.textContent = 'Δεν υπάρχει διαθέσιμο πρόχειρο για επανάληψη αποστολής.';
                }
                focusElement(textarea, {
                  preventScroll: isCompactViewport(),
                  announcement: 'Η εστίαση μεταφέρθηκε στο πεδίο μηνύματος για επανάληψη.'
                });
                return;
              }
              setComposerState('submitting', 'Επανάληψη αποστολής σε εξέλιξη...');
              if (live) live.textContent = 'Επανάληψη αποστολής...';
              persistDraft(textarea.value);
              form.requestSubmit(submitButton);
            });
          }
          if (restoreDraftButton instanceof HTMLButtonElement) {
            restoreDraftButton.addEventListener('click', () => {
              const restored = restoreDraft({ force: true, announceMissing: true });
              if (!restored) {
                setFormFeedback(form, 'Δεν βρέθηκε αποθηκευμένο πρόχειρο για αυτό το thread.', 'error');
                return;
              }
              syncComposer();
              setFormFeedback(form, 'Το πρόχειρο επαναφέρθηκε. Μπορείτε να συνεχίσετε ή να στείλετε ξανά.', 'neutral');
              if (live) live.textContent = 'Το πρόχειρο επαναφέρθηκε από την αποθήκευση.';
              focusElement(textarea, {
                preventScroll: isCompactViewport(),
                announcement: 'Επαναφέρθηκε πρόχειρο και η εστίαση μεταφέρθηκε στο πεδίο μηνύματος.'
              });
            });
          }
          syncComposer();
        }

        form.addEventListener('submit', (event) => {
          if (isOffline()) {
            event.preventDefault();
            announcePendingState(form, 'Δεν υπάρχει σύνδεση. Δοκιμάστε ξανά μόλις επανέλθει το δίκτυο.', 'assertive');
            setFormFeedback(form, 'Δεν υπάρχει σύνδεση. Περιμένετε επαναφορά δικτύου και δοκιμάστε ξανά.', 'error');
            if (isComposerForm) {
              setComposerState('error', 'Δεν υπάρχει σύνδεση για αποστολή.');
              if (live) live.textContent = 'Δεν υπάρχει σύνδεση. Περιμένετε επαναφορά δικτύου.';
            }
            syncOfflineAlert();
            return;
          }
          if (form.getAttribute('aria-busy') === 'true') {
            event.preventDefault();
            announcePendingState(form, 'Η υποβολή βρίσκεται ήδη σε εξέλιξη.', 'polite');
            setFormFeedback(form, 'Η υποβολή βρίσκεται ήδη σε εξέλιξη.', 'error');
            return;
          }
          if (!form.checkValidity()) {
            event.preventDefault();
            const invalidField = form.querySelector(':invalid');
            if (invalidField instanceof HTMLElement) {
              focusElement(invalidField, {
                preventScroll: isCompactViewport(),
                announcement: 'Η εστίαση μεταφέρθηκε στο μη έγκυρο πεδίο.'
              });
            }
            form.reportValidity();
            announcePendingState(form, 'Ελέγξτε τα πεδία και προσπαθήστε ξανά.', 'assertive');
            setFormFeedback(form, 'Ελέγξτε τα πεδία και δοκιμάστε ξανά.', 'error');
            return;
          }
          if (textarea instanceof HTMLTextAreaElement && textarea.value.trim().length === 0) {
            event.preventDefault();
            if (error) error.classList.remove('hidden');
            if (live) live.textContent = 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».';
            textarea.setAttribute('aria-invalid', 'true');
            setComposerState('error', 'Δεν ήταν δυνατή η αποστολή: κενό μήνυμα.');
            announcePendingState(form, 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».', 'assertive');
            setFormFeedback(form, 'Γράψτε πρώτα το μήνυμά σας και έπειτα πατήστε «Αποστολή».', 'error');
            textarea.reportValidity();
            focusElement(textarea, {
              preventScroll: isCompactViewport(),
              announcement: 'Η εστίαση μεταφέρθηκε στο πεδίο μηνύματος.'
            });
            return;
          }
          if (isComposerForm) {
            if (textarea instanceof HTMLTextAreaElement) persistDraft(textarea.value);
            setComposerState('submitting', 'Αποστολή μηνύματος σε εξέλιξη...');
            if (live) live.textContent = 'Αποστολή μηνύματος...';
          }
          announcePendingState(form, form.getAttribute('data-pending-live-label') || 'Η υποβολή εκτελείται.');
          setFormFeedback(form, form.getAttribute('data-pending-live-label') || 'Η υποβολή εκτελείται.', 'pending');
          setFormPending(form, true);
        });
      }

      window.addEventListener('pageshow', () => {
        for (const form of pendingForms) {
          setFormPending(form, false);
          resetFormFeedback(form);
        }
        if (globalSubmitLive instanceof HTMLElement) globalSubmitLive.textContent = '';
        announceFocusState('');
        announceThreadFilterState('');
        const composerTextarea = document.querySelector('#composer-message');
        if (composerTextarea instanceof HTMLTextAreaElement) {
          composerTextarea.dispatchEvent(new Event('input', { bubbles: true }));
        }
        syncOfflineAlert();
      });
      window.addEventListener('online', syncOfflineAlert);
      window.addEventListener('offline', syncOfflineAlert);
      syncOfflineAlert();

      if (!(focusToast instanceof HTMLElement)) {
        const composerForm = document.querySelector('.js-composer-form');
        const composerInput = document.querySelector('#composer-message');
        if (composerForm instanceof HTMLFormElement && composerForm.dataset.focusComposer === 'true' && composerInput instanceof HTMLTextAreaElement) {
          requestAnimationFrame(() => focusElement(composerInput, {
            preventScroll: isCompactViewport(),
            announcement: 'Η εστίαση μεταφέρθηκε στο composer για νέα αποστολή.'
          }));
        }
      }
    })();
  </script>
</Layout>
