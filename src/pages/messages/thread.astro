---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  clean,
  getMessageThreadId,
  readNdjson,
  writeNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const threadId = clean(url.searchParams.get('threadId'));
const viewerEmail = clean(url.searchParams.get('viewerEmail')).toLowerCase();
const status = clean(url.searchParams.get('status'));
const messageStatus = clean(url.searchParams.get('message'));
const threadBlockedByModeration = messageStatus === 'blocked';

const allMessages = await readNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH);
const visibilityActions = await readNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH);
const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const threadMessages = allMessages
  .filter((message) => getMessageThreadId(message) === threadId)
  .sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));

const isParticipant = threadMessages.some(
  (message) => message.senderEmail.toLowerCase() === viewerEmail || message.recipientEmail.toLowerCase() === viewerEmail
);

if (threadId && viewerEmail && isParticipant) {
  const states = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
  const next = states.filter((entry) => !(entry.threadId === threadId && entry.viewerEmail === viewerEmail));
  const lastReadAt = threadMessages.at(-1)?.submittedAt || new Date().toISOString();
  next.push({ threadId, viewerEmail, lastReadAt });
  await writeNdjson(MESSAGE_READ_STATE_FILE_PATH, next);
}

const canReply = threadMessages.length > 0 && isParticipant && !threadBlockedByModeration;
const latest = threadMessages.at(-1);
const recipientForReply = latest
  ? latest.senderEmail.toLowerCase() === viewerEmail
    ? latest.recipientEmail
    : latest.senderEmail
  : '';
const professionalSlug = latest?.professionalSlug ?? '';
const hasMissingParams = !threadId || !viewerEmail;
const hasAccessIssue = !hasMissingParams && !isParticipant;
---

<Layout title="Thread μηνυμάτων | GreekHandy" description="Προβολή συνομιλίας με χρονική σειρά μηνυμάτων.">
  <main class="mx-auto max-w-4xl px-4 py-14">
    <a href={`/messages?viewerEmail=${encodeURIComponent(viewerEmail)}`} class="text-sm font-semibold text-blue-700 hover:underline">&larr; Επιστροφή στις συνομιλίες</a>

    <h1 class="mt-3 text-2xl font-bold text-gray-900">Συνομιλία</h1>

    {hasMissingParams && (
      <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
        <p class="font-semibold">Δεν μπορέσαμε να ανοίξουμε τη συνομιλία.</p>
        <p class="mt-1 text-sm">Λείπουν τα απαραίτητα στοιχεία threadId ή viewerEmail.</p>
      </div>
    )}

    {hasAccessIssue && (
      <div class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-800">
        <p class="font-semibold">Δεν έχετε πρόσβαση σε αυτό το thread.</p>
        <p class="mt-1 text-sm">Επιστρέψτε στη λίστα συνομιλιών και ανοίξτε ένα thread όπου συμμετέχετε.</p>
      </div>
    )}

    {threadId && viewerEmail && isParticipant && (
      <>
        {messageStatus === 'submitted' && <p class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">Το μήνυμα στάλθηκε επιτυχώς.</p>}
        {messageStatus === 'invalid' && <p class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">Μη έγκυρα στοιχεία μηνύματος. Ελέγξτε το περιεχόμενο και προσπαθήστε ξανά.</p>}
        {messageStatus === 'error' && <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800">Δεν ήταν δυνατή η αποστολή μηνύματος. Προσπαθήστε ξανά σε λίγο.</p>}
        {messageStatus === 'blocked' && <p class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-800">Η αποστολή σε αυτό το thread έχει μπλοκαριστεί από moderation.</p>}

        {status === 'reported' && <p class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">Η αναφορά καταχωρήθηκε και θα εξεταστεί από την ομάδα moderation.</p>}
        {status === 'report-error' && <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800">Δεν ήταν δυνατή η αναφορά.</p>}
        {status === 'report-invalid' && <p class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800">Μη έγκυρα στοιχεία αναφοράς.</p>}
        {status === 'report-forbidden' && <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800">Δεν έχετε πρόσβαση για αναφορά αυτού του μηνύματος.</p>}

        <section class="mt-6 space-y-3">
          {threadMessages.length === 0 && (
            <div class="rounded-lg border border-gray-200 bg-white px-4 py-4 text-gray-700">
              <p class="font-semibold text-gray-900">Δεν υπάρχουν μηνύματα ακόμη.</p>
              <p class="mt-1 text-sm text-gray-600">Στείλτε το πρώτο μήνυμα για να ξεκινήσει η συνομιλία.</p>
            </div>
          )}

          {threadMessages.map((message) => {
            const own = message.senderEmail.toLowerCase() === viewerEmail;
            const hidden = hiddenMessageIds.has(message.id);
            return (
              <article class={`rounded-2xl border p-4 shadow-sm ${own ? 'border-indigo-200 bg-gradient-to-br from-indigo-50 to-white' : 'border-gray-200 bg-white'}`}>
                <p class="text-xs text-gray-500">{own ? 'Εσείς' : message.senderName} • {new Date(message.submittedAt).toLocaleString('el-GR')}</p>
                <p class="mt-2 text-sm leading-6 text-gray-800">{hidden ? 'Το μήνυμα έχει κρυφτεί από moderation.' : message.message}</p>

                {hidden && <p class="mt-2 inline-flex rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-[11px] font-semibold text-amber-800">Κρυφό από moderation</p>}

                {!hidden && !own && (
                  <form action="/api/messages/report" method="POST" class="js-pending-form mt-3 rounded-lg border border-amber-200 bg-amber-50/60 p-3">
                    <input type="hidden" name="threadId" value={threadId} />
                    <input type="hidden" name="messageId" value={message.id} />
                    <input type="hidden" name="senderEmail" value={viewerEmail} />
                    <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />
                    <p class="text-xs font-semibold text-amber-900">Εργαλείο moderation</p>
                    <label class="mt-2 block text-xs text-amber-900">
                      Αιτία αναφοράς
                      <select name="reason" class="mt-1 w-full rounded-md border border-amber-300 bg-white px-2 py-1 text-xs text-gray-800">
                        <option value="spam">Spam</option>
                        <option value="abuse">Κακοποίηση</option>
                        <option value="harassment">Παρενόχληση</option>
                        <option value="other" selected>Άλλο</option>
                      </select>
                    </label>
                    <label class="mt-2 block text-xs text-amber-900">
                      Σχόλιο (προαιρετικό)
                      <input type="text" name="details" maxlength="400" class="mt-1 w-full rounded-md border border-amber-300 bg-white px-2 py-1 text-xs text-gray-800" placeholder="Περιγράψτε σύντομα το θέμα" />
                    </label>
                    <button type="submit" data-default-label="Αναφορά μηνύματος" class="mt-2 text-xs font-semibold text-amber-900 underline underline-offset-2">Αναφορά μηνύματος</button>
                  </form>
                )}
              </article>
            );
          })}
        </section>

        {!canReply && threadBlockedByModeration && (
          <div class="mt-6 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900">
            <p class="font-semibold">Το thread είναι περιορισμένο.</p>
            <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων έχει απενεργοποιηθεί από την ομάδα moderation.</p>
          </div>
        )}

        {canReply && (
          <form action="/api/messages/submit" method="POST" class="js-pending-form mt-6 rounded-2xl border border-indigo-100 bg-gradient-to-br from-indigo-50 to-white p-4 shadow-sm">
            <h2 class="text-base font-bold text-gray-900">Νέο μήνυμα</h2>
            <p class="mt-1 text-xs text-gray-600">Απάντηση μέσα στο ίδιο thread. Η συνομιλία ενημερώνεται αυτόματα στη λίστα.</p>
            <input type="hidden" name="professionalSlug" value={professionalSlug} />
            <input type="hidden" name="threadId" value={threadId} />
            <input type="hidden" name="senderName" value="Participant" />
            <input type="hidden" name="senderEmail" value={viewerEmail} />
            <input type="hidden" name="recipientEmail" value={recipientForReply} />
            <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />
            <textarea name="message" rows="4" required maxlength="2000" class="mt-3 w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm"></textarea>
            <button type="submit" data-default-label="Αποστολή" class="mt-3 rounded-lg bg-indigo-700 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-800 disabled:cursor-not-allowed disabled:opacity-60">Αποστολή</button>
          </form>
        )}
      </>
    )}
  </main>

  <script is:inline>
    for (const form of document.querySelectorAll('.js-pending-form')) {
      form.addEventListener('submit', () => {
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;
        submitButton.disabled = true;
        const defaultLabel = submitButton.dataset.defaultLabel || submitButton.textContent || 'Αποστολή';
        submitButton.textContent = 'Επεξεργασία...';
        submitButton.setAttribute('aria-busy', 'true');
        form.classList.add('opacity-80');
        form.setAttribute('data-submit-label', defaultLabel);
      }, { once: true });
    }
  </script>
</Layout>
