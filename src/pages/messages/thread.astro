---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_TRIAGE_ACTIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  clean,
  getMessageThreadId,
  readNdjson,
  writeNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const threadId = clean(url.searchParams.get('threadId'));
const viewerEmail = clean(url.searchParams.get('viewerEmail')).toLowerCase();
const status = clean(url.searchParams.get('status'));
const messageStatus = clean(url.searchParams.get('message'));
const knownThreadStatuses = new Set(['', 'reported', 'report-error', 'report-invalid', 'report-forbidden', 'loading']);
const knownMessageStatuses = new Set(['', 'submitted', 'invalid', 'error', 'blocked', 'loading']);
const showLoadingState = status === 'loading' || messageStatus === 'loading';
const hasUnknownStatus = status !== '' && !knownThreadStatuses.has(status);
const hasUnknownMessageStatus = messageStatus !== '' && !knownMessageStatuses.has(messageStatus);
const formatDateTime = (value: string) => new Date(value).toLocaleString('el-GR');
const toDomId = (value: string, fallback: string) => {
  const normalized = value.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  const fallbackNormalized = fallback.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  return normalized || fallbackNormalized || 'item';
};

let threadLoadError = '';
const safeReadNdjson = async <T,>(path: string, label: string): Promise<T[]> => {
  try {
    return await readNdjson<T>(path);
  } catch {
    if (!threadLoadError) threadLoadError = `Δεν ήταν δυνατή η φόρτωση δεδομένων (${label}).`;
    return [];
  }
};

const allMessages = await safeReadNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH, 'μηνύματα');
const visibilityActions = await safeReadNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH, 'ορατότητα');
const triageActions = await safeReadNdjson<{ threadId?: string; action?: string }>(MESSAGE_TRIAGE_ACTIONS_FILE_PATH, 'moderation');

const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const latestTriageActionByThread = new Map<string, string>();
for (const entry of triageActions) {
  if (entry.threadId && entry.action) latestTriageActionByThread.set(entry.threadId, entry.action);
}

const threadMessages = allMessages
  .filter((message) => getMessageThreadId(message) === threadId)
  .sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));

const isParticipant = threadMessages.some(
  (message) => message.senderEmail.toLowerCase() === viewerEmail || message.recipientEmail.toLowerCase() === viewerEmail
);

let readStateWriteError = '';
if (threadId && viewerEmail && isParticipant && !showLoadingState) {
  try {
    const states = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
    const next = states.filter((entry) => !(entry.threadId === threadId && entry.viewerEmail === viewerEmail));
    const lastReadAt = threadMessages.at(-1)?.submittedAt || new Date().toISOString();
    next.push({ threadId, viewerEmail, lastReadAt });
    await writeNdjson(MESSAGE_READ_STATE_FILE_PATH, next);
  } catch {
    readStateWriteError = 'Δεν ήταν δυνατή η ενημέρωση της κατάστασης ανάγνωσης.';
  }
}

const latestThreadAction = threadId ? (latestTriageActionByThread.get(threadId) || '') : '';
const threadBlockedByModeration = messageStatus === 'blocked' || latestThreadAction === 'block';
const threadReviewedByModeration = latestThreadAction === 'review';
const threadRejectedByModeration = latestThreadAction === 'reject';

const hiddenMessagesCount = threadMessages.filter((message) => hiddenMessageIds.has(message.id)).length;
const visibleMessagesCount = Math.max(0, threadMessages.length - hiddenMessagesCount);
const threadHasAdminHidden = hiddenMessagesCount > 0;
const threadMutedByModeration = threadMessages.length > 0 && hiddenMessagesCount === threadMessages.length;
const threadUnderModeration = threadBlockedByModeration || threadReviewedByModeration || threadRejectedByModeration || threadHasAdminHidden;
const threadModerationTone = threadBlockedByModeration
  ? 'blocked'
  : threadHasAdminHidden
    ? 'hidden'
    : threadReviewedByModeration
      ? 'reported'
      : threadRejectedByModeration
        ? 'rejected'
        : 'active';

const threadModerationLabel = threadModerationTone === 'blocked'
  ? 'Μπλοκαρισμένη συνομιλία'
  : threadModerationTone === 'hidden'
    ? 'Κρυφό περιεχόμενο'
    : threadModerationTone === 'reported'
      ? 'Αναφορά σε έλεγχο'
      : threadModerationTone === 'rejected'
        ? 'Αναφορά χωρίς περιορισμό'
        : 'Ενεργή συνομιλία';

const threadModerationDescription = threadModerationTone === 'blocked'
  ? 'Η συνομιλία έχει μπλοκαριστεί από moderation. Μπορείτε να διαβάζετε το ιστορικό, αλλά δεν επιτρέπεται νέα αποστολή.'
  : threadModerationTone === 'hidden'
    ? threadMutedByModeration
      ? 'Όλα τα μηνύματα είναι κρυφά από moderation. Η απάντηση είναι προσωρινά απενεργοποιημένη.'
      : `Μέρος της συνομιλίας έχει κρυφτεί από moderation (κρυφά: ${hiddenMessagesCount}/${threadMessages.length}).`
    : threadModerationTone === 'reported'
      ? 'Η συνομιλία έχει αναφερθεί και βρίσκεται σε ενεργό έλεγχο moderation.'
      : threadModerationTone === 'rejected'
        ? 'Η τελευταία αναφορά έκλεισε χωρίς πρόσθετο περιορισμό. Το thread παραμένει ενεργό.'
        : 'Δεν υπάρχει ενεργός περιορισμός moderation.';

const threadModerationBannerClass = threadModerationTone === 'blocked'
  ? 'border-rose-300 bg-gradient-to-r from-rose-50/95 via-white to-rose-50/80 text-rose-900'
  : threadModerationTone === 'hidden'
    ? 'border-orange-300 bg-gradient-to-r from-orange-50/95 via-white to-amber-50/80 text-orange-900'
    : threadModerationTone === 'reported'
      ? 'border-sky-300 bg-gradient-to-r from-sky-50/95 via-white to-sky-50/80 text-sky-900'
      : threadModerationTone === 'rejected'
        ? 'border-amber-300 bg-gradient-to-r from-amber-50/95 via-white to-amber-50/80 text-amber-900'
        : 'border-emerald-300 bg-gradient-to-r from-emerald-50/95 via-white to-emerald-50/80 text-emerald-900';
const moderationSeverityLabel = threadModerationTone === 'blocked'
  ? 'Κρίσιμος περιορισμός'
  : threadModerationTone === 'hidden'
    ? 'Ενισχυμένος έλεγχος περιεχομένου'
    : threadModerationTone === 'reported'
      ? 'Ενεργός έλεγχος αναφοράς'
      : threadModerationTone === 'rejected'
        ? 'Καταγεγραμμένη αναφορά'
        : 'Κανονική λειτουργία';

const canReply = threadMessages.length > 0 && isParticipant && !threadBlockedByModeration && !threadMutedByModeration;
const showReportedConversationBanner = !threadBlockedByModeration && (threadReviewedByModeration || threadRejectedByModeration);
const reportedConversationBannerTitle = threadReviewedByModeration
  ? 'Αναφερόμενη συνομιλία σε έλεγχο'
  : 'Αναφερόμενη συνομιλία με ολοκληρωμένο έλεγχο';
const reportedConversationBannerDescription = threadReviewedByModeration
  ? 'Η ομάδα moderation αξιολογεί το thread. Η αποστολή παραμένει διαθέσιμη μέχρι να επιβληθεί διαφορετικός περιορισμός.'
  : 'Η αναφορά εξετάστηκε και έκλεισε χωρίς μπλοκάρισμα ή νέα απόκρυψη περιεχομένου.';
const moderationReplyGuidance = canReply
  ? 'Μπορείτε να συνεχίσετε με απάντηση σε αυτό το thread.'
  : threadBlockedByModeration
    ? 'Η αποστολή νέου μηνύματος είναι απενεργοποιημένη.'
    : threadMutedByModeration
      ? 'Η απάντηση είναι απενεργοποιημένη μέχρι να αρθεί η απόκρυψη.'
      : 'Το composer δεν είναι διαθέσιμο σε αυτή την κατάσταση.';
const latest = threadMessages.at(-1);
const recipientForReply = latest
  ? latest.senderEmail.toLowerCase() === viewerEmail
    ? latest.recipientEmail
    : latest.senderEmail
  : '';
const professionalSlug = latest?.professionalSlug ?? '';
const hasMissingParams = !threadId || !viewerEmail;
const hasAccessIssue = !hasMissingParams && !isParticipant && !threadLoadError;
const composerInitialState = messageStatus === 'submitted'
  ? 'success'
  : messageStatus === 'invalid' || messageStatus === 'error' || messageStatus === 'blocked'
    ? 'error'
    : 'idle';
const composerInitialStateLabel = composerInitialState === 'success'
  ? 'Το τελευταίο μήνυμα στάλθηκε επιτυχώς.'
  : composerInitialState === 'error'
    ? 'Η τελευταία αποστολή απέτυχε. Ελέγξτε το κείμενο και δοκιμάστε ξανά.'
    : 'Το composer είναι έτοιμο για αποστολή.';

const participants = new Set<string>();
for (const message of threadMessages) {
  participants.add(message.senderEmail.toLowerCase());
  participants.add(message.recipientEmail.toLowerCase());
}
const counterpartEmail = [...participants].find((email) => email !== viewerEmail) || recipientForReply.toLowerCase();
---

<Layout title="Συνομιλία μηνυμάτων | GreekHandy" description="Αναλυτική προβολή thread με moderation badges, reporting εργαλεία και κατάσταση απάντησης.">
  <main class="thread-shell mx-auto max-w-6xl px-4 py-10 md:py-14">
    <a
      href={`/messages?viewerEmail=${encodeURIComponent(viewerEmail)}`}
      class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-50"
    >
      <span aria-hidden="true">←</span>
      Επιστροφή στις συνομιλίες
    </a>

    <section class="mt-4 overflow-hidden rounded-[2rem] border border-slate-200/80 bg-gradient-to-br from-[#f8fbff] via-white to-[#f3f7fc] p-6 shadow-[0_14px_42px_-28px_rgba(15,23,42,0.42)] md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">GreekHandy Συνομιλία</p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">Συνομιλία</h1>
          <p class="mt-3 text-sm leading-6 text-slate-600">Πλήρες ιστορικό μηνυμάτων με ενισχυμένη ανάγνωση context και εμφανή moderation κατάσταση.</p>
        </div>

        <div class="rounded-2xl border border-sky-200/70 bg-white/90 px-4 py-3 text-right shadow-[0_12px_34px_-24px_rgba(2,132,199,0.5)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-sky-700">Προβολή ως</p>
          <p class="mt-1 break-all text-sm font-semibold text-slate-900">{viewerEmail || 'Άγνωστος χρήστης'}</p>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-2xl border border-slate-200 bg-white/90 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Μηνύματα</p>
          <p class="mt-1 text-xl font-bold text-slate-900">{threadMessages.length}</p>
          <p class="text-xs text-slate-500">στο ίδιο thread</p>
        </article>
        <article class="rounded-2xl border border-emerald-300 bg-emerald-50/75 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-emerald-800">Ορατά</p>
          <p class="mt-1 text-xl font-bold text-emerald-900">{visibleMessagesCount}</p>
          <p class="text-xs text-emerald-800">άμεσα διαθέσιμα</p>
        </article>
        <article class="rounded-2xl border border-orange-300 bg-orange-50/80 px-4 py-3">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-orange-800">Κρυφά</p>
          <p class="mt-1 text-xl font-bold text-orange-900">{hiddenMessagesCount}</p>
          <p class="text-xs text-orange-800">από moderation</p>
        </article>
        <article class={`rounded-2xl border px-4 py-3 ${threadUnderModeration ? 'border-amber-300 bg-amber-50/80' : 'border-sky-300 bg-sky-50/80'}`}>
          <p class={`text-[11px] font-semibold uppercase tracking-[0.12em] ${threadUnderModeration ? 'text-amber-800' : 'text-sky-800'}`}>Κατάσταση</p>
          <p class={`mt-1 text-xl font-bold ${threadUnderModeration ? 'text-amber-900' : 'text-sky-900'}`}>{threadModerationLabel}</p>
          <p class={`text-xs ${threadUnderModeration ? 'text-amber-800' : 'text-sky-800'}`}>{moderationSeverityLabel}</p>
        </article>
      </div>

      {threadId && (
        <p class="mt-4 rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-600">
          Κωδικός thread: <span class="font-mono text-slate-800">{threadId}</span>
        </p>
      )}
      <p class="mt-2 text-xs text-slate-500">Με το άνοιγμα του thread, τα τρέχοντα μηνύματα σημειώνονται ως διαβασμένα για τον χρήστη προβολής.</p>
    </section>

    {hasMissingParams && (
      <div class="thread-alert thread-alert--amber mt-5" role="alert">
        <p class="font-semibold">Δεν μπορέσαμε να ανοίξουμε τη συνομιλία.</p>
        <p class="mt-1 text-sm">Λείπουν τα απαραίτητα στοιχεία <code>threadId</code> ή <code>viewerEmail</code>.</p>
      </div>
    )}

    {hasAccessIssue && (
      <div class="thread-alert thread-alert--rose mt-5" role="alert">
        <p class="font-semibold">Δεν έχετε πρόσβαση σε αυτό το thread.</p>
        <p class="mt-1 text-sm">Επιστρέψτε στη λίστα συνομιλιών και επιλέξτε thread όπου συμμετέχετε.</p>
      </div>
    )}
    {threadLoadError && (
      <div class="thread-alert thread-alert--rose mt-5" role="alert">
        <p class="font-semibold">Δεν ήταν δυνατή η πλήρης φόρτωση της συνομιλίας.</p>
        <p class="mt-1 text-sm">{threadLoadError}</p>
      </div>
    )}

    {threadId && viewerEmail && isParticipant && (
      <>
        {messageStatus === 'submitted' && <p class="thread-alert thread-alert--emerald mt-5" role="status" aria-live="polite">Το μήνυμα στάλθηκε επιτυχώς.</p>}
        {messageStatus === 'invalid' && <p class="thread-alert thread-alert--amber mt-5" role="alert">Μη έγκυρα στοιχεία μηνύματος. Ελέγξτε το περιεχόμενο και προσπαθήστε ξανά.</p>}
        {messageStatus === 'error' && <p class="thread-alert thread-alert--rose mt-5" role="alert">Δεν ήταν δυνατή η αποστολή μηνύματος. Προσπαθήστε ξανά σε λίγο.</p>}
        {messageStatus === 'blocked' && <p class="thread-alert thread-alert--rose mt-5" role="alert">Η αποστολή σε αυτό το thread έχει μπλοκαριστεί από moderation.</p>}

        {status === 'reported' && <p class="thread-alert thread-alert--sky mt-5" role="status" aria-live="polite">Η αναφορά καταχωρήθηκε και θα εξεταστεί από την ομάδα moderation.</p>}
        {status === 'report-error' && <p class="thread-alert thread-alert--rose mt-5" role="alert">Δεν ήταν δυνατή η αποστολή της αναφοράς.</p>}
        {status === 'report-invalid' && <p class="thread-alert thread-alert--amber mt-5" role="alert">Μη έγκυρα στοιχεία αναφοράς.</p>}
        {status === 'report-forbidden' && <p class="thread-alert thread-alert--rose mt-5" role="alert">Δεν έχετε πρόσβαση για αναφορά αυτού του μηνύματος.</p>}
        {hasUnknownStatus && (
          <p class="thread-alert mt-5 border-slate-300 bg-slate-50 text-slate-700" role="status" aria-live="polite">
            Ελήφθη άγνωστη κατάσταση thread: <code>{status}</code>.
          </p>
        )}
        {hasUnknownMessageStatus && (
          <p class="thread-alert mt-5 border-slate-300 bg-slate-50 text-slate-700" role="status" aria-live="polite">
            Ελήφθη άγνωστη κατάσταση μηνύματος: <code>{messageStatus}</code>.
          </p>
        )}
        {readStateWriteError && (
          <p class="thread-alert thread-alert--amber mt-5" role="alert">{readStateWriteError}</p>
        )}
        {showLoadingState && (
          <p class="thread-alert thread-alert--sky mt-5 flex items-center gap-2" role="status" aria-live="polite">
            <span class="h-3 w-3 animate-spin rounded-full border-2 border-sky-300 border-t-sky-700"></span>
            Φόρτωση συνομιλίας...
          </p>
        )}

        <nav class="mt-5 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm" aria-label="Γρήγορη πλοήγηση συνομιλίας">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Γρήγορη πλοήγηση</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <a href="#thread-history" class="inline-flex items-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
              Ιστορικό μηνυμάτων
            </a>
            {canReply && (
              <a href="#thread-composer" class="inline-flex items-center rounded-full border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                Μετάβαση στο composer
              </a>
            )}
          </div>
        </nav>

        {threadBlockedByModeration && (
          <div class="mt-5 rounded-2xl border border-rose-300 bg-gradient-to-r from-rose-50/95 via-white to-rose-50/80 px-4 py-4 text-rose-900 shadow-sm">
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-rose-800">Περιορισμός αποστολής</p>
            <p class="mt-1 text-sm font-semibold">Μπλοκαρισμένη συνομιλία</p>
            <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων είναι απενεργοποιημένη από moderation.</p>
            <p class="mt-1 text-xs">Μπορείτε να διαβάσετε το ιστορικό και τις αναφορές, αλλά το composer παραμένει κλειδωμένο μέχρι να αρθεί ο περιορισμός.</p>
          </div>
        )}
        {showReportedConversationBanner && (
          <div class={`mt-5 rounded-2xl border px-4 py-4 shadow-sm ${threadReviewedByModeration ? 'border-sky-300 bg-gradient-to-r from-sky-50/95 via-white to-sky-50/80 text-sky-900' : 'border-amber-300 bg-gradient-to-r from-amber-50/95 via-white to-amber-50/80 text-amber-900'}`}>
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em]">{reportedConversationBannerTitle}</p>
            <p class="mt-1 text-sm">{reportedConversationBannerDescription}</p>
          </div>
        )}

        <div class={`mt-5 rounded-2xl border px-4 py-4 shadow-sm ${threadModerationBannerClass}`}>
          <div class="flex flex-wrap items-start justify-between gap-2">
            <p class="font-semibold">Κατάσταση thread: {threadModerationLabel}</p>
            <span class="rounded-full border border-current/20 bg-white/80 px-2.5 py-1 text-[11px] font-semibold">{moderationSeverityLabel}</span>
          </div>
          <p class="mt-1 text-sm">{threadModerationDescription}</p>
          <p class="mt-2 rounded-lg border border-current/20 bg-white/75 px-3 py-2 text-xs font-medium">{moderationReplyGuidance}</p>
        </div>

        <section class="mt-5 rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm text-slate-700 shadow-sm" aria-label="Ροή απόκρισης thread">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Ροή απάντησης</p>
          <ol class="mt-2 space-y-2">
            <li class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
              1. Ελέγξτε την τελευταία κατάσταση moderation πριν απαντήσετε.
            </li>
            <li class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2">
              2. Αναφέρετε εισερχόμενο μήνυμα αν απαιτείται αξιολόγηση από moderation.
            </li>
            <li class={`rounded-lg border px-3 py-2 font-medium ${canReply ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : 'border-amber-200 bg-amber-50 text-amber-900'}`}>
              3. {canReply ? 'Το composer είναι ενεργό. Η απάντηση θα σταλεί στο ίδιο thread.' : 'Το composer είναι ανενεργό μέχρι να αρθεί ο τρέχων περιορισμός.'}
            </li>
          </ol>
        </section>

        <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_16px_42px_-30px_rgba(15,23,42,0.5)] md:p-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Κάρτα συνομιλίας</h2>
              <p class="mt-1 text-sm text-slate-600">Γρήγορη εικόνα για συμμετέχοντα, ορατότητα και moderation context.</p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              {threadBlockedByModeration && <span class="rounded-full border border-rose-300 bg-rose-100 px-2.5 py-1 text-[11px] font-semibold text-rose-900">Μπλοκαρισμένη</span>}
              {!threadBlockedByModeration && threadHasAdminHidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Κρυφό περιεχόμενο</span>}
              {!threadBlockedByModeration && !threadHasAdminHidden && threadReviewedByModeration && <span class="rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 text-[11px] font-semibold text-sky-900">Αναφορά σε έλεγχο</span>}
              {!threadBlockedByModeration && !threadHasAdminHidden && threadRejectedByModeration && <span class="rounded-full border border-amber-300 bg-amber-100 px-2.5 py-1 text-[11px] font-semibold text-amber-900">Αναφορά χωρίς περιορισμό</span>}
              {!threadBlockedByModeration && threadMutedByModeration && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Σε σίγαση</span>}
              {!threadUnderModeration && <span class="rounded-full border border-emerald-300 bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-900">Ενεργή</span>}
            </div>
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Συμμετέχων</p>
              <p class="mt-1 break-all text-sm font-semibold text-slate-900">{counterpartEmail || 'Μη διαθέσιμος'}</p>
            </article>
            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Κατάσταση</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">{threadModerationLabel}</p>
              <p class="mt-0.5 text-xs text-slate-600">{moderationSeverityLabel}</p>
            </article>
            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Ορατότητα</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">Ορατά {visibleMessagesCount} / Κρυφά {hiddenMessagesCount}</p>
              <p class="mt-0.5 text-xs text-slate-600">Σύνολο μηνυμάτων: {threadMessages.length}</p>
            </article>
            <article class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Τελευταία δραστηριότητα</p>
              <p class="mt-1 text-sm font-semibold text-slate-900">{latest ? formatDateTime(latest.submittedAt) : 'Δεν υπάρχει activity'}</p>
              <p class="mt-0.5 text-xs text-slate-600">Παραλήπτης απάντησης: {recipientForReply || 'Μη διαθέσιμος'}</p>
            </article>
          </div>

          <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50/80 px-3 py-2 text-xs text-slate-600">
            Ενέργειες moderation: <span class="font-semibold text-sky-800">αναφορά</span> · <span class="font-semibold text-rose-800">μπλοκάρισμα</span> · <span class="font-semibold text-orange-800">απόκρυψη</span>
          </div>
        </section>

        <section id="thread-history" class="mt-5 rounded-2xl border border-slate-200 bg-white/70 px-4 py-4 shadow-sm md:px-5" aria-labelledby="thread-history-title">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 id="thread-history-title" class="text-lg font-semibold text-slate-900">Ιστορικό μηνυμάτων</h2>
              <p id="thread-history-description" class="mt-1 text-sm text-slate-600">Προβολή όλων των μηνυμάτων του thread με άμεσες ενέργειες αναφοράς στα εισερχόμενα.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-right">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Ροή</p>
              <p class="mt-1 text-xs font-semibold text-slate-700">{threadMessages.length} μηνύματα</p>
            </div>
          </div>

          <div class="mt-4 space-y-3" role="list" aria-describedby="thread-history-description">
            {showLoadingState && [1, 2, 3].map((item) => (
              <article class="animate-pulse rounded-2xl border border-slate-200 bg-white p-4 shadow-sm" aria-hidden="true" role="listitem">
                <div class="h-3 w-24 rounded bg-slate-200"></div>
                <div class="mt-3 h-3 w-full rounded bg-slate-100"></div>
                <div class="mt-2 h-3 w-5/6 rounded bg-slate-100"></div>
              </article>
            ))}

            {!showLoadingState && threadMessages.length === 0 && (
              <div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 px-5 py-6 shadow-sm">
                <p class="text-lg font-semibold text-slate-900">Δεν υπάρχουν μηνύματα ακόμη.</p>
                <p class="mt-1 text-sm text-slate-600">Στείλτε το πρώτο μήνυμα για να ξεκινήσει η συνομιλία.</p>
                <p class="mt-2 text-xs text-slate-500">Οι καταστάσεις αναφοράς, μπλοκαρίσματος και απόκρυψης εμφανίζονται αυτόματα όταν υπάρξει activity.</p>
              </div>
            )}

            {!showLoadingState && threadMessages.map((message) => {
              const own = message.senderEmail.toLowerCase() === viewerEmail;
              const hidden = hiddenMessageIds.has(message.id);
              const messageIdToken = toDomId(message.id, `message-${message.submittedAt}`);
              const reasonId = `report-reason-${messageIdToken}`;
              const detailsId = `report-details-${messageIdToken}`;
              const reportHintId = `report-hint-${messageIdToken}`;
              return (
                <div class={`flex ${own ? 'justify-end' : 'justify-start'}`} role="listitem">
                  <article class={`thread-message w-full max-w-3xl ${
                    hidden
                      ? 'thread-message--hidden'
                      : own
                        ? 'thread-message--own'
                        : 'thread-message--incoming'
                  }`}>
                    <div class="flex flex-wrap items-start justify-between gap-2">
                      <div>
                        <p class="text-xs font-semibold text-slate-700">{own ? 'Εσείς' : (message.senderName || 'Συνεργάτης')}</p>
                        <p class="mt-0.5 text-xs text-slate-500">{formatDateTime(message.submittedAt)}</p>
                      </div>
                      <div class="flex flex-wrap gap-1.5">
                        {own && <span class="rounded-full border border-sky-300 bg-sky-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-sky-900">Εξερχόμενο</span>}
                        {!own && <span class="rounded-full border border-slate-300 bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-700">Εισερχόμενο</span>}
                        {hidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-orange-900">Κρυφό περιεχόμενο</span>}
                      </div>
                    </div>

                    <p class={`mt-2 text-sm leading-7 ${hidden ? 'font-medium text-orange-900' : 'whitespace-pre-wrap text-slate-800'}`}>
                      {hidden ? 'Το μήνυμα έχει αποκρυφτεί από moderation.' : message.message}
                    </p>

                    {hidden && <p class="mt-2 text-xs font-semibold text-orange-900">Η προβολή του περιεχομένου είναι περιορισμένη από την ομάδα moderation.</p>}

                    {!hidden && !own && (
                      <details class="thread-report mt-3 rounded-xl border border-amber-200 bg-gradient-to-br from-amber-50/80 to-white p-3">
                        <summary class="cursor-pointer text-xs font-semibold text-amber-900">Αναφορά μηνύματος στη διαχείριση</summary>
                        <form action="/api/messages/report" method="POST" class="js-pending-form mt-3 space-y-2">
                          <input type="hidden" name="threadId" value={threadId} />
                          <input type="hidden" name="messageId" value={message.id} />
                          <input type="hidden" name="senderEmail" value={viewerEmail} />
                          <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />

                          <label class="block text-xs font-medium text-amber-900">
                            Αιτία αναφοράς
                            <select id={reasonId} name="reason" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800">
                              <option value="spam">Spam</option>
                              <option value="abuse">Κακοποίηση</option>
                              <option value="harassment">Παρενόχληση</option>
                              <option value="other" selected>Άλλο</option>
                            </select>
                          </label>

                          <label class="block text-xs font-medium text-amber-900">
                            Σχόλιο (προαιρετικό)
                            <input id={detailsId} type="text" name="details" maxlength="400" class="mt-1 w-full rounded-lg border border-amber-300 bg-white px-2.5 py-2 text-xs text-slate-800" placeholder="Περιγράψτε σύντομα το θέμα" aria-describedby={reportHintId} />
                          </label>

                          <p id={reportHintId} class="text-[11px] text-amber-900">Η αναφορά αποστέλλεται στη διαχείριση χωρίς να αλλάζει άμεσα η ροή της συνομιλίας.</p>
                          <button type="submit" data-default-label="Υποβολή αναφοράς" data-pending-label="Υποβολή..." class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-xs font-semibold text-amber-900 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-65">
                            Υποβολή αναφοράς
                          </button>
                        </form>
                      </details>
                    )}
                  </article>
                </div>
              );
            })}
          </div>
        </section>

        {!canReply && threadBlockedByModeration && (
          <div class="thread-alert thread-alert--rose mt-6" role="alert">
            <p class="font-semibold">Το thread είναι περιορισμένο.</p>
            <p class="mt-1 text-sm">Η αποστολή νέων μηνυμάτων έχει απενεργοποιηθεί από την ομάδα moderation.</p>
          </div>
        )}

        {!threadBlockedByModeration && threadMutedByModeration && (
          <div class="thread-alert thread-alert--orange mt-6" role="alert">
            <p class="font-semibold">Η συνομιλία βρίσκεται σε κατάσταση σίγασης.</p>
            <p class="mt-1 text-sm">Τα μηνύματα είναι κρυφά από moderation. Δεν μπορείτε να στείλετε νέο μήνυμα όσο ισχύει ο περιορισμός.</p>
          </div>
        )}

        {!canReply && !threadBlockedByModeration && !threadMutedByModeration && (
          <div class="thread-alert thread-alert--amber mt-6" role="alert">
            <p class="font-semibold">Δεν είναι διαθέσιμο το composer.</p>
            <p class="mt-1 text-sm">Ελέγξτε ότι υπάρχει έγκυρος παραλήπτης και ότι το thread είναι ενεργό.</p>
          </div>
        )}

        {canReply && (
          <form
            id="thread-composer"
            action="/api/messages/submit"
            method="POST"
            class="js-pending-form js-composer-form mt-6 rounded-2xl border border-sky-200 bg-gradient-to-br from-sky-50 to-white p-5 shadow-[0_16px_42px_-30px_rgba(14,116,144,0.45)]"
            data-composer-state={composerInitialState}
            aria-labelledby="thread-composer-title"
            aria-describedby="thread-composer-description composer-state composer-shortcuts composer-error composer-count composer-live"
          >
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <h2 id="thread-composer-title" class="text-lg font-semibold text-slate-900">Composer απάντησης</h2>
                <p id="thread-composer-description" class="mt-1 text-sm text-slate-600">Απάντηση μέσα στο ίδιο thread με αυτόματη ενημέρωση στη λίστα συνομιλιών.</p>
              </div>
              <span id="composer-state" class={`inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold ${
                composerInitialState === 'success'
                  ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
                  : composerInitialState === 'error'
                    ? 'border-rose-300 bg-rose-100 text-rose-900'
                    : 'border-sky-300 bg-sky-100 text-sky-900'
              }`} role="status" aria-live="polite">
                {composerInitialStateLabel}
              </span>
            </div>
            <input type="hidden" name="professionalSlug" value={professionalSlug} />
            <input type="hidden" name="threadId" value={threadId} />
            <input type="hidden" name="senderName" value="Participant" />
            <input type="hidden" name="senderEmail" value={viewerEmail} />
            <input type="hidden" name="recipientEmail" value={recipientForReply} />
            <input type="hidden" name="returnTo" value={`/messages/thread?threadId=${encodeURIComponent(threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`} />
            <label for="composer-message" class="mt-3 block text-xs font-semibold uppercase tracking-[0.12em] text-slate-600">Κείμενο απάντησης</label>
            <textarea
              id="composer-message"
              name="message"
              rows="4"
              required
              maxlength="2000"
              minlength="1"
              aria-describedby="thread-composer-description composer-state composer-shortcuts composer-error composer-count composer-live"
              aria-keyshortcuts="Control+Enter Meta+Enter"
              aria-invalid="false"
              class="mt-3 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm leading-6 text-slate-900 focus:border-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-100"
              placeholder="Γράψτε το μήνυμά σας"
            ></textarea>
            <p id="composer-shortcuts" class="mt-2 text-xs text-slate-500">Συντόμευση πληκτρολογίου: <span class="font-semibold text-slate-700">Ctrl+Enter</span> (ή <span class="font-semibold text-slate-700">Cmd+Enter</span> σε Mac) για αποστολή.</p>
            <div class="mt-2 flex items-center justify-between text-xs">
              <p id="composer-error" class="hidden font-medium text-rose-700" role="alert">Το μήνυμα δεν μπορεί να είναι κενό.</p>
              <p id="composer-count" class="text-slate-500">0 / 2000</p>
            </div>
            <p id="composer-live" class="mt-1 text-xs font-medium text-slate-600" aria-live="polite"></p>
            <button type="submit" data-default-label="Αποστολή" data-pending-label="Αποστολή..." disabled class="mt-3 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700 disabled:cursor-not-allowed disabled:opacity-65">Αποστολή</button>
          </form>
        )}
      </>
    )}
  </main>

  <style>
    .thread-shell {
      position: relative;
      isolation: isolate;
    }

    .thread-shell::before {
      content: '';
      position: absolute;
      inset: 2rem -1rem auto -1rem;
      height: 12rem;
      background:
        radial-gradient(circle at 12% 28%, rgba(14, 116, 144, 0.13) 0, transparent 56%),
        radial-gradient(circle at 88% 18%, rgba(245, 158, 11, 0.14) 0, transparent 52%);
      z-index: -1;
      pointer-events: none;
    }

    .thread-shell :where(a, button, input, select, textarea, summary):focus-visible {
      outline: 3px solid rgba(14, 116, 144, 0.4);
      outline-offset: 2px;
      box-shadow: 0 0 0 4px rgba(14, 116, 144, 0.12);
    }

    .thread-alert {
      border-radius: 0.85rem;
      border: 1px solid rgb(203 213 225);
      background: rgb(248 250 252);
      padding: 0.75rem 1rem;
      color: rgb(51 65 85);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .thread-alert--sky {
      border-color: rgb(186 230 253);
      background: rgb(240 249 255);
      color: rgb(12 74 110);
    }

    .thread-alert--emerald {
      border-color: rgb(167 243 208);
      background: rgb(236 253 245);
      color: rgb(6 95 70);
    }

    .thread-alert--amber {
      border-color: rgb(253 230 138);
      background: rgb(255 251 235);
      color: rgb(146 64 14);
    }

    .thread-alert--orange {
      border-color: rgb(254 215 170);
      background: rgb(255 247 237);
      color: rgb(154 52 18);
    }

    .thread-alert--rose {
      border-color: rgb(254 205 211);
      background: rgb(255 241 242);
      color: rgb(136 19 55);
    }

    .thread-message {
      border-radius: 1rem;
      border: 1px solid rgb(226 232 240);
      background: white;
      padding: 1rem;
      box-shadow: 0 14px 32px -28px rgba(15, 23, 42, 0.5);
      transition: border-color 160ms ease, box-shadow 160ms ease;
    }

    .thread-message:focus-within {
      border-color: rgb(125 211 252);
      box-shadow:
        0 0 0 3px rgba(14, 116, 144, 0.14),
        0 14px 32px -28px rgba(15, 23, 42, 0.5);
    }

    .thread-message--incoming {
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.9));
    }

    .thread-message--own {
      border-color: rgb(186 230 253);
      background: linear-gradient(145deg, rgba(240, 249, 255, 0.95), rgba(255, 255, 255, 0.95));
    }

    .thread-message--hidden {
      border-color: rgb(253 186 116);
      background: linear-gradient(145deg, rgba(255, 247, 237, 0.95), rgba(255, 255, 255, 0.95));
    }

    .thread-report[open] {
      border-color: rgb(252 211 77);
      box-shadow: 0 10px 30px -24px rgba(180, 83, 9, 0.55);
    }

    .js-composer-form[data-composer-state='error'] {
      border-color: rgb(253 164 175);
      box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.12);
    }

    .js-composer-form[data-composer-state='success'] {
      border-color: rgb(110 231 183);
      box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.14);
    }

    .js-composer-form[data-composer-state='submitting'] {
      border-color: rgb(125 211 252);
      box-shadow: 0 0 0 3px rgba(14, 116, 144, 0.16);
    }

    .composer-count--warning {
      color: rgb(161 98 7);
      font-weight: 600;
    }

    .composer-count--limit {
      color: rgb(190 24 93);
      font-weight: 700;
    }
  </style>

  <script is:inline>
    for (const form of document.querySelectorAll('.js-pending-form')) {
      const submitButton = form.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) continue;

      const isComposerForm = form.classList.contains('js-composer-form');
      const textarea = isComposerForm ? form.querySelector('textarea[name="message"]') : null;
      const counter = isComposerForm ? form.querySelector('#composer-count') : null;
      const error = isComposerForm ? form.querySelector('#composer-error') : null;
      const live = isComposerForm ? form.querySelector('#composer-live') : null;
      const composerState = isComposerForm ? form.querySelector('#composer-state') : null;
      const defaultLabel = submitButton.dataset.defaultLabel || submitButton.textContent || 'Υποβολή';
      const pendingLabel = submitButton.dataset.pendingLabel || 'Υποβολή...';
      const maxLength = textarea instanceof HTMLTextAreaElement && textarea.maxLength > 0 ? textarea.maxLength : 2000;
      const warningThreshold = Math.max(0, maxLength - 200);
      let preserveInitialComposerFeedback = isComposerForm && ['success', 'error'].includes(form.getAttribute('data-composer-state') || '');

      const setComposerState = (state, message) => {
        if (!(composerState instanceof HTMLElement)) return;
        const toneClass = state === 'success'
          ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
          : state === 'error'
            ? 'border-rose-300 bg-rose-100 text-rose-900'
            : state === 'submitting'
              ? 'border-slate-300 bg-slate-200 text-slate-800'
              : 'border-sky-300 bg-sky-100 text-sky-900';
        composerState.className = `inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold ${toneClass}`;
        composerState.textContent = message;
        form.setAttribute('data-composer-state', state);
      };

      const syncComposer = () => {
        if (!(textarea instanceof HTMLTextAreaElement)) return;
        const length = textarea.value.trim().length;
        const remaining = maxLength - length;
        const isBusy = submitButton.getAttribute('aria-busy') === 'true';
        submitButton.disabled = length === 0 || isBusy;
        if (counter) {
          counter.textContent = `${length} / ${maxLength}`;
          counter.classList.toggle('composer-count--warning', length > 0 && remaining <= 200 && remaining > 0);
          counter.classList.toggle('composer-count--limit', remaining <= 0);
        }
        if (error) error.classList.toggle('hidden', length > 0);
        textarea.setAttribute('aria-invalid', length === 0 ? 'true' : 'false');

        if (!isBusy) {
          if (length > 0) {
            preserveInitialComposerFeedback = false;
            setComposerState('idle', 'Το composer είναι έτοιμο για αποστολή.');
          } else if (!preserveInitialComposerFeedback) {
            setComposerState('idle', 'Το composer είναι έτοιμο για αποστολή.');
          }
        }

        if (live) {
          if (length === 0 && live.textContent === 'Πληκτρολογήστε μήνυμα πριν την αποστολή.') return;
          if (remaining <= 200 && length > 0) {
            live.textContent = remaining === 0 ? 'Φτάσατε το όριο χαρακτήρων.' : `Απομένουν ${remaining} χαρακτήρες.`;
            return;
          }
          if (live.textContent.startsWith('Απομένουν') || live.textContent === 'Φτάσατε το όριο χαρακτήρων.') {
            live.textContent = '';
          }
        }
      };

      if (textarea instanceof HTMLTextAreaElement) {
        textarea.addEventListener('input', syncComposer);
        textarea.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            if (error) error.classList.add('hidden');
            if (live) live.textContent = '';
            return;
          }
          if (event.key !== 'Enter' || (!event.ctrlKey && !event.metaKey)) return;
          event.preventDefault();
          const length = textarea.value.trim().length;
          if (length === 0) {
            if (error) error.classList.remove('hidden');
            if (live) live.textContent = 'Πληκτρολογήστε μήνυμα πριν την αποστολή.';
            submitButton.disabled = true;
            textarea.setAttribute('aria-invalid', 'true');
            setComposerState('error', 'Δεν ήταν δυνατή η αποστολή: κενό μήνυμα.');
            textarea.focus();
            return;
          }
          if (submitButton.getAttribute('aria-busy') === 'true') return;
          setComposerState('submitting', 'Αποστολή μηνύματος σε εξέλιξη...');
          if (live) live.textContent = 'Αποστολή μηνύματος...';
          form.requestSubmit(submitButton);
        });
        textarea.addEventListener('blur', syncComposer);
        syncComposer();
      }

      form.addEventListener('submit', (event) => {
        if (submitButton.getAttribute('aria-busy') === 'true') {
          event.preventDefault();
          return;
        }
        if (textarea instanceof HTMLTextAreaElement && textarea.value.trim().length === 0) {
          event.preventDefault();
          if (error) error.classList.remove('hidden');
          if (live) live.textContent = 'Πληκτρολογήστε μήνυμα πριν την αποστολή.';
          submitButton.disabled = true;
          textarea.setAttribute('aria-invalid', 'true');
          setComposerState('error', 'Δεν ήταν δυνατή η αποστολή: κενό μήνυμα.');
          textarea.focus();
          return;
        }
        submitButton.disabled = true;
        setComposerState(isComposerForm ? 'submitting' : 'idle', isComposerForm ? 'Αποστολή μηνύματος σε εξέλιξη...' : 'Επεξεργασία σε εξέλιξη...');
        if (live) live.textContent = 'Αποστολή μηνύματος...';
        submitButton.textContent = pendingLabel;
        submitButton.setAttribute('aria-busy', 'true');
        submitButton.setAttribute('aria-disabled', 'true');
        form.classList.add('opacity-80');
        form.setAttribute('data-submit-label', defaultLabel);
      });
    }

    window.addEventListener('pageshow', () => {
      for (const form of document.querySelectorAll('.js-pending-form')) {
        form.classList.remove('opacity-80');
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) continue;
        const defaultLabel = submitButton.dataset.defaultLabel || form.getAttribute('data-submit-label') || submitButton.textContent || 'Υποβολή';
        submitButton.disabled = false;
        submitButton.textContent = defaultLabel;
        submitButton.removeAttribute('aria-busy');
        submitButton.removeAttribute('aria-disabled');
      }
      const composerForm = document.querySelector('.js-composer-form');
      if (!(composerForm instanceof HTMLFormElement)) return;
      const textarea = composerForm.querySelector('textarea[name="message"]');
      const submitButton = composerForm.querySelector('button[type="submit"]');
      const counter = composerForm.querySelector('#composer-count');
      const error = composerForm.querySelector('#composer-error');
      const live = composerForm.querySelector('#composer-live');
      const composerState = composerForm.querySelector('#composer-state');
      if (!(textarea instanceof HTMLTextAreaElement) || !(submitButton instanceof HTMLButtonElement)) return;
      const length = textarea.value.trim().length;
      submitButton.disabled = length === 0;
      const maxLength = textarea.maxLength > 0 ? textarea.maxLength : 2000;
      const remaining = maxLength - length;
      if (counter) {
        counter.textContent = `${length} / ${maxLength}`;
        counter.classList.toggle('composer-count--warning', length > 0 && remaining <= 200 && remaining > 0);
        counter.classList.toggle('composer-count--limit', remaining <= 0);
      }
      if (error) error.classList.toggle('hidden', length > 0);
      textarea.setAttribute('aria-invalid', length === 0 ? 'true' : 'false');
      if (live && (live.textContent.startsWith('Απομένουν') || live.textContent === 'Φτάσατε το όριο χαρακτήρων.')) {
        live.textContent = '';
      }
      if (composerState instanceof HTMLElement && length > 0) {
        composerState.className = 'inline-flex rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 text-[11px] font-semibold text-sky-900';
        composerState.textContent = 'Το composer είναι έτοιμο για αποστολή.';
        composerForm.setAttribute('data-composer-state', 'idle');
      }
    });
  </script>
</Layout>
