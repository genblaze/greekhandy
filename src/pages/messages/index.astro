---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  getMessageThreadId,
  readNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const viewerEmail = (url.searchParams.get('viewerEmail') ?? '').trim().toLowerCase();
const status = (url.searchParams.get('status') ?? '').trim();

const truncatePreview = (value: string, max = 110) => {
  const normalized = value.replace(/\s+/g, ' ').trim();
  if (normalized.length <= max) return normalized;
  return `${normalized.slice(0, max - 1).trimEnd()}…`;
};

const allMessages = await readNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH);
const readStates = await readNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH);
const visibilityActions = await readNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH);
const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const readStateByThread = new Map<string, string>();
for (const state of readStates) {
  if (state.viewerEmail === viewerEmail) readStateByThread.set(state.threadId, state.lastReadAt);
}

const threadMap = new Map<string, MessageSubmission[]>();
for (const message of allMessages) {
  if (message.senderEmail.toLowerCase() !== viewerEmail && message.recipientEmail.toLowerCase() !== viewerEmail) continue;
  const messageThreadId = getMessageThreadId(message);
  const list = threadMap.get(messageThreadId) || [];
  list.push(message);
  threadMap.set(messageThreadId, list);
}

const threads = Array.from(threadMap.entries())
  .map(([threadId, messages]) => {
    const ordered = [...messages].sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));
    const lastMessage = ordered.at(-1)!;
    const lastReadAt = readStateByThread.get(threadId) || '';
    const unreadCount = ordered.filter((message) => message.senderEmail.toLowerCase() !== viewerEmail && (!lastReadAt || message.submittedAt > lastReadAt)).length;
    const isLastFromViewer = lastMessage.senderEmail.toLowerCase() === viewerEmail;
    const senderLabel = isLastFromViewer ? 'Εσείς' : (lastMessage.senderName || 'Συνεργάτης');
    const lastPreview = hiddenMessageIds.has(lastMessage.id)
      ? 'Το μήνυμα έχει κρυφτεί από moderation.'
      : truncatePreview(lastMessage.message);

    return {
      threadId,
      professionalSlug: lastMessage.professionalSlug,
      lastMessageAt: lastMessage.submittedAt,
      unreadCount,
      lastPreview,
      senderLabel,
      messagesCount: ordered.length,
      isLastFromViewer
    };
  })
  .sort((a, b) => b.lastMessageAt.localeCompare(a.lastMessageAt));
---

<Layout title="Συνομιλίες | GreekHandy" description="Λίστα συνομιλιών με προεπισκόπηση και μη αναγνωσμένα μηνύματα.">
  <main class="mx-auto max-w-4xl px-4 py-14">
    <h1 class="text-3xl font-bold text-gray-900">Συνομιλίες</h1>
    <p class="mt-2 text-sm text-gray-600">MVP inbox με ένδειξη μη αναγνωσμένων και καθαρή προεπισκόπηση τελευταίου μηνύματος.</p>

    {status === 'invalid' && (
      <p class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">Δεν ήταν δυνατή η ενημέρωση ως αναγνωσμένη (μη έγκυρα στοιχεία).</p>
    )}
    {status === 'forbidden' && (
      <p class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-800">Δεν έχετε πρόσβαση σε αυτό το thread.</p>
    )}
    {status === 'error' && (
      <p class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-800">Προέκυψε σφάλμα κατά την ενημέρωση της συνομιλίας. Δοκιμάστε ξανά.</p>
    )}

    {!viewerEmail && (
      <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
        <p class="font-semibold">Δεν μπορέσαμε να φορτώσουμε τις συνομιλίες.</p>
        <p class="mt-1 text-sm">Λείπει η παράμετρος <code>viewerEmail</code> από το URL.</p>
      </div>
    )}

    {viewerEmail && (
      <section class="mt-6 space-y-3">
        {threads.length === 0 && (
          <div class="rounded-xl border border-gray-200 bg-white px-4 py-5 text-gray-700">
            <p class="font-semibold text-gray-900">Δεν υπάρχουν συνομιλίες ακόμη.</p>
            <p class="mt-1 text-sm text-gray-600">Μόλις σταλεί ή ληφθεί το πρώτο μήνυμα, θα εμφανιστεί εδώ.</p>
          </div>
        )}

        {threads.map((thread) => (
          <a
            href={`/messages/thread?threadId=${encodeURIComponent(thread.threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`}
            class={`block rounded-xl border bg-white p-4 shadow-sm transition ${thread.unreadCount > 0 ? 'border-indigo-300 ring-1 ring-indigo-100 hover:border-indigo-400' : 'border-gray-200 hover:border-blue-300'}`}
          >
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div class="flex items-center gap-2">
                <h2 class="font-semibold text-gray-900">/{thread.professionalSlug}</h2>
                {thread.unreadCount > 0 && <span class="h-2.5 w-2.5 rounded-full bg-indigo-600" aria-label="Μη αναγνωσμένα μηνύματα"></span>}
              </div>
              <p class="text-xs text-gray-500">{new Date(thread.lastMessageAt).toLocaleString('el-GR')}</p>
            </div>

            <p class="mt-2 text-sm text-gray-700">
              <span class={`font-medium ${thread.isLastFromViewer ? 'text-gray-500' : 'text-gray-900'}`}>{thread.senderLabel}:</span>{' '}
              {thread.lastPreview}
            </p>

            <div class="mt-2 flex items-center justify-between">
              <p class="text-xs text-gray-500">Μηνύματα: {thread.messagesCount}</p>
              {thread.unreadCount > 0 && <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-semibold text-indigo-800">{thread.unreadCount} μη αναγνωσμένα</span>}
            </div>
          </a>
        ))}
      </section>
    )}
  </main>
</Layout>
