              <div class="thread-card__heading-row flex flex-wrap items-start justify-between gap-3">
                <div class="thread-card__identity" id={threadMetaId}>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">Thread</p>
                  <h2 id={threadHeadingId} class={`mt-1 text-xl ${thread.unreadCount > 0 ? 'font-bold text-slate-950' : 'font-semibold text-slate-900'}`}>/{thread.professionalSlug}</h2>
                  {thread.needsReply && <p class="mt-1 inline-flex rounded-full border border-indigo-300 bg-indigo-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em] text-indigo-900">Άμεση απάντηση</p>}
                  <p class="mt-1 text-xs text-slate-500">Συμμετέχων: <span class="font-medium text-slate-700">{thread.counterpartEmail || 'Μη διαθέσιμος'}</span></p>
                  <p class="mt-1 text-[11px] text-slate-500">ID: <span class="font-mono text-slate-700">{thread.threadId}</span></p>
                </div>

                <div class="thread-card__timeline rounded-xl border border-slate-200 bg-white/85 px-3 py-2 text-right" role="status" aria-live="polite" aria-atomic="true">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Τελευταία κίνηση</p>
                  <p class="mt-1 text-xs font-semibold text-slate-800">
                    <time datetime={thread.lastMessageAt}>{formatDateTime(thread.lastMessageAt)}</time>
                  </p>
                  <p class="mt-1 text-[11px] text-slate-500">{threadRecencyLabel}</p>
                  <p class={`mt-1 text-[11px] font-semibold ${thread.needsReply ? 'text-indigo-900' : 'text-slate-600'}`}>{thread.responseFlowLabel}</p>
                </div>
              </div>

              <div id={threadSignalsId} class="thread-card__signals mt-3 flex flex-wrap items-center gap-2" role="status" aria-live="polite" aria-atomic="true">
                <p class="thread-card__signals-label text-[10px] font-semibold uppercase tracking-[0.1em] text-slate-500">Σήματα κατάστασης</p>
                <span class={`inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-[11px] font-semibold ${thread.hasUnread ? 'border-sky-300 bg-sky-100 text-sky-900' : 'border-slate-300 bg-slate-100 text-slate-700'}`}>
                  {thread.hasUnread && (
                    <>
                      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-sky-600" aria-hidden="true"></span>
                      <span class="sr-only">Μη αναγνωσμένα μηνύματα</span>
                    </>
                  )}
                  {thread.unreadLabel}
                </span>
                <span class={`rounded-full border px-2.5 py-1 text-[11px] font-semibold ${thread.moderationSummaryClass}`}>
                  Moderation: {thread.moderationStateSummaryLabel}
                </span>
                <span class="rounded-full border border-slate-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700">Αποστολή: {thread.moderationSendStateLabel}</span>
                <span class="rounded-full border border-slate-300 bg-white px-2.5 py-1 text-[11px] font-semibold text-slate-700">Εστίαση: {thread.triageFocusLabel}</span>
                {thread.needsReply && <span class="rounded-full border border-indigo-300 bg-indigo-100 px-2.5 py-1 text-[11px] font-semibold text-indigo-900">Χρειάζεται απάντηση</span>}
                {thread.isBlocked && <span class="rounded-full border border-rose-300 bg-rose-100 px-2.5 py-1 text-[11px] font-semibold text-rose-900">Μπλοκαρισμένο</span>}
                {!thread.isBlocked && thread.isAdminHidden && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Κρυφό περιεχόμενο</span>}
                {!thread.isBlocked && !thread.isAdminHidden && thread.threadAction === 'review' && <span class="rounded-full border border-sky-300 bg-sky-100 px-2.5 py-1 text-[11px] font-semibold text-sky-900">Αναφορά σε έλεγχο</span>}
                {!thread.isBlocked && !thread.isAdminHidden && thread.threadAction === 'reject' && <span class="rounded-full border border-amber-300 bg-amber-100 px-2.5 py-1 text-[11px] font-semibold text-amber-900">Αναφορά χωρίς περιορισμό</span>}
                {!thread.isBlocked && thread.isMuted && <span class="rounded-full border border-orange-300 bg-orange-100 px-2.5 py-1 text-[11px] font-semibold text-orange-900">Σε σίγαση</span>}
                {thread.stateTone === 'active' && <span class="rounded-full border border-emerald-300 bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-900">Ενεργή</span>}
              </div>

              <div class="mt-3 grid gap-2 text-xs sm:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Εστίαση triage
                  <p class="mt-0.5 text-sm font-semibold text-slate-900">{thread.triageFocusLabel}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Επίδραση moderation
                  <p class="mt-0.5 text-sm font-semibold text-slate-900">{thread.moderationImpactLabel}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Επόμενη κίνηση
                  <p class={`mt-0.5 text-sm font-semibold ${thread.needsReply ? 'text-indigo-900' : 'text-slate-900'}`}>{thread.moderationNextStepLabel}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Moderation λειτουργία
                  <p class="mt-0.5 text-[11px] font-semibold text-slate-900">{thread.moderationSendStateLabel}</p>
                  <p class="mt-0.5 text-[11px] text-slate-700">{thread.moderationVisibilityStateLabel}</p>
                  <p class="mt-0.5 text-[11px] text-slate-700">{thread.moderationReviewStateLabel}</p>
                </div>
              </div>

              <div class="mt-3 rounded-xl border border-slate-200/80 bg-white/70 px-3 py-3">
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Τελευταίο μήνυμα</p>
                <div class="mt-1 flex flex-wrap items-center gap-1.5 text-[11px] text-slate-500">
                  <span class="rounded-full border border-slate-300 bg-slate-100 px-2 py-0.5 font-semibold text-slate-700">Αποστολέας: {thread.senderLabel}</span>
                  <span class={`rounded-full border px-2 py-0.5 font-semibold ${thread.hasUnread ? 'border-sky-300 bg-sky-100 text-sky-900' : 'border-slate-300 bg-slate-100 text-slate-700'}`}>{thread.unreadLabel}</span>
                </div>
                <p id={threadPreviewId} class={`thread-preview mt-1 text-sm leading-6 ${thread.unreadCount > 0 ? 'text-slate-900' : 'text-slate-700'}`}>
                  <span class={`font-semibold ${thread.isLastFromViewer ? 'text-slate-500' : 'text-slate-900'}`}>{thread.senderLabel}:</span>{' '}
                  {thread.lastPreview}
                </p>
              </div>

              <div class="mt-3 grid gap-2 text-xs sm:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Μηνύματα
                  <p class="mt-0.5 text-sm font-semibold text-slate-800">{thread.messagesCount}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Κρυφά
                  <p class="mt-0.5 text-sm font-semibold text-slate-800">{thread.hiddenMessagesCount}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Ροή απάντησης
                  <p class={`mt-0.5 text-sm font-semibold ${thread.needsReply ? 'text-indigo-900' : 'text-slate-800'}`}>{thread.responseFlowLabel}</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-white/80 px-3 py-2 text-slate-600">
                  Θέση στην ουρά
                  <p class={`mt-0.5 text-sm font-semibold ${threadQueuePosition && threadQueuePosition <= 3 ? 'text-indigo-900' : 'text-slate-800'}`}>{threadQueuePosition ? `#${threadQueuePosition}` : 'Εκτός τρέχουσας ουράς'}</p>
                </div>
              </div>

              <div id={threadStatusId} class={`thread-card__moderation mt-3 rounded-lg border px-3 py-2 text-xs ${thread.isModerated ? thread.moderationBannerClass : 'border-slate-200 bg-slate-50 text-slate-600'}`} role="status" aria-live="polite" aria-atomic="true" aria-labelledby={threadModerationHeadingId} aria-describedby={threadModerationHintId}>
                <p class="text-[10px] font-semibold uppercase tracking-[0.1em] opacity-75">Moderation panel</p>
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <p id={threadModerationHeadingId} class="font-semibold">Κατάσταση moderation: {thread.moderationLabel}</p>
                  {thread.isBlocked && <p class="font-semibold uppercase tracking-[0.08em] text-rose-900">Αποστολή κλειδωμένη</p>}
                  {!thread.isBlocked && thread.threadAction === 'review' && <p class="font-semibold uppercase tracking-[0.08em] text-sky-900">Αναφορά σε εξέλιξη</p>}
                  {!thread.isBlocked && thread.threadAction === 'reject' && <p class="font-semibold uppercase tracking-[0.08em] text-amber-900">Αναφορά ολοκληρωμένη</p>}
                </div>
                {thread.isModerated && <p class="mt-1 font-semibold">{thread.moderationBannerTitle}</p>}
                <p id={threadModerationHintId} class={thread.isModerated ? 'mt-0.5' : 'mt-1'}>{thread.moderationHint}</p>
                <p class="mt-1 text-[11px] font-medium">Αποστολή: {thread.moderationSendStateLabel} · Ορατότητα: {thread.moderationVisibilityStateLabel} · Αναφορές: {thread.moderationReviewStateLabel}</p>
                <div class="mt-2 rounded-md border border-current/20 bg-white/70 px-2.5 py-2">
                  <p class="font-semibold">Επίδραση: {thread.moderationImpactLabel}</p>
                  <p class="mt-0.5">{thread.moderationImpactHint}</p>
                  <p class="mt-2 font-semibold">Επόμενη κίνηση: {thread.moderationNextStepLabel}</p>
                  <p class="mt-0.5">{thread.moderationNextStepHint}</p>
                </div>
              </div>
              <p class="mt-2 rounded-lg border border-slate-200 bg-white/75 px-3 py-2 text-xs text-slate-600">{thread.priorityHint}</p>

              <div class="thread-card__actions mt-4 flex flex-wrap items-center gap-2.5">
                <a
                  href={`/messages/thread?threadId=${encodeURIComponent(thread.threadId)}&viewerEmail=${encodeURIComponent(viewerEmail)}`}
                  class="inline-flex items-center rounded-lg bg-slate-900 px-3.5 py-2 text-xs font-semibold text-white transition hover:bg-slate-700"
                  aria-label={`Άνοιγμα συνομιλίας ${thread.professionalSlug}`}
                >
                  {thread.needsReply ? 'Απάντηση τώρα' : 'Άνοιγμα συνομιλίας'}
                </a>

                {thread.unreadCount > 0 && (
                  <form
                    action="/api/messages/read"
                    method="POST"
                    class="js-pending-form"
                    data-pending-live-label="Η κατάσταση ανάγνωσης ενημερώνεται."
                    data-pending-timeout-label="Η ενημέρωση ανάγνωσης καθυστέρησε. Δοκιμάστε ξανά."
                    data-pending-timeout-ms="15000"
                  >
                    <input type="hidden" name="threadId" value={thread.threadId} />
                    <input type="hidden" name="viewerEmail" value={viewerEmail} />
                    <input type="hidden" name="returnTo" value={listReturnTo} />
                    <button type="submit" data-default-label="Σήμανση ως διαβασμένο" data-pending-label="Ενημέρωση..." class="rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-65" aria-label={`Σήμανση ως διαβασμένο για ${thread.professionalSlug}`}>
                      Σήμανση ως διαβασμένο
                    </button>
                  </form>
                )}

                {thread.isBlocked && (
                  <a href={blockedQueueHref} class="rounded-lg border border-rose-300 bg-rose-50 px-3.5 py-2 text-xs font-semibold text-rose-900 transition hover:border-rose-400 hover:bg-rose-100">
                    Ουρά μπλοκαρισμένων
                  </a>
                )}
                {!thread.isBlocked && thread.isReported && (
                  <a href={reportedQueueHref} class="rounded-lg border border-amber-300 bg-amber-50 px-3.5 py-2 text-xs font-semibold text-amber-900 transition hover:border-amber-400 hover:bg-amber-100">
                    Ουρά αναφορών
                  </a>
                )}
                {!thread.isBlocked && !thread.isReported && thread.hasUnread && (
                  <a href={unreadQueueHref} class="rounded-lg border border-sky-300 bg-sky-50 px-3.5 py-2 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
                    Ουρά μη αναγνωσμένων
                  </a>
                )}
              </div>
                  </article>
                </li>
              );
            })}
          </ol>
        )}
      </section>
    )}
  </main>

  <style>
    .messages-skip-link {
      position: absolute;
      left: 1rem;
      top: 0.35rem;
      z-index: 80;
      transform: translateY(-160%);
      border-radius: 9999px;
      border: 1px solid rgb(14 116 144);
      background: rgb(255 255 255);
      padding: 0.4rem 0.7rem;
      font-size: 0.72rem;
      font-weight: 700;
      color: rgb(12 74 110);
      box-shadow: 0 8px 18px -12px rgba(15, 23, 42, 0.6);
      transition: transform 140ms ease;
    }

    .messages-skip-link:focus-visible {
      transform: translateY(0);
    }

    .messages-shell {
      position: relative;
      isolation: isolate;
    }

    .messages-shell::before {
      content: '';
      position: absolute;
      inset: 2rem -1rem auto -1rem;
      height: 12rem;
      background:
        radial-gradient(circle at 8% 22%, rgba(14, 116, 144, 0.12) 0, transparent 55%),
        radial-gradient(circle at 92% 16%, rgba(251, 191, 36, 0.14) 0, transparent 52%);
      z-index: -1;
      pointer-events: none;
    }

    .messages-shell :where(a, button, input, select, textarea):focus-visible {
      outline: 3px solid rgba(14, 116, 144, 0.4);
      outline-offset: 3px;
      box-shadow: 0 0 0 4px rgba(14, 116, 144, 0.12);
    }

    .messages-toast-stack {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 70;
      display: grid;
      width: min(28rem, calc(100vw - 2rem));
      gap: 0.6rem;
      pointer-events: none;
    }

    .messages-toast {
      pointer-events: auto;
      border-radius: 0.95rem;
      border: 1px solid rgb(203 213 225);
      background: rgb(248 250 252);
      padding: 0.75rem 0.85rem;
      color: rgb(51 65 85);
      box-shadow: 0 18px 36px -24px rgba(15, 23, 42, 0.6);
      transition: opacity 140ms ease, transform 140ms ease;
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .messages-toast.is-dismissing {
      opacity: 0;
      transform: translateX(10px);
    }

    .messages-toast--sky {
      border-color: rgb(186 230 253);
      background: rgb(240 249 255);
      color: rgb(12 74 110);
    }

    .messages-toast--amber {
      border-color: rgb(253 230 138);
      background: rgb(255 251 235);
      color: rgb(146 64 14);
    }

    .messages-toast--rose {
      border-color: rgb(254 205 211);
      background: rgb(255 241 242);
      color: rgb(136 19 55);
    }

    .messages-toast--slate {
      border-color: rgb(203 213 225);
      background: rgb(248 250 252);
      color: rgb(51 65 85);
    }

    .messages-toast__dismiss {
      flex-shrink: 0;
      border-radius: 0.6rem;
      border: 1px solid currentColor;
      background: rgba(255, 255, 255, 0.72);
      padding: 0.25rem 0.55rem;
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1;
    }

    .messages-toast__dismiss:hover {
      background: rgba(255, 255, 255, 0.92);
    }

    .loading-thread-card {
      position: relative;
      overflow: hidden;
    }

    .loading-thread-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 10%, rgba(255, 255, 255, 0.65) 46%, transparent 82%);
      transform: translateX(-100%);
      animation: thread-loading-shimmer 1.5s ease-in-out infinite;
      pointer-events: none;
    }

    .loading-thread-card__bar {
      background: linear-gradient(90deg, rgb(226 232 240), rgb(241 245 249), rgb(226 232 240));
      background-size: 220% 100%;
      animation: thread-loading-bar 1.35s ease-in-out infinite;
    }

    .messages-results-header {
      display: flex;
      flex-wrap: wrap;
      align-items: start;
      justify-content: space-between;
      gap: 0.75rem;
      border: 1px solid rgb(226 232 240);
      border-radius: 1rem;
      padding: 0.85rem 1rem;
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.88));
      box-shadow: 0 14px 34px -30px rgba(15, 23, 42, 0.46);
    }

    .messages-results-header__stats {
      border: 1px solid rgb(226 232 240);
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.92);
      padding: 0.5rem 0.7rem;
      font-size: 0.72rem;
      color: rgb(71 85 105);
      line-height: 1.5;
      min-width: 14.5rem;
    }

    .messages-results-header__state {
      letter-spacing: 0.01em;
    }

    @keyframes thread-loading-shimmer {
      100% {
        transform: translateX(100%);
      }
    }

    @keyframes thread-loading-bar {
      0%, 100% {
        background-position: 0% 0;
      }
      50% {
        background-position: 100% 0;
      }
    }

    .thread-card {
      position: relative;
      overflow: hidden;
      border-radius: 1rem;
      border: 1px solid rgb(226 232 240);
      background: linear-gradient(140deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.9));
      padding: 1.25rem;
      box-shadow: 0 20px 40px -32px rgba(15, 23, 42, 0.5);
      transition: box-shadow 180ms ease, border-color 180ms ease, transform 180ms ease;
    }

    .thread-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 24px 50px -34px rgba(15, 23, 42, 0.58);
    }

    .thread-card:focus-within {
      border-color: rgb(56 189 248);
      box-shadow:
        0 0 0 3px rgba(14, 116, 144, 0.14),
        0 24px 50px -34px rgba(15, 23, 42, 0.58);
    }

    .thread-card__topline {
      padding-bottom: 0.45rem;
      border-bottom: 1px dashed rgb(226 232 240);
    }

    .thread-card__heading-row {
      margin-top: 0.75rem;
    }

    .thread-card__identity {
      max-width: min(100%, 40rem);
    }

    .thread-card__signals {
      padding-top: 0.15rem;
    }

    .thread-card__attention {
      letter-spacing: 0.01em;
    }

    .thread-card__signals-label {
      flex-basis: 100%;
      margin-bottom: 0.1rem;
    }

    .thread-card__digest {
      line-height: 1.45;
      letter-spacing: 0.01em;
    }

    .thread-card__moderation {
      position: relative;
      border-width: 1px;
    }

    .thread-card__moderation::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 0.18rem;
      background: currentColor;
      opacity: 0.12;
      pointer-events: none;
    }

    .thread-card__actions {
      margin-top: 1rem;
      padding-top: 0.25rem;
      border-top: 1px solid rgb(226 232 240 / 0.8);
    }

    .thread-card__timeline {
      min-width: 13.5rem;
      line-height: 1.45;
    }

    .thread-card[data-moderation-state='blocked'] .thread-card__actions {
      border-top-color: rgb(251 113 133 / 0.45);
    }

    .thread-card[data-moderation-state='reported'] .thread-card__actions {
      border-top-color: rgb(245 158 11 / 0.45);
    }

    .thread-preview {
      display: -webkit-box;
      overflow: hidden;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .thread-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 0.3rem;
      background: rgb(148 163 184);
      opacity: 0.7;
    }

    .thread-card--unread {
      border-color: rgb(125 211 252);
    }

    .thread-card--unread::before {
      background: rgb(14 116 144);
      opacity: 1;
    }

    .thread-card--blocked {
      border-color: rgb(253 164 175);
      background: linear-gradient(145deg, rgba(255, 241, 242, 0.92), rgba(255, 255, 255, 0.95));
    }

    .thread-card--blocked::before {
      background: rgb(190 18 60);
      opacity: 0.95;
    }

    .thread-card--hidden {
      border-color: rgb(253 186 116);
      background: linear-gradient(145deg, rgba(255, 247, 237, 0.94), rgba(255, 255, 255, 0.95));
    }

    .thread-card--hidden::before {
      background: rgb(194 65 12);
      opacity: 0.9;
    }

    .thread-card--reported {
      border-color: rgb(252 211 77);
      background: linear-gradient(145deg, rgba(255, 251, 235, 0.95), rgba(255, 255, 255, 0.95));
    }

    .thread-card--reported::before {
      background: rgb(202 138 4);
      opacity: 0.95;
    }

    .thread-card--active::before {
      background: rgb(34 197 94);
      opacity: 0.85;
    }

    .thread-card--needs-reply {
      box-shadow:
        0 0 0 2px rgba(99, 102, 241, 0.16),
        0 20px 40px -32px rgba(15, 23, 42, 0.5);
    }

    .thread-card--pending {
      border-color: rgb(125 211 252);
      box-shadow:
        0 0 0 3px rgba(14, 116, 144, 0.16),
        0 20px 40px -32px rgba(15, 23, 42, 0.5);
    }

    .js-pending-form[aria-busy='true'] {
      opacity: 0.82;
    }

    .js-pending-form[aria-busy='true'] :where(input:not([type='hidden']), textarea, select, button) {
      cursor: wait;
    }

    @media (prefers-reduced-motion: reduce) {
      .messages-skip-link {
        transition: none;
      }

      .loading-thread-card::after,
      .loading-thread-card__bar {
        animation: none;
      }

      .thread-card {
        transition: none;
      }
    }

    @media (max-width: 640px) {
      .messages-toast-stack {
        top: 0.75rem;
        left: 0.75rem;
        right: 0.75rem;
        width: auto;
      }

      .thread-card__timeline {
        min-width: 100%;
        text-align: left;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const toasts = Array.from(document.querySelectorAll('.js-messages-toast'));
      const dismissToast = (toast) => {
        if (!(toast instanceof HTMLElement) || toast.dataset.removed === 'true') return;
        toast.dataset.removed = 'true';
        const focusFallback = toast.contains(document.activeElement)
          ? (document.querySelector('#thread-search') || document.querySelector('#messages-results'))
          : null;
        toast.classList.add('is-dismissing');
        window.setTimeout(() => {
          toast.remove();
          if (focusFallback instanceof HTMLElement) focusFallback.focus();
        }, 150);
      };

      for (const toast of toasts) {
        const dismissButton = toast.querySelector('[data-toast-dismiss]');
        if (dismissButton instanceof HTMLButtonElement) {
          dismissButton.addEventListener('click', () => dismissToast(toast));
        }
        toast.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          event.preventDefault();
          dismissToast(toast);
        });
        const autoHideMs = Number(toast.getAttribute('data-autohide-ms') || '0');
        if (Number.isFinite(autoHideMs) && autoHideMs > 0) {
          window.setTimeout(() => dismissToast(toast), autoHideMs);
        }
      }

      const focusToast = document.querySelector('.js-messages-toast[data-focus-on-load="true"]');
      if (focusToast instanceof HTMLElement) {
        requestAnimationFrame(() => focusToast.focus());
      }

      const pendingForms = Array.from(document.querySelectorAll('.js-pending-form')).filter((form) => form instanceof HTMLFormElement);
      const submitLiveRegion = document.querySelector('#messages-submit-live');
      const pendingTimeouts = new WeakMap();
      const clearPendingTimeout = (form) => {
        const timer = pendingTimeouts.get(form);
        if (typeof timer === 'number') {
          window.clearTimeout(timer);
        }
        pendingTimeouts.delete(form);
      };
      const announceSubmitState = (message) => {
        if (submitLiveRegion instanceof HTMLElement) submitLiveRegion.textContent = message;
      };
      const setFormPending = (form, isPending) => {
        const submitButton = form.querySelector('button[type="submit"]');
        if (!(submitButton instanceof HTMLButtonElement)) return;
        const controls = Array.from(form.querySelectorAll('button, input, select, textarea')).filter((control) => (
          !(control instanceof HTMLInputElement && control.type === 'hidden')
        ));
        const parentCard = form.closest('.thread-card');
        clearPendingTimeout(form);

        form.setAttribute('aria-busy', isPending ? 'true' : 'false');
        form.classList.toggle('opacity-80', isPending);
        if (parentCard instanceof HTMLElement) {
          parentCard.classList.toggle('thread-card--pending', isPending);
          parentCard.setAttribute('aria-busy', isPending ? 'true' : 'false');
        }

        if (isPending) {
          for (const control of controls) {
            control.setAttribute('data-pending-disabled', control.disabled ? 'true' : 'false');
            control.disabled = true;
            control.setAttribute('aria-disabled', 'true');
          }
          const defaultLabel = submitButton.dataset.defaultLabel || submitButton.textContent || 'Υποβολή';
          const pendingLabel = submitButton.dataset.pendingLabel || 'Επεξεργασία...';
          form.setAttribute('data-submit-label', defaultLabel);
          submitButton.textContent = pendingLabel;
          submitButton.setAttribute('aria-busy', 'true');
          const timeoutMs = Number(form.getAttribute('data-pending-timeout-ms') || '15000');
          if (Number.isFinite(timeoutMs) && timeoutMs > 0) {
            const timeoutId = window.setTimeout(() => {
              if (form.getAttribute('aria-busy') !== 'true') return;
              setFormPending(form, false);
              announceSubmitState(form.getAttribute('data-pending-timeout-label') || 'Η ενέργεια καθυστέρησε. Δοκιμάστε ξανά.');
            }, timeoutMs);
            pendingTimeouts.set(form, timeoutId);
          }
          return;
        }

        for (const control of controls) {
          const wasDisabled = control.getAttribute('data-pending-disabled') === 'true';
          control.disabled = wasDisabled;
          control.removeAttribute('data-pending-disabled');
          if (!control.disabled) control.removeAttribute('aria-disabled');
        }
        const defaultLabel = submitButton.dataset.defaultLabel || form.getAttribute('data-submit-label') || submitButton.textContent || 'Υποβολή';
        submitButton.textContent = defaultLabel;
        submitButton.removeAttribute('aria-busy');
        if (!submitButton.disabled) submitButton.removeAttribute('aria-disabled');
      };

      for (const form of pendingForms) {
        form.addEventListener('submit', (event) => {
          if (form.getAttribute('aria-busy') === 'true') {
            event.preventDefault();
            announceSubmitState('Η ενημέρωση βρίσκεται ήδη σε εξέλιξη.');
            return;
          }
          if (!form.checkValidity()) {
            event.preventDefault();
            form.reportValidity();
            announceSubmitState('Ελέγξτε τα στοιχεία και δοκιμάστε ξανά.');
            return;
          }
          announceSubmitState(form.getAttribute('data-pending-live-label') || 'Η ενημέρωση εκτελείται.');
          setFormPending(form, true);
        });
      }

      window.addEventListener('pageshow', () => {
        for (const form of pendingForms) {
          setFormPending(form, false);
        }
        announceSubmitState('');
      });
    })();
  </script>
</Layout>
