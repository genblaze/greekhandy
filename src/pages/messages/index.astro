---
import Layout from '../../layouts/Layout.astro';

const hasLegacyParams = Astro.url.searchParams.has('viewerEmail')
  || Astro.url.searchParams.has('professional')
  || Astro.url.searchParams.has('professionalSlug')
  || Astro.url.searchParams.has('thread');
---

<Layout
  title="Μηνύματα | GreekHandy"
  description="Ασφαλής πρόσβαση στα μηνύματα μέσω των σωστών ροών του GreekHandy."
  canonicalUrl="https://greekhandy.gr/messages"
>
  <main class="mx-auto max-w-3xl px-4 py-12 md:px-6">
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wide text-sky-700">Inbox entry update</p>
      <h1 class="mt-2 text-2xl font-bold text-slate-900">Η δημόσια είσοδος μηνυμάτων ενημερώθηκε</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">
        Για ασφαλή και σταθερή εμπειρία, η πρόσβαση στα μηνύματα γίνεται πλέον από τις καθορισμένες ροές του GreekHandy,
        χωρίς κρυφές παραμέτρους URL.
      </p>

      {hasLegacyParams && (
        <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="status" aria-live="polite">
          Εντοπίστηκε παλιός σύνδεσμος με παραμέτρους. Χρησιμοποιήστε τις επιλογές παρακάτω για σωστή είσοδο.
        </div>
      )}

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <a
          href="/professionals/messages"
          class="inline-flex min-h-11 items-center justify-center rounded-lg bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
        >
          Είσοδος στα Μηνύματα Επαγγελματιών
        </a>
        <a
          href="/professionals"
          class="inline-flex min-h-11 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 transition hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
        >
          Μετάβαση στον Κατάλογο Επαγγελματιών
        </a>
      </div>

      <p class="mt-4 text-xs text-slate-500">
        Αν αντιμετωπίζετε πρόβλημα πρόσβασης, χρησιμοποιήστε τη φόρμα στην ενότητα «Επικοινωνία» για υποστήριξη.
      </p>
    </section>
  </main>
</Layout>
