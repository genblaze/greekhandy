---
import Layout from '../../layouts/Layout.astro';
import {
  MESSAGE_READ_STATE_FILE_PATH,
  MESSAGE_SUBMISSIONS_FILE_PATH,
  MESSAGE_TRIAGE_ACTIONS_FILE_PATH,
  MESSAGE_VISIBILITY_FILE_PATH,
  getMessageThreadId,
  readNdjson,
  type MessageReadState,
  type MessageSubmission
} from '../../lib/messaging';

const url = new URL(Astro.request.url);
const viewerEmail = (url.searchParams.get('viewerEmail') ?? '').trim().toLowerCase();
const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const hasViewerEmail = viewerEmail.length > 0;
const hasValidViewerEmail = EMAIL_PATTERN.test(viewerEmail);
const canLoadThreads = hasViewerEmail && hasValidViewerEmail;
const status = (url.searchParams.get('status') ?? '').trim();
const searchQueryRaw = (url.searchParams.get('q') ?? '').trim();
const searchQuery = searchQueryRaw.toLowerCase();
const sortMode = (url.searchParams.get('sort') ?? '').trim() === 'unread' ? 'unread' : 'recent';
const showUnreadFirst = sortMode === 'unread';
const showUnreadOnly = (url.searchParams.get('unread') ?? '') === '1';
const showBlockedOnly = (url.searchParams.get('blocked') ?? '') === '1';
const showReportedOnly = (url.searchParams.get('reported') ?? '') === '1';
const activeFilterCount = Number(showUnreadOnly) + Number(showBlockedOnly) + Number(showReportedOnly);
const hasListFilters = Boolean(searchQueryRaw) || activeFilterCount > 0 || showUnreadFirst;
const knownListStatuses = new Set(['', 'loading', 'invalid', 'forbidden', 'error']);
const showLoadingState = status === 'loading';
const hasUnknownStatus = status !== '' && !knownListStatuses.has(status);
const formatDateTime = (value: string) => new Date(value).toLocaleString('el-GR');
const formatUnreadCount = (count: number) => (count === 1 ? '1 μη αναγνωσμένο' : `${count} μη αναγνωσμένα`);
const LOADING_SKELETON_ROWS = [1, 2, 3];
const toDomId = (value: string, fallback: string) => {
  const normalized = value.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  const fallbackNormalized = fallback.trim().toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '');
  return normalized || fallbackNormalized || 'item';
};

const truncatePreview = (value: string, max = 120) => {
  const normalized = value.replace(/\s+/g, ' ').trim();
  if (normalized.length <= max) return normalized;
  return `${normalized.slice(0, max - 1).trimEnd()}…`;
};

let listLoadError = '';
const safeReadNdjson = async <T,>(path: string, label: string): Promise<T[]> => {
  try {
    return await readNdjson<T>(path);
  } catch {
    if (!listLoadError) listLoadError = `Δεν ήταν δυνατή η φόρτωση δεδομένων (${label}).`;
    return [];
  }
};

type ListHrefOptions = {
  q?: string;
  unread?: boolean;
  blocked?: boolean;
  reported?: boolean;
  sort?: 'recent' | 'unread';
};

const buildListHref = (options: ListHrefOptions = {}) => {
  const params = new URLSearchParams();
  if (hasValidViewerEmail) params.set('viewerEmail', viewerEmail);
  if (options.q?.trim()) params.set('q', options.q.trim());
  if (options.unread) params.set('unread', '1');
  if (options.blocked) params.set('blocked', '1');
  if (options.reported) params.set('reported', '1');
  if (options.sort === 'unread') params.set('sort', 'unread');
  const query = params.toString();
  return query ? `/messages?${query}` : '/messages';
};

const allMessages = canLoadThreads
  ? await safeReadNdjson<MessageSubmission>(MESSAGE_SUBMISSIONS_FILE_PATH, 'μηνύματα')
  : [];
const readStates = canLoadThreads
  ? await safeReadNdjson<MessageReadState>(MESSAGE_READ_STATE_FILE_PATH, 'κατάσταση ανάγνωσης')
  : [];
const visibilityActions = canLoadThreads
  ? await safeReadNdjson<{ messageId?: string; action?: string }>(MESSAGE_VISIBILITY_FILE_PATH, 'ορατότητα')
  : [];
const triageActions = canLoadThreads
  ? await safeReadNdjson<{ threadId?: string; action?: string }>(MESSAGE_TRIAGE_ACTIONS_FILE_PATH, 'moderation')
  : [];

const hiddenMessageIds = new Set(visibilityActions.filter((entry) => entry.action === 'hide' && entry.messageId).map((entry) => entry.messageId as string));

const latestTriageActionByThread = new Map<string, string>();
for (const entry of triageActions) {
  if (entry.threadId && entry.action) latestTriageActionByThread.set(entry.threadId, entry.action);
}

const readStateByThread = new Map<string, string>();
for (const state of readStates) {
  if (state.viewerEmail === viewerEmail) readStateByThread.set(state.threadId, state.lastReadAt);
}

const threadMap = new Map<string, MessageSubmission[]>();
for (const message of allMessages) {
  if (message.senderEmail.toLowerCase() !== viewerEmail && message.recipientEmail.toLowerCase() !== viewerEmail) continue;
  const messageThreadId = getMessageThreadId(message);
  const list = threadMap.get(messageThreadId) || [];
  list.push(message);
  threadMap.set(messageThreadId, list);
}

const threads = Array.from(threadMap.entries())
  .map(([threadId, messages]) => {
    const ordered = [...messages].sort((a, b) => a.submittedAt.localeCompare(b.submittedAt));
    const lastMessage = ordered.at(-1)!;
    const lastReadAt = readStateByThread.get(threadId) || '';
    const isLastFromViewer = lastMessage.senderEmail.toLowerCase() === viewerEmail;
    const senderLabel = isLastFromViewer ? 'Εσείς' : (lastMessage.senderName || 'Συνεργάτης');
    const participantEmails = new Set<string>();
    let unreadCount = 0;
    let hiddenMessagesCount = 0;
    for (const msg of ordered) {
      const senderEmail = msg.senderEmail.toLowerCase();
      const recipientEmail = msg.recipientEmail.toLowerCase();
      participantEmails.add(senderEmail);
      participantEmails.add(recipientEmail);
      if (senderEmail !== viewerEmail && (!lastReadAt || msg.submittedAt > lastReadAt)) unreadCount += 1;
      if (hiddenMessageIds.has(msg.id)) hiddenMessagesCount += 1;
    }
    const hasUnread = unreadCount > 0;
    const counterpartEmail = [...participantEmails].find((email) => email !== viewerEmail) || '';
    const lastMessageHidden = hiddenMessageIds.has(lastMessage.id);
    const threadAction = latestTriageActionByThread.get(threadId) || '';
    const isBlocked = threadAction === 'block';
    const isReported = threadAction === 'review' || threadAction === 'reject';
    const isAdminHidden = hiddenMessagesCount > 0;
    const isModerated = isBlocked || isReported || isAdminHidden;
    const isMuted = !isBlocked && lastMessageHidden;
    const moderationState = isBlocked ? 'blocked' : isAdminHidden ? 'admin-hidden' : isReported ? 'reported' : 'active';
    const stateTone = isBlocked ? 'blocked' : isMuted ? 'muted' : moderationState === 'admin-hidden' ? 'admin-hidden' : moderationState === 'reported' ? 'reported' : 'active';
    const unreadLabel = hasUnread ? formatUnreadCount(unreadCount) : 'Χωρίς μη αναγνωσμένα';
    const needsReply = hasUnread && !isLastFromViewer && !isBlocked;
    const responseFlowLabel = needsReply
      ? 'Χρειάζεται απάντηση'
      : isLastFromViewer
        ? 'Αναμονή απάντησης'
        : 'Ενημερωμένη ροή';
    const moderationLabel = isBlocked
      ? 'Μπλοκαρισμένη'
      : isAdminHidden
        ? 'Κρυφό περιεχόμενο'
        : threadAction === 'review'
          ? 'Αναφορά σε έλεγχο'
          : threadAction === 'reject'
            ? 'Αναφορά χωρίς περιορισμό'
            : 'Ενεργή';
    const moderationHint = isBlocked
      ? 'Το thread έχει μπλοκαριστεί από moderation και δεν δέχεται νέες απαντήσεις.'
      : isAdminHidden
        ? hiddenMessagesCount === ordered.length
          ? 'Όλα τα μηνύματα έχουν αποκρυφτεί από τη διαχείριση.'
          : `Κρυφά μηνύματα: ${hiddenMessagesCount} από ${ordered.length}.`
        : threadAction === 'review'
          ? 'Η συνομιλία είναι σε ενεργή αναφορά και αξιολογείται από moderation.'
          : threadAction === 'reject'
            ? 'Η τελευταία αναφορά ολοκληρώθηκε χωρίς περιορισμό.'
            : 'Δεν υπάρχει ενεργός περιορισμός moderation.';
    const moderationBannerTitle = isBlocked
      ? 'Μπλοκαρισμένη συνομιλία'
      : isAdminHidden
        ? 'Περιορισμένη ορατότητα περιεχομένου'
        : threadAction === 'review'
          ? 'Αναφερόμενη συνομιλία'
          : threadAction === 'reject'
            ? 'Αναφορά καταχωρήθηκε'
            : '';
    const moderationImpactLabel = isBlocked
      ? 'Αποστολή κλειδωμένη'
      : isAdminHidden
        ? 'Περιορισμένη ορατότητα'
        : threadAction === 'review'
          ? 'Αναφορά υπό αξιολόγηση'
        : threadAction === 'reject'
          ? 'Αναφορά ολοκληρωμένη'
          : 'Χωρίς περιορισμό';
    const moderationStateSummaryLabel = isBlocked
      ? 'Μπλοκ αποστολής'
      : isAdminHidden
        ? hiddenMessagesCount === ordered.length
          ? 'Πλήρης απόκρυψη περιεχομένου'
          : 'Μερική απόκρυψη περιεχομένου'
        : threadAction === 'review'
          ? 'Αναφορά σε ενεργό έλεγχο'
          : threadAction === 'reject'
            ? 'Αναφορά ολοκληρώθηκε'
            : 'Χωρίς ενεργό περιορισμό';
    const moderationSummaryClass = isBlocked
      ? 'border-rose-300 bg-rose-100 text-rose-900'
      : isAdminHidden
        ? 'border-orange-300 bg-orange-100 text-orange-900'
        : threadAction === 'review'
          ? 'border-sky-300 bg-sky-100 text-sky-900'
          : threadAction === 'reject'
            ? 'border-amber-300 bg-amber-100 text-amber-900'
            : 'border-emerald-300 bg-emerald-100 text-emerald-900';
    const moderationImpactHint = isBlocked
      ? 'Δεν επιτρέπεται νέα αποστολή μέχρι να αρθεί το μπλοκάρισμα.'
      : isAdminHidden
        ? hiddenMessagesCount === ordered.length
          ? 'Όλο το περιεχόμενο του thread παραμένει κρυφό.'
          : `Περιορισμένη προβολή: ${hiddenMessagesCount}/${ordered.length} μηνύματα είναι κρυφά.`
        : threadAction === 'review'
          ? 'Η ροή παραμένει ενεργή όσο εξετάζεται η αναφορά.'
          : threadAction === 'reject'
            ? 'Ο έλεγχος ολοκληρώθηκε χωρίς νέο περιορισμό.'
            : 'Το moderation δεν επηρεάζει τη ροή του thread.';
    const moderationSendStateLabel = isBlocked
      ? 'Κλειδωμένη αποστολή'
      : isMuted
        ? 'Προσωρινά ανενεργή αποστολή'
        : 'Διαθέσιμη αποστολή';
    const moderationVisibilityStateLabel = isAdminHidden
      ? hiddenMessagesCount === ordered.length
        ? 'Πλήρως περιορισμένη ορατότητα'
        : `Περιορισμένη ορατότητα (${hiddenMessagesCount}/${ordered.length})`
      : 'Πλήρης ορατότητα';
    const moderationReviewStateLabel = threadAction === 'review'
      ? 'Αναφορά σε ενεργό έλεγχο'
      : threadAction === 'reject'
        ? 'Αναφορά ολοκληρωμένη'
        : 'Χωρίς ενεργή αναφορά';
    const moderationNextStepLabel = isBlocked
      ? 'Αναμονή άρσης μπλοκαρίσματος'
      : needsReply
        ? 'Απάντηση στο εισερχόμενο'
        : threadAction === 'review'
          ? 'Παρακολούθηση ενεργής αναφοράς'
          : hasUnread
            ? 'Γρήγορη ανάγνωση unread'
            : threadAction === 'reject'
              ? 'Συνέχιση κανονικής ροής'
              : 'Καμία άμεση ενέργεια';
    const moderationNextStepHint = isBlocked
      ? 'Ανοίξτε το thread μόνο για έλεγχο ιστορικού και κατάστασης moderation.'
      : needsReply
        ? 'Ανοίξτε τη συνομιλία και απαντήστε στον τελευταίο αποστολέα.'
        : threadAction === 'review'
          ? 'Παρακολουθήστε την κατάσταση μέχρι να κλείσει ο έλεγχος.'
          : hasUnread
            ? 'Διαβάστε τα μη αναγνωσμένα και ενημερώστε την κατάσταση.'
            : 'Δεν απαιτείται triage ενέργεια τώρα.';
    const moderationBannerClass = isBlocked
      ? 'border-rose-300 bg-gradient-to-r from-rose-50/95 via-white to-rose-50/70 text-rose-950'
      : isAdminHidden
        ? 'border-orange-300 bg-gradient-to-r from-orange-50/95 via-white to-amber-50/70 text-orange-950'
        : threadAction === 'review'
          ? 'border-sky-300 bg-gradient-to-r from-sky-50/95 via-white to-sky-50/70 text-sky-950'
          : threadAction === 'reject'
            ? 'border-amber-300 bg-gradient-to-r from-amber-50/95 via-white to-amber-50/70 text-amber-950'
            : '';
    const priorityTier = isBlocked
      ? 'critical'
      : threadAction === 'review' || isAdminHidden || needsReply
        ? 'high'
        : hasUnread || threadAction === 'reject'
          ? 'medium'
          : 'normal';
    const priorityLabel = priorityTier === 'critical'
      ? 'Κρίσιμη προτεραιότητα'
      : priorityTier === 'high'
        ? 'Υψηλή προτεραιότητα'
        : priorityTier === 'medium'
          ? 'Μεσαία προτεραιότητα'
          : 'Κανονική ροή';
    const priorityHint = priorityTier === 'critical'
      ? 'Το thread έχει ενεργό μπλοκάρισμα και απαιτεί άμεσο έλεγχο πριν από επόμενη ενέργεια.'
      : priorityTier === 'high'
        ? needsReply
          ? 'Υπάρχει εισερχόμενο μη αναγνωσμένο μήνυμα που χρειάζεται απάντηση.'
          : threadAction === 'review'
            ? 'Υπάρχει ενεργή αναφορά στη συνομιλία και χρειάζεται παρακολούθηση.'
            : 'Υπάρχει περιορισμός περιεχομένου που χρειάζεται προσοχή.'
        : priorityTier === 'medium'
          ? hasUnread
            ? 'Υπάρχουν μη αναγνωσμένα μηνύματα προς επεξεργασία.'
            : 'Η αναφορά έχει καταγραφεί χωρίς ενεργό περιορισμό.'
          : 'Δεν υπάρχουν άμεσες εκκρεμότητες στο thread.';
    const priorityClass = priorityTier === 'critical'
      ? 'border-rose-300 bg-rose-50 text-rose-900'
      : priorityTier === 'high'
        ? 'border-indigo-300 bg-indigo-50 text-indigo-900'
        : priorityTier === 'medium'
          ? 'border-sky-300 bg-sky-50 text-sky-900'
          : 'border-emerald-300 bg-emerald-50 text-emerald-900';
    const triageFocusLabel = isBlocked
      ? 'Κλειδωμένο από moderation'
      : needsReply
        ? 'Απαιτείται απάντηση'
        : threadAction === 'review'
          ? 'Ενεργή αναφορά'
          : hasUnread
            ? 'Unread σε εκκρεμότητα'
            : threadAction === 'reject'
              ? 'Αναφορά ολοκληρώθηκε'
              : 'Καμία εκκρεμότητα';
    const lastPreview = lastMessageHidden
      ? 'Το τελευταίο μήνυμα έχει αποκρυφτεί από moderation.'
      : truncatePreview(lastMessage.message);
    const searchIndex = [
      lastMessage.professionalSlug,
      threadId,
      counterpartEmail,
      senderLabel,
      lastPreview
    ]
      .join(' ')
      .toLowerCase();

    return {
      threadId,
      professionalSlug: lastMessage.professionalSlug,
      lastMessageAt: lastMessage.submittedAt,
      unreadCount,
      hasUnread,
      unreadLabel,
      lastPreview,
      senderLabel,
      counterpartEmail,
      messagesCount: ordered.length,
      isLastFromViewer,
      needsReply,
      responseFlowLabel,
      hiddenMessagesCount,
      isBlocked,
      isReported,
      isAdminHidden,
      isModerated,
      isMuted,
      stateTone,
      moderationState,
      moderationLabel,
      moderationHint,
      moderationBannerTitle,
      moderationBannerClass,
      moderationStateSummaryLabel,
      moderationSummaryClass,
      moderationImpactLabel,
      moderationImpactHint,
      moderationSendStateLabel,
      moderationVisibilityStateLabel,
      moderationReviewStateLabel,
      moderationNextStepLabel,
      moderationNextStepHint,
      priorityTier,
      priorityLabel,
      priorityHint,
      priorityClass,
      triageFocusLabel,
      threadAction,
      searchIndex
    };
  });

const totalUnread = threads.reduce((sum, thread) => sum + thread.unreadCount, 0);
const totalThreads = threads.length;
const totalUnreadThreads = threads.filter((thread) => thread.hasUnread).length;
const totalNeedsReply = threads.filter((thread) => thread.needsReply).length;
const totalBlocked = threads.filter((thread) => thread.isBlocked).length;
const totalMuted = threads.filter((thread) => thread.isMuted).length;
const totalAdminHidden = threads.filter((thread) => thread.isAdminHidden).length;
const totalReported = threads.filter((thread) => thread.isReported).length;
const totalModerated = threads.filter((thread) => thread.isModerated).length;
const totalActive = threads.filter((thread) => thread.stateTone === 'active').length;
const totalCriticalPriority = threads.filter((thread) => thread.priorityTier === 'critical').length;
const totalHighPriority = threads.filter((thread) => thread.priorityTier === 'high').length;
const totalMediumPriority = threads.filter((thread) => thread.priorityTier === 'medium').length;
const totalUnreadLabel = totalUnread > 0 ? formatUnreadCount(totalUnread) : 'Χωρίς μη αναγνωσμένα';
const filteredThreads = threads
  .filter((thread) => {
    if (showUnreadOnly && !thread.hasUnread) return false;
    if (showBlockedOnly && !thread.isBlocked) return false;
    if (showReportedOnly && !thread.isReported) return false;
    if (!searchQuery) return true;
    return thread.searchIndex.includes(searchQuery);
  })
  .sort((a, b) => {
    if (showUnreadFirst) {
      if (a.hasUnread !== b.hasUnread) return Number(b.hasUnread) - Number(a.hasUnread);
      if (a.unreadCount !== b.unreadCount) return b.unreadCount - a.unreadCount;
    }
    return b.lastMessageAt.localeCompare(a.lastMessageAt);
  });
const filteredThreadsCount = filteredThreads.length;
const hasFilteredResults = filteredThreadsCount > 0;
const filteredNeedsAttention = filteredThreads.filter((thread) => thread.priorityTier !== 'normal').length;
const filteredNeedsReplyCount = filteredThreads.filter((thread) => thread.needsReply).length;
const filteredBlockedCount = filteredThreads.filter((thread) => thread.isBlocked).length;
const filteredReportedCount = filteredThreads.filter((thread) => thread.isReported).length;
const filteredModerationWatchCount = filteredThreads.filter((thread) => thread.isModerated && !thread.isBlocked).length;
const filteredActiveCount = filteredThreads.filter((thread) => thread.stateTone === 'active').length;
const filteredHiddenCount = filteredThreads.filter((thread) => thread.isAdminHidden).length;
const filteredMutedCount = filteredThreads.filter((thread) => thread.isMuted).length;
const filteredClearFlowCount = Math.max(0, filteredThreadsCount - filteredNeedsAttention);
const getThreadHref = (id: string) => `/messages/thread?threadId=${encodeURIComponent(id)}&viewerEmail=${encodeURIComponent(viewerEmail)}`;
const priorityRank: Record<string, number> = { critical: 0, high: 1, medium: 2, normal: 3 };
const triageOrderedThreads = [...filteredThreads].sort((a, b) => {
  const rankDiff = (priorityRank[a.priorityTier] ?? 9) - (priorityRank[b.priorityTier] ?? 9);
  if (rankDiff !== 0) return rankDiff;
  if (a.needsReply !== b.needsReply) return Number(b.needsReply) - Number(a.needsReply);
  if (a.hasUnread !== b.hasUnread) return Number(b.hasUnread) - Number(a.hasUnread);
  return b.lastMessageAt.localeCompare(a.lastMessageAt);
});
const nextTriageThread = triageOrderedThreads.at(0) ?? null;
const nextTriageHref = nextTriageThread ? getThreadHref(nextTriageThread.threadId) : '';
const nextTriageLabel = !nextTriageThread
  ? 'Δεν υπάρχει ενεργό triage item.'
  : nextTriageThread.isBlocked
    ? 'Άνοιγμα μπλοκαρισμένου thread για έλεγχο ιστορικού'
    : nextTriageThread.needsReply
      ? 'Απάντηση σε εισερχόμενο μήνυμα'
      : nextTriageThread.threadAction === 'review'
        ? 'Παρακολούθηση ενεργής αναφοράς'
        : nextTriageThread.hasUnread
          ? 'Επεξεργασία unread ροής'
          : 'Έλεγχος moderation context';
const nextTriageHint = !nextTriageThread
  ? 'Μόλις προκύψει νέο thread, θα εμφανιστεί εδώ η προτεινόμενη επόμενη κίνηση.'
  : `${nextTriageThread.professionalSlug} · ${nextTriageThread.triageFocusLabel} · ${nextTriageThread.moderationLabel}`;
const nextTriageQueueLabel = !nextTriageThread
  ? 'Χωρίς ενεργό triage'
  : nextTriageThread.priorityTier === 'critical'
    ? 'Κρίσιμη ουρά'
    : nextTriageThread.priorityTier === 'high'
      ? 'Υψηλή προτεραιότητα'
      : nextTriageThread.priorityTier === 'medium'
        ? 'Μεσαία προτεραιότητα'
        : 'Κανονική ροή';
const nextTriageQueueClass = !nextTriageThread
  ? 'border-slate-300 bg-slate-100 text-slate-700'
  : nextTriageThread.priorityTier === 'critical'
    ? 'border-rose-300 bg-rose-100 text-rose-900'
    : nextTriageThread.priorityTier === 'high'
      ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
      : nextTriageThread.priorityTier === 'medium'
        ? 'border-sky-300 bg-sky-100 text-sky-900'
        : 'border-emerald-300 bg-emerald-100 text-emerald-900';
const nextTriageQueueHint = !nextTriageThread
  ? 'Η ουρά θα ενεργοποιηθεί μόλις προκύψει νέο thread.'
  : nextTriageThread.priorityHint;
const clearFiltersHref = buildListHref();
const currentViewHref = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: showBlockedOnly,
  reported: showReportedOnly,
  sort: sortMode
});
const listReturnTo = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: showBlockedOnly,
  reported: showReportedOnly,
  sort: sortMode
});
const unreadChipHref = buildListHref({
  q: searchQueryRaw,
  unread: !showUnreadOnly,
  blocked: showBlockedOnly,
  reported: showReportedOnly,
  sort: sortMode
});
const blockedChipHref = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: !showBlockedOnly,
  reported: showReportedOnly,
  sort: sortMode
});
const reportedChipHref = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: showBlockedOnly,
  reported: !showReportedOnly,
  sort: sortMode
});
const recentSortHref = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: showBlockedOnly,
  reported: showReportedOnly,
  sort: 'recent'
});
const unreadFirstSortHref = buildListHref({
  q: searchQueryRaw,
  unread: showUnreadOnly,
  blocked: showBlockedOnly,
  reported: showReportedOnly,
  sort: 'unread'
});
const unreadQueueHref = buildListHref({ unread: true, sort: 'unread' });
const blockedQueueHref = buildListHref({ blocked: true, sort: 'unread' });
const reportedQueueHref = buildListHref({ reported: true, sort: 'unread' });
const triageCriticalCount = triageOrderedThreads.filter((thread) => thread.priorityTier === 'critical').length;
const triageHighCount = triageOrderedThreads.filter((thread) => thread.priorityTier === 'high').length;
const triageMediumCount = triageOrderedThreads.filter((thread) => thread.priorityTier === 'medium').length;
const triageNormalCount = triageOrderedThreads.filter((thread) => thread.priorityTier === 'normal').length;
const triagePositionByThread = new Map(triageOrderedThreads.map((thread, index) => [thread.threadId, index + 1]));
const hasPartialResults = Boolean(listLoadError) && filteredThreadsCount > 0;
const hasViewerParamIssue = !hasViewerEmail || !hasValidViewerEmail;
const listStateSummary = !hasViewerEmail
  ? 'Προσθέστε `viewerEmail` στο URL για να φορτωθούν οι συνομιλίες.'
  : !hasValidViewerEmail
    ? 'Το `viewerEmail` δεν είναι έγκυρο. Διορθώστε τη μορφή email για να εμφανιστεί το inbox.'
    : showLoadingState
      ? 'Η λίστα συνομιλιών φορτώνει. Περιμένετε λίγα δευτερόλεπτα για πλήρη συγχρονισμό.'
      : listLoadError
        ? hasPartialResults
          ? `Υπάρχει σφάλμα φόρτωσης αλλά προβάλλονται ${filteredThreadsCount} διαθέσιμα threads.`
          : 'Υπάρχει σφάλμα φόρτωσης και δεν είναι διαθέσιμα αποτελέσματα.'
        : threads.length === 0
          ? 'Δεν υπάρχουν συνομιλίες ακόμα για αυτόν τον λογαριασμό.'
          : hasFilteredResults
            ? `Προβάλλονται ${filteredThreadsCount} threads από ${totalThreads}.`
            : 'Τα τρέχοντα φίλτρα δεν επιστρέφουν αποτελέσματα.';
const listStateTitle = !hasViewerEmail
  ? 'Απαιτείται viewerEmail'
  : !hasValidViewerEmail
    ? 'Μη έγκυρο viewerEmail'
    : showLoadingState
      ? 'Συγχρονισμός λίστας σε εξέλιξη'
      : listLoadError
        ? 'Η λίστα χρειάζεται επαναφόρτωση'
        : threads.length === 0
          ? 'Δεν έχει ξεκινήσει ακόμη συνομιλία'
          : hasFilteredResults
            ? 'Η λίστα είναι διαθέσιμη'
            : 'Δεν υπάρχουν αντιστοιχίσεις με τα τρέχοντα φίλτρα';
const listStateToneClass = hasViewerParamIssue
  ? 'border-amber-200 bg-amber-50/80 text-amber-900'
  : showLoadingState
    ? 'border-sky-200 bg-sky-50/80 text-sky-900'
    : listLoadError
      ? 'border-rose-200 bg-rose-50/80 text-rose-900'
      : !hasFilteredResults && threads.length > 0
        ? 'border-amber-200 bg-amber-50/80 text-amber-900'
        : 'border-emerald-200 bg-emerald-50/80 text-emerald-900';
const listStateFocusLabel = !hasViewerEmail
  ? 'Ρύθμιση URL'
  : !hasValidViewerEmail
    ? 'Διόρθωση email'
    : showLoadingState
      ? 'Συγχρονισμός ουράς'
      : listLoadError
        ? 'Ανάκτηση δεδομένων'
        : !hasFilteredResults && threads.length > 0
          ? 'Προσαρμογή φίλτρων'
          : hasFilteredResults
            ? 'Επόμενη triage ενέργεια'
            : 'Έναρξη inbox';
const listStateActionLabel = !hasViewerEmail || !hasValidViewerEmail
  ? 'Καθαρισμός URL'
  : showLoadingState
    ? ''
    : listLoadError
      ? 'Επανάληψη φόρτωσης'
      : threads.length === 0
        ? 'Ανανέωση λίστας'
        : hasFilteredResults
          ? (nextTriageThread ? 'Άνοιγμα προτεινόμενου thread' : 'Μετάβαση στα φίλτρα')
          : 'Καθαρισμός φίλτρων';
const listStateActionHref = !hasViewerEmail || !hasValidViewerEmail
  ? '/messages'
  : showLoadingState
    ? ''
    : listLoadError
      ? currentViewHref
      : threads.length === 0
        ? buildListHref({ sort: 'recent' })
        : hasFilteredResults
          ? (nextTriageHref || '#messages-controls')
          : clearFiltersHref;
const listStateSupportHint = !hasViewerEmail
  ? 'Παράδειγμα: `/messages?viewerEmail=name@example.com`.'
  : !hasValidViewerEmail
    ? 'Χρησιμοποιήστε πλήρη διεύθυνση email (π.χ. name@example.com).'
    : listLoadError
      ? 'Ορισμένα badges moderation μπορεί να μην αποδίδονται μέχρι να ολοκληρωθεί η ανάκτηση.'
      : hasFilteredResults
        ? `Ενεργή προβολή: ${filteredNeedsReplyCount} για απάντηση, ${filteredBlockedCount} μπλοκαρισμένα, ${filteredHiddenCount} με περιορισμένη ορατότητα, ${filteredReportedCount} σε αναφορές.`
        : threads.length === 0
          ? 'Το πρώτο thread θα εμφανιστεί αυτόματα εδώ μόλις υπάρξει activity.'
          : 'Δοκιμάστε διαφορετικά φίλτρα για να επανέλθουν αποτελέσματα.';
const listStateRecoveryHint = hasViewerParamIssue
  ? 'Μόλις διορθωθεί το URL, η ανάκτηση inbox εκτελείται άμεσα χωρίς επιπλέον ρυθμίσεις.'
  : showLoadingState
    ? 'Αν η φόρτωση καθυστερεί ασυνήθιστα, ανανεώστε τη σελίδα για νέο συγχρονισμό.'
    : listLoadError
      ? 'Προβάλλονται όσα δεδομένα ανακτήθηκαν. Ελέγξτε ξανά τη λίστα μετά από επανάληψη φόρτωσης.'
      : !hasFilteredResults && threads.length > 0
        ? 'Η προσαρμογή φίλτρων μπορεί να αποκαταστήσει άμεσα τα αποτελέσματα.'
        : 'Η τρέχουσα προβολή είναι σταθερή και έτοιμη για triage ενέργειες.';
const listStateAriaRole = hasViewerParamIssue || (listLoadError && !hasPartialResults) ? 'alert' : 'status';
const listStateAriaLive = hasViewerParamIssue || (listLoadError && !hasPartialResults) ? 'assertive' : 'polite';
const activeFilterChips: Array<{ label: string; href: string; tone: 'sky' | 'rose' | 'amber' }> = [];
if (showUnreadOnly) activeFilterChips.push({ label: 'Μόνο μη αναγνωσμένα', href: unreadChipHref, tone: 'sky' });
if (showBlockedOnly) activeFilterChips.push({ label: 'Μόνο μπλοκαρισμένα', href: blockedChipHref, tone: 'rose' });
if (showReportedOnly) activeFilterChips.push({ label: 'Μόνο αναφερόμενα', href: reportedChipHref, tone: 'amber' });
const inboxReadinessLabel = showLoadingState
  ? 'Inbox σε συγχρονισμό'
  : listLoadError
    ? 'Inbox με περιορισμένη ορατότητα'
    : filteredNeedsReplyCount > 0 || filteredBlockedCount > 0
      ? 'Inbox με άμεση εκκρεμότητα'
      : hasFilteredResults
        ? 'Inbox σε σταθερή ροή'
        : 'Inbox χωρίς ενεργές αντιστοιχίσεις';
const inboxReadinessClass = showLoadingState
  ? 'border-sky-300 bg-sky-100 text-sky-900'
  : listLoadError
    ? 'border-rose-300 bg-rose-100 text-rose-900'
    : filteredNeedsReplyCount > 0 || filteredBlockedCount > 0
      ? 'border-indigo-300 bg-indigo-100 text-indigo-900'
      : hasFilteredResults
        ? 'border-emerald-300 bg-emerald-100 text-emerald-900'
        : 'border-amber-300 bg-amber-100 text-amber-900';
const inboxReadinessHint = listLoadError
  ? 'Πιθανές ελλείψεις σε badges/moderation έως ότου ολοκληρωθεί το retry.'
  : filteredNeedsReplyCount > 0
    ? `Υπάρχουν ${filteredNeedsReplyCount} thread(s) που χρειάζονται απάντηση.`
    : filteredBlockedCount > 0
      ? `Υπάρχουν ${filteredBlockedCount} μπλοκαρισμένα thread(s) για έλεγχο.`
      : hasFilteredResults
        ? `Καθαρή ροή: ${filteredClearFlowCount} thread(s) χωρίς άμεση εκκρεμότητα.`
        : 'Προσαρμόστε τα φίλτρα για να εμφανιστούν διαθέσιμα threads.';
---

<Layout title="Συνομιλίες | GreekHandy" description="Λίστα συνομιλιών με καθαρή ιεραρχία, moderation badges και βασικές ενέργειες.">
  <main class="messages-shell mx-auto max-w-6xl px-4 py-10 md:py-14">
    <a href="#messages-results" class="messages-skip-link">Μετάβαση στη λίστα συνομιλιών</a>
    <section class="overflow-hidden rounded-[2rem] border border-slate-200/80 bg-gradient-to-br from-[#f9fcff] via-white to-[#f4f7fb] p-6 shadow-[0_12px_40px_-24px_rgba(15,23,42,0.35)] md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">GreekHandy Επικοινωνία</p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 md:text-4xl">Κέντρο Συνομιλιών</h1>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">Οργανωμένη εικόνα όλων των threads με καθαρή ιεραρχία, unread προτεραιότητα και ορατές καταστάσεις moderation.</p>
        </div>

        {canLoadThreads && (
          <div class="rounded-2xl border border-sky-200/70 bg-white/90 px-4 py-3 text-right shadow-[0_8px_28px_-20px_rgba(14,116,144,0.45)]">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-sky-700">Προβολή λογαριασμού</p>
            <p class="mt-1 text-sm font-semibold text-slate-900">{viewerEmail}</p>
          </div>
        )}
      </div>

      {canLoadThreads && (
        <div class="mt-6 grid gap-2.5 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-slate-200 bg-white/90 px-3 py-2.5 text-xs text-slate-600">
            <p class="font-semibold uppercase tracking-[0.12em] text-slate-500">Συνομιλίες</p>
            <p class="mt-1 text-lg font-bold text-slate-900">{totalThreads}</p>
          </div>
          <div class={`rounded-2xl border px-3 py-2.5 text-xs ${totalUnread > 0 ? 'border-sky-300 bg-sky-50 text-sky-900' : 'border-emerald-300 bg-emerald-50 text-emerald-900'}`}>
            <p class="font-semibold uppercase tracking-[0.12em]">Μη αναγνωσμένα</p>
            <p class="mt-1 text-sm font-semibold">{totalUnreadLabel}</p>
            <p class="mt-1 text-[11px] font-medium">Χρειάζονται απάντηση: {totalNeedsReply}</p>
          </div>
          <div class="rounded-2xl border border-indigo-300 bg-indigo-50 px-3 py-2.5 text-xs text-indigo-900">
            <p class="font-semibold uppercase tracking-[0.12em]">Ουρά προτεραιότητας</p>
            <p class="mt-1 text-sm font-semibold">Κρίσιμα: {totalCriticalPriority} · Υψηλά: {totalHighPriority} · Μεσαία: {totalMediumPriority}</p>
            <a href={unreadQueueHref} class="mt-1 inline-flex rounded-md border border-indigo-300 bg-white px-2 py-1 text-[11px] font-semibold text-indigo-900 transition hover:bg-indigo-100">Άνοιγμα ουράς</a>
          </div>
          <div class="rounded-2xl border border-rose-300 bg-rose-50 px-3 py-2.5 text-xs text-rose-900">
            <p class="font-semibold uppercase tracking-[0.12em]">Moderation κατάσταση</p>
            <p class="mt-1 text-sm font-semibold">Σύνολο: {totalModerated} · Αναφορές: {totalReported} · Μπλοκ: {totalBlocked}</p>
            <p class="mt-1 text-[11px] font-medium">Σίγαση: {totalMuted} · Κρυφά: {totalAdminHidden} · Ενεργές: {totalActive}</p>
          </div>
        </div>
      )}
    </section>

    {canLoadThreads && (
      <nav class="mt-4 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm" aria-label="Γρήγορη πλοήγηση inbox">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Γρήγορη πλοήγηση</p>
        <div class="mt-2 flex flex-wrap gap-2">
          <a href="#messages-controls" aria-controls="messages-controls" class="inline-flex items-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
            Φίλτρα και αναζήτηση
          </a>
          <a href="#messages-triage" aria-controls="messages-triage" class="inline-flex items-center rounded-full border border-indigo-300 bg-indigo-50 px-3 py-1.5 text-xs font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
            Triage προτεραιότητα
          </a>
          <a href="#messages-results" aria-controls="messages-results" class="inline-flex items-center rounded-full border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
            Λίστα συνομιλιών
          </a>
        </div>
      </nav>
    )}

    <section class="messages-toast-stack" aria-label="Καταστάσεις λίστας συνομιλιών">
      {status === 'invalid' && (
        <div class="messages-toast messages-toast--amber js-messages-toast" role="alert" tabindex="-1" data-focus-on-load="true">
          <p class="text-sm font-semibold">Δεν ήταν δυνατή η ενημέρωση ως αναγνωσμένη λόγω μη έγκυρων στοιχείων.</p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
      {status === 'forbidden' && (
        <div class="messages-toast messages-toast--rose js-messages-toast" role="alert" tabindex="-1" data-focus-on-load="true">
          <p class="text-sm font-semibold">Δεν έχετε πρόσβαση σε αυτό το thread.</p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
      {status === 'error' && (
        <div class="messages-toast messages-toast--rose js-messages-toast" role="alert" tabindex="-1" data-focus-on-load="true">
          <p class="text-sm font-semibold">Προέκυψε σφάλμα κατά την ενημέρωση της κατάστασης. Δοκιμάστε ξανά.</p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
      {showLoadingState && (
        <div class="messages-toast messages-toast--sky js-messages-toast" role="status" aria-live="polite" tabindex="-1" data-autohide-ms="0">
          <p class="flex items-center gap-2 text-sm font-semibold">
            <span class="h-3 w-3 animate-spin rounded-full border-2 border-sky-300 border-t-sky-700" aria-hidden="true"></span>
            Φόρτωση συνομιλιών...
          </p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
      {hasUnknownStatus && (
        <div class="messages-toast messages-toast--slate js-messages-toast" role="status" aria-live="polite" tabindex="-1" data-focus-on-load="true">
          <p class="text-sm font-semibold">Ελήφθη άγνωστη κατάσταση ενημέρωσης: <code>{status}</code>. Επαναφορτώστε τη σελίδα.</p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
      {listLoadError && (
        <div class="messages-toast messages-toast--rose js-messages-toast" role="alert" tabindex="-1" data-focus-on-load="true">
          <p class="text-sm font-semibold">Δεν ήταν δυνατή η πλήρης φόρτωση της λίστας.</p>
          <button type="button" class="messages-toast__dismiss" data-toast-dismiss aria-label="Κλείσιμο ειδοποίησης">Κλείσιμο</button>
        </div>
      )}
    </section>
    <p id="messages-submit-live" class="sr-only" role="status" aria-live="assertive" aria-atomic="true"></p>

    {listLoadError && (
      <div class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-4 text-rose-900" role="alert" aria-live="assertive">
        <p class="font-semibold">Δεν ήταν δυνατή η πλήρης φόρτωση της λίστας.</p>
        <p class="mt-1 text-sm">{listLoadError}</p>
        <p class="mt-1 text-xs">Μπορεί να λείπουν badges/moderation ενδείξεις μέχρι να επανέλθει η ανάγνωση δεδομένων. {hasPartialResults ? 'Προβάλλονται όσα στοιχεία ήταν διαθέσιμα.' : 'Δεν βρέθηκαν ανακτήσιμα στοιχεία.'}</p>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <a href={currentViewHref} class="inline-flex rounded-lg border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold text-rose-900 transition hover:bg-rose-100">
            Επανάληψη φόρτωσης
          </a>
          <a href={clearFiltersHref} class="inline-flex rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
            Καθαρισμός φίλτρων
          </a>
        </div>
      </div>
    )}

    {canLoadThreads && (
      <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-[0_10px_30px_-24px_rgba(15,23,42,0.4)]" aria-label="Υπόμνημα moderation">
        <div class="border-b border-slate-200/80 bg-gradient-to-r from-slate-50 via-white to-sky-50/80 px-4 py-3 text-xs text-slate-600">
          <span class="font-semibold text-slate-800">Υπόμνημα moderation:</span>
          <span class="ml-2">οπτική σήμανση των threads χωρίς αλλαγή συμπεριφοράς.</span>
        </div>
        <div class="flex flex-wrap gap-2 px-4 py-3 text-xs">
          <span class="rounded-full border border-sky-300 bg-sky-100 px-2 py-0.5 font-semibold text-sky-900">Αναφορά σε έλεγχο</span>
          <span class="rounded-full border border-rose-300 bg-rose-100 px-2 py-0.5 font-semibold text-rose-900">Μπλοκαρισμένη</span>
          <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 font-semibold text-orange-900">Κρυφό περιεχόμενο</span>
          <span class="rounded-full border border-orange-300 bg-orange-100 px-2 py-0.5 font-semibold text-orange-900">Σε σίγαση</span>
          <span class="rounded-full border border-amber-300 bg-amber-100 px-2 py-0.5 font-semibold text-amber-900">Αναφορά χωρίς περιορισμό</span>
        </div>
      </div>
    )}

    {canLoadThreads && (
      <section id="messages-controls" class="mt-6 rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_14px_36px_-28px_rgba(15,23,42,0.45)]">
        <form method="GET" action="/messages" class="space-y-3" aria-label="Αναζήτηση συνομιλιών" role="search" aria-describedby="messages-results-summary">
          <input type="hidden" name="viewerEmail" value={viewerEmail} />
          {showUnreadOnly && <input type="hidden" name="unread" value="1" />}
          {showBlockedOnly && <input type="hidden" name="blocked" value="1" />}
          {showReportedOnly && <input type="hidden" name="reported" value="1" />}
          {showUnreadFirst && <input type="hidden" name="sort" value="unread" />}
          <div>
            <label for="thread-search" class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600">Αναζήτηση thread</label>
            <div class="mt-1 flex flex-wrap items-center gap-2">
              <input
                id="thread-search"
                type="search"
                name="q"
                value={searchQueryRaw}
                placeholder="slug, email, preview, thread id"
                aria-describedby="thread-search-hint messages-results-summary"
                enterkeyhint="search"
                class="min-w-[220px] flex-1 rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder:text-slate-400"
              />
              <button type="submit" class="rounded-lg bg-slate-900 px-3.5 py-2 text-xs font-semibold text-white transition hover:bg-slate-700">Αναζήτηση</button>
              {hasListFilters && (
                <a href={clearFiltersHref} class="rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
                  Καθαρισμός όλων
                </a>
              )}
            </div>
            <p id="thread-search-hint" class="mt-2 text-[11px] text-slate-500">Αναζητήστε με slug, email συμμετέχοντα, preview μηνύματος ή thread ID.</p>
          </div>
        </form>

        <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600">Ταξινόμηση λίστας</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <a
              href={recentSortHref}
              aria-current={!showUnreadFirst ? 'page' : undefined}
              class={`inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold transition ${!showUnreadFirst ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50'}`}
            >
              Πιο πρόσφατα πρώτα
            </a>
            <a
              href={unreadFirstSortHref}
              aria-current={showUnreadFirst ? 'page' : undefined}
              class={`inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold transition ${showUnreadFirst ? 'border-sky-500 bg-sky-600 text-white' : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50'}`}
            >
              Μη αναγνωσμένα πρώτα
            </a>
          </div>
        </div>

        <div class="mt-4 rounded-xl border border-slate-200 bg-gradient-to-r from-slate-50 via-white to-slate-50/80 px-3 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600">Γρήγορη διαλογή λίστας</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <a href={unreadQueueHref} class="inline-flex items-center gap-1 rounded-full border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100">
              Εισερχόμενα για απάντηση ({totalNeedsReply})
