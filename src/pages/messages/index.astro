---
import Layout from '../../layouts/Layout.astro';

const url = new URL(Astro.request.url);
const viewerEmail = (url.searchParams.get('viewerEmail') || '').trim().toLowerCase();
const συνομιλίαId = (url.searchParams.get('συνομιλίαId') || url.searchParams.get('συνομιλία') || '').trim();
const statusRaw = (url.searchParams.get('status') || '').trim().toLowerCase();
const listQuery = (url.searchParams.get('q') || '').trim();
const unreadOnly = (url.searchParams.get('unread') || '') === '1';
const blockedOnly = (url.searchParams.get('blocked') || '') === '1';
const reportedOnly = (url.searchParams.get('reported') || '') === '1';
const sortMode = (url.searchParams.get('sort') || '').trim().toLowerCase() === 'unread' ? 'unread' : 'recent';
const hasLegacyParams = url.searchParams.has('professional')
  || url.searchParams.has('professionalSlug')
  || url.searchParams.has('συνομιλία');

const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const THREAD_PATTERN = /^[a-z0-9|@._-]{1,220}$/;
const KNOWN_STATUSES = new Set(['', 'loading', 'invalid', 'forbidden', 'error']);

const hasViewerEmail = viewerEmail.length > 0;
const hasValidViewerEmail = EMAIL_PATTERN.test(viewerEmail);
const hasThreadId = συνομιλίαId.length > 0;
const hasValidThreadId = THREAD_PATTERN.test(συνομιλίαId);
const hasValidThreadContext = hasValidViewerEmail && hasValidThreadId;
const hasPartialThreadContext = hasViewerEmail || hasThreadId;
const hasUnknownStatus = !KNOWN_STATUSES.has(statusRaw);

const listContextParts: string[] = [];
if (listQuery) listContextParts.push(`Αναζήτηση: "${listQuery}"`);
if (unreadOnly) listContextParts.push('Μόνο μη αναγνωσμένα');
if (blockedOnly) listContextParts.push('Μόνο μπλοκαρισμένα');
if (reportedOnly) listContextParts.push('Μόνο αναφερόμενα');
if (sortMode === 'unread') listContextParts.push('Sort: μη αναγνωσμένα πρώτα');
const listContextLabel = listContextParts.length > 0
  ? `Ενεργά φίλτρα: ${listContextParts.join(' · ')}`
  : 'Δεν έχουν εφαρμοστεί φίλτρα.';

const buildThreadHref = (options: { loading?: boolean } = {}) => {
  const params = new URLSearchParams();
  if (hasValidThreadId) params.set('συνομιλίαId', συνομιλίαId);
  if (hasValidViewerEmail) params.set('viewerEmail', viewerEmail);
  if (listQuery) params.set('listQ', listQuery);
  if (unreadOnly) params.set('listUnread', '1');
  if (blockedOnly) params.set('listBlocked', '1');
  if (reportedOnly) params.set('listReported', '1');
  if (sortMode === 'unread') params.set('listSort', 'unread');
  if (options.loading) params.set('status', 'loading');
  const query = params.toString();
  return query ? `/messages/συνομιλία?${query}` : '/messages/συνομιλία';
};

const συνομιλίαEntryHref = buildThreadHref();
const συνομιλίαLoadingHref = buildThreadHref({ loading: true });

const statusToneClass = statusRaw === 'error' || statusRaw === 'forbidden'
  ? 'border-rose-200 bg-rose-50 text-rose-900'
  : statusRaw === 'invalid'
    ? 'border-amber-200 bg-amber-50 text-amber-900'
    : statusRaw === 'loading'
      ? 'border-sky-200 bg-sky-50 text-sky-900'
      : 'border-slate-200 bg-slate-50 text-slate-800';

const statusTitle = statusRaw === 'error'
  ? 'Προσωρινό πρόβλημα στα μηνύματα.'
  : statusRaw === 'forbidden'
    ? 'Δεν ήταν δυνατή η πρόσβαση στη συνομιλία.'
    : statusRaw === 'invalid'
      ? 'Ο σύνδεσμος δεν ήταν πλήρης.'
      : statusRaw === 'loading'
        ? 'Γίνεται φόρτωση των μηνυμάτων σας.'
        : hasUnknownStatus
          ? 'Χρειάζεται ανανέωση για να συνεχίσετε.'
          : '';

const statusDescription = statusRaw === 'error'
  ? 'Περιμένετε λίγα δευτερόλεπτα και πατήστε «Επανέλεγχος πρόσβασης συνομιλίας». Αν το πρόβλημα επιμείνει, επιστρέψτε στη λίστα επαγγελματιών.'
  : statusRaw === 'forbidden'
    ? 'Ανοίξτε τη συνομιλία από το λογαριασμό που τη δημιούργησε.'
    : statusRaw === 'invalid'
      ? 'Ανοίξτε ξανά από το σημείο όπου ξεκινήσατε την επικοινωνία.'
      : statusRaw === 'loading'
        ? 'Αν καθυστερεί, πατήστε «Επανέλεγχος φόρτωσης».'
        : hasUnknownStatus
          ? 'Κάντε ανανέωση σελίδας για νέο έλεγχο.'
          : '';

const entryToneClass = hasValidThreadContext
  ? 'border-emerald-200 bg-emerald-50/70 text-emerald-900'
  : hasPartialThreadContext
    ? 'border-amber-200 bg-amber-50/70 text-amber-900'
    : 'border-slate-200 bg-slate-50/80 text-slate-700';

const entryTitle = hasValidThreadContext
  ? 'Η συνομιλία σας είναι έτοιμη.'
  : hasPartialThreadContext
    ? 'Χρειάζεται ασφαλής είσοδος για να ανοίξει η συνομιλία.'
    : 'Συνδεθείτε για να δείτε τα μηνύματά σας.';

const entryDescription = hasValidThreadContext
  ? 'Μπορείτε να συνεχίσετε απευθείας στη συνομιλία σας.'
  : hasPartialThreadContext
    ? 'Ο σύνδεσμος δεν περιέχει όλα τα απαραίτητα στοιχεία για άμεση είσοδο.'
    : 'Για προστασία των συνομιλιών, η πρόσβαση γίνεται μόνο με λογαριασμό ή από έγκυρο σύνδεσμο που δημιουργήθηκε μέσα από το GreekHandy.';

const συνομιλίαEntryActionLabel = 'Άνοιγμα συνομιλίας';
const συνομιλίαRetryActionLabel = 'Επανέλεγχος πρόσβασης συνομιλίας';
---

<Layout
  title="Inbox Μηνυμάτων | GreekHandy"
  description="Καθαρή και ασφαλής είσοδος στα μηνύματα GreekHandy, με σαφή καθοδήγηση και αξιόπιστες καταστάσεις φόρτωσης."
  canonicalUrl="https://greekhandy.gr/messages"
>
  <main class="messages-shell mx-auto max-w-4xl px-4 py-10 md:px-6 md:py-14">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-[0_18px_40px_-30px_rgba(15,23,42,0.5)] md:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">Μηνύματα · GreekHandy</p>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 md:text-3xl">Είσοδος στα μηνύματα</h1>
      <p class="mt-3 text-sm leading-6 text-slate-700">
        Για να δείτε τις συνομιλίες σας, χρειάζεται σύνδεση ή έγκυρη συνέχεια από προφίλ επαγγελματία. Αν είστε επισκέπτης, ξεκινήστε από τον κατάλογο επαγγελματιών.
      </p>

      {(statusTitle || hasLegacyParams) && (
        <div class={`mt-4 rounded-xl border px-4 py-3 text-sm ${statusToneClass}`} role={statusRaw === 'error' || statusRaw === 'forbidden' ? 'alert' : 'status'} aria-live={statusRaw === 'error' || statusRaw === 'forbidden' ? 'assertive' : 'polite'} aria-atomic="true">
          {statusTitle && <p class="font-semibold">{statusTitle}</p>}
          {statusDescription && <p class="mt-1">{statusDescription}</p>}
          {hasLegacyParams && (
            <p class="mt-1 text-xs">
              Εντοπίστηκε παλιός σύνδεσμος. Χρησιμοποιήστε τα κουμπιά παρακάτω για σωστή είσοδο.
            </p>
          )}
        </div>
      )}

      <section id="συνομιλία-entry-guide" class={`mt-5 rounded-2xl border px-4 py-4 text-sm ${entryToneClass}`} aria-labelledby="συνομιλία-entry-guide-title" aria-describedby="συνομιλία-entry-guide-description">
        <p id="συνομιλία-entry-guide-title" class="font-semibold">{entryTitle}</p>
        <p id="συνομιλία-entry-guide-description" class="mt-1">{entryDescription}</p>
        <div class="mt-3 rounded-lg border border-current/20 bg-white/75 px-3 py-3 text-xs leading-5">
          {hasValidThreadContext
            ? 'Η πρόσβαση επιβεβαιώθηκε και η συνομιλία μπορεί να ανοίξει κανονικά.'
            : hasPartialThreadContext
              ? 'Ο σύνδεσμος φαίνεται ελλιπής. Ανοίξτε την επικοινωνία από το προφίλ επαγγελματία για ασφαλή είσοδο.'
              : 'Δεν βρέθηκε ενεργή συνομιλία. Χρησιμοποιήστε το βασικό κουμπί για να μεταβείτε σε επαγγελματίες και να ξεκινήσετε νέα επικοινωνία.'}
        </div>
        <p class="mt-2 text-[11px] font-medium">Κατάσταση φίλτρων: {listContextLabel}</p>
      </section>


      {!hasValidThreadContext && (
        <section class="mt-5 rounded-2xl border border-slate-200 bg-slate-50/90 px-4 py-4 text-sm text-slate-700" aria-label="Οδηγίες για επισκέπτες χωρίς σύνδεση">
          <p class="font-semibold text-slate-900">Δεν βλέπετε ακόμη συνομιλίες;</p>
          <p class="mt-1">Αν δεν έχετε συνδεθεί, εδώ εμφανίζονται μόνο οδηγίες εισόδου. Για να ξεκινήσετε συνομιλία, ανοίξτε προφίλ επαγγελματία και επιλέξτε «Αποστολή μηνύματος».</p>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-xs text-slate-600">
            <li>Βήμα 1: Μετάβαση σε επαγγελματίες</li>
            <li>Βήμα 2: Επιλογή προφίλ και έναρξη επικοινωνίας</li>
            <li>Βήμα 3: Επιστροφή εδώ με έγκυρη πρόσβαση</li>
          </ul>
        </section>
      )}
      {hasValidThreadContext ? (
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <a
            href={συνομιλίαEntryHref}
            class="messages-touch-target inline-flex min-h-11 items-center justify-center rounded-xl bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
          >
            {συνομιλίαEntryActionLabel}
          </a>
          <a
            href={συνομιλίαLoadingHref}
            class="messages-touch-target inline-flex min-h-11 items-center justify-center rounded-xl border border-sky-300 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-900 transition hover:border-sky-400 hover:bg-sky-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
          >
            {συνομιλίαRetryActionLabel}
          </a>
        </div>
        <p class="mt-2 text-xs text-slate-600">Η ανανέωση θα ελέγξει ξανά τη διαθεσιμότητα της ίδιας συνομιλίας.</p>
      ) : (
        <div class="mt-5">
          <a
            href="/professionals"
            class="messages-touch-target inline-flex min-h-11 w-full items-center justify-center rounded-xl bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
          >
            Μετάβαση σε Επαγγελματίες
          </a>
          <p class="mt-2 text-xs text-slate-600">Με το πάτημα θα ανοίξει ο κατάλογος επαγγελματιών, όπου μπορείτε να επιλέξετε προφίλ και να ξεκινήσετε νέα συνομιλία με σωστή πρόσβαση.</p>
        </div>
      )}

      {hasValidThreadContext && (<section data-resume-card class="mt-5 hidden rounded-2xl border border-indigo-200 bg-indigo-50/80 px-4 py-4 text-sm text-indigo-900" aria-live="polite" aria-atomic="true" aria-labelledby="μηνύματα-resume-title" aria-describedby="μηνύματα-resume-description">
        <p id="μηνύματα-resume-title" class="font-semibold">Τελευταία συνομιλία στη συσκευή</p>
        <p id="μηνύματα-resume-description" class="mt-1 text-xs">Βρέθηκε πρόσφατη συνομιλία από την ίδια συσκευή.</p>
        <p class="mt-2 text-xs" data-resume-meta></p>
        <div class="mt-3 flex flex-wrap gap-2">
          <a data-resume-open href="/messages/συνομιλία" class="messages-touch-target inline-flex min-h-11 items-center justify-center rounded-lg border border-indigo-300 bg-white px-3 py-1.5 text-xs font-semibold text-indigo-900 transition hover:border-indigo-400 hover:bg-indigo-100">
            Άνοιγμα τελευταίας συνομιλίας
          </a>
          <a data-resume-list href="/messages" class="messages-touch-target inline-flex min-h-11 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50">
            Επιστροφή στη σελίδα μηνυμάτων
          </a>
        </div>
      </section>)}

      <p class="mt-5 text-xs text-slate-500">
        Αν συνεχίσει το πρόβλημα, επικοινωνήστε με την ομάδα GreekHandy από τη σελίδα «Επικοινωνία».
      </p>
    </section>
  </main>

  <style>
    .messages-shell :where(a, button, input):focus-visible {
      outline: 3px solid rgba(14, 116, 144, 0.4);
      outline-offset: 3px;
      box-shadow: 0 0 0 4px rgba(14, 116, 144, 0.12);
    }

    @media (max-width: 640px) {
      .messages-touch-target {
        width: 100%;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const resumeCard = document.querySelector('[data-resume-card]');
      if (!(resumeCard instanceof HTMLElement)) return;

      const resumeMeta = resumeCard.querySelector('[data-resume-meta]');
      const resumeOpen = resumeCard.querySelector('[data-resume-open]');
      const resumeList = resumeCard.querySelector('[data-resume-list]');
      if (!(resumeMeta instanceof HTMLElement) || !(resumeOpen instanceof HTMLAnchorElement) || !(resumeList instanceof HTMLAnchorElement)) return;

      const getStorage = () => {
        try {
          const storage = window.localStorage;
          const probeKey = '__gh_messages_resume_probe__';
          storage.setItem(probeKey, '1');
          storage.removeItem(probeKey);
          return storage;
        } catch {
          return null;
        }
      };

      const storage = getStorage();
      if (!storage) return;

      const searchParams = new URLSearchParams(window.location.search);
      const scopedViewer = (searchParams.get('viewerEmail') || '').trim().toLowerCase();
      const keys = [];

      if (scopedViewer) {
        keys.push(`gh:last-συνομιλία-visit:${scopedViewer}`);
      } else {
        for (let index = 0; index < storage.length; index += 1) {
          const key = storage.key(index) || '';
          if (key.startsWith('gh:last-συνομιλία-visit:')) keys.push(key);
        }
      }

      let latest = null;
      for (const key of keys) {
        let parsed = null;
        try {
          parsed = JSON.parse(storage.getItem(key) || 'null');
        } catch {
          parsed = null;
        }
        if (!parsed || typeof parsed !== 'object') continue;
        if (typeof parsed.href !== 'string' || !parsed.href.startsWith('/messages/συνομιλία')) continue;
        const savedAt = Number(parsed.savedAt || 0);
        if (!Number.isFinite(savedAt) || savedAt <= 0) continue;
        if (!latest || savedAt > latest.savedAt) latest = parsed;
      }

      if (!latest) return;

      const formattedDate = new Intl.DateTimeFormat('el-GR', {
        dateStyle: 'short',
        timeStyle: 'short'
      }).format(new Date(latest.savedAt));
      const counterpart = typeof latest.counterpartEmail === 'string' && latest.counterpartEmail.length > 0
        ? latest.counterpartEmail
        : 'μη διαθέσιμος συμμετέχων';

      resumeMeta.textContent = `Τελευταία δραστηριότητα: ${formattedDate} · Συμμετέχων: ${counterpart}`;
      resumeOpen.href = latest.href;
      if (typeof latest.listHref === 'string' && latest.listHref.startsWith('/messages')) {
        resumeList.href = latest.listHref;
      } else {
        resumeList.hidden = true;
      }

      resumeCard.classList.remove('hidden');
    })();
  </script>
</Layout>
