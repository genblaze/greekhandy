---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import { NAV_TARGETS, PRIMARY_NAV_LINKS, TOP_NAV_LINKS } from '../config/navigation';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const { title, description, canonicalUrl, ogImage, twitterCard } = Astro.props;
Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');
const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);
const isRouteActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="el">
  <head>
    <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} twitterCard={twitterCard} />
    <slot name="head" />
  </head>
  <body class="bg-slate-50 font-sans text-slate-900 antialiased">
    <a
      href="#gh-site-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-3 focus:z-[90] focus:rounded-full focus:border focus:border-sky-600 focus:bg-white focus:px-3 focus:py-1.5 focus:text-xs focus:font-semibold focus:text-sky-900 focus:shadow-lg focus:outline-none"
    >
      Μετάβαση στο κύριο περιεχόμενο
    </a>
    <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-md">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6">
        <a href="/" class="text-xl font-semibold tracking-tight text-slate-900 md:text-2xl">GreekHandy</a>
        <div class="hidden items-center gap-6 text-sm font-medium text-slate-700 md:flex">
          <a href="/" class="transition hover:text-slate-900">Αρχική</a>
          <a href="/#services" class="transition hover:text-slate-900">Υπηρεσίες</a>
          {TOP_NAV_LINKS.map((navLink) => (
            <a
              href={navLink.href}
              aria-current={isRouteActive(navLink.href) ? 'page' : undefined}
              class={`transition hover:text-slate-900 ${isRouteActive(navLink.href) ? 'text-slate-900 underline decoration-2 underline-offset-8' : ''}`}
            >
              {navLink.label}
            </a>
          ))}
          <a href={NAV_TARGETS.contact} class="rounded-full border border-slate-300 px-4 py-2 transition hover:border-slate-400 hover:bg-slate-100">Επικοινωνία</a>
        </div>
      </nav>
      <div class="border-t border-slate-200/80 md:hidden">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Μενού</p>
          <button
            type="button"
            data-mobile-nav-toggle
            aria-controls="mobile-nav-drawer"
            aria-expanded="false"
            aria-haspopup="dialog"
            aria-label="Άνοιγμα μενού πλοήγησης"
            class="inline-flex min-h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
          >
            ☰ Μενού
          </button>
        </div>

        <div data-mobile-nav-overlay class="fixed inset-0 z-40 hidden bg-slate-900/45" aria-hidden="true"></div>
        <nav
          id="mobile-nav-drawer"
          data-mobile-nav-drawer
          role="dialog"
          aria-modal="true"
          aria-labelledby="mobile-nav-title"
          aria-label="Κύρια πλοήγηση κινητού"
          aria-hidden="true"
          tabindex="-1"
          class="fixed right-0 top-0 z-50 hidden h-full w-[min(88vw,22rem)] border-l border-slate-200 bg-white p-4 shadow-2xl"
        >
          <div class="flex items-center justify-between border-b border-slate-200 pb-3">
            <p id="mobile-nav-title" class="text-sm font-semibold text-slate-900">Πλοήγηση</p>
            <button
              type="button"
              data-mobile-nav-close
              aria-label="Κλείσιμο μενού πλοήγησης"
              class="inline-flex min-h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
            >
              Κλείσιμο
            </button>
          </div>
          <ul class="mt-4 space-y-2">
            {PRIMARY_NAV_LINKS.map((navLink) => (
              <li>
                <a
                  href={navLink.href}
                  data-mobile-nav-link
                  aria-current={isRouteActive(navLink.href) ? 'page' : undefined}
                  class={`flex min-h-11 items-center rounded-lg px-3 text-sm font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 ${isRouteActive(navLink.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900'}`}
                >
                  {navLink.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <div id="gh-site-content">
      <slot />
    </div>

    <footer class="mt-12 border-t border-slate-200 bg-white py-12 text-slate-600">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">GreekHandy</h3>
            <p class="text-sm leading-relaxed">Βρείτε αξιόπιστους επαγγελματίες για κάθε εργασία στην Ελλάδα.</p>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">Δημοφιλείς Υπηρεσίες</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={NAV_TARGETS.guides} class="transition hover:text-slate-900">Οδηγοί GreekHandy</a></li>
              <li><a href="/ilektrologoi" class="transition hover:text-slate-900">Ηλεκτρολόγοι</a></li>
              <li><a href="/ydravlikoi" class="transition hover:text-slate-900">Υδραυλικοί</a></li>
              <li><a href="/elaiokhrwmatistes" class="transition hover:text-slate-900">Ελαιοχρωματιστές</a></li>
              <li><a href="/katharismoi" class="transition hover:text-slate-900">Καθαρισμοί</a></li>
              <li><a href="/techniki-klimatismou" class="transition hover:text-slate-900">Κλιματισμός</a></li>
            </ul>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">Επικοινωνία</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={NAV_TARGETS.contact} class="transition hover:text-slate-900">Σελίδα επικοινωνίας</a></li>
              <li><a href="mailto:info@greekhandy.gr" class="transition hover:text-slate-900">info@greekhandy.gr</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-slate-200 pt-8 text-center text-sm text-slate-500">
          <p>&copy; {new Date().getFullYear()} GreekHandy. Με επιφύλαξη παντός δικαιώματος.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toolbarSelector = '[data-accessibility-toolbar], .accessibility-toolbar, #accessibility-toolbar';
        const collisionTargetSelector = '[data-gh-widget-avoid], [data-selection-dock], [data-detail-panel], [role="dialog"][aria-modal="true"], [data-mobile-nav-drawer]';
        const actionableSelector = 'a[href], button:not([disabled]), input:not([type="hidden"]):not([disabled]), select:not([disabled]), textarea:not([disabled]), [role="button"], [tabindex]:not([tabindex="-1"])';
        const root = document.documentElement;
        const dockBindings = new Map();
        let dockCounter = 0;
        let dockSyncQueued = false;
        const schedule = (callback) => {
          if (typeof window.requestIdleCallback === 'function') {
            window.requestIdleCallback(() => callback(), { timeout: 1200 });
            return;
          }
          window.setTimeout(callback, 0);
        };
        const getFirstFocusable = (node) => node.querySelector('button, a[href], input, select, textarea, [role="button"], [tabindex]:not([tabindex="-1"])');
        const parsePx = (value) => {
          const parsed = Number.parseFloat(value || '');
          return Number.isFinite(parsed) ? parsed : 0;
        };
        const isElementVisible = (node) => {
          if (!(node instanceof HTMLElement)) return false;
          if (node.hidden) return false;
          const style = window.getComputedStyle(node);
          if (style.display === 'none' || style.visibility === 'hidden' || style.visibility === 'collapse') return false;
          if (style.opacity === '0') return false;
          return true;
        };
        const isRectVisible = (rect) => rect.width > 0 && rect.height > 0
          && rect.bottom > 0 && rect.right > 0
          && rect.top < window.innerHeight && rect.left < window.innerWidth;
        const intersects = (a, b, margin = 0) => !(
          a.right < (b.left - margin)
          || a.left > (b.right + margin)
          || a.bottom < (b.top - margin)
          || a.top > (b.bottom + margin)
        );
        const hasActionableContent = (node) => {
          if (!(node instanceof HTMLElement)) return false;
          if (node.matches(actionableSelector)) return true;
          return node.querySelector(actionableSelector) instanceof HTMLElement;
        };
        const getFloatingContainer = (node) => {
          let current = node;
          while (current instanceof HTMLElement && current !== document.body) {
            const style = window.getComputedStyle(current);
            if (style.position === 'fixed' || style.position === 'sticky') return current;
            current = current.parentElement;
          }
          return null;
        };
        const cleanupDetachedToolbars = () => {
          for (const [toolbar, binding] of dockBindings.entries()) {
            if (toolbar instanceof HTMLElement && toolbar.isConnected) continue;
            if (binding.trigger instanceof HTMLElement && binding.trigger.isConnected) {
              binding.trigger.remove();
            }
            dockBindings.delete(toolbar);
          }
        };
        const getCollisionTargets = () => {
          const targets = [];
          const seen = new Set();
          for (const node of document.querySelectorAll(collisionTargetSelector)) {
            if (!(node instanceof HTMLElement) || seen.has(node)) continue;
            seen.add(node);
            targets.push(node);
          }
          for (const control of document.querySelectorAll(actionableSelector)) {
            if (!(control instanceof HTMLElement)) continue;
            const floatingContainer = getFloatingContainer(control);
            if (!(floatingContainer instanceof HTMLElement) || seen.has(floatingContainer)) continue;
            seen.add(floatingContainer);
            targets.push(floatingContainer);
          }
          return targets;
        };
        const syncDockCollisionOffsets = () => {
          const firstBindingEntry = dockBindings.values().next();
          const primaryBinding = firstBindingEntry.done ? null : firstBindingEntry.value;
          if (!primaryBinding?.trigger) {
            root.style.setProperty('--gh-accessibility-dock-offset-bottom', '0px');
            root.style.setProperty('--gh-accessibility-dock-offset-right', '0px');
            return;
          }
          root.style.setProperty('--gh-accessibility-dock-offset-bottom', '0px');
          root.style.setProperty('--gh-accessibility-dock-offset-right', '0px');

          const trigger = primaryBinding.trigger;
          const triggerRect = trigger.getBoundingClientRect();
          const triggerStyle = window.getComputedStyle(trigger);
          const baseRight = parsePx(triggerStyle.right);
          const baseBottom = parsePx(triggerStyle.bottom);
          const triggerSize = Math.max(44, Math.round(Math.max(triggerRect.width, triggerRect.height)));
          const panelWidth = Math.min(352, Math.max(window.innerWidth - 24, triggerSize));
          const panelHeight = Math.min(Math.max(window.innerHeight * 0.62, 220), 512);
          const collisionPadding = 10;
          const targets = getCollisionTargets();
          let bottomOffset = 0;
          let rightOffset = 0;

          for (let pass = 0; pass < 3; pass += 1) {
            let changed = false;
            const rightEdge = Math.max(0, window.innerWidth - baseRight - rightOffset);
            const bottomEdge = Math.max(0, window.innerHeight - baseBottom - bottomOffset);
            const collisionZone = {
              left: Math.max(0, rightEdge - panelWidth),
              right: rightEdge,
              top: Math.max(0, bottomEdge - triggerSize - panelHeight - 10),
              bottom: bottomEdge
            };

            for (const target of targets) {
              if (!(target instanceof HTMLElement)) continue;
              if (target === trigger || target === primaryBinding.toolbar || primaryBinding.toolbar.contains(target)) continue;
              if (!isElementVisible(target) || !hasActionableContent(target)) continue;

              const computed = window.getComputedStyle(target);
              const isExplicitTarget = target.hasAttribute('data-gh-widget-avoid');
              const isFloatingTarget = computed.position === 'fixed' || computed.position === 'sticky';
              if (!isExplicitTarget && !isFloatingTarget) continue;

              const rect = target.getBoundingClientRect();
              if (!isRectVisible(rect) || !intersects(collisionZone, rect, collisionPadding)) continue;

              const verticalPush = Math.max(0, collisionZone.bottom + collisionPadding - rect.top);
              const horizontalPush = Math.max(0, collisionZone.right + collisionPadding - rect.left);
              if (verticalPush <= 0 && horizontalPush <= 0) continue;

              if (verticalPush > 0 && (horizontalPush <= 0 || verticalPush <= horizontalPush)) {
                const nextBottomOffset = Math.min(Math.round(verticalPush), Math.round(window.innerHeight * 0.72));
                if (nextBottomOffset > bottomOffset) {
                  bottomOffset = nextBottomOffset;
                  changed = true;
                }
              } else {
                const nextRightOffset = Math.min(Math.round(horizontalPush), Math.round(window.innerWidth * 0.62));
                if (nextRightOffset > rightOffset) {
                  rightOffset = nextRightOffset;
                  changed = true;
                }
              }
            }

            if (!changed) break;
          }

          root.style.setProperty('--gh-accessibility-dock-offset-bottom', `${Math.max(0, bottomOffset)}px`);
          root.style.setProperty('--gh-accessibility-dock-offset-right', `${Math.max(0, rightOffset)}px`);
        };
        const getToolbarSafeInset = (binding) => {
          if (!(binding?.trigger instanceof HTMLElement)) return 0;
          const triggerRect = binding.trigger.getBoundingClientRect();
          const collapsedInset = Math.max(72, Math.round(triggerRect.height + 22));
          if (!(binding.toolbar instanceof HTMLElement) || binding.open !== true) return collapsedInset;
          const toolbarRect = binding.toolbar.getBoundingClientRect();
          if (toolbarRect.height <= 0 || toolbarRect.width <= 0) return collapsedInset;
          return Math.round(Math.min(collapsedInset + toolbarRect.height + 12, window.innerHeight * 0.78));
        };
        const syncToolbarSafeArea = () => {
          cleanupDetachedToolbars();
          syncDockCollisionOffsets();
          let nextInset = 0;
          for (const binding of dockBindings.values()) {
            nextInset = Math.max(nextInset, getToolbarSafeInset(binding));
          }
          const resolvedInset = dockBindings.size > 0 ? Math.max(nextInset, 72) : 0;
          root.style.setProperty('--gh-accessibility-toolbar-safe-area', `${resolvedInset}px`);
        };
        const queueDockSync = () => {
          if (dockSyncQueued) return;
          dockSyncQueued = true;
          window.requestAnimationFrame(() => {
            dockSyncQueued = false;
            schedule(syncToolbarSafeArea);
          });
        };
        const setDockOpen = (binding, nextOpen, focusPanel = false) => {
          if (!(binding?.toolbar instanceof HTMLElement) || !(binding.trigger instanceof HTMLButtonElement)) return;
          binding.open = nextOpen;
          binding.toolbar.setAttribute('data-gh-docked-open', nextOpen ? 'true' : 'false');
          binding.toolbar.setAttribute('data-gh-widget-expanded', nextOpen ? 'true' : 'false');
          binding.toolbar.setAttribute('aria-hidden', nextOpen ? 'false' : 'true');
          if ('inert' in binding.toolbar) binding.toolbar.inert = !nextOpen;
          binding.trigger.setAttribute('aria-expanded', nextOpen ? 'true' : 'false');
          binding.trigger.setAttribute('aria-label', nextOpen ? 'Κλείσιμο εργαλείων προσβασιμότητας' : 'Άνοιγμα εργαλείων προσβασιμότητας');

          if (!nextOpen && binding.toolbar.contains(document.activeElement)) {
            binding.trigger.focus({ preventScroll: true });
          }
          if (nextOpen && focusPanel) {
            schedule(() => {
              const target = getFirstFocusable(binding.toolbar);
              if (target instanceof HTMLElement) target.focus({ preventScroll: true });
            });
          }
          queueDockSync();
        };
        const closeDockedToolbars = (exceptToolbar = null) => {
          for (const [toolbar, binding] of dockBindings.entries()) {
            if (toolbar === exceptToolbar) continue;
            if (binding.open) setDockOpen(binding, false);
          }
        };
        const attachToolbar = (node) => {
          if (!(node instanceof HTMLElement) || dockBindings.has(node) || node.dataset.ghWidgetBound === 'true') return;
          dockCounter += 1;
          node.dataset.ghWidgetBound = 'true';
          if (!node.id) node.id = `gh-accessibility-toolbar-${dockCounter}`;
          const trigger = document.createElement('button');
          trigger.type = 'button';
          trigger.className = 'gh-accessibility-dock-trigger';
          trigger.id = `gh-accessibility-trigger-${dockCounter}`;
          trigger.setAttribute('aria-controls', node.id);
          trigger.innerHTML = '<span class="gh-accessibility-dock-icon" aria-hidden="true">A11y</span><span class="sr-only">Εργαλεία προσβασιμότητας</span>';
          document.body.append(trigger);

          const binding = { toolbar: node, trigger, open: false };
          dockBindings.set(node, binding);
          setDockOpen(binding, false);

          trigger.addEventListener('click', () => {
            const willOpen = !binding.open;
            if (willOpen) closeDockedToolbars(node);
            setDockOpen(binding, willOpen, willOpen);
          });
          node.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key !== 'Escape' || !binding.open) return;
            event.preventDefault();
            setDockOpen(binding, false);
            trigger.focus({ preventScroll: true });
          });
          const stateObserver = new MutationObserver(() => {
            queueDockSync();
          });
          stateObserver.observe(node, {
            attributes: true,
            attributeFilter: ['aria-expanded', 'aria-hidden', 'class', 'style']
          });
          if (typeof ResizeObserver === 'function') {
            const resizeObserver = new ResizeObserver(() => {
              queueDockSync();
            });
            resizeObserver.observe(node);
            resizeObserver.observe(trigger);
          }
        };
        const scanToolbars = () => {
          for (const toolbar of document.querySelectorAll(toolbarSelector)) {
            attachToolbar(toolbar);
          }
          syncToolbarSafeArea();
        };
        const start = () => {
          if (window.location.hash === '#contact' && window.location.pathname === '/') {
            window.history.replaceState({}, '', '/epikoinonia');
          }

          schedule(scanToolbars);
          if (!(document.body instanceof HTMLElement)) return;
          const skipTarget = document.querySelector('#gh-site-content');
          if (skipTarget instanceof HTMLElement && !skipTarget.hasAttribute('tabindex')) {
            skipTarget.setAttribute('tabindex', '-1');
          }
          const mainContent = document.querySelector('main');
          if (mainContent instanceof HTMLElement) {
            if (!mainContent.id) mainContent.id = 'gh-main-content';
            if (!mainContent.hasAttribute('tabindex')) mainContent.setAttribute('tabindex', '-1');
          }
          const discoveryObserver = new MutationObserver(() => {
            schedule(scanToolbars);
          });
          discoveryObserver.observe(document.body, { childList: true, subtree: true });
          window.setTimeout(() => {
            discoveryObserver.disconnect();
          }, 20000);
          window.addEventListener('resize', queueDockSync, { passive: true });
          window.addEventListener('orientationchange', queueDockSync, { passive: true });
          window.addEventListener('scroll', queueDockSync, { passive: true });
          document.addEventListener('click', queueDockSync, true);
          document.addEventListener('pointerdown', (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            let shouldClose = true;
            for (const binding of dockBindings.values()) {
              if (binding.toolbar.contains(target) || binding.trigger.contains(target)) {
                shouldClose = false;
                break;
              }
            }
            if (shouldClose) closeDockedToolbars();
            queueDockSync();
          });
          document.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent) || event.key !== 'Escape') return;
            closeDockedToolbars();
            queueDockSync();
          });

          const toggle = document.querySelector('[data-mobile-nav-toggle]');
          const closeButton = document.querySelector('[data-mobile-nav-close]');
          const drawer = document.querySelector('[data-mobile-nav-drawer]');
          const overlay = document.querySelector('[data-mobile-nav-overlay]');
          const links = Array.from(document.querySelectorAll('[data-mobile-nav-link]'));
          const pageContent = document.querySelector('#gh-site-content');
          const focusableSelector = 'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
          const desktopQuery = typeof window.matchMedia === 'function' ? window.matchMedia('(min-width: 768px)') : null;
          let navOpen = false;
          let restoreFocusElement = null;
          let bodyLockPaddingRight = '';
          let touchStartX = 0;
          let touchStartY = 0;

          if (!(toggle instanceof HTMLButtonElement) || !(drawer instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;

          const setBackgroundInert = (inert) => {
            if (!(pageContent instanceof HTMLElement) || !('inert' in pageContent)) return;
            pageContent.inert = inert;
          };
          const getFocusableDrawerItems = () => Array.from(drawer.querySelectorAll(focusableSelector))
            .filter((item) => item instanceof HTMLElement && !item.hasAttribute('disabled') && item.getAttribute('aria-hidden') !== 'true');
          const syncBodyScrollLock = (lock) => {
            if (lock) {
              const scrollbarWidth = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
              bodyLockPaddingRight = document.body.style.paddingRight || '';
              if (scrollbarWidth > 0) document.body.style.paddingRight = `${scrollbarWidth}px`;
              document.body.classList.add('overflow-hidden');
              return;
            }
            document.body.classList.remove('overflow-hidden');
            document.body.style.paddingRight = bodyLockPaddingRight;
          };
          const setOpen = (open, options = {}) => {
            const shouldRestoreFocus = options.restoreFocus !== false;
            if (open === navOpen) return;
            navOpen = open;
            if (open && document.activeElement instanceof HTMLElement) {
              restoreFocusElement = document.activeElement;
            }
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            toggle.setAttribute('aria-label', open ? 'Κλείσιμο μενού πλοήγησης' : 'Άνοιγμα μενού πλοήγησης');
            drawer.classList.toggle('hidden', !open);
            drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
            if ('inert' in drawer) drawer.inert = !open;
            overlay.classList.toggle('hidden', !open);
            overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
            setBackgroundInert(open);
            syncBodyScrollLock(open);
            if (open) {
              const firstFocusable = getFocusableDrawerItems().find((item) => item instanceof HTMLElement);
              if (firstFocusable instanceof HTMLElement) {
                firstFocusable.focus({ preventScroll: true });
              } else {
                drawer.focus({ preventScroll: true });
              }
            } else {
              if (shouldRestoreFocus) {
                const target = restoreFocusElement instanceof HTMLElement ? restoreFocusElement : toggle;
                target.focus({ preventScroll: true });
              }
              restoreFocusElement = null;
            }
            queueDockSync();
          };
          const trapDrawerFocus = (event) => {
            if (!navOpen || event.key !== 'Tab') return;
            const focusableItems = getFocusableDrawerItems();
            if (focusableItems.length === 0) {
              event.preventDefault();
              drawer.focus({ preventScroll: true });
              return;
            }
            const firstItem = focusableItems[0];
            const lastItem = focusableItems[focusableItems.length - 1];
            const activeElement = document.activeElement;
            if (event.shiftKey && activeElement === firstItem) {
              event.preventDefault();
              lastItem.focus({ preventScroll: true });
              return;
            }
            if (!event.shiftKey && activeElement === lastItem) {
              event.preventDefault();
              firstItem.focus({ preventScroll: true });
            }
          };

          toggle.addEventListener('click', () => {
            setOpen(!navOpen);
          });

          closeButton?.addEventListener('click', () => setOpen(false));
          overlay.addEventListener('click', () => setOpen(false));
          links.forEach((link) => link.addEventListener('click', () => setOpen(false, { restoreFocus: false })));
          drawer.addEventListener('keydown', trapDrawerFocus);
          drawer.addEventListener('touchstart', (event) => {
            const touch = event.touches[0];
            if (!touch) return;
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
          }, { passive: true });
          drawer.addEventListener('touchmove', (event) => {
            if (!navOpen) return;
            const touch = event.touches[0];
            if (!touch) return;
            const deltaX = touch.clientX - touchStartX;
            const deltaY = touch.clientY - touchStartY;
            if (deltaX > 70 && Math.abs(deltaY) < 48) {
              setOpen(false);
            }
          }, { passive: true });

          document.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key === 'Escape' && navOpen) {
              event.preventDefault();
              setOpen(false);
            }
          });
          if (desktopQuery) {
            const closeOnDesktop = (event) => {
              if (event.matches && navOpen) setOpen(false, { restoreFocus: false });
            };
            if (typeof desktopQuery.addEventListener === 'function') {
              desktopQuery.addEventListener('change', closeOnDesktop);
            } else if (typeof desktopQuery.addListener === 'function') {
              desktopQuery.addListener(closeOnDesktop);
            }
          }
          window.addEventListener('pageshow', () => {
            if (navOpen) setOpen(false, { restoreFocus: false });
          });
          setOpen(false, { restoreFocus: false });
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start, { once: true });
          return;
        }
        start();
      })();
    </script>
  
    <script is:inline>
      (() => {
        const ATTR_PREFIX = `data-${'astro-source'}`;
        const stripNode = (node) => {
          if (!(node instanceof Element)) return;
          for (const attr of Array.from(node.attributes)) {
            if (attr.name.startsWith(ATTR_PREFIX)) node.removeAttribute(attr.name);
          }
          node.querySelectorAll('*').forEach((el) => {
            for (const attr of Array.from(el.attributes)) {
              if (attr.name.startsWith(ATTR_PREFIX)) el.removeAttribute(attr.name);
            }
          });
        };

        const run = () => stripNode(document.documentElement);
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run, { once: true });
        } else {
          run();
        }

        const mo = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            mutation.addedNodes.forEach((node) => stripNode(node));
            if (mutation.type === 'attributes' && mutation.target instanceof Element) {
              stripNode(mutation.target);
            }
          }
        });
        mo.observe(document.documentElement, { childList: true, subtree: true, attributes: true });
      })();
    </script>

  </body>
</html>
