---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import { NAV_TARGETS, PRIMARY_NAV_LINKS, TOP_NAV_LINKS } from '../config/navigation';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const { title, description, canonicalUrl, ogImage, twitterCard } = Astro.props;
Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');
const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);
const isRouteActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="el">
  <head>
    <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} twitterCard={twitterCard} />
    <slot name="head" />
  </head>
  <body class="bg-slate-50 font-sans text-slate-900 antialiased">
    <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur-md">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6">
        <a href="/" class="text-xl font-semibold tracking-tight text-slate-900 md:text-2xl">GreekHandy</a>
        <div class="hidden items-center gap-6 text-sm font-medium text-slate-700 md:flex">
          <a href="/" class="transition hover:text-slate-900">Αρχική</a>
          <a href="/#services" class="transition hover:text-slate-900">Υπηρεσίες</a>
          {TOP_NAV_LINKS.map((navLink) => (
            <a
              href={navLink.href}
              class={`transition hover:text-slate-900 ${isRouteActive(navLink.href) ? 'text-slate-900 underline decoration-2 underline-offset-8' : ''}`}
            >
              {navLink.label}
            </a>
          ))}
          <a href="/#contact" class="rounded-full border border-slate-300 px-4 py-2 transition hover:border-slate-400 hover:bg-slate-100">Επικοινωνία</a>
        </div>
      </nav>
      <div class="border-t border-slate-200/80 md:hidden">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Μενού</p>
          <button
            type="button"
            data-mobile-nav-toggle
            aria-controls="mobile-nav-drawer"
            aria-expanded="false"
            class="inline-flex min-h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
          >
            ☰ Μενού
          </button>
        </div>

        <div data-mobile-nav-overlay class="fixed inset-0 z-40 hidden bg-slate-900/45" aria-hidden="true"></div>
        <nav
          id="mobile-nav-drawer"
          data-mobile-nav-drawer
          aria-label="Κύρια πλοήγηση κινητού"
          aria-hidden="true"
          class="fixed right-0 top-0 z-50 hidden h-full w-[min(88vw,22rem)] border-l border-slate-200 bg-white p-4 shadow-2xl"
        >
          <div class="flex items-center justify-between border-b border-slate-200 pb-3">
            <p class="text-sm font-semibold text-slate-900">Πλοήγηση</p>
            <button
              type="button"
              data-mobile-nav-close
              class="inline-flex min-h-10 items-center justify-center rounded-md border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2"
            >
              Κλείσιμο
            </button>
          </div>
          <ul class="mt-4 space-y-2">
            {PRIMARY_NAV_LINKS.map((navLink) => (
              <li>
                <a
                  href={navLink.href}
                  data-mobile-nav-link
                  class={`flex min-h-11 items-center rounded-lg px-3 text-sm font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 ${isRouteActive(navLink.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-700 hover:bg-slate-50 hover:text-slate-900'}`}
                >
                  {navLink.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="mt-12 border-t border-slate-200 bg-white py-12 text-slate-600">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">GreekHandy</h3>
            <p class="text-sm leading-relaxed">Βρείτε αξιόπιστους επαγγελματίες για κάθε εργασία στην Ελλάδα.</p>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">Δημοφιλείς Υπηρεσίες</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={NAV_TARGETS.guides} class="transition hover:text-slate-900">Οδηγοί GreekHandy</a></li>
              <li><a href="/ilektrologoi" class="transition hover:text-slate-900">Ηλεκτρολόγοι</a></li>
              <li><a href="/ydravlikoi" class="transition hover:text-slate-900">Υδραυλικοί</a></li>
              <li><a href="/elaiokhrwmatistes" class="transition hover:text-slate-900">Ελαιοχρωματιστές</a></li>
              <li><a href="/katharismoi" class="transition hover:text-slate-900">Καθαρισμοί</a></li>
              <li><a href="/techniki-klimatismou" class="transition hover:text-slate-900">Κλιματισμός</a></li>
            </ul>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold text-slate-900">Επικοινωνία</h3>
            <p class="text-sm">info@greekhandy.gr</p>
          </div>
        </div>
        <div class="mt-8 border-t border-slate-200 pt-8 text-center text-sm text-slate-500">
          <p>&copy; {new Date().getFullYear()} GreekHandy. Με επιφύλαξη παντός δικαιώματος.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const toolbarSelector = '[data-accessibility-toolbar], .accessibility-toolbar, #accessibility-toolbar';
        const root = document.documentElement;
        const schedule = (callback) => {
          if (typeof window.requestIdleCallback === 'function') {
            window.requestIdleCallback(() => callback(), { timeout: 1200 });
            return;
          }
          window.setTimeout(callback, 0);
        };
        const getToolbarSafeInset = (toolbar) => {
          if (!(toolbar instanceof HTMLElement)) return 0;
          const rect = toolbar.getBoundingClientRect();
          if (rect.height <= 0 || rect.width <= 0) return 0;
          const expanded = toolbar.getAttribute('data-gh-widget-expanded') !== 'false';
          if (!expanded) return Math.round(Math.min(rect.height + 8, 72));
          return Math.round(Math.min(rect.height + 12, window.innerHeight * 0.6));
        };
        const syncToolbarSafeArea = () => {
          let nextInset = 0;
          for (const toolbar of document.querySelectorAll(toolbarSelector)) {
            if (!(toolbar instanceof HTMLElement)) continue;
            nextInset = Math.max(nextInset, getToolbarSafeInset(toolbar));
          }
          root.style.setProperty('--gh-accessibility-toolbar-safe-area', `${nextInset}px`);
        };
        const syncToolbarState = (toolbar) => {
          const collapsedByAttr = toolbar.getAttribute('aria-expanded') === 'false';
          const collapsedByClass = toolbar.classList.contains('is-collapsed');
          toolbar.setAttribute('data-gh-widget-expanded', collapsedByAttr || collapsedByClass ? 'false' : 'true');
          schedule(syncToolbarSafeArea);
        };
        const attachToolbar = (node) => {
          if (!(node instanceof HTMLElement) || node.dataset.ghWidgetBound === 'true') return;
          node.dataset.ghWidgetBound = 'true';
          syncToolbarState(node);

          const stateObserver = new MutationObserver(() => {
            syncToolbarState(node);
          });
          stateObserver.observe(node, {
            attributes: true,
            attributeFilter: ['aria-expanded', 'class']
          });

          if (typeof ResizeObserver === 'function') {
            const resizeObserver = new ResizeObserver(() => {
              schedule(syncToolbarSafeArea);
            });
            resizeObserver.observe(node);
          }
        };
        const scanToolbars = () => {
          for (const toolbar of document.querySelectorAll(toolbarSelector)) {
            attachToolbar(toolbar);
          }
          syncToolbarSafeArea();
        };
        const start = () => {
          schedule(scanToolbars);
          if (!(document.body instanceof HTMLElement)) return;
          const discoveryObserver = new MutationObserver(() => {
            schedule(scanToolbars);
          });
          discoveryObserver.observe(document.body, { childList: true, subtree: true });
          window.setTimeout(() => {
            discoveryObserver.disconnect();
          }, 20000);
          window.addEventListener('resize', () => schedule(syncToolbarSafeArea), { passive: true });
          window.addEventListener('orientationchange', () => schedule(syncToolbarSafeArea), { passive: true });

          const toggle = document.querySelector('[data-mobile-nav-toggle]');
          const close = document.querySelector('[data-mobile-nav-close]');
          const drawer = document.querySelector('[data-mobile-nav-drawer]');
          const overlay = document.querySelector('[data-mobile-nav-overlay]');
          const links = Array.from(document.querySelectorAll('[data-mobile-nav-link]'));

          if (!(toggle instanceof HTMLButtonElement) || !(drawer instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;

          const setOpen = (open) => {
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            drawer.classList.toggle('hidden', !open);
            drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
            overlay.classList.toggle('hidden', !open);
            overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
            document.body.classList.toggle('overflow-hidden', open);
            if (open) {
              const firstLink = links.find((link) => link instanceof HTMLElement);
              if (firstLink instanceof HTMLElement) firstLink.focus();
            } else {
              toggle.focus();
            }
          };

          toggle.addEventListener('click', () => {
            const open = toggle.getAttribute('aria-expanded') === 'true';
            setOpen(!open);
          });

          close?.addEventListener('click', () => setOpen(false));
          overlay.addEventListener('click', () => setOpen(false));
          links.forEach((link) => link.addEventListener('click', () => setOpen(false)));

          document.addEventListener('keydown', (event) => {
            if (!(event instanceof KeyboardEvent)) return;
            if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
              event.preventDefault();
              setOpen(false);
            }
          });
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start, { once: true });
          return;
        }
        start();
      })();
    </script>
  </body>
</html>
