---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
}

const { title, description, canonicalUrl } = Astro.props;
const hasCustomHead = Astro.slots.has('head');
---

<!doctype html>
<html lang="el">
  <head>
    {hasCustomHead ? (
      <slot name="head" />
    ) : (
      <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} />
    )}
  </head>
  <body class="font-sans text-gray-900 bg-white">
    <!-- Header -->
    <header class="bg-blue-600 text-white">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold">GreekHandy</a>
        <div class="flex gap-6">
          <a href="/" class="hover:underline">Αρχική</a>
          <a href="#services" class="hover:underline">Υπηρεσίες</a>
          <a href="#contact" class="hover:underline">Επικοινωνία</a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <slot />

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 py-12">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">GreekHandy</h3>
            <p class="text-sm">Βρείτε αξιόπιστους επαγγελματίες για κάθε εργασία στην Ελλάδα.</p>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Δημοφιλείς Υπηρεσίες</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/ilektrologos" class="hover:text-white">Ηλεκτρολόγος</a></li>
              <li><a href="/ydravlikos" class="hover:text-white">Υδραυλικός</a></li>
              <li><a href="/elaioxromatistis" class="hover:text-white">Ελαιοχρωματιστής</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Επικοινωνία</h3>
            <p class="text-sm">info@greekhandy.gr</p>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} GreekHandy. Με επιφύλαξη παντός δικαιώματος.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
