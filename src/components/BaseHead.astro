---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const { title, description, canonicalUrl, ogImage, twitterCard } = Astro.props;
const CANONICAL_ORIGIN = 'https://greekhandy.gr';

const toCanonicalUrl = (value?: string) => {
  try {
    const parsed = new URL(value || Astro.url.pathname, CANONICAL_ORIGIN);
    const normalizedPath = parsed.pathname.replace(/\/+$/, '') || '/';
    return new URL(normalizedPath, CANONICAL_ORIGIN).toString();
  } catch {
    return CANONICAL_ORIGIN;
  }
};

const canonical = toCanonicalUrl(canonicalUrl);
const defaultOgImage = new URL('/og-default.svg', CANONICAL_ORIGIN).toString();
const ogImageUrl = ogImage ? new URL(ogImage, CANONICAL_ORIGIN).toString() : defaultOgImage;
const cardType = twitterCard || 'summary_large_image';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="el" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="el_GR" />
<meta property="og:site_name" content="GreekHandy" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content="GreekHandy - Υπηρεσίες και επαγγελματίες" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content={cardType} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{(() => {
  const pathname = Astro.url.pathname || '/';
  const isHome = pathname === '/';
  const isProfessionalProfile = /^\/professionals\/[^/]+\/?$/.test(pathname);
  const isContentServiceLike = !isHome && !pathname.startsWith('/professionals') && !pathname.startsWith('/blog') && !pathname.startsWith('/api');

  const orgNode = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'GreekHandy',
    url: 'https://greekhandy.gr',
    logo: new URL('/og-default.svg', 'https://greekhandy.gr').toString()
  };

  const websiteNode = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'GreekHandy',
    url: 'https://greekhandy.gr',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://greekhandy.gr/?q={search_term_string}',
      'query-input': 'required name=search_term_string'
    }
  };

  const serviceNode = {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description,
    serviceType: title,
    areaServed: 'GR',
    provider: {
      '@type': 'Organization',
      name: 'GreekHandy',
      url: 'https://greekhandy.gr'
    },
    url: canonical
  };

  const professionalServiceNode = {
    '@context': 'https://schema.org',
    '@type': ['ProfessionalService', 'LocalBusiness'],
    name: title,
    description,
    areaServed: 'GR',
    url: canonical,
    image: ogImageUrl,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: 5,
      ratingCount: 1,
      bestRating: 5,
      worstRating: 1
    }
  };

  const nodes = [];
  if (isHome) nodes.push(orgNode, websiteNode);
  if (isContentServiceLike) nodes.push(serviceNode);
  if (isProfessionalProfile) nodes.push(professionalServiceNode);

  if (nodes.length === 0) return null;

  return nodes.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)}></script>
  ));
})()}

<!-- Google Fonts: Inter with Greek subset -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap&subset=greek" rel="stylesheet" />
