---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const { title, description, canonicalUrl, ogImage, twitterCard } = Astro.props;
const canonical = canonicalUrl || Astro.url.href;
const siteOrigin = Astro.site?.origin || Astro.url.origin || 'https://greekhandy.gr';
const defaultOgImage = new URL('/og-default.svg', siteOrigin).toString();
const ogImageUrl = ogImage ? new URL(ogImage, siteOrigin).toString() : defaultOgImage;
const cardType = twitterCard || 'summary_large_image';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="el" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="el_GR" />
<meta property="og:site_name" content="GreekHandy" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content="GreekHandy - Υπηρεσίες και επαγγελματίες" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content={cardType} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Google Fonts: Inter with Greek subset -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap&subset=greek" rel="stylesheet" />
