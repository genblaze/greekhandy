                {jobs.length > INITIAL_JOBS_PER_CATEGORY && (
                  <div class="mt-4 rounded-xl border border-cyan-100 bg-cyan-50 px-4 py-3 text-sm text-cyan-900">
                    Εμφανίζονται οι {INITIAL_JOBS_PER_CATEGORY} πιο σχετικές υπηρεσίες για ταχύτερη φόρτωση.
                    <a href={`/${category.slug}`} class="ml-1 font-semibold underline underline-offset-2">Δείτε όλες τις {jobs.length} υπηρεσίες της κατηγορίας.</a>
                  </div>
                )}
              </details>
            );
          })}

          {primaryCatalogCategories.length > INITIAL_VISIBLE_CATALOG_CATEGORY_COUNT && (
            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="text-xs text-slate-600" data-progressive-summary="homepage-catalog" role="status" aria-live="polite">
                  Εμφανίζονται {Math.min(INITIAL_VISIBLE_CATALOG_CATEGORY_COUNT, primaryCatalogCategories.length)} από {primaryCatalogCategories.length} κατηγορίες καταλόγου.
                </p>
                <button
                  type="button"
                  data-progressive-toggle="homepage-catalog"
                  data-initial-visible={INITIAL_VISIBLE_CATALOG_CATEGORY_COUNT}
                  data-progressive-noun="κατηγορίες καταλόγου"
                  aria-controls="catalog-cards-list"
                  aria-expanded="false"
                  class="inline-flex rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100"
                >
                  Εμφάνιση περισσότερων κατηγοριών καταλόγου
                </button>
              </div>
            </div>
          )}

          {deferredCatalogCategories.length > 0 && (
            <details class="rounded-2xl border border-slate-200 bg-white p-5">
              <summary class="cursor-pointer text-sm font-semibold text-slate-700">Περισσότερες κατηγορίες καταλόγου ({deferredCatalogCategories.length})</summary>
              <p class="mt-2 text-xs text-slate-500">Για να διατηρούμε την αρχική σελίδα γρήγορη, οι επιπλέον κατηγορίες εμφανίζονται συνοπτικά.</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {deferredCatalogCategories.map(({ category, jobs }) => (
                  <a href={`/${category.slug}`} class="rounded-full border border-slate-300 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-white">
                    {category.nameGr} ({jobs.length})
                  </a>
                ))}
              </div>
            </details>
          )}
        </div>
      </div>
    </section>

