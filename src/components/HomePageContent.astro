    <nav class="sr-only" aria-label="SEO crawl links κατηγοριών και βασικών υπηρεσιών">
      <ul>
        {categoriesWithJobs.map(({ category, jobs }) => (
          <li>
            <a href={`/${category.slug}`}>{category.nameGr}</a>
            <ul>
              {jobs.slice(0, SEO_CATEGORY_JOB_LINK_COUNT).map(job => (
                <li><a href={`/${job.slug}`}>{job.nameGr}</a></li>
              ))}
