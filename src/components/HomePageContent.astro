---
import Layout from '../layouts/Layout.astro';
import { NAV_CLIENT_ALIAS_REDIRECTS } from '../config/navigation';

interface Category {
  id: string;
  slug: string;
  nameGr: string;
  description?: string;
  priority?: number;
  icon?: string;
  cities?: string[];
}

interface ContentPage {
  slug: string;
  nameGr: string;
  nameEn?: string;
  h1?: string;
  heroText?: string;
  metaDescription?: string;
  summary?: {
    intent?: string;
    priceRangeEUR?: string;
  };
  sections?: { heading?: string; content?: string }[];
  categoryId?: string;
  categorySlug?: string;
  categoryNameGr?: string;
}

interface ProfessionalProfile {
  slug: string;
  name: string;
  profession: string;
  city?: string;
  areasServed?: string[];
  experienceYears?: number;
  bio?: string;
  services?: string[];
  approved?: boolean;
  published?: boolean;
}

interface SearchItem {
  href: string;
  nameGr: string;
  description: string;
  priceRange?: string;
  typeLabel: string;
  categoryName: string;
  cities: string[];
  searchText: string;
  icon: string;
}

const majorCities = [
  { value: 'athina', label: 'Αθήνα' },
  { value: 'thessaloniki', label: 'Θεσσαλονίκη' },
  { value: 'patra', label: 'Πάτρα' },
  { value: 'irakleio', label: 'Ηράκλειο' },
  { value: 'larisa', label: 'Λάρισα' },
  { value: 'volos', label: 'Βόλος' },
  { value: 'ioannina', label: 'Ιωάννινα' }
];

const cityLabelByValue = Object.fromEntries(majorCities.map(city => [city.value, city.label]));
const majorCityValues = new Set(majorCities.map(city => city.value));

const fallbackIconsBySlug: Record<string, string> = {
  ilektrologoi: '⚡',
  ydravlikoi: '🚰',
  elaiokhrwmatistes: '🎨',
  katharismoi: '🧽',
  'techniki-klimatismou': '❄️'
};

const normalizeText = (value = '') => value
  .toLocaleLowerCase('el-GR')
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .replace(/ς/g, 'σ')
  .replace(/\s+/g, ' ')
  .trim();

const cityValueByNormalizedLabel = new Map(majorCities.map(city => [normalizeText(city.label), city.value]));

const getCityValuesFromText = (cities: string[] = []) => {
  const resolvedCities = new Set<string>();

  for (const city of cities) {
    const normalizedCity = normalizeText(city);
    if (!normalizedCity) continue;
    if (majorCityValues.has(normalizedCity)) {
      resolvedCities.add(normalizedCity);
      continue;
    }
    const matchedCity = cityValueByNormalizedLabel.get(normalizedCity);
    if (matchedCity) resolvedCities.add(matchedCity);
  }

  return [...resolvedCities];
};

const contentFiles = import.meta.glob('../../data/content/*.json', { eager: true });
const allPages: ContentPage[] = [];
for (const [, mod] of Object.entries(contentFiles)) {
  const data = (mod as any).default ?? mod;
  if (data?.slug) allPages.push(data as ContentPage);
}

let categories: Category[] = [];
try {
  const catFile = await import('../../data/categories.json');
  categories = ((catFile.default ?? catFile) as Category[])
    .slice()
    .sort((a, b) => (a.priority ?? 999) - (b.priority ?? 999));
} catch {}

const categorySlugs = new Set(categories.map(cat => cat.slug));
const categoryPages = allPages.filter(page => categorySlugs.has(page.slug));
const jobPages = allPages.filter(page => !categorySlugs.has(page.slug));

const categoriesById = new Map(categories.map(cat => [cat.id, cat]));
const categoriesBySlug = new Map(categories.map(cat => [cat.slug, cat]));

const getCategoryForPage = (page: ContentPage) => {
  if (categorySlugs.has(page.slug)) return categoriesBySlug.get(page.slug);
  return categoriesById.get(page.categoryId ?? '') ?? categoriesBySlug.get(page.categorySlug ?? '');
};

const getCategoryIcon = (category?: Category) => {
  if (category?.icon) return category.icon;
  if (category?.slug && fallbackIconsBySlug[category.slug]) return fallbackIconsBySlug[category.slug];
  return '🛠️';
};

const getCitiesForCategory = (category?: Category) => {
  const filteredCities = (category?.cities ?? []).filter(city => majorCities.some(option => option.value === city));
  return filteredCities.length > 0 ? filteredCities : majorCities.map(city => city.value);
};

const jobsByCategory: Record<string, ContentPage[]> = {};
for (const job of jobPages) {
  const category = getCategoryForPage(job);
  const categoryKey = category?.id ?? job.categoryId ?? job.categorySlug ?? 'other';
  if (!jobsByCategory[categoryKey]) jobsByCategory[categoryKey] = [];
  jobsByCategory[categoryKey].push(job);
}

for (const key of Object.keys(jobsByCategory)) {
  jobsByCategory[key].sort((a, b) => a.nameGr.localeCompare(b.nameGr, 'el'));
}

let professionalProfiles: ProfessionalProfile[] = [];
try {
  const profilesFile = await import('../../data/professionals.json');
  professionalProfiles = ((profilesFile.default ?? profilesFile) as ProfessionalProfile[])
    .filter(profile => profile.approved === true && profile.published === true);
} catch {}

const MAX_HOMEPAGE_JOB_SEARCH_SAMPLE = 180;
const sampledJobPages = jobPages.slice(0, MAX_HOMEPAGE_JOB_SEARCH_SAMPLE);

const pageSearchItems: SearchItem[] = [...categoryPages, ...sampledJobPages]
  .map(page => {
    const category = getCategoryForPage(page);
    const cityValues = getCitiesForCategory(category);

    const searchableText = normalizeText([
      page.nameGr,
      page.nameEn,
      page.h1,
      page.metaDescription,
      page.heroText,
      page.summary?.intent,
      page.categoryNameGr,
      category?.nameGr
    ].filter(Boolean).join(' '));

    const isCategoryPage = categorySlugs.has(page.slug);
    const typeLabel = isCategoryPage ? 'Κατηγορία' : 'Υπηρεσία';

    return {
      href: `/${page.slug}`,
      nameGr: page.nameGr,
      description: page.summary?.intent ?? page.metaDescription ?? category?.description ?? '',
      priceRange: page.summary?.priceRangeEUR,
      typeLabel,
      categoryName: isCategoryPage ? '' : (page.categoryNameGr ?? category?.nameGr ?? ''),
      cities: cityValues,
      searchText: searchableText,
      icon: getCategoryIcon(category)
    };
  });

const professionalSearchItems: SearchItem[] = professionalProfiles.map(profile => {
  const cityValues = getCityValuesFromText([profile.city ?? '', ...(profile.areasServed ?? [])]);
  const searchText = normalizeText([
    profile.name,
    profile.profession,
    profile.city,
    profile.bio,
    profile.services?.join(' '),
    profile.areasServed?.join(' ')
  ].filter(Boolean).join(' '));

  return {
    href: `/professionals/${profile.slug}`,
    nameGr: profile.name,
    description: profile.bio ?? '',
    typeLabel: 'Επαγγελματίας',
    categoryName: profile.profession,
    cities: cityValues,
    searchText,
    icon: '👤'
  };
});

const searchItems = [...pageSearchItems, ...professionalSearchItems]
  .sort((a, b) => a.nameGr.localeCompare(b.nameGr, 'el'));

const availableCityValues = new Set(searchItems.flatMap(item => item.cities));

const siteUrl = new URL('/', Astro.site).toString();
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: 'GreekHandy',
  url: siteUrl,
  logo: new URL('/favicon.svg', Astro.site).toString(),
  areaServed: {
    '@type': 'Country',
    name: 'Greece'
  }
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}#website`,
  url: siteUrl,
  name: 'GreekHandy',
  inLanguage: 'el-GR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  },
  publisher: {
    '@id': `${siteUrl}#organization`
  }
};
const cityOptions = majorCities.filter(city => availableCityValues.has(city.value));

const totalServices = jobPages.length;
const categoriesWithJobs = categories
  .map(category => ({
    category,
    jobs: jobsByCategory[category.id] ?? []
  }))
  .filter(entry => entry.jobs.length > 0);
const hasServiceCatalog = categoriesWithJobs.length > 0;

const servicesWithPriceRange = jobPages.filter(job => Boolean(job.summary?.priceRangeEUR)).length;
const totalProfessionals = professionalProfiles.length;

const heroHighlights = [
  'Καθαρή επιλογή υπηρεσιών χωρίς θόρυβο',
  'Προσανατολισμός σε πραγματικά κόστη και χρόνος απόκρισης',
  'Συνέπεια σε κάθε βήμα από αίτημα μέχρι ανάθεση'
];

const evidenceCards = [
  {
    title: `${categoriesWithJobs.length} επιμελημένες κατηγορίες`,
    description: 'Οργανωμένη αγορά με ξεκάθαρα μονοπάτια πλοήγησης για κάθε ανάγκη κατοικίας ή επαγγελματικού χώρου.',
    tag: 'Δομή'
  },
  {
    title: `${servicesWithPriceRange} υπηρεσίες με ενδεικτικό κόστος`,
    description: 'Μετρήσιμες προσδοκίες πριν την επικοινωνία, ώστε να συγκρίνετε λύσεις με ουσία και όχι μόνο τιμή.',
    tag: 'Διαφάνεια'
  },
  {
    title: `${totalProfessionals} δημοσιευμένα προφίλ επαγγελματιών`,
    description: 'Προφίλ με ειδικότητα, περιοχή και περιγραφή εργασιών για γρήγορο ταίριασμα με το έργο σας.',
    tag: 'Κάλυψη'
  }
];

const processSteps = [
  {
    heading: 'Ορίζετε την ανάγκη',
    detail: 'Επιλέγετε υπηρεσία ή κατηγορία και καταγράφετε τι ακριβώς χρειάζεστε.'
  },
  {
    heading: 'Λαμβάνετε στοχευμένες επιλογές',
    detail: 'Βλέπετε επαγγελματίες και υπηρεσίες που ταιριάζουν στην πόλη και στις απαιτήσεις σας.'
  },
  {
    heading: 'Κλείνετε με σιγουριά',
    detail: 'Συγκρίνετε με βάση εύρος τιμής, εμπειρία και διαθεσιμότητα και προχωράτε άμεσα.'
  }
];

const INITIAL_CATEGORY_GRID_COUNT = 6;
const INITIAL_VISIBLE_CATEGORY_GRID_COUNT = 4;
const INITIAL_JOBS_PER_CATEGORY = 3;
const INITIAL_SEARCH_RESULTS_COUNT = 24;
const INITIAL_VISIBLE_SEARCH_RESULTS_COUNT = 12;
const INITIAL_CATALOG_CATEGORY_COUNT = 4;
const INITIAL_VISIBLE_CATALOG_CATEGORY_COUNT = 3;
const CATALOG_QUICK_NAV_COUNT = 10;
const SEO_CATEGORY_JOB_LINK_COUNT = 1;

const socialProofItems = [
  {
    title: 'Ανακαίνιση διαμερίσματος στην Αθήνα',
    quote: 'Εντοπίσαμε συνεργείο για υδραυλικά και βαψίματα την ίδια ημέρα, με ξεκάθαρο πλαίσιο κόστους από την αρχή.',
    outcome: 'Συνδυασμένη ανάθεση 2 ειδικοτήτων σε 48 ώρες'
  },
  {
    title: 'Συντήρηση πολυκατοικίας στη Θεσσαλονίκη',
    quote: 'Η δομή των κατηγοριών μας βοήθησε να κλείσουμε ηλεκτρολόγο χωρίς αλλεπάλληλα τηλεφωνήματα.',
    outcome: 'Ολοκλήρωση πρώτης επίσκεψης σε λιγότερο από 24 ώρες'
  },
  {
    title: 'Επαγγελματικός χώρος στο Ηράκλειο',
    quote: 'Βρήκαμε τεχνικό κλιματισμού με εμπειρία σε εμπορικούς χώρους και ξεκάθαρο χρονοδιάγραμμα εργασιών.',
    outcome: 'Επανεκκίνηση λειτουργίας χώρου μέσα στο Σαββατοκύριακο'
  }
];

const homepageSearchItems = searchItems.slice(0, INITIAL_SEARCH_RESULTS_COUNT);
const primaryCatalogCategories = categoriesWithJobs.slice(0, INITIAL_CATALOG_CATEGORY_COUNT);
const deferredCatalogCategories = categoriesWithJobs.slice(INITIAL_CATALOG_CATEGORY_COUNT);
const featuredCategoryEntries = categoriesWithJobs.slice(0, INITIAL_CATEGORY_GRID_COUNT);
const overflowCategoryEntries = categoriesWithJobs.slice(INITIAL_CATEGORY_GRID_COUNT);

const homeMetaTitle = 'GreekHandy - Βρείτε Αξιόπιστους Επαγγελματίες στην Ελλάδα';
const homeMetaDescription = 'Η πλατφόρμα GreekHandy σάς βοηθά να βρείτε τον κατάλληλο επαγγελματία για κάθε εργασία: υδραυλικοί, ηλεκτρολόγοι, καθαρισμοί και περισσότερα, με ξεκάθαρη πληροφόρηση.';
---

<Layout
  title={homeMetaTitle}
  description={homeMetaDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <main class="home-root overflow-x-clip bg-[#f4f6fb] pb-24 text-slate-900">
    <section class="gh-hero relative overflow-hidden px-4 pb-14 pt-10 text-white md:px-6 md:pb-18 md:pt-12" aria-labelledby="home-hero-title" aria-describedby="hero-mobile-readability-help">
      <div class="absolute inset-0 -z-20 bg-[#030711]"></div>
      <div class="gh-hero-bg absolute inset-0 -z-10"></div>
      <div class="gh-hero-overlay absolute inset-0 -z-10"></div>
      <div class="absolute inset-0 -z-10 bg-slate-950/60"></div>

      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="inline-flex items-center rounded-full border border-cyan-200/70 bg-slate-950/80 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-100">
            Δίκτυο Έμπιστων Επαγγελματιών GreekHandy
          </p>
          <h1 id="home-hero-title" class="gh-display mt-4 max-w-3xl text-[2.2rem] font-semibold leading-[1.14] tracking-[-0.015em] text-white drop-shadow-[0_2px_14px_rgba(2,6,23,0.55)] md:mt-5 md:text-[4rem]">
            Βρείτε τον κατάλληλο επαγγελματία
            <span class="block text-cyan-50">γρήγορα, με καθαρά κριτήρια και σιγουριά.</span>
          </h1>
          <p class="mt-3 max-w-2xl text-[1rem] leading-[1.82] text-slate-50 md:mt-4 md:text-[1.16rem] md:leading-[1.78]">
            Συγκρίνετε επαγγελματίες με πραγματικές αξιολογήσεις, διαφανείς υπηρεσίες και ξεκάθαρα επόμενα βήματα,
            ώστε να περνάτε από την πρώτη αναζήτηση σε ασφαλή ανάθεση χωρίς καθυστερήσεις.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3" aria-label="Κύριες ενέργειες αρχικής σελίδας">
            <p id="hero-mobile-readability-help" class="w-full rounded-lg border border-white/35 bg-slate-950/70 px-3 py-2 text-xs leading-relaxed text-cyan-50">Βρείτε άμεσα τον κατάλληλο επαγγελματία με καθαρή σύγκριση και ξεκάθαρα βήματα.</p>
            <p class="w-full text-xs text-cyan-100" id="hero-cta-help">Πατήστε «Ξεκινήστε Αναζήτηση» για να δείτε σχετικές κατηγορίες και επαγγελματίες στην πόλη σας.</p>
            <a href="#search-browse" aria-label="Ξεκινήστε άμεσα αναζήτηση επαγγελματία" aria-describedby="hero-cta-help" class="gh-primary-cta inline-flex min-h-11 items-center rounded-full bg-cyan-300 px-7 py-3 text-sm font-bold uppercase tracking-wide text-slate-950 shadow-[0_14px_34px_-16px_rgba(34,211,238,0.95)] transition hover:bg-cyan-200 active:bg-cyan-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900">
              Ξεκινήστε Αναζήτηση
            </a>
            <a href="/professionals/register" class="inline-flex items-center rounded-full border border-cyan-100/75 bg-slate-950/45 px-4 py-2 text-sm font-semibold text-cyan-50 transition hover:bg-slate-900/70 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900">
              Είστε επαγγελματίας; Γίνετε Συνεργάτης
            </a>
          </div>

          <ul class="mt-8 hidden gap-2 text-sm text-slate-50 md:grid md:grid-cols-2" aria-label="Σήματα εμπιστοσύνης αρχικής σελίδας">
            {heroHighlights.map(item => (
              <li class="rounded-xl border border-white/45 bg-slate-900/70 px-4 py-3">{item}</li>
            ))}
          </ul>
        </div>

        <aside class="rounded-[2rem] border border-white/35 bg-slate-900/55 p-6 shadow-[0_30px_120px_-40px_rgba(15,23,42,0.9)] backdrop-blur-[1.5px] md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">Πίνακας Εμπιστοσύνης</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">Τι κερδίζετε άμεσα στο GreekHandy</h2>

          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-2xl border border-white/15 bg-black/15 p-4">
              <p class="text-3xl font-semibold text-cyan-100">{totalServices}+</p>
              <p class="mt-1 text-xs uppercase tracking-wide text-slate-200">Υπηρεσίες</p>
            </div>
            <div class="rounded-2xl border border-white/15 bg-black/15 p-4">
              <p class="text-3xl font-semibold text-cyan-100">{categoriesWithJobs.length}</p>
              <p class="mt-1 text-xs uppercase tracking-wide text-slate-200">Κατηγορίες</p>
            </div>
            <div class="rounded-2xl border border-white/15 bg-black/15 p-4">
              <p class="text-3xl font-semibold text-cyan-100">{totalProfessionals}</p>
              <p class="mt-1 text-xs uppercase tracking-wide text-slate-200">Προφίλ</p>
            </div>
            <div class="rounded-2xl border border-white/15 bg-black/15 p-4">
              <p class="text-3xl font-semibold text-cyan-100">7</p>
              <p class="mt-1 text-xs uppercase tracking-wide text-slate-200">Μεγάλες Πόλεις</p>
            </div>
          </div>

          <div class="mt-6 space-y-3 border-t border-white/20 pt-5 text-sm text-slate-100">
            <p class="flex items-start gap-2"><span aria-hidden="true">01</span><span>Ενιαία αναζήτηση για υπηρεσίες, κατηγορίες και επαγγελματίες.</span></p>
            <p class="flex items-start gap-2"><span aria-hidden="true">02</span><span>Φίλτρα πόλης ώστε να βλέπετε μόνο σχετικές επιλογές.</span></p>
            <p class="flex items-start gap-2"><span aria-hidden="true">03</span><span>Γρήγορη μετάβαση από αξιολόγηση σε επικοινωνία.</span></p>
          </div>
        </aside>
      </div>

      <div class="mx-auto mt-10 max-w-6xl">
        <nav class="mb-4 hidden flex-wrap gap-2 lg:flex" aria-label="Γρήγορη πλοήγηση αρχικής">
          <a href="#search-browse" class="rounded-full border border-white/55 bg-slate-900/45 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900/60">Αναζήτηση</a>
          <a href="#trust-layer" class="rounded-full border border-white/55 bg-slate-900/45 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900/60">Εμπιστοσύνη</a>
          <a href="#services" class="rounded-full border border-white/55 bg-slate-900/45 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900/60">Κατηγορίες</a>
          <a href="#catalog" class="rounded-full border border-white/55 bg-slate-900/45 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900/60">Κατάλογος</a>
          <a href="#contact" class="rounded-full border border-white/55 bg-slate-900/45 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900/60">Επικοινωνία</a>
        </nav>
        <div class="hidden gap-4 rounded-3xl border border-white/30 bg-slate-900/30 p-5 md:grid md:grid-cols-3 md:p-7">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">Αξία Πλατφόρμας</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-100">Πλατφόρμα επιλογής τεχνικών με premium εμπειρία πλοήγησης και καθαρή ενημέρωση πριν από κάθε ανάθεση.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">Για Ιδιώτες Και Επιχειρήσεις</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-100">Από μικροεπισκευές μέχρι απαιτητικές εγκαταστάσεις, με την ίδια δομημένη προσέγγιση.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-100">Γρήγορη Απόφαση</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-100">Σαφή CTA, κοινωνική απόδειξη και ξεκάθαρα βήματα για να κλείνετε απόφαση γρηγορότερα.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="search-browse" class="relative z-20 mx-auto -mt-16 max-w-6xl px-4 md:px-6">
      <div class="rounded-[2rem] border border-slate-200/80 bg-white p-6 shadow-[0_30px_100px_-52px_rgba(2,6,23,0.58)] md:p-10">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-700">Αναζήτηση GreekHandy</p>
            <h2 class="gh-display mt-2 text-3xl text-slate-900 md:text-4xl">Βρείτε ακριβώς αυτό που χρειάζεστε</h2>
            <p class="mt-3 max-w-3xl text-sm leading-relaxed text-slate-600 md:text-base">Ξεκινήστε από κατηγορία και προχωρήστε σε στοχευμένα προφίλ με λιγότερα βήματα και καθαρή σύγκριση.</p>
          </div>
