    <section id="contact" class="px-4 pb-16 pt-12 md:px-6">
      <div class="mx-auto max-w-6xl rounded-3xl border border-cyan-200 bg-cyan-50 p-6 md:p-9">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="max-w-3xl">
