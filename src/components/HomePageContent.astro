  <script is:inline define:vars={{ navClientAliasRedirects: NAV_CLIENT_ALIAS_REDIRECTS }}>
    (() => {
      const normalizePath = (path) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
      const aliasPath = `${normalizePath(window.location.pathname)}${window.location.hash}`;
      const canonicalContactPath = navClientAliasRedirects[aliasPath];
      if (typeof canonicalContactPath !== 'string' || canonicalContactPath.length === 0) return;
      const query = window.location.search || '';
      window.location.replace(`${canonicalContactPath}${query}`);
    })();
  </script>

  <script is:inline>
    (() => {
      const normalizeText = (value = '') => value
        .toLocaleLowerCase('el-GR')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/ς/g, 'σ')
        .replace(/\s+/g, ' ')
        .trim();

      const searchInput = document.querySelector('[data-search-input]');
      const cityFilter = document.querySelector('[data-city-filter]');
      const resetButton = document.querySelector('[data-reset-filters]');
      const resultCards = Array.from(document.querySelectorAll('[data-search-item]'));
      const resultsCount = document.querySelector('[data-results-count]');
      const emptyState = document.querySelector('[data-empty-state]');
      const loadingState = document.querySelector('[data-search-loading]');
      const errorState = document.querySelector('[data-search-error]');
      const errorStateTitle = document.querySelector('[data-search-error-title]');
      const errorStateDescription = document.querySelector('[data-search-error-description]');
      const retryButton = document.querySelector('[data-search-retry]');
      const emptyResetButton = document.querySelector('[data-empty-reset]');
      const resultsList = document.querySelector('[data-results-list]');
      const searchState = document.querySelector('[data-search-state]');
      const searchRevealToggle = document.querySelector('[data-search-reveal-toggle]');
      const searchRevealSummary = document.querySelector('[data-search-reveal-summary]');
      const applySetupFallbackState = () => {
        if (loadingState instanceof HTMLElement) loadingState.classList.add('hidden');
        if (errorState instanceof HTMLElement) {
          if (errorStateTitle instanceof HTMLElement) {
            errorStateTitle.textContent = 'Η αναζήτηση δεν είναι διαθέσιμη αυτή τη στιγμή.';
          }
          if (errorStateDescription instanceof HTMLElement) {
            errorStateDescription.textContent = 'Συνεχίστε από κατηγορίες ή προφίλ για άμεση επιλογή.';
          }
          errorState.classList.remove('hidden');
        }
        if (searchState instanceof HTMLElement) {
          searchState.dataset.state = 'error';
          searchState.textContent = 'Η ζωντανή αναζήτηση δεν ενεργοποιήθηκε. Συνεχίστε από κατηγορίες ή προφίλ.';
        }
      };

      if (
        !(searchInput instanceof HTMLInputElement)
        || !(cityFilter instanceof HTMLSelectElement)
        || !(resetButton instanceof HTMLButtonElement)
        || !(resultsCount instanceof HTMLElement)
        || !(emptyState instanceof HTMLElement)
        || !(resultsList instanceof HTMLElement)
      ) {
        applySetupFallbackState();
        return;
      }

      const parsedCards = resultCards.map(card => ({
        card,
        searchText: card.dataset.searchText || '',
        cities: (card.dataset.cities || '').split('|').filter(Boolean)
      }));
      const totalItems = parsedCards.length;
      const initialVisibleResultLimit = Number.parseInt(resultsList.dataset.initialVisible || '12', 10) || 12;
      const SEARCH_DEBOUNCE_MS = 110;
      let updateTimer = null;
      let searchRevealExpanded = false;

      const getCityLabel = () => {
        const selectedOption = cityFilter.options[cityFilter.selectedIndex];
        return selectedOption ? selectedOption.textContent : '';
      };

      const setLoadingState = (active) => {
        resultsList.setAttribute('aria-busy', active ? 'true' : 'false');
        if (loadingState instanceof HTMLElement) loadingState.classList.toggle('hidden', !active);
        if (active) emptyState.classList.add('hidden');
        if (active && errorState instanceof HTMLElement) errorState.classList.add('hidden');
        if (active && searchState instanceof HTMLElement) {
          searchState.dataset.state = 'loading';
          searchState.textContent = 'Η αναζήτηση συγχρονίζεται...';
        }
      };

      const setSearchState = (tone, message) => {
        if (!(searchState instanceof HTMLElement)) return;
        searchState.dataset.state = tone;
        searchState.textContent = message;
      };

      const hideErrorState = () => {
        if (errorState instanceof HTMLElement) errorState.classList.add('hidden');
      };

      const showErrorState = (descriptionText) => {
        if (errorState instanceof HTMLElement) {
          if (errorStateTitle instanceof HTMLElement) {
            errorStateTitle.textContent = 'Η αναζήτηση δεν είναι διαθέσιμη αυτή τη στιγμή.';
          }
          if (errorStateDescription instanceof HTMLElement) {
            errorStateDescription.textContent = descriptionText;
          }
          errorState.classList.remove('hidden');
        }
        setSearchState('error', 'Η αναζήτηση δεν είναι διαθέσιμη αυτή τη στιγμή. Συνεχίστε από κατηγορίες ή προφίλ.');
      };

      const applyResults = () => {
        try {
          hideErrorState();

          const keyword = normalizeText(searchInput.value);
          const selectedCity = cityFilter.value;
          const matchedCards = parsedCards.filter((item) => {
            const keywordMatch = !keyword || item.searchText.includes(keyword);
            const cityMatch = !selectedCity || item.cities.includes(selectedCity);
            return keywordMatch && cityMatch;
          });
          const matchedItems = matchedCards.length;

          if (matchedItems <= initialVisibleResultLimit) searchRevealExpanded = false;
          const visibleItems = searchRevealExpanded
            ? matchedItems
            : Math.min(matchedItems, initialVisibleResultLimit);

          parsedCards.forEach((item) => item.card.classList.add('hidden'));
          matchedCards.slice(0, visibleItems).forEach((item) => item.card.classList.remove('hidden'));

          if (!totalItems) {
            resultsCount.textContent = 'Προσωρινά δεν υπάρχει διαθέσιμο δείγμα αναζήτησης. Συνεχίστε από τις κατηγορίες παρακάτω.';
            emptyState.classList.add('hidden');
            setSearchState('empty-catalog', 'Δεν υπάρχει ακόμη διαθέσιμο δείγμα αναζήτησης. Χρησιμοποιήστε τις κατηγορίες ή τα προφίλ.');
            return;
          }

          const cityLabel = selectedCity ? getCityLabel() : '';
          if (!keyword && !selectedCity) {
            resultsCount.textContent = `Βρέθηκαν ${matchedItems} διαθέσιμες υπηρεσίες, κατηγορίες και επαγγελματίες.`;
          } else if (cityLabel && keyword) {
            resultsCount.textContent = `${matchedItems} αποτελέσματα για «${searchInput.value.trim()}» στην ${cityLabel}.`;
          } else if (cityLabel) {
            resultsCount.textContent = `${matchedItems} αποτελέσματα στην ${cityLabel}.`;
          } else {
            resultsCount.textContent = `${matchedItems} αποτελέσματα για «${searchInput.value.trim()}».`;
          }

          if (searchRevealSummary instanceof HTMLElement) {
            searchRevealSummary.textContent = matchedItems === 0
              ? 'Δεν υπάρχουν διαθέσιμα αποτελέσματα για εμφάνιση.'
              : `Εμφανίζονται ${visibleItems} από ${matchedItems} αποτελέσματα.`;
          }
          if (searchRevealToggle instanceof HTMLButtonElement) {
            const hasOverflow = matchedItems > initialVisibleResultLimit;
            searchRevealToggle.classList.toggle('hidden', !hasOverflow);
            searchRevealToggle.setAttribute('aria-expanded', searchRevealExpanded ? 'true' : 'false');
            if (hasOverflow) {
              searchRevealToggle.textContent = searchRevealExpanded
                ? 'Εμφάνιση λιγότερων αποτελεσμάτων'
                : `Εμφάνιση περισσότερων αποτελεσμάτων (${Math.max(matchedItems - visibleItems, 0)})`;
            }
          }

          emptyState.classList.toggle('hidden', matchedItems > 0);
          if (matchedItems > 0) {
            setSearchState('ready', `Βρέθηκαν ${matchedItems} σχετικά αποτελέσματα.`);
          } else {
            setSearchState('no-match', 'Δεν βρέθηκαν αποτελέσματα για τον τρέχοντα συνδυασμό φίλτρων.');
          }
        } catch {
          showErrorState('Κάντε επανάληψη ή χρησιμοποιήστε την πλοήγηση κατηγοριών για να συνεχίσετε χωρίς καθυστέρηση.');
        } finally {
          setLoadingState(false);
        }
      };

      const scheduleUpdate = () => {
        setLoadingState(true);
        if (updateTimer) window.clearTimeout(updateTimer);
        updateTimer = window.setTimeout(applyResults, SEARCH_DEBOUNCE_MS);
      };

      setLoadingState(true);

      searchInput.addEventListener('input', scheduleUpdate);
      cityFilter.addEventListener('change', scheduleUpdate);
      resetButton.addEventListener('click', () => {
        searchInput.value = '';
        cityFilter.value = '';
        searchRevealExpanded = false;
        scheduleUpdate();
        searchInput.focus();
      });
      if (searchRevealToggle instanceof HTMLButtonElement) {
        searchRevealToggle.addEventListener('click', () => {
          searchRevealExpanded = !searchRevealExpanded;
          applyResults();
        });
      }
      if (retryButton instanceof HTMLButtonElement) {
        retryButton.addEventListener('click', () => {
          scheduleUpdate();
          searchInput.focus();
        });
      }
      if (emptyResetButton instanceof HTMLButtonElement) {
        emptyResetButton.addEventListener('click', () => {
          searchInput.value = '';
          cityFilter.value = '';
          searchRevealExpanded = false;
          scheduleUpdate();
          searchInput.focus();
        });
      }

      scheduleUpdate();
    })();
  </script>

  <script is:inline>
    (() => {
      const revealButtons = Array.from(document.querySelectorAll('[data-progressive-toggle]'));
      if (!revealButtons.length) return;

      revealButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const group = button.dataset.progressiveToggle || '';
        if (!group) return;

        const items = Array.from(document.querySelectorAll(`[data-progressive-item="${group}"]`));
        if (!items.length) return;
        const summary = document.querySelector(`[data-progressive-summary="${group}"]`);
        const noun = button.dataset.progressiveNoun || 'καταχωρήσεις';
        const initialVisible = Math.max(1, Number.parseInt(button.dataset.initialVisible || '1', 10) || 1);
        let expanded = false;

        const updateView = () => {
          const visibleCount = expanded ? items.length : Math.min(initialVisible, items.length);
          items.forEach((item, index) => item.classList.toggle('hidden', index >= visibleCount));
          button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
          button.textContent = expanded
            ? 'Εμφάνιση λιγότερων'
            : `Εμφάνιση περισσότερων (${Math.max(items.length - visibleCount, 0)})`;

          if (summary instanceof HTMLElement) {
            summary.textContent = `Εμφανίζονται ${visibleCount} από ${items.length} ${noun}.`;
          }
        };

        if (items.length <= initialVisible) {
          button.classList.add('hidden');
          if (summary instanceof HTMLElement) {
            summary.textContent = `Εμφανίζονται ${items.length} από ${items.length} ${noun}.`;
          }
          return;
        }

        button.addEventListener('click', () => {
          expanded = !expanded;
          updateView();
        });

        updateView();
      });
    })();
  </script>

