{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.greekhandy.gr"
        }
      ],
      "destination": "https://greekhandy.gr/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?:\\d{1,3}\\.){3}\\d{1,3}"
        }
      ],
      "destination": "https://greekhandy.gr/$1",
      "permanent": true
    }
  ]
}
